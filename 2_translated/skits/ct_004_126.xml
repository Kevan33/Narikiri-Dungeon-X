    <Entry>
      <PointerOffset>43240</PointerOffset>
      <VoiceId>&lt;audio:VCT_004_126_002&gt;</VoiceId>
      <JapaneseText>&lt;Mel&gt;～、もうそっちいってもいいか？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>2</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>43332</PointerOffset>
      <VoiceId>&lt;audio:VCT_004_126_003&gt;</VoiceId>
      <JapaneseText>あ、ちょっとまって！
………うん、よし</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>3</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>43396</PointerOffset>
      <VoiceId>&lt;audio:VCT_004_126_004&gt;</VoiceId>
      <JapaneseText>もういいよ</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>4</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>43508</PointerOffset>
      <VoiceId>&lt;audio:VCT_004_126_005&gt;</VoiceId>
      <JapaneseText>ほんとにひとりでだいじょーぶか？
危なくなったらすぐ呼べよ</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>5</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>43600</PointerOffset>
      <VoiceId>&lt;audio:VCT_004_126_006&gt;</VoiceId>
      <JapaneseText>てか何で急にひとりで戦おうと思ったんだ？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>6</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>43704</PointerOffset>
      <VoiceId>&lt;audio:VCT_004_126_007&gt;</VoiceId>
      <JapaneseText>そーいうことは聞かないの、
女の子には色々あるんだよ</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>7</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>43768</PointerOffset>
      <VoiceId>&lt;audio:VCT_004_126_008&gt;</VoiceId>
      <JapaneseText>言えない……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>8</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>43892</PointerOffset>
      <VoiceId>&lt;audio:VCT_004_126_009&gt;</VoiceId>
      <JapaneseText>風でめくれたり、びしょぬれで透けたりが
