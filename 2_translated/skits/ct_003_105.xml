    <Entry>
      <PointerOffset>43028</PointerOffset>
      <VoiceId>&lt;audio:VCT_003_105_001&gt;</VoiceId>
      <JapaneseText>&lt;Rody&gt;、
ここちょっと見て……</JapaneseText>
      <EnglishText>Hey &lt;Rody&gt; look at this!</EnglishText>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>1</Id>
      <Status>Editing</Status>
    </Entry>
    <Entry>
      <PointerOffset>43092</PointerOffset>
      <VoiceId>&lt;audio:VCT_003_105_002&gt;</VoiceId>
      <JapaneseText>どれどれ……</JapaneseText>
      <EnglishText>Let's see...</EnglishText>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>2</Id>
      <Status>Editing</Status>
    </Entry>
    <Entry>
      <PointerOffset>43196</PointerOffset>
      <VoiceId>&lt;audio:VCT_003_105_003&gt;</VoiceId>
      <JapaneseText>……&lt;Dio&gt;、大変！
&lt;Mel&gt;が悪い子になっちゃった！</JapaneseText>
      <EnglishText>&lt;Dio&gt;, we have an emergency! &lt;Mel&gt; is becoming a bad kid!</EnglishText>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>3</Id>
      <Status>Editing</Status>
    </Entry>
    <Entry>
      <PointerOffset>43312</PointerOffset>
      <VoiceId>&lt;audio:VCT_003_105_004&gt;</VoiceId>
      <JapaneseText>大人の人を呼び捨てにしたんだ！
今までこんなことなかったのに……</JapaneseText>
      <EnglishText>She referred to an adult without using an honorific! It's the first time she's ever done such a thing...</EnglishText>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>4</Id>
      <Status>Editing</Status>
    </Entry>
    <Entry>
      <PointerOffset>43384</PointerOffset>
      <VoiceId>&lt;audio:VCT_003_105_005&gt;</VoiceId>
      <JapaneseText>いや……あのなぁ……</JapaneseText>
      <EnglishText>Uhm...That's, uh...</EnglishText>
      <Notes/>
      <SpeakerId>4</SpeakerId>
      <Id>5</Id>
      <Status>Editing</Status>
    </Entry>
    <Entry>
      <PointerOffset>43468</PointerOffset>
      <VoiceId>&lt;audio:VCT_003_105_006&gt;</VoiceId>
      <JapaneseText>オレだって
呼び捨てにしてるぜ？</JapaneseText>
      <EnglishText>She refers to me without an honorific, you know.</EnglishText>
      <Notes/>
      <SpeakerId>4</SpeakerId>
      <Id>6</Id>
      <Status>Editing</Status>
    </Entry>
    <Entry>
      <PointerOffset>43544</PointerOffset>
      <VoiceId>&lt;audio:VCT_003_105_007&gt;</VoiceId>
      <JapaneseText>&lt;Dio&gt;はそういう子だもん</JapaneseText>
      <EnglishText>But you are still a kid!</EnglishText>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>7</Id>
      <Status>Editing</Status>
    </Entry>
    <Entry>
      <PointerOffset>43616</PointerOffset>
      <VoiceId>&lt;audio:VCT_003_105_008&gt;</VoiceId>
      <JapaneseText>そういう子って……</JapaneseText>
      <EnglishText>Still...a kid...</EnglishText>
      <Notes/>
      <SpeakerId>4</SpeakerId>
      <Id>8</Id>
      <Status>Editing</Status>
    </Entry>
    <Entry>
      <PointerOffset>43696</PointerOffset>
      <VoiceId>&lt;audio:VCT_003_105_009&gt;</VoiceId>
      <JapaneseText>……『悪い子』って意味か！？</JapaneseText>
      <EnglishText>...So I AM A BAD KID?!</EnglishText>
      <Notes/>
      <SpeakerId>4</SpeakerId>
      <Id>9</Id>
      <Status>Editing</Status>
    </Entry>
