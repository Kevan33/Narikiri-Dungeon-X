    <Entry>
      <PointerOffset>43120</PointerOffset>
      <VoiceId>&lt;audio:VCT_001_025_001&gt;</VoiceId>
      <JapaneseText>…………</JapaneseText>
      <EnglishText>*sigh*</EnglishText>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>1</Id>
      <Status>Editing</Status>
    </Entry>
    <Entry>
      <PointerOffset>43260</PointerOffset>
      <VoiceId>&lt;audio:VCT_001_025_003&gt;</VoiceId>
      <JapaneseText>ふたりとも気もそぞろ……？</JapaneseText>
      <EnglishText>Those two are really nervous...</EnglishText>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>2</Id>
      <Status>Editing</Status>
    </Entry>
    <Entry>
      <PointerOffset>43340</PointerOffset>
      <VoiceId>&lt;audio:VCT_001_025_004&gt;</VoiceId>
      <JapaneseText>まぁ、しょうがないだろうな</JapaneseText>
      <EnglishText>Well, there's nothing we can do.</EnglishText>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>3</Id>
      <Status>Editing</Status>
    </Entry>
    <Entry>
      <PointerOffset>43432</PointerOffset>
      <VoiceId>&lt;audio:VCT_001_025_005&gt;</VoiceId>
      <JapaneseText>……よし、作戦会議だよ、
双子ちゃん！</JapaneseText>
      <EnglishText>...Ok! Twins! It's time for a strategy meeting!</EnglishText>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>4</Id>
      <Status>Editing</Status>
    </Entry>
    <Entry>
      <PointerOffset>43500</PointerOffset>
      <VoiceId>&lt;audio:VCT_001_025_006&gt;</VoiceId>
      <JapaneseText>作戦、会議……？</JapaneseText>
      <EnglishText>Strategy...meeting?</EnglishText>
      <Notes/>
      <SpeakerId>4</SpeakerId>
      <Id>5</Id>
      <Status>Editing</Status>
    </Entry>
    <Entry>
      <PointerOffset>43608</PointerOffset>
      <VoiceId>&lt;audio:VCT_001_025_007&gt;</VoiceId>
      <JapaneseText>エトちゃんを取り戻す作戦だよ。
名付けて奪還エックス！</JapaneseText>
      <EnglishText>We need a strategy to get Miss Eto back. Its name...Operation Rescue X!</EnglishText>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>6</Id>
      <Status>Editing</Status>
    </Entry>
    <Entry>
      <PointerOffset>43688</PointerOffset>
      <VoiceId>&lt;audio:VCT_001_025_008&gt;</VoiceId>
      <JapaneseText>なんでエックスなんですか？</JapaneseText>
      <EnglishText>What does the X mean?</EnglishText>
      <Notes/>
      <SpeakerId>5</SpeakerId>
      <Id>7</Id>
      <Status>Editing</Status>
    </Entry>
    <Entry>
      <PointerOffset>43764</PointerOffset>
      <VoiceId>&lt;audio:VCT_001_025_009&gt;</VoiceId>
      <JapaneseText>カッコいいかなと思って</JapaneseText>
      <EnglishText>So we know it's cool!</EnglishText>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>8</Id>
      <Status>Editing</Status>
    </Entry>
    <Entry>
      <PointerOffset>43880</PointerOffset>
      <VoiceId>&lt;audio:VCT_001_025_010&gt;</VoiceId>
      <JapaneseText>エックスよりもウルトラローリングアタックの
方がカッコイイぜ？</JapaneseText>
      <EnglishText>Since you used X, why not Ultra Rolling Attack?</EnglishText>
      <Notes/>
      <SpeakerId>4</SpeakerId>
      <Id>9</Id>
      <Status>Editing</Status>
    </Entry>
    <Entry>
      <PointerOffset>43960</PointerOffset>
      <VoiceId>&lt;audio:VCT_001_025_011&gt;</VoiceId>
      <JapaneseText>技の名前じゃないんだから……</JapaneseText>
      <EnglishText>That's not the name of an Arte...</EnglishText>
      <Notes/>
      <SpeakerId>5</SpeakerId>
      <Id>10</Id>
      <Status>Editing</Status>
    </Entry>
    <Entry>
      <PointerOffset>44052</PointerOffset>
      <VoiceId>&lt;audio:VCT_001_025_012&gt;</VoiceId>
      <JapaneseText>……あれが&lt;Rody&gt;なりの
気遣いか……</JapaneseText>
      <EnglishText>...Heh, &lt;Rody&gt; sure is a kind one...</EnglishText>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>11</Id>
      <Status>Editing</Status>
    </Entry>
