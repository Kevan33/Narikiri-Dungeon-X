    <Entry>
      <PointerOffset>45428</PointerOffset>
      <VoiceId>&lt;audio:VCT_004_114_001&gt;</VoiceId>
      <JapaneseText>うーん</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>1</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>45504</PointerOffset>
      <VoiceId>&lt;audio:VCT_004_114_002&gt;</VoiceId>
      <JapaneseText>？　どうしたの、&lt;Dio&gt;</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>2</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>45620</PointerOffset>
      <VoiceId>&lt;audio:VCT_004_114_003&gt;</VoiceId>
      <JapaneseText>いやさ……なんだかオレら、
スゲー強くなった、と思うんだけど……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>3</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>45708</PointerOffset>
      <VoiceId>&lt;audio:VCT_004_114_004&gt;</VoiceId>
      <JapaneseText>うん、今ならわたしも実感できるかも</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>4</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>45812</PointerOffset>
      <VoiceId>&lt;audio:VCT_004_114_005&gt;</VoiceId>
      <JapaneseText>……その割に&lt;Dio&gt;はしゃがないんだね、
前みたいに</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>5</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>45940</PointerOffset>
      <VoiceId>&lt;audio:VCT_004_114_006&gt;</VoiceId>
      <JapaneseText>うん……強いってのはコレだけじゃない
……気がすんだよな……よくわかんねけど</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>6</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>46020</PointerOffset>
      <VoiceId>&lt;audio:VCT_004_114_007&gt;</VoiceId>
      <JapaneseText>そう、かな……うん、そうだね</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>7</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>46128</PointerOffset>
      <VoiceId>&lt;audio:VCT_004_114_008&gt;</VoiceId>
      <JapaneseText>ただ速いとか腕力があるだけって
本当の強さじゃないかも</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>8</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>46236</PointerOffset>
      <VoiceId>&lt;audio:VCT_004_114_009&gt;</VoiceId>
      <JapaneseText>だろ？　なんつーか、オレらは
『なりきり士』なワケで……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>9</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>46348</PointerOffset>
      <VoiceId>&lt;audio:VCT_004_114_010&gt;</VoiceId>
      <JapaneseText>そっか！　いろんな職業に
なりきりれてこその強さも重要だよね</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>10</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>46444</PointerOffset>
      <VoiceId>&lt;audio:VCT_004_114_011&gt;</VoiceId>
      <JapaneseText>えーとじゃあどーすりゃいいんだ？つまり……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>11</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>46536</PointerOffset>
      <VoiceId>&lt;audio:VCT_004_114_012&gt;</VoiceId>
      <JapaneseText>どう？　手がかかんなくなって、寂しい？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>12</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>46648</PointerOffset>
      <VoiceId>&lt;audio:VCT_004_114_013&gt;</VoiceId>
      <JapaneseText>そう、だね……でもそれと同じくらい……
うれしくもあるんだ</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>4</SpeakerId>
      <Id>13</Id>
      <Status>To Do</Status>
    </Entry>
  </Strings>
