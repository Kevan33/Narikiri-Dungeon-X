    <Entry>
      <PointerOffset>45708</PointerOffset>
      <VoiceId>&lt;audio:VCT_004_159_001&gt;</VoiceId>
      <JapaneseText>……闇に生き、闇に消えるぜ……
しゅっ！　しゅっ！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>1</Id>
      <OldPtr>37440</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>45776</PointerOffset>
      <VoiceId>&lt;audio:VCT_004_159_002&gt;</VoiceId>
      <JapaneseText>なに、それ……？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>2</Id>
      <OldPtr>39056</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>45892</PointerOffset>
      <VoiceId>&lt;audio:VCT_004_159_003&gt;</VoiceId>
      <JapaneseText>へへーん、カッコいいだろ。
このコスチューム超お気に入りなんだ</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>3</Id>
      <OldPtr>39360</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>45956</PointerOffset>
      <VoiceId>&lt;audio:VCT_004_159_004&gt;</VoiceId>
      <JapaneseText>クルール！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>4</Id>
      <OldPtr>40100</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>46056</PointerOffset>
      <VoiceId>&lt;audio:VCT_004_159_005&gt;</VoiceId>
      <JapaneseText>たしかにちょっとカッコいいかも
しれないけど……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>5</Id>
      <OldPtr>40484</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>46168</PointerOffset>
      <VoiceId>&lt;audio:VCT_004_159_006&gt;</VoiceId>
      <JapaneseText>この覆面がポイントだぜ！
『なりきり士』やっててよかった～</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>6</Id>
      <OldPtr>40652</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>46236</PointerOffset>
      <VoiceId>&lt;audio:VCT_004_159_007&gt;</VoiceId>
      <JapaneseText>全然わかんない</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>4</SpeakerId>
      <Id>7</Id>
      <OldPtr>41604</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>46356</PointerOffset>
      <VoiceId>&lt;audio:VCT_004_159_008&gt;</VoiceId>
      <JapaneseText>ふっふっふっ！　やっぱ、女子どもには
このかっこよさはわからねーよな</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>8</Id>
      <OldPtr>41812</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>46428</PointerOffset>
      <VoiceId>&lt;audio:VCT_004_159_009&gt;</VoiceId>
      <JapaneseText>これぞ漢のロマン！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>9</Id>
      <OldPtr>42928</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>46508</PointerOffset>
      <VoiceId>&lt;audio:VCT_004_159_010&gt;</VoiceId>
      <JapaneseText>自分だって子どものくせに……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>4</SpeakerId>
      <Id>10</Id>
      <OldPtr>43996</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>46600</PointerOffset>
      <VoiceId>&lt;audio:VCT_004_159_011&gt;</VoiceId>
      <JapaneseText>まあまあ、機嫌すごくいいし、ここは、ね？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>11</Id>
      <OldPtr>44500</OldPtr>
      <Status>To Do</Status>
    </Entry>
