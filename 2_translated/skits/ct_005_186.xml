    <Entry>
      <PointerOffset>45960</PointerOffset>
      <VoiceId>&lt;audio:VCT_005_186_001&gt;</VoiceId>
      <JapaneseText>&lt;Suzu&gt;最近、ちゃん、食欲ないけど平気？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>1</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>46068</PointerOffset>
      <VoiceId>&lt;audio:VCT_005_186_002&gt;</VoiceId>
      <JapaneseText>&lt;Suzu&gt;あっ、忘れてた！
ちゃん辛いもの苦手なんだっけ！？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>2</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>46168</PointerOffset>
      <VoiceId>&lt;audio:VCT_005_186_003&gt;</VoiceId>
      <JapaneseText>そっか……ここんとこ
カレー続きだったから……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>3</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>46272</PointerOffset>
      <VoiceId>&lt;audio:VCT_005_186_004&gt;</VoiceId>
      <JapaneseText>それで、今日は甘口と辛口、
ふた種類作ってみました</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>4</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>46380</PointerOffset>
      <VoiceId>&lt;audio:VCT_005_186_005&gt;</VoiceId>
      <JapaneseText>もっと早く気付けばよかったんですが……
……ごめんなさい</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>5</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>46512</PointerOffset>
      <VoiceId>&lt;audio:VCT_005_186_006&gt;</VoiceId>
      <JapaneseText>そういうことではありません。最近、少し体調が
よくなくて、食欲がなかっただけです</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>4</SpeakerId>
      <Id>6</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>46584</PointerOffset>
      <VoiceId>&lt;audio:VCT_005_186_007&gt;</VoiceId>
      <JapaneseText>辛いのだって平気です</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>4</SpeakerId>
      <Id>7</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>46648</PointerOffset>
      <VoiceId>&lt;audio:VCT_005_186_008&gt;</VoiceId>
      <JapaneseText>え、でも……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>8</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>46768</PointerOffset>
      <VoiceId>&lt;audio:VCT_005_186_009&gt;</VoiceId>
      <JapaneseText>これくらいの辛さに耐えられないようでは
忍びとしての修行が足りません</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>4</SpeakerId>
      <Id>9</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>46852</PointerOffset>
      <VoiceId>&lt;audio:VCT_005_186_010&gt;</VoiceId>
      <JapaneseText>&lt;Suzu&gt;ちゃん、食べない方が……！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>10</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>46916</PointerOffset>
      <VoiceId>&lt;audio:VCT_005_186_011&gt;</VoiceId>
      <JapaneseText>んっ……！！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>4</SpeakerId>
      <Id>11</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>47008</PointerOffset>
      <VoiceId>&lt;audio:VCT_005_186_012&gt;</VoiceId>
      <JapaneseText>&lt;Suzu&gt;きゃあっ！　ちゃん倒れちゃった！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>12</Id>
      <Status>To Do</Status>
    </Entry>
