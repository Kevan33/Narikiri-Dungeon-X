    </Entry>
    <Entry>
      <PointerOffset>42276,42424,42640,42776,42888,42996,43092</PointerOffset>
      <JapaneseText>&lt;Claus&gt;</JapaneseText>
      <EnglishText/>
      <Notes/>
      <Id>2</Id>
      <Status>To Do</Status>
    </Entry>
  </Speakers>
  <Strings>
    <Section>Main</Section>
    <Entry>
      <PointerOffset>42180</PointerOffset>
      <VoiceId>&lt;audio:VCT_001_022_001&gt;</VoiceId>
      <JapaneseText>で、結局、どうだった？
ダオスと戦ってみてさ</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>1</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>42280</PointerOffset>
      <VoiceId>&lt;audio:VCT_001_022_002&gt;</VoiceId>
      <JapaneseText>ああ、ダオスか……決死の覚悟をした奴は
強かった</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>2</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>42364</PointerOffset>
      <VoiceId>&lt;audio:VCT_001_022_003&gt;</VoiceId>
      <JapaneseText>魔王の名もダテじゃないってことか</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>3</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>42428</PointerOffset>
      <VoiceId>&lt;audio:VCT_001_022_004&gt;</VoiceId>
      <JapaneseText>魔王、ね……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>4</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>42508</PointerOffset>
      <VoiceId>&lt;audio:VCT_001_022_005&gt;</VoiceId>
      <JapaneseText>みんな……そう呼んでるよね</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>5</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>42572</PointerOffset>
      <VoiceId>&lt;audio:VCT_001_022_006&gt;</VoiceId>
      <JapaneseText>なに……？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>6</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>42644</PointerOffset>
      <VoiceId>&lt;audio:VCT_001_022_007&gt;</VoiceId>
      <JapaneseText>いや、なんでもないさ</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>7</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>42708</PointerOffset>
      <VoiceId>&lt;audio:VCT_001_022_008&gt;</VoiceId>
      <JapaneseText>ふーん……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>8</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>42780</PointerOffset>
      <VoiceId>&lt;audio:VCT_001_022_009&gt;</VoiceId>
      <JapaneseText>ダオスが魔王なら……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>9</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>42892</PointerOffset>
      <VoiceId>&lt;audio:VCT_001_022_010&gt;</VoiceId>
      <JapaneseText>彼の故郷の人たちから見れば、
私たちが魔王ってことだな……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>10</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>43000</PointerOffset>
      <VoiceId>&lt;audio:VCT_001_022_011&gt;</VoiceId>
      <JapaneseText>それもいいだろう……この世界を
守るのなら、それでも……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>11</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>43096</PointerOffset>
      <VoiceId>&lt;audio:VCT_001_022_012&gt;</VoiceId>
      <JapaneseText>そうか……奴も……
同じ気持ちだったか……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>12</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>43160</PointerOffset>
      <VoiceId>&lt;audio:VCT_001_022_013&gt;</VoiceId>
      <JapaneseText>魔王、か……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>13</Id>
      <Status>To Do</Status>
    </Entry>
  </Strings>
  <Strings>
    <Section>Notice</Section>
  </Strings>
</SceneText>
