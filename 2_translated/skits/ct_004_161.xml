  <Strings>
    <Section>Main</Section>
    <Entry>
      <PointerOffset>46040</PointerOffset>
      <VoiceId>&lt;audio:VCT_004_161_000&gt;</VoiceId>
      <JapaneseText>ぐぁあっ！　無理だ！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>1</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>46104</PointerOffset>
      <VoiceId>&lt;audio:VCT_004_161_001&gt;</VoiceId>
      <JapaneseText>どうしたの？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>2</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>46204</PointerOffset>
      <VoiceId>&lt;audio:VCT_004_161_002&gt;</VoiceId>
      <JapaneseText>このカニのコスチューム、もーガマンできねーっ！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>3</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>46280</PointerOffset>
      <VoiceId>&lt;audio:VCT_004_161_003&gt;</VoiceId>
      <JapaneseText>カワイイと思うけど……？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>4</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>46404</PointerOffset>
      <VoiceId>&lt;audio:VCT_004_161_004&gt;</VoiceId>
      <JapaneseText>カワイイとかどうでもいい！
そんなよりこいつ、横にしか動けねーんだぜ！？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>5</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>46528</PointerOffset>
      <VoiceId>&lt;audio:VCT_004_161_005&gt;</VoiceId>
      <JapaneseText>一歩前にでりゃいいのを、
ぐるっと回んなきゃなんねー……もどかしいって！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>6</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>46644</PointerOffset>
      <VoiceId>&lt;audio:VCT_004_161_006&gt;</VoiceId>
      <JapaneseText>……それは確かに面倒だけど……
でもカニにもいいところ、あるよ？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>7</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>46732</PointerOffset>
      <VoiceId>&lt;audio:VCT_004_161_007&gt;</VoiceId>
      <JapaneseText>は？　いいとこ？　んなもんねーって！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>8</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>46800</PointerOffset>
      <VoiceId>&lt;audio:VCT_004_161_008&gt;</VoiceId>
      <JapaneseText>甲羅が硬い、とか</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>9</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>46884</PointerOffset>
      <VoiceId>&lt;audio:VCT_004_161_009&gt;</VoiceId>
      <JapaneseText>確かに硬いっちゃ硬いけどさ……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>10</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>47004</PointerOffset>
      <VoiceId>&lt;audio:VCT_004_161_010&gt;</VoiceId>
      <JapaneseText>でしょ？　だから、よけて戦うんじゃなくて、
受けて戦うタイプなんだよ</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>11</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>47092</PointerOffset>
      <VoiceId>&lt;audio:VCT_004_161_011&gt;</VoiceId>
      <JapaneseText>そんなもんなのか！？
で、でも……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>12</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>47188</PointerOffset>
      <VoiceId>&lt;audio:VCT_004_161_012&gt;</VoiceId>
      <JapaneseText>だめだ！
やっぱもどかしくてたまんねーっ！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>13</Id>
      <Status>To Do</Status>
    </Entry>
  </Strings>
</SceneText>
