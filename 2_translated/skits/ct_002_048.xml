    <Entry>
      <PointerOffset>42232</PointerOffset>
      <VoiceId>&lt;audio:VCT_002_048_001&gt;</VoiceId>
      <JapaneseText>さっき&lt;Dio&gt;くんが着ていた衣装……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>1</Id>
      <OldPtr>37120</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>42356</PointerOffset>
      <VoiceId>&lt;audio:VCT_002_048_002&gt;</VoiceId>
      <JapaneseText>&lt;Chester&gt;さんのお家の整理を
お手伝いしてる時に見たものに似てるんですが……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>2</Id>
      <OldPtr>37360</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>42444</PointerOffset>
      <VoiceId>&lt;audio:VCT_002_048_003&gt;</VoiceId>
      <JapaneseText>きっと、&lt;Chester&gt;が
彼にあげたんだろう</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>3</Id>
      <OldPtr>37528</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>42544</PointerOffset>
      <VoiceId>&lt;audio:VCT_002_048_004&gt;</VoiceId>
      <JapaneseText>あれは……&lt;Chester&gt;が
アミィのために作ったものだよ</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>4</Id>
      <OldPtr>37892</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>42664</PointerOffset>
      <VoiceId>&lt;audio:VCT_002_048_005&gt;</VoiceId>
      <JapaneseText>&lt;Chester&gt;さん……あの子たちと
アミィさんを重ねて見ていたのでしょうか</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>5</Id>
      <OldPtr>38204</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>42760</PointerOffset>
      <VoiceId>&lt;audio:VCT_002_048_006&gt;</VoiceId>
      <JapaneseText>……あいつはアミィの死から
解放されるべきだ</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>6</Id>
      <OldPtr>38552</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>42860</PointerOffset>
      <VoiceId>&lt;audio:VCT_002_048_007&gt;</VoiceId>
      <JapaneseText>後ろを振り返り続けてたら、
アミィも喜ばないよ</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>7</Id>
      <OldPtr>39176</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>42948</PointerOffset>
      <VoiceId>&lt;audio:VCT_002_048_008&gt;</VoiceId>
      <JapaneseText>……本人にそう言ってあげないんですか</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>8</Id>
      <OldPtr>39612</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>43032</PointerOffset>
      <VoiceId>&lt;audio:VCT_002_048_009&gt;</VoiceId>
      <JapaneseText>そうだね。僕が言ってやらないと</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>9</Id>
      <OldPtr>39972</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>43096</PointerOffset>
      <VoiceId>&lt;audio:VCT_002_048_010&gt;</VoiceId>
      <JapaneseText>………………</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>10</Id>
      <OldPtr>40084</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>43216</PointerOffset>
      <VoiceId>&lt;audio:VCT_002_048_011&gt;</VoiceId>
      <JapaneseText>&lt;Chester&gt;さんを傷つけたくない……
&lt;Cless&gt;さんは優しいんですね。でも……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>11</Id>
      <OldPtr>40468</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>43324</PointerOffset>
      <VoiceId>&lt;audio:VCT_002_048_012&gt;</VoiceId>
      <JapaneseText>わかってるよ、&lt;Mint&gt;。
正直に言うのも……優しさだよね</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>12</Id>
      <OldPtr>40972</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>43384</PointerOffset>
      <VoiceId>&lt;audio:VCT_002_048_013&gt;</VoiceId>
      <JapaneseText>…………</JapaneseText>
      <EnglishText/>
      <Notes/>
