    <Entry>
      <PointerOffset>48020</PointerOffset>
      <VoiceId>&lt;audio:VCT_004_140_001&gt;</VoiceId>
      <JapaneseText>魔物つえー。もうクタクタ……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>1</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>48088</PointerOffset>
      <VoiceId>&lt;audio:VCT_004_140_002&gt;</VoiceId>
      <JapaneseText>クルールゥ……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>2</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>48164</PointerOffset>
      <VoiceId>&lt;audio:VCT_004_140_003&gt;</VoiceId>
      <JapaneseText>&lt;Dio&gt;任せて、回復するよ</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>3</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>48268</PointerOffset>
      <VoiceId>&lt;audio:VCT_004_140_004&gt;</VoiceId>
      <JapaneseText>ちょっと待て！！
この前&lt;Couleur&gt;に間違った術かけてたろ</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>4</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>48348</PointerOffset>
      <VoiceId>&lt;audio:VCT_004_140_005&gt;</VoiceId>
      <JapaneseText>オレはそんなのごめんだかんな</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>5</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>48440</PointerOffset>
      <VoiceId>&lt;audio:VCT_004_140_006&gt;</VoiceId>
      <JapaneseText>へーきへーき、もうバッチリ使えるもん！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>6</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>48508</PointerOffset>
      <VoiceId>&lt;audio:VCT_004_140_007&gt;</VoiceId>
      <JapaneseText>ファーストエイド</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>7</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>48580</PointerOffset>
      <VoiceId>&lt;audio:VCT_004_140_008&gt;</VoiceId>
      <JapaneseText>…………！　ひゃ……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>8</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>48664</PointerOffset>
      <VoiceId>&lt;audio:VCT_004_140_009&gt;</VoiceId>
      <JapaneseText>……あ、あれ？　体が軽くなった</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>9</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>48772</PointerOffset>
      <VoiceId>&lt;audio:VCT_004_140_010&gt;</VoiceId>
      <JapaneseText>でしょ。&lt;Mint&gt;さんに教えてもらって、
練習したんだから</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>10</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>48896</PointerOffset>
      <VoiceId>&lt;audio:VCT_004_140_011&gt;</VoiceId>
      <JapaneseText>サービスで、もうひとつファーストエイド
さらにおまけで、ファーストエイド</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>11</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>48980</PointerOffset>
      <VoiceId>&lt;audio:VCT_004_140_012&gt;</VoiceId>
      <JapaneseText>うおぉぉ！！　元気ありまくる！！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>12</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>49088</PointerOffset>
      <VoiceId>&lt;audio:VCT_004_140_013&gt;</VoiceId>
      <JapaneseText>オレ、もっともっともっと戦ってくる！！
行くぜ&lt;Couleur&gt;！！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>13</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>49152</PointerOffset>
      <VoiceId>&lt;audio:VCT_004_140_014&gt;</VoiceId>
      <JapaneseText>クルール！！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>14</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>49236</PointerOffset>
      <VoiceId>&lt;audio:VCT_004_140_015&gt;</VoiceId>
      <JapaneseText>あれ？　やりすぎちゃったかな？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>15</Id>
      <Status>To Do</Status>
    </Entry>
