    <Entry>
      <PointerOffset>43932</PointerOffset>
      <VoiceId>&lt;audio:VCT_002_071_001&gt;</VoiceId>
      <JapaneseText>&lt;Suzu&gt;ちゃん、聞いていいかな？
あの仮面のふたりにどんな幻見せられたの？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>1</Id>
      <OldPtr>37208</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>44032</PointerOffset>
      <VoiceId>&lt;audio:VCT_002_071_002&gt;</VoiceId>
      <JapaneseText>&lt;Dio&gt;さんと&lt;Mel&gt;さん、
おふたりと暮らす幻です</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>2</Id>
      <OldPtr>37724</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>44152</PointerOffset>
      <VoiceId>&lt;audio:VCT_002_071_003&gt;</VoiceId>
      <JapaneseText>え？　オレらと？　もしかして、
オレらにイジメられたりしてたのか？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>3</Id>
      <OldPtr>38360</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>44256</PointerOffset>
      <VoiceId>&lt;audio:VCT_002_071_004&gt;</VoiceId>
      <JapaneseText>いえ、おふたりと一緒に楽しい日々を
暮らしていました</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>4</Id>
      <OldPtr>39308</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>44372</PointerOffset>
      <VoiceId>&lt;audio:VCT_002_071_005&gt;</VoiceId>
      <JapaneseText>なんだよ、もっとヤな幻で
&lt;Suzu&gt;ちゃん追いつめてっかと思ったぜ</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>5</Id>
      <OldPtr>39660</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>44512</PointerOffset>
      <VoiceId>&lt;audio:VCT_002_071_006&gt;</VoiceId>
      <JapaneseText>わたしも……ミミズやカエルが降ってきたり、
アメンボだらけの池に放り込まれたりとか……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>6</Id>
      <OldPtr>40364</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>44580</PointerOffset>
      <VoiceId>&lt;audio:VCT_002_071_007&gt;</VoiceId>
      <JapaneseText>や、やめろよ……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>7</Id>
      <OldPtr>41040</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>44672</PointerOffset>
      <VoiceId>&lt;audio:VCT_002_071_008&gt;</VoiceId>
      <JapaneseText>……そんな幻なら、
耐えればいいだけです</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>8</Id>
      <OldPtr>41372</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>44760</PointerOffset>
      <VoiceId>&lt;audio:VCT_002_071_009&gt;</VoiceId>
      <JapaneseText>そ、そっか？　強いな、&lt;Suzu&gt;ちゃんは</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>9</Id>
      <OldPtr>41796</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>44868</PointerOffset>
      <VoiceId>&lt;audio:VCT_002_071_010&gt;</VoiceId>
      <JapaneseText>いえ、むしろ、私を揺るがすのは、
そうではないもの……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>10</Id>
      <OldPtr>42348</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>44984</PointerOffset>
      <VoiceId>&lt;audio:VCT_002_071_011&gt;</VoiceId>
      <JapaneseText>憧れや羨望でしょうか。
……まだまだ修行が足りないのです、私は</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>11</Id>
      <OldPtr>42852</OldPtr>
      <Status>To Do</Status>
    </Entry>
