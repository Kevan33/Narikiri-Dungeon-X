    <Entry>
      <PointerOffset>41372</PointerOffset>
      <VoiceId>&lt;audio:VCT_003_091_001&gt;</VoiceId>
      <JapaneseText>さっきのダオス、前に会った時と
違った気がしたの……わたしだけ、かな</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>1</Id>
      <OldPtr>37320</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>41444</PointerOffset>
      <VoiceId>&lt;audio:VCT_003_091_002&gt;</VoiceId>
      <JapaneseText>あ、ぼくもそう思った</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>2</Id>
      <OldPtr>37636</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>41516</PointerOffset>
      <VoiceId>&lt;audio:VCT_003_091_003&gt;</VoiceId>
      <JapaneseText>クルッ、クルール！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>3</Id>
      <OldPtr>37880</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>41604</PointerOffset>
      <VoiceId>&lt;audio:VCT_003_091_004&gt;</VoiceId>
      <JapaneseText>あれ、そっか？
オレ、気付かなかった</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>4</SpeakerId>
      <Id>4</Id>
      <OldPtr>38200</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>41696</PointerOffset>
      <VoiceId>&lt;audio:VCT_003_091_005&gt;</VoiceId>
      <JapaneseText>前に比べてダオスの影が
薄かったでしょ？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>5</Id>
      <OldPtr>38640</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>41768</PointerOffset>
      <VoiceId>&lt;audio:VCT_003_091_006&gt;</VoiceId>
      <JapaneseText>え？　そうだったか？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>4</SpeakerId>
      <Id>6</Id>
      <OldPtr>39088</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>41864</PointerOffset>
      <VoiceId>&lt;audio:VCT_003_091_007&gt;</VoiceId>
      <JapaneseText>観察力が足りないよ、&lt;Dio&gt;は。
ね、&lt;Mel&gt;？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>7</Id>
      <OldPtr>39452</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>41936</PointerOffset>
      <VoiceId>&lt;audio:VCT_003_091_008&gt;</VoiceId>
      <JapaneseText>あ、え、ええっと……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>8</Id>
      <OldPtr>40180</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>42064</PointerOffset>
      <VoiceId>&lt;audio:VCT_003_091_009&gt;</VoiceId>
      <JapaneseText>……前みたいに匂いがしなかった……
なんて言って、わかってもらえる、かな……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>9</Id>
      <OldPtr>40480</OldPtr>
      <Status>To Do</Status>
    </Entry>
