    <Entry>
      <PointerOffset>49232,49352,49636,49888,50100</PointerOffset>
      <JapaneseText>アルベルト</JapaneseText>
      <EnglishText/>
      <Notes/>
      <Id>3</Id>
      <Status>To Do</Status>
    </Entry>
  </Speakers>
  <Strings>
    <Section>Main</Section>
    <Entry>
      <PointerOffset>49008</PointerOffset>
      <VoiceId>&lt;audio:VCT_001_008_001&gt;</VoiceId>
      <JapaneseText>あれ？　なんかヘンくね？
さっきまで戦い疲れてたのに……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>1</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>49080</PointerOffset>
      <VoiceId>&lt;audio:VCT_001_008_002&gt;</VoiceId>
      <JapaneseText>体力が回復してる？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>2</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>49236</PointerOffset>
      <VoiceId>&lt;audio:VCT_001_008_003&gt;</VoiceId>
      <JapaneseText>&lt;Mel&gt;&lt;Mel&gt;エッヘヘ～ン！　アルベルト様が教えてやるだーよ。
それも『なりきり士』の力のひとつだ、∀</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>3</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>49356</PointerOffset>
      <VoiceId>&lt;audio:VCT_001_008_004&gt;</VoiceId>
      <JapaneseText>ノルン様の加護ある場所なら、
大地の力で体力も全回復だ～～よ♪</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>4</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>49480</PointerOffset>
      <VoiceId>&lt;audio:VCT_001_008_005&gt;</VoiceId>
      <JapaneseText>おまえがそんなでけーずーたい隠して、
手伝わないから疲れるんだっての！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>5</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>49640</PointerOffset>
      <VoiceId>&lt;audio:VCT_001_008_006&gt;</VoiceId>
      <JapaneseText>はん、おら、戦ってもええだが、衣装がボロボロになるだど！
偉そうなこと言って。おめぇが使えねぇからだろ！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>6</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>49736</PointerOffset>
      <VoiceId>&lt;audio:VCT_001_008_007&gt;</VoiceId>
      <JapaneseText>&lt;Dio&gt;、アルベルトさんも……
やめてください</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>7</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>49892</PointerOffset>
      <VoiceId>&lt;audio:VCT_001_008_008&gt;</VoiceId>
      <JapaneseText>&lt;Mel&gt;&lt;Mel&gt;あう～～ん、ぅ、言ってやってほしいだ。
このクソぼうずに、おらがどれだけ大変かっちゅーの</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>8</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>49960</PointerOffset>
      <VoiceId>&lt;audio:VCT_001_008_009&gt;</VoiceId>
      <JapaneseText>こんのぉ～……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>9</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>50104</PointerOffset>
      <VoiceId>&lt;audio:VCT_001_008_010&gt;</VoiceId>
      <JapaneseText>っつーことで、ダンジョンから外に出れば、
体力が全快だで、いちいち寝る必要もないだーよ</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>10</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>50188</PointerOffset>
      <VoiceId>&lt;audio:VCT_001_008_011&gt;</VoiceId>
      <JapaneseText>……誰に向かって
言ってんだ？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>11</Id>
      <Status>To Do</Status>
    </Entry>
  </Strings>
  <Strings>
