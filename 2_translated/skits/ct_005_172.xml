    <Entry>
      <PointerOffset>44672</PointerOffset>
      <VoiceId>&lt;audio:VCT_005_172_001&gt;</VoiceId>
      <JapaneseText>ねぇ……&lt;Dio&gt;の作る料理……
少し塩少なめにしてみたら？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>1</Id>
      <OldPtr>37412</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>44772</PointerOffset>
      <VoiceId>&lt;audio:VCT_005_172_002&gt;</VoiceId>
      <JapaneseText>これ以上、塩少なくしたら、
味が薄くなるっての</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>2</Id>
      <OldPtr>38208</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>44872</PointerOffset>
      <VoiceId>&lt;audio:VCT_005_172_003&gt;</VoiceId>
      <JapaneseText>このフレンチトースト、甘すぎ。
砂糖入れすぎだよ</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>3</Id>
      <OldPtr>38708</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>44964</PointerOffset>
      <VoiceId>&lt;audio:VCT_005_172_004&gt;</VoiceId>
      <JapaneseText>そーか？　あぐっ……
もぐもぐもぐ……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>4</Id>
      <OldPtr>39288</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>45036</PointerOffset>
      <VoiceId>&lt;audio:VCT_005_172_005&gt;</VoiceId>
      <JapaneseText>なんだよ、ウマいぜ？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>5</Id>
      <OldPtr>40032</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>45112</PointerOffset>
      <VoiceId>&lt;audio:VCT_005_172_006&gt;</VoiceId>
      <JapaneseText>クルルー！　クルール！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>6</Id>
      <OldPtr>40532</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>45192</PointerOffset>
      <VoiceId>&lt;audio:VCT_005_172_007&gt;</VoiceId>
      <JapaneseText>ほら、&lt;Couleur&gt;も言ってるでしょ</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>7</Id>
      <OldPtr>41248</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>45284</PointerOffset>
      <VoiceId>&lt;audio:VCT_005_172_008&gt;</VoiceId>
      <JapaneseText>こいつは
何言ってんのかわかんねだろ！？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>8</Id>
      <OldPtr>41624</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>45412</PointerOffset>
      <VoiceId>&lt;audio:VCT_005_172_009&gt;</VoiceId>
      <JapaneseText>このフレンチトーストと普通の料理、
一緒に食えばちょうどいい感じになるって</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>9</Id>
      <OldPtr>42192</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>45476</PointerOffset>
      <VoiceId>&lt;audio:VCT_005_172_010&gt;</VoiceId>
      <JapaneseText>なんないって</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>4</SpeakerId>
      <Id>10</Id>
      <OldPtr>43264</OldPtr>
      <Status>To Do</Status>
    </Entry>
