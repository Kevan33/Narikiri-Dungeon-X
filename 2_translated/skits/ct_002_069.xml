    </Entry>
    <Entry>
      <PointerOffset>42476,42624,42828,43012,43132,43332,43484,43572</PointerOffset>
      <JapaneseText>&lt;Rondoline&gt;</JapaneseText>
      <EnglishText/>
      <Notes/>
