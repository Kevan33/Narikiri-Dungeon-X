      <VoiceId>&lt;audio:VCT_001_010_001&gt;</VoiceId>
      <JapaneseText>&lt;Claus&gt;あれが、時空戦士のひとり……だった
博士なんてな……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>1</Id>
      <Status>To Do</Status>
