  <Strings>
    <Section>Main</Section>
    <Entry>
      <PointerOffset>48604</PointerOffset>
      <VoiceId>&lt;audio:VCT_001_003_001&gt;</VoiceId>
      <JapaneseText>&lt;Mel&gt;、ちゃんと必要なもの
買ったね</JapaneseText>
      <EnglishText>&lt;Mel&gt;! You bought such beautiful wares!</EnglishText>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>1</Id>
      <Status>Editing</Status>
    </Entry>
    <Entry>
      <PointerOffset>48692</PointerOffset>
      <VoiceId>&lt;audio:VCT_001_003_002&gt;</VoiceId>
      <JapaneseText>&lt;Dio&gt;、ほら、
ボタン掛け違えてる</JapaneseText>
      <EnglishText>&lt;Dio&gt;, here! We need to visit some cloth button stores!</EnglishText>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>2</Id>
      <Status>Editing</Status>
    </Entry>
    <Entry>
      <PointerOffset>48784</PointerOffset>
      <VoiceId>&lt;audio:VCT_001_003_003&gt;</VoiceId>
      <JapaneseText>エト助は、ふたりの保護者みたいだなや</JapaneseText>
      <EnglishText>Eto, you really do a good job taking care of these kids! Such honest love!</EnglishText>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>3</Id>
      <Status>Editing</Status>
    </Entry>
    <Entry>
      <PointerOffset>48880</PointerOffset>
      <VoiceId>&lt;audio:VCT_001_003_004&gt;</VoiceId>
      <JapaneseText>そうだよ！
ぼくはふたりのお母さんだもん！</JapaneseText>
      <EnglishText>But of course! That's because I am their mother!</EnglishText>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>4</Id>
      <Status>Editing</Status>
    </Entry>
    <Entry>
      <PointerOffset>48964</PointerOffset>
      <VoiceId>&lt;audio:VCT_001_003_005&gt;</VoiceId>
      <JapaneseText>へん、エトが
母ちゃんなもんかよ</JapaneseText>
      <EnglishText>Heh, you'd need to be nuts to think Eto is our mother!</EnglishText>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>5</Id>
      <Status>Editing</Status>
    </Entry>
    <Entry>
      <PointerOffset>49080</PointerOffset>
      <VoiceId>&lt;audio:VCT_001_003_006&gt;</VoiceId>
      <JapaneseText>あはは～～ん。
おめぇ、ほんとはエト助のこと、大好きなんだべ</JapaneseText>
      <EnglishText>Hehehe! Don't act like you dislike Eto, because truth of the matter is you're a huge momma's boy!</EnglishText>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>6</Id>
      <Status>Editing</Status>
    </Entry>
    <Entry>
      <PointerOffset>49168</PointerOffset>
      <VoiceId>&lt;audio:VCT_001_003_007&gt;</VoiceId>
      <JapaneseText>うるせー！　タンス野郎は黙ってろ！！</JapaneseText>
      <EnglishText>W-what did you say!? Shut your trap, dresser bastard!</EnglishText>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>7</Id>
      <Status>Editing</Status>
    </Entry>
    <Entry>
      <PointerOffset>49320</PointerOffset>
      <VoiceId>&lt;audio:VCT_001_003_008&gt;</VoiceId>
      <JapaneseText>はぁん？　誰に向かってタンス言ってんだど！
おめぇなんぞ、毛も生えてねぇ、ハゲぼうずのくせが！</JapaneseText>
      <EnglishText>Huh? Who are you calling a bastard? Look at that huge forehead, you are gonna become a beautiful bald kid in no time!</EnglishText>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>8</Id>
      <Status>Editing</Status>
    </Entry>
    <Entry>
      <PointerOffset>49408</PointerOffset>
      <VoiceId>&lt;audio:VCT_001_003_009&gt;</VoiceId>
      <JapaneseText>ほら、ふたりともけんかしちゃだめ！</JapaneseText>
      <EnglishText>Hey! You two there! Stop fighting!</EnglishText>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>9</Id>
      <Status>Editing</Status>
    </Entry>
    <Entry>
      <PointerOffset>49492</PointerOffset>
      <VoiceId>&lt;audio:VCT_001_003_010&gt;</VoiceId>
      <JapaneseText>す……すまねーだ、母ちゃん</JapaneseText>
      <EnglishText>I-I'm sorry, mom.</EnglishText>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>10</Id>
      <Status>Editing</Status>
    </Entry>
    <Entry>
      <PointerOffset>49576</PointerOffset>
      <VoiceId>&lt;audio:VCT_001_003_011&gt;</VoiceId>
      <JapaneseText>あれ……アルベルトさんまで……</JapaneseText>
      <EnglishText>Eh? Now even Mister Albert...</EnglishText>
      <Notes/>
      <SpeakerId>4</SpeakerId>
      <Id>11</Id>
      <Status>Editing</Status>
    </Entry>
  </Strings>
</SceneText>
