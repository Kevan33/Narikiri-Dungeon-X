    <Entry>
      <PointerOffset>47704</PointerOffset>
      <VoiceId>&lt;audio:VCT_004_168_001&gt;</VoiceId>
      <JapaneseText>よし！　これでコスチューム全部マスターしたよ！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>1</Id>
      <OldPtr>37344</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>47852</PointerOffset>
      <VoiceId>&lt;audio:VCT_004_168_002&gt;</VoiceId>
      <JapaneseText>すごいだー！　さすがだー！　かしこいだー！
やっぱ&lt;Mel&gt;&lt;Mel&gt;は、すんばらしい娘っ子だでよ</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>2</Id>
      <OldPtr>37956</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>47952</PointerOffset>
      <VoiceId>&lt;audio:VCT_004_168_003&gt;</VoiceId>
      <JapaneseText>えへへ、ありがとうございます、
アルベルトさん♪</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>3</Id>
      <OldPtr>38928</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>48100</PointerOffset>
      <VoiceId>&lt;audio:VCT_004_168_004&gt;</VoiceId>
      <JapaneseText>きゅっほーーーん∀　&lt;Mel&gt;&lt;Mel&gt;に感謝されただ。
おら、今日と言う日を一生忘れねーだーよ！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>4</Id>
      <OldPtr>39720</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>48176</PointerOffset>
      <VoiceId>&lt;audio:VCT_004_168_005&gt;</VoiceId>
      <JapaneseText>ったく、見てらんねー……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>5</Id>
      <OldPtr>41184</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>48244</PointerOffset>
      <VoiceId>&lt;audio:VCT_004_168_006&gt;</VoiceId>
      <JapaneseText>キュルーン……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>4</SpeakerId>
      <Id>6</Id>
      <OldPtr>41712</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>48380</PointerOffset>
      <VoiceId>&lt;audio:VCT_004_168_007&gt;</VoiceId>
      <JapaneseText>何をごちゃごちゃ言ってるだ。おめぇも悔しかったら
サッサとやることやってくるだど</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>7</Id>
      <OldPtr>42052</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>48516</PointerOffset>
      <VoiceId>&lt;audio:VCT_004_168_008&gt;</VoiceId>
      <JapaneseText>の～～～、&lt;Mel&gt;&lt;Mel&gt;？　ほんとに頑張ったで、
おらが特別プレゼントあげるだーよ</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>8</Id>
      <OldPtr>43140</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>48580</PointerOffset>
      <VoiceId>&lt;audio:VCT_004_168_009&gt;</VoiceId>
      <JapaneseText>え、本当に？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>9</Id>
      <OldPtr>44240</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>48744</PointerOffset>
      <VoiceId>&lt;audio:VCT_004_168_010&gt;</VoiceId>
      <JapaneseText>じゃっじゃっじゃ、じゃ～～～ん！　おらの直筆サイン入り、
色紙をプレゼントー！　特別に手形も押してあるでよ</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>10</Id>
      <OldPtr>44556</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>48832</PointerOffset>
      <VoiceId>&lt;audio:VCT_004_168_011&gt;</VoiceId>
      <JapaneseText>あ、ありがとう……アルベルトさん……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>11</Id>
      <OldPtr>46516</OldPtr>
      <Status>To Do</Status>
    </Entry>
