    <Entry>
      <PointerOffset>50080</PointerOffset>
      <VoiceId>&lt;audio:VCT_002_068_001&gt;</VoiceId>
      <JapaneseText>うーん、ここからの風景、絵にしたら、
いい感じになるな、たぶん</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>1</Id>
      <OldPtr>37444</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>50188</PointerOffset>
      <VoiceId>&lt;audio:VCT_002_068_002&gt;</VoiceId>
      <JapaneseText>絵？　芸術的センスゼロのおまえが
絵なんか描いてるのか？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>2</Id>
      <OldPtr>38068</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>50300</PointerOffset>
      <VoiceId>&lt;audio:VCT_002_068_003&gt;</VoiceId>
      <JapaneseText>センスゼロなんて、&lt;Arche&gt;さんの絵、
情熱的でステキですよ？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>3</Id>
      <OldPtr>39244</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>50368</PointerOffset>
      <VoiceId>&lt;audio:VCT_002_068_004&gt;</VoiceId>
      <JapaneseText>そ、そうなのか？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>4</Id>
      <OldPtr>40080</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>50444</PointerOffset>
      <VoiceId>&lt;audio:VCT_002_068_005&gt;</VoiceId>
      <JapaneseText>そうそう♪　ね、&lt;Dio&gt;？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>5</Id>
      <OldPtr>40272</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>50532</PointerOffset>
      <VoiceId>&lt;audio:VCT_002_068_006&gt;</VoiceId>
      <JapaneseText>え……？　あ、んんん……
う～ん……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>4</SpeakerId>
      <Id>6</Id>
      <OldPtr>40816</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>50600</PointerOffset>
      <VoiceId>&lt;audio:VCT_002_068_007&gt;</VoiceId>
      <JapaneseText>何、その反応！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>7</Id>
      <OldPtr>41744</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>50744</PointerOffset>
      <VoiceId>&lt;audio:VCT_002_068_008&gt;</VoiceId>
      <JapaneseText>ははっ、なんかその反応、逆に興味湧いたな。
その情熱的にステキでビミョーな絵、見せてくれよ</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>8</Id>
      <OldPtr>43008</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>50820</PointerOffset>
      <VoiceId>&lt;audio:VCT_002_068_009&gt;</VoiceId>
      <JapaneseText>何よ！　&lt;Chester&gt;のバカっ！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>9</Id>
      <OldPtr>45032</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>50924</PointerOffset>
      <VoiceId>&lt;audio:VCT_002_068_010&gt;</VoiceId>
      <JapaneseText>あ、&lt;Arche&gt;さん……！
もう……&lt;Chester&gt;さんのバカっ！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>10</Id>
      <OldPtr>45956</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>51004</PointerOffset>
      <VoiceId>&lt;audio:VCT_002_068_011&gt;</VoiceId>
      <JapaneseText>あ、おいっ！　なんだよ……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>11</Id>
      <OldPtr>47232</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>51076</PointerOffset>
      <VoiceId>&lt;audio:VCT_002_068_012&gt;</VoiceId>
      <JapaneseText>&lt;Chester&gt;のおバカさん</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>5</SpeakerId>
      <Id>12</Id>
      <OldPtr>47876</OldPtr>
      <Status>To Do</Status>
