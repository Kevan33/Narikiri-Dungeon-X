<?xml version='1.0' encoding='UTF-8'?>
<SceneText>
  <Speakers>
    <Section>Speaker</Section>
    <Entry>
      <PointerOffset>43352,43484,43624,43756,43892,44028,44100</PointerOffset>
      <JapaneseText>アルベルト</JapaneseText>
      <EnglishText/>
      <Notes/>
      <Id>1</Id>
      <Status>To Do</Status>
    </Entry>
  </Speakers>
  <Strings>
    <Section>Main</Section>
    <Entry>
      <PointerOffset>43356</PointerOffset>
      <VoiceId>&lt;audio:VCT_003_112_001&gt;</VoiceId>
      <JapaneseText>はぁ～、きんにいらねぇだ！　おんもしろくねぇだ！
このピリピリした空気感、おらの出番がねーだよ</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>1</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>43488</PointerOffset>
      <VoiceId>&lt;audio:VCT_003_112_002&gt;</VoiceId>
      <JapaneseText>そりゃ、緊張感も大事だぁ。
んだども、ここまで張り詰めてたら気が重いっつーの</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>2</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>43628</PointerOffset>
      <VoiceId>&lt;audio:VCT_003_112_003&gt;</VoiceId>
      <JapaneseText>ふくろだぬきぐらい能天気なら楽チンだが、
おらはナイーブな方だで、空気が読める男だよ</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>3</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>43760</PointerOffset>
      <VoiceId>&lt;audio:VCT_003_112_004&gt;</VoiceId>
      <JapaneseText>&lt;Mel&gt;&lt;Mel&gt;そったらこっで、このままのポケットで
大人しくしてるのが一番だぁ</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>4</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>43896</PointerOffset>
      <VoiceId>&lt;audio:VCT_003_112_005&gt;</VoiceId>
      <JapaneseText>ま、まさか、おらの出番はここまでで、
もう日の光を浴びられないなんてことに……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>5</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>44032</PointerOffset>
      <VoiceId>&lt;audio:VCT_003_112_006&gt;</VoiceId>
      <JapaneseText>んーなバカな話、あるわけねぇ！
おらが出ないっつーことは、芋のないカレーと同じだ</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>6</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>44104</PointerOffset>
      <VoiceId>&lt;audio:VCT_003_112_007&gt;</VoiceId>
      <JapaneseText>……どゆこと？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>7</Id>
      <Status>To Do</Status>
    </Entry>
  </Strings>
  <Strings>
    <Section>Notice</Section>
  </Strings>
</SceneText>
