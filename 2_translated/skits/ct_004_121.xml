    <Entry>
      <PointerOffset>45800</PointerOffset>
      <VoiceId>&lt;audio:VCT_004_121_000&gt;</VoiceId>
      <JapaneseText>ふぅ</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>1</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>45932</PointerOffset>
      <VoiceId>&lt;audio:VCT_004_121_001&gt;</VoiceId>
      <JapaneseText>&lt;Rody&gt;すげー！　すげーすげー！　今の戦闘の技すげー！
なぁ、オレもやりたい！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>2</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>46044</PointerOffset>
      <VoiceId>&lt;audio:VCT_004_121_002&gt;</VoiceId>
      <JapaneseText>ん～、だねー。教えてもいいけど、
私の秘奥義は難しいよ～？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>3</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>46128</PointerOffset>
      <VoiceId>&lt;audio:VCT_004_121_003&gt;</VoiceId>
      <JapaneseText>覚悟のうえです！　ししょーっ！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>4</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>46236</PointerOffset>
      <VoiceId>&lt;audio:VCT_004_121_004&gt;</VoiceId>
      <JapaneseText>よろしい。ではまず
『おーばーりみっつげーじ』を溜めてね</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>5</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>46340</PointerOffset>
      <VoiceId>&lt;audio:VCT_004_121_005&gt;</VoiceId>
      <JapaneseText>お、おーばーりみっつ？
ブレイブオーバーじゃなくて？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>6</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>46496</PointerOffset>
      <VoiceId>&lt;audio:VCT_004_121_006&gt;</VoiceId>
      <JapaneseText>そうそう。『おーばーりみっつ』。画面左側に縦に伸びてる
やつね。それを『れべる』３以上にして発動するの</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>7</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>46644</PointerOffset>
      <VoiceId>&lt;audio:VCT_004_121_007&gt;</VoiceId>
      <JapaneseText>あ、それとスキル『すぺさる』をセットしておくのを
忘れないようにね。それで奥義を決めたときに……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>8</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>46740</PointerOffset>
      <VoiceId>&lt;audio:VCT_004_121_008&gt;</VoiceId>
      <JapaneseText>？　？？？？？？？？
ダメだ。全然わかんね～</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>9</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>46804</PointerOffset>
      <VoiceId>&lt;audio:VCT_004_121_009_a&gt;</VoiceId>
      <JapaneseText>なーんてね</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>10</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>46880</PointerOffset>
      <VoiceId>&lt;audio:VCT_004_121_009&gt;</VoiceId>
      <JapaneseText>からかわれてるんだよ……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>11</Id>
      <Status>To Do</Status>
    </Entry>
