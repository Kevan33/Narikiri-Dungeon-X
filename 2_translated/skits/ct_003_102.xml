    <Entry>
      <PointerOffset>41860</PointerOffset>
      <VoiceId>&lt;audio:VCT_003_102_001&gt;</VoiceId>
      <JapaneseText>そう言えば前にノルンさん、
『希望のひとしずく』から生まれたって言ってたよね</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>1</Id>
      <OldPtr>37208</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>41928</PointerOffset>
      <VoiceId>&lt;audio:VCT_003_102_002&gt;</VoiceId>
      <JapaneseText>そうだっけ……？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>2</Id>
      <OldPtr>37728</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>42044</PointerOffset>
      <VoiceId>&lt;audio:VCT_003_102_003&gt;</VoiceId>
      <JapaneseText>それってさ、世界樹の根っこんとこにあった
マナ溜まりってヤツだろ</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>3</Id>
      <OldPtr>37976</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>42188</PointerOffset>
      <VoiceId>&lt;audio:VCT_003_102_004&gt;</VoiceId>
      <JapaneseText>ノルンさんってつまりはデリス・カーラーンにある
大樹カーラーンの子どもみたいなものなんだね</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>4</Id>
      <OldPtr>38352</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>42256</PointerOffset>
      <VoiceId>&lt;audio:VCT_003_102_005&gt;</VoiceId>
      <JapaneseText>樹が母ちゃん？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>5</Id>
      <OldPtr>38916</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>42344</PointerOffset>
      <VoiceId>&lt;audio:VCT_003_102_006&gt;</VoiceId>
      <JapaneseText>樹がお母さんでも
別にいいでしょ？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>6</Id>
      <OldPtr>39228</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>42420</PointerOffset>
      <VoiceId>&lt;audio:VCT_003_102_007&gt;</VoiceId>
      <JapaneseText>お父さんかもしれないよ</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>7</Id>
      <OldPtr>39684</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>42508</PointerOffset>
      <VoiceId>&lt;audio:VCT_003_102_008&gt;</VoiceId>
      <JapaneseText>じゃあ、ユグドラシルは兄ちゃんか？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>8</Id>
      <OldPtr>39864</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>42576</PointerOffset>
      <VoiceId>&lt;audio:VCT_003_102_009&gt;</VoiceId>
      <JapaneseText>妹じゃないかな</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>9</Id>
      <OldPtr>40280</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>42640</PointerOffset>
      <VoiceId>&lt;audio:VCT_003_102_010&gt;</VoiceId>
      <JapaneseText>なんでだ？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>10</Id>
      <OldPtr>40516</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>42724</PointerOffset>
      <VoiceId>&lt;audio:VCT_003_102_011&gt;</VoiceId>
      <JapaneseText>え？　うーんと、
なんとなく？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>11</Id>
      <OldPtr>40628</OldPtr>
      <Status>To Do</Status>
    </Entry>
