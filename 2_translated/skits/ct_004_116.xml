    <Entry>
      <PointerOffset>44316</PointerOffset>
      <VoiceId>&lt;audio:VCT_004_116_001&gt;</VoiceId>
      <JapaneseText>なぁ、平和なこの時代、
オレらほど戦ってるヤツいねーよな</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>1</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>44440</PointerOffset>
      <VoiceId>&lt;audio:VCT_004_116_002&gt;</VoiceId>
      <JapaneseText>平和……確かに魔物はいるけど、
基本的にわたしたちの時代は平和なんだよね</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>2</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>44560</PointerOffset>
      <VoiceId>&lt;audio:VCT_004_116_003&gt;</VoiceId>
      <JapaneseText>だろ？　だったら実戦経験とかゆーヤツも
オレらがトップだぜ、きっと</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>3</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>44676</PointerOffset>
      <VoiceId>&lt;audio:VCT_004_116_004&gt;</VoiceId>
      <JapaneseText>戦争とかもないわけだから、
そうかな？　うん、そうだね、たぶん</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>4</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>44780</PointerOffset>
      <VoiceId>&lt;audio:VCT_004_116_005&gt;</VoiceId>
      <JapaneseText>つまりだ！　自分たちの時代なら
オレら人類最強だぜ！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>5</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>44892</PointerOffset>
      <VoiceId>&lt;audio:VCT_004_116_006&gt;</VoiceId>
      <JapaneseText>ええっ！？　そ、そうかな、
もっと強い人もいると思うけど……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>6</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>44980</PointerOffset>
      <VoiceId>&lt;audio:VCT_004_116_007&gt;</VoiceId>
      <JapaneseText>いねーいねー！
オレ、さいきょう！！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>7</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>45052</PointerOffset>
      <VoiceId>&lt;audio:VCT_004_116_008&gt;</VoiceId>
      <JapaneseText>んっふっふっふ……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>8</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>45112</PointerOffset>
