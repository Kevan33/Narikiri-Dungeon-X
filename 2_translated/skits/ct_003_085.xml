      <PointerOffset>42140</PointerOffset>
      <VoiceId>&lt;audio:VCT_003_085_001&gt;</VoiceId>
      <JapaneseText>もし、家にいたら、
今頃、お風呂入ってる時間だな……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>1</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>42216</PointerOffset>
      <VoiceId>&lt;audio:VCT_003_085_002&gt;</VoiceId>
      <JapaneseText>オレは、本読んでるかも</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>2</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>42316</PointerOffset>
      <VoiceId>&lt;audio:VCT_003_085_003&gt;</VoiceId>
      <JapaneseText>せっかく読みたかったのに、
あいつらのせいで……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>3</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>42396</PointerOffset>
      <VoiceId>&lt;audio:VCT_003_085_004&gt;</VoiceId>
      <JapaneseText>&lt;Dio&gt;&lt;Mel&gt;大丈夫だよ、、</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>4</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>42496</PointerOffset>
      <VoiceId>&lt;audio:VCT_003_085_005&gt;</VoiceId>
      <JapaneseText>明日の今頃はきっと家で、
ゆっくりしてるはずだよ</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>5</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>42564</PointerOffset>
      <VoiceId>&lt;audio:VCT_003_085_006&gt;</VoiceId>
      <JapaneseText>そう、かな……？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>6</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>42632</PointerOffset>
      <VoiceId>&lt;audio:VCT_003_085_007&gt;</VoiceId>
