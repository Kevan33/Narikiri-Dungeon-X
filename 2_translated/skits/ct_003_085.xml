      <SpeakerId>4</SpeakerId>
      <Id>7</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>42720</PointerOffset>
      <VoiceId>&lt;audio:VCT_003_085_008&gt;</VoiceId>
      <JapaneseText>うん。そんなふうに想像してごらんよ</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>8</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>42808</PointerOffset>
      <VoiceId>&lt;audio:VCT_003_085_009&gt;</VoiceId>
      <JapaneseText>なんかあっという間だって思わない？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>9</Id>
      <Status>To Do</Status>
