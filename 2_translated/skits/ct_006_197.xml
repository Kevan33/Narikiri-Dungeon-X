    <Entry>
      <PointerOffset>51092</PointerOffset>
      <VoiceId>&lt;audio:VCT_006_197_001&gt;</VoiceId>
      <JapaneseText>んっ……んん……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>1</Id>
      <OldPtr>37336</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>51164</PointerOffset>
      <VoiceId>&lt;audio:VCT_006_197_002&gt;</VoiceId>
      <JapaneseText>どうしたの、かぜ？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>2</Id>
      <OldPtr>38068</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>51272</PointerOffset>
      <VoiceId>&lt;audio:VCT_006_197_003&gt;</VoiceId>
      <JapaneseText>わかねけど、ちょっと喉の調子が……
……ん、んっん……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>3</Id>
      <OldPtr>38372</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>51352</PointerOffset>
      <VoiceId>&lt;audio:VCT_006_197_004&gt;</VoiceId>
      <JapaneseText>体調管理には気をつけないと</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>4</Id>
      <OldPtr>39208</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>51424</PointerOffset>
      <VoiceId>&lt;audio:VCT_006_197_005&gt;</VoiceId>
      <JapaneseText>お～い、チビ助ぇ</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>5</Id>
      <OldPtr>39320</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>51544</PointerOffset>
      <VoiceId>&lt;audio:VCT_006_197_006&gt;</VoiceId>
      <JapaneseText>んだよ！　また、屁掛けようってのか！
その手は二度と喰わねぇぞ！！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>6</Id>
      <OldPtr>40356</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>51612</PointerOffset>
      <VoiceId>&lt;audio:VCT_006_197_007&gt;</VoiceId>
      <JapaneseText>こ、これって……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>7</Id>
      <OldPtr>41276</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>51764</PointerOffset>
      <VoiceId>&lt;audio:VCT_006_197_008&gt;</VoiceId>
      <JapaneseText>もぎたての新鮮なフルーツだでよ。カゼの初期なら
十分なビタミン取って、サッサと寝れば治るだーよ</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>8</Id>
      <OldPtr>41704</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>51860</PointerOffset>
      <VoiceId>&lt;audio:VCT_006_197_009&gt;</VoiceId>
      <JapaneseText>&lt;Dio&gt;のために？
……でも、どうして……？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>9</Id>
      <OldPtr>42648</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>51976</PointerOffset>
      <VoiceId>&lt;audio:VCT_006_197_010&gt;</VoiceId>
      <JapaneseText>細かいこたぁ、どうでもいいだど。
それ食って、とっとと寝れ！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>10</Id>
      <OldPtr>43288</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>52068</PointerOffset>
      <VoiceId>&lt;audio:VCT_006_197_011&gt;</VoiceId>
      <JapaneseText>……ふふ、悪く言う割に心配してるんだ♪</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>11</Id>
      <OldPtr>44036</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>52160</PointerOffset>
      <VoiceId>&lt;audio:VCT_006_197_012&gt;</VoiceId>
      <JapaneseText>ほら、&lt;Dio&gt;も早くそれ食べて休んだラ？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>12</Id>
      <OldPtr>44860</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>52236</PointerOffset>
      <VoiceId>&lt;audio:VCT_006_197_013&gt;</VoiceId>
      <JapaneseText>……いや、あの、その……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>13</Id>
      <OldPtr>45460</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>52328</PointerOffset>
      <VoiceId>&lt;audio:VCT_006_197_014&gt;</VoiceId>
      <JapaneseText>サ……サンキュー……タン……アルベルト</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>14</Id>
      <OldPtr>45692</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>52404</PointerOffset>
      <VoiceId>&lt;audio:VCT_006_197_015&gt;</VoiceId>
      <JapaneseText>あの子ったら照れちゃって</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>15</Id>
      <OldPtr>46668</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>52500</PointerOffset>
      <VoiceId>&lt;audio:VCT_006_197_016&gt;</VoiceId>
      <JapaneseText>……アルベルトも優しいところ、
あるんだね！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>16</Id>
      <OldPtr>47092</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>52600</PointerOffset>
      <VoiceId>&lt;audio:VCT_006_197_017&gt;</VoiceId>
      <JapaneseText>あ～ん？　誰が優しいって？　バカこくでねーよ</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>17</Id>
      <OldPtr>47532</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>52736</PointerOffset>
      <VoiceId>&lt;audio:VCT_006_197_018&gt;</VoiceId>
      <JapaneseText>え？　だ、だって、あのフルーツって、
&lt;Dio&gt;のために、わざわざ取ってきたんでしょ？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>18</Id>
      <OldPtr>48120</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>52812</PointerOffset>
      <VoiceId>&lt;audio:VCT_006_197_019&gt;</VoiceId>
      <JapaneseText>昨日の食材の残りだ</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>19</Id>
      <OldPtr>48540</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>52916</PointerOffset>
      <VoiceId>&lt;audio:VCT_006_197_020&gt;</VoiceId>
      <JapaneseText>じゃあ、早く寝ろって、
&lt;Dio&gt;の体調を気遣ってじゃ？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>20</Id>
      <OldPtr>48936</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>53076</PointerOffset>
      <VoiceId>&lt;audio:VCT_006_197_021&gt;</VoiceId>
      <JapaneseText>あいつがカゼ引こうが、おらには関係ねぇだーよ！
&lt;Mel&gt;&lt;Mel&gt;に感染ると迷惑だで、サッサと治させたいだけだ</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>21</Id>
      <OldPtr>49304</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>53160</PointerOffset>
      <VoiceId>&lt;audio:VCT_006_197_022&gt;</VoiceId>
      <JapaneseText>&lt;Dio&gt;には黙っておかなきゃ……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>22</Id>
      <OldPtr>50220</OldPtr>
      <Status>To Do</Status>
    </Entry>
