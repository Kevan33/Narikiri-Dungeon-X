<SceneText>
  <Speakers>
    <Section>Speaker</Section>
    <Entry>
      <PointerOffset>41892,42100,42212,42324,42728</PointerOffset>
      <JapaneseText>&lt;Suzu&gt;</JapaneseText>
      <EnglishText/>
      <Notes/>
      <Id>1</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>41976,42428,42524,42640</PointerOffset>
      <JapaneseText>&lt;Dio&gt;</JapaneseText>
      <EnglishText/>
      <Notes/>
      <Id>2</Id>
      <Status>To Do</Status>
    </Entry>
  </Speakers>
  <Strings>
    <Section>Main</Section>
    <Entry>
      <PointerOffset>41896</PointerOffset>
      <VoiceId>&lt;audio:VCT_004_146_001&gt;</VoiceId>
      <JapaneseText>ずいぶん戦いましたね。すばらしいです</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>1</Id>
      <OldPtr>37120</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>41980</PointerOffset>
      <VoiceId>&lt;audio:VCT_004_146_002&gt;</VoiceId>
      <JapaneseText>これだけ戦えば十分極めたんじゃね</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>2</Id>
      <OldPtr>37408</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>42104</PointerOffset>
      <VoiceId>&lt;audio:VCT_004_146_003&gt;</VoiceId>
      <JapaneseText>忍びは生涯鍛え行く者です。
極めるということは、死ぬ寸前までありません</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>3</Id>
      <OldPtr>38048</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>42216</PointerOffset>
      <VoiceId>&lt;audio:VCT_004_146_004&gt;</VoiceId>
      <JapaneseText>ですが、&lt;Dio&gt;さんは
肉体も精神も存分に強くなったと思います</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>4</Id>
      <OldPtr>38692</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>42328</PointerOffset>
      <VoiceId>&lt;audio:VCT_004_146_005&gt;</VoiceId>
      <JapaneseText>里の頭領として
あなたに『つるにんじゃ』の称号を差し上げます</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>5</Id>
      <OldPtr>39036</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>42432</PointerOffset>
      <VoiceId>&lt;audio:VCT_004_146_006&gt;</VoiceId>
      <JapaneseText>おお、ありがと！！
オレ、ちょっとは強くなれたんだな</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>6</Id>
      <OldPtr>39636</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>42528</PointerOffset>
      <VoiceId>&lt;audio:VCT_004_146_007&gt;</VoiceId>
      <JapaneseText>&lt;Suzu&gt;ちゃんが困った時は
すぐに駆けつけるぜ</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>7</Id>
      <OldPtr>40220</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>42644</PointerOffset>
      <VoiceId>&lt;audio:VCT_004_146_008&gt;</VoiceId>
      <JapaneseText>だから、何かあったら独りで抱えないで
呼んでくれよ、仲間だかんな</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>8</Id>
      <OldPtr>40664</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>42732</PointerOffset>
      <VoiceId>&lt;audio:VCT_004_146_009&gt;</VoiceId>
      <JapaneseText>&lt;Dio&gt;さん、
ありがとうございます</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>9</Id>
      <OldPtr>41032</OldPtr>
      <Status>To Do</Status>
    </Entry>
  </Strings>
  <Strings>
    <Section>Notice</Section>
  </Strings>
</SceneText>
