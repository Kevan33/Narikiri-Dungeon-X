    <Entry>
      <PointerOffset>42900</PointerOffset>
      <VoiceId>&lt;audio:VCT_001_002_001&gt;</VoiceId>
      <JapaneseText>ヴァルハラか。なつかしいな～</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>1</Id>
      <OldPtr>37208</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>42996</PointerOffset>
      <VoiceId>&lt;audio:VCT_001_002_002&gt;</VoiceId>
      <JapaneseText>前来たのは……
仲間探してた時だったっけ…</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>2</Id>
      <OldPtr>37528</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>43092</PointerOffset>
      <VoiceId>&lt;audio:VCT_001_002_003&gt;</VoiceId>
      <JapaneseText>……エトはまたいつか、
旅立っちゃうの……？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>3</Id>
      <OldPtr>37932</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>43216</PointerOffset>
      <VoiceId>&lt;audio:VCT_001_002_004&gt;</VoiceId>
      <JapaneseText>仲間を探して？　うふふ、きみたちを
ほってどこかに行けるはずないでしょ？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>4</Id>
      <OldPtr>38772</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>43276</PointerOffset>
      <VoiceId>&lt;audio:VCT_001_002_005&gt;</VoiceId>
      <JapaneseText>本当に？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>5</Id>
      <OldPtr>39668</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>43344</PointerOffset>
      <VoiceId>&lt;audio:VCT_001_002_006&gt;</VoiceId>
      <JapaneseText>ずっと一緒だよ？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>6</Id>
      <OldPtr>39964</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>43436</PointerOffset>
      <VoiceId>&lt;audio:VCT_001_002_007&gt;</VoiceId>
      <JapaneseText>マジで、&lt;Mel&gt;って
エトには甘えん坊だな</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>7</Id>
      <OldPtr>40264</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>43504</PointerOffset>
      <VoiceId>&lt;audio:VCT_001_002_008&gt;</VoiceId>
      <JapaneseText>&lt;Dio&gt;もでしょ</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>8</Id>
      <OldPtr>41288</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>43620</PointerOffset>
      <VoiceId>&lt;audio:VCT_001_002_009&gt;</VoiceId>
      <JapaneseText>……だってね……きみたちがいれば
他に仲間なんて必要ないかラ……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>9</Id>
      <OldPtr>41996</OldPtr>
      <Status>To Do</Status>
    </Entry>
