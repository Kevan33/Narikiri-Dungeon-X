    <Entry>
      <PointerOffset>44576</PointerOffset>
      <VoiceId>&lt;audio:VCT_002_039_001&gt;</VoiceId>
      <JapaneseText>&lt;Mel&gt;、おなか空いてない？
なにか食べなくて平気？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>1</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>44648</PointerOffset>
      <VoiceId>&lt;audio:VCT_002_039_002&gt;</VoiceId>
      <JapaneseText>うん、平気だよ、全然</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>2</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>44728</PointerOffset>
      <VoiceId>&lt;audio:VCT_002_039_003&gt;</VoiceId>
      <JapaneseText>&lt;Mel&gt;、その『全然』、違うぞ</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>3</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>44800</PointerOffset>
      <VoiceId>&lt;audio:VCT_002_039_004&gt;</VoiceId>
      <JapaneseText>え？　どういうこと？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>4</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>44892</PointerOffset>
      <VoiceId>&lt;audio:VCT_002_039_005&gt;</VoiceId>
      <JapaneseText>『全然』の後には、必ず否定の言葉が来んだ</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>5</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>45000</PointerOffset>
      <VoiceId>&lt;audio:VCT_002_039_006&gt;</VoiceId>
      <JapaneseText>だから、全然ダメ、とか
全然おもしろくねーとかはいいけど</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>6</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>45096</PointerOffset>
      <VoiceId>&lt;audio:VCT_002_039_007&gt;</VoiceId>
      <JapaneseText>全然いいとか、全然面白いとかは
違うんだぜ</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>7</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>45192</PointerOffset>
      <VoiceId>&lt;audio:VCT_002_039_008&gt;</VoiceId>
      <JapaneseText>へぇ……さすが、色々と
本読んでるだけあるね</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>8</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>45256</PointerOffset>
      <VoiceId>&lt;audio:VCT_002_039_009&gt;</VoiceId>
      <JapaneseText>クリュル～</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>4</SpeakerId>
      <Id>9</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>45316</PointerOffset>
      <VoiceId>&lt;audio:VCT_002_039_010&gt;</VoiceId>
      <JapaneseText>…………</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>10</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>45404</PointerOffset>
      <VoiceId>&lt;audio:VCT_002_039_011&gt;</VoiceId>
      <JapaneseText>それできみは
何も食べなくて平気？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>11</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>45508</PointerOffset>
      <VoiceId>&lt;audio:VCT_002_039_012&gt;</VoiceId>
      <JapaneseText>え？　オレ？　うーんと、
オレも全然だいじょーぶ！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>12</Id>
      <Status>To Do</Status>
    </Entry>
