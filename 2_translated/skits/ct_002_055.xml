    <Entry>
      <PointerOffset>43948</PointerOffset>
      <VoiceId>&lt;audio:VCT_002_055_001&gt;</VoiceId>
      <JapaneseText>アルテミスさんを見てたらなぜか、
&lt;Arche&gt;さんを思い出します……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>1</Id>
      <OldPtr>37208</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>44020</PointerOffset>
      <VoiceId>&lt;audio:VCT_002_055_002&gt;</VoiceId>
      <JapaneseText>似てるからじゃないか</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>2</Id>
      <OldPtr>37440</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>44084</PointerOffset>
      <VoiceId>&lt;audio:VCT_002_055_003&gt;</VoiceId>
      <JapaneseText>似てるかな？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>3</Id>
      <OldPtr>37552</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>44176</PointerOffset>
      <VoiceId>&lt;audio:VCT_002_055_004&gt;</VoiceId>
      <JapaneseText>寂しがりやのくせに、強がりな感じとかな</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>4</Id>
      <OldPtr>37704</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>44296</PointerOffset>
      <VoiceId>&lt;audio:VCT_002_055_005&gt;</VoiceId>
      <JapaneseText>それでしょうか。でも、それ以上に
強く印象づいてることがあるんです</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>5</Id>
      <OldPtr>38264</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>44400</PointerOffset>
      <VoiceId>&lt;audio:VCT_002_055_006&gt;</VoiceId>
      <JapaneseText>ダオス戦役中であいつに会った時に
何があったんだ？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>6</Id>
      <OldPtr>38564</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>44528</PointerOffset>
      <VoiceId>&lt;audio:VCT_002_055_007&gt;</VoiceId>
      <JapaneseText>えっと……彼にルナと会うのを邪魔されて、
でも、&lt;Arche&gt;と僕がキスしたら……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>7</Id>
      <OldPtr>38844</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>44608</PointerOffset>
      <VoiceId>&lt;audio:VCT_002_055_008&gt;</VoiceId>
      <JapaneseText>だ、誰が誰とキスだって！？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>8</Id>
      <OldPtr>39224</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>44716</PointerOffset>
      <VoiceId>&lt;audio:VCT_002_055_009&gt;</VoiceId>
      <JapaneseText>だ、黙っててゴメン、&lt;Chester&gt;。
でも、何もしてないんだって</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>9</Id>
      <OldPtr>40840</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>44796</PointerOffset>
      <VoiceId>&lt;audio:VCT_002_055_010&gt;</VoiceId>
      <JapaneseText>あ、そ、そっか……って……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>10</Id>
      <OldPtr>41396</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>44904</PointerOffset>
      <VoiceId>&lt;audio:VCT_002_055_011&gt;</VoiceId>
      <JapaneseText>いや、別にあいつが誰と
キスしようと関係ねぇけどさ……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>11</Id>
      <OldPtr>42140</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>44964</PointerOffset>
      <VoiceId>&lt;audio:VCT_002_055_012&gt;</VoiceId>
      <JapaneseText>…………</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>12</Id>
      <OldPtr>42832</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>45080</PointerOffset>
      <VoiceId>&lt;audio:VCT_002_055_013&gt;</VoiceId>
      <JapaneseText>……あの時の印象が強いから、
思い出すんですね、&lt;Arche&gt;さんを……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>13</Id>
      <OldPtr>43132</OldPtr>
      <Status>To Do</Status>
    </Entry>
