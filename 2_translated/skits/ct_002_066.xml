    <Entry>
      <PointerOffset>49600</PointerOffset>
      <VoiceId>&lt;audio:VCT_002_066_001&gt;</VoiceId>
      <JapaneseText>オレらが牢屋に捕まってる間、
のんびり温泉つかりやがって！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>1</Id>
      <OldPtr>37632</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>49668</PointerOffset>
      <VoiceId>&lt;audio:VCT_002_066_002&gt;</VoiceId>
      <JapaneseText>クルルルルゥ～？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>2</Id>
      <OldPtr>38556</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>49748</PointerOffset>
      <VoiceId>&lt;audio:VCT_002_066_003&gt;</VoiceId>
      <JapaneseText>&lt;Couleur&gt;に怒っても仕方ないよ</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>3</Id>
      <OldPtr>38948</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>49844</PointerOffset>
      <VoiceId>&lt;audio:VCT_002_066_004&gt;</VoiceId>
      <JapaneseText>そうそう。
いい湯加減で気持ちよかったよね？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>4</SpeakerId>
      <Id>4</Id>
      <OldPtr>39388</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>49912</PointerOffset>
      <VoiceId>&lt;audio:VCT_002_066_005&gt;</VoiceId>
      <JapaneseText>クールール～ン♪</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>5</Id>
      <OldPtr>40216</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>50004</PointerOffset>
      <VoiceId>&lt;audio:VCT_002_066_006&gt;</VoiceId>
      <JapaneseText>ロ、&lt;Rody&gt;まで
オレらをほうって……？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>6</Id>
      <OldPtr>40652</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>50112</PointerOffset>
      <VoiceId>&lt;audio:VCT_002_066_007&gt;</VoiceId>
      <JapaneseText>だって、あの時は君たちが
捕まってるなんて知らなかったし</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>4</SpeakerId>
      <Id>7</Id>
      <OldPtr>41148</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>50232</PointerOffset>
      <VoiceId>&lt;audio:VCT_002_066_008&gt;</VoiceId>
      <JapaneseText>おらも温泉入りてぇだーよ。
ふくろだぬきが入ったなんて許せないだ</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>5</SpeakerId>
      <Id>8</Id>
      <OldPtr>41536</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>50344</PointerOffset>
      <VoiceId>&lt;audio:VCT_002_066_009&gt;</VoiceId>
      <JapaneseText>うちのお湯は酸性なので、
金具が錆びてしまうかもしれません</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>6</SpeakerId>
      <Id>9</Id>
      <OldPtr>42580</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>50428</PointerOffset>
      <VoiceId>&lt;audio:VCT_002_066_010&gt;</VoiceId>
      <JapaneseText>それに湿気で腐っちゃうかもだしね</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>4</SpeakerId>
      <Id>10</Id>
      <OldPtr>43068</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>50584</PointerOffset>
      <VoiceId>&lt;audio:VCT_002_066_011&gt;</VoiceId>
      <JapaneseText>やんだやんだぁ。おらも&lt;Mel&gt;&lt;Mel&gt;と&lt;Rody&gt;たんと
ミーたまと&lt;Suzu&gt;ちんと一緒に温泉入りてぇだ～よ</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>5</SpeakerId>
      <Id>11</Id>
      <OldPtr>43440</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>50688</PointerOffset>
      <VoiceId>&lt;audio:VCT_002_066_012&gt;</VoiceId>
      <JapaneseText>だったら、腐ったまま、
二度と湯からあがってくんな！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>12</Id>
      <OldPtr>45288</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>50776</PointerOffset>
      <VoiceId>&lt;audio:VCT_002_066_013&gt;</VoiceId>
      <JapaneseText>そういう&lt;Dio&gt;こそ、
入らないの？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>13</Id>
      <OldPtr>46916</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>50868</PointerOffset>
      <VoiceId>&lt;audio:VCT_002_066_014&gt;</VoiceId>
      <JapaneseText>え？　オレは……遠慮しとく。
あはは……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>14</Id>
      <OldPtr>47544</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>50956</PointerOffset>
      <VoiceId>&lt;audio:VCT_002_066_015&gt;</VoiceId>
      <JapaneseText>&lt;Dio&gt;……
お風呂が嫌いなんです……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>15</Id>
      <OldPtr>48444</OldPtr>
      <Status>To Do</Status>
    </Entry>
