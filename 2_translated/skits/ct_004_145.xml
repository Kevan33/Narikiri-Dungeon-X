    <Entry>
      <PointerOffset>41332</PointerOffset>
      <VoiceId>&lt;audio:VCT_004_145_001&gt;</VoiceId>
      <JapaneseText>シノビになってみて
どうですか？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>1</Id>
      <OldPtr>37208</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>41420</PointerOffset>
      <VoiceId>&lt;audio:VCT_004_145_002&gt;</VoiceId>
      <JapaneseText>わたし、&lt;Dio&gt;にぴったりだと思うよ</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>2</Id>
      <OldPtr>37320</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>41540</PointerOffset>
      <VoiceId>&lt;audio:VCT_004_145_003&gt;</VoiceId>
      <JapaneseText>オレもなんかスゲーしっくりする。
気配とか全然消せたんじゃねーかな？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>3</Id>
      <OldPtr>37640</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>41620</PointerOffset>
      <VoiceId>&lt;audio:VCT_004_145_004&gt;</VoiceId>
      <JapaneseText>い、いえ、まだ気配を感じます</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>4</Id>
      <OldPtr>38484</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>41732</PointerOffset>
      <VoiceId>&lt;audio:VCT_004_145_005&gt;</VoiceId>
      <JapaneseText>しかし、もっと修行を積めば
気配を消せるようになるでしょう</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>5</Id>
      <OldPtr>38844</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>41864</PointerOffset>
      <VoiceId>&lt;audio:VCT_004_145_006&gt;</VoiceId>
      <JapaneseText>時に非情であることが忍びには求められます。
そうでなければ、務まらないことも……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>6</Id>
      <OldPtr>39288</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>41964</PointerOffset>
      <VoiceId>&lt;audio:VCT_004_145_007&gt;</VoiceId>
      <JapaneseText>そのことを心に留めて
忍びを極めていってください</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>7</Id>
      <OldPtr>39916</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>42044</PointerOffset>
      <VoiceId>&lt;audio:VCT_004_145_008&gt;</VoiceId>
      <JapaneseText>さすが、&lt;Suzu&gt;ちゃんだね……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>8</Id>
      <OldPtr>40236</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>42116</PointerOffset>
      <VoiceId>&lt;audio:VCT_004_145_009&gt;</VoiceId>
      <JapaneseText>ああ。やってやる！！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>9</Id>
      <OldPtr>40404</OldPtr>
      <Status>To Do</Status>
    </Entry>
