    <Entry>
      <PointerOffset>46024</PointerOffset>
      <VoiceId>&lt;audio:VCT_006_210_001&gt;</VoiceId>
      <JapaneseText>グミうめぇ！　超うめぇ！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>1</Id>
      <OldPtr>37268</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>46116</PointerOffset>
      <VoiceId>&lt;audio:VCT_006_210_002&gt;</VoiceId>
      <JapaneseText>&lt;Dio&gt;、グミは
おやつじゃないんだから！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>2</Id>
      <OldPtr>38008</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>46232</PointerOffset>
      <VoiceId>&lt;audio:VCT_006_210_003&gt;</VoiceId>
      <JapaneseText>全然だいじょーぶだって。
そもそも薬なんだし、体にもいいんだろ？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>3</Id>
      <OldPtr>38452</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>46312</PointerOffset>
      <VoiceId>&lt;audio:VCT_006_210_004&gt;</VoiceId>
      <JapaneseText>わかってないな～お子ちゃまは</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>4</Id>
      <OldPtr>39360</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>46368</PointerOffset>
      <VoiceId>&lt;audio:VCT_006_210_005&gt;</VoiceId>
      <JapaneseText>え？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>5</Id>
      <OldPtr>39884</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>46496</PointerOffset>
      <VoiceId>&lt;audio:VCT_006_210_006&gt;</VoiceId>
      <JapaneseText>いい？　薬品ってのは、重ねて使うと、
体に抗体ができて効きにくくなるんだから</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>6</Id>
      <OldPtr>40120</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>46572</PointerOffset>
      <VoiceId>&lt;audio:VCT_006_210_007&gt;</VoiceId>
      <JapaneseText>えっ！？　マ、マジで？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>7</Id>
      <OldPtr>41008</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>46716</PointerOffset>
      <VoiceId>&lt;audio:VCT_006_210_008&gt;</VoiceId>
      <JapaneseText>マジもマジ、大マジ。頭痛薬とかもそうだしね、
使いすぎるとだんだん効きにくくなってくるって</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>8</Id>
      <OldPtr>41740</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>46824</PointerOffset>
      <VoiceId>&lt;audio:VCT_006_210_009&gt;</VoiceId>
      <JapaneseText>イザという時。グミが効かなかったら……
……困るよね～</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>9</Id>
      <OldPtr>42720</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>46892</PointerOffset>
      <VoiceId>&lt;audio:VCT_006_210_010&gt;</VoiceId>
      <JapaneseText>そ、そんな……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>10</Id>
      <OldPtr>43404</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>46960</PointerOffset>
      <VoiceId>&lt;audio:VCT_006_210_011&gt;</VoiceId>
      <JapaneseText>ほ、ほんとうに？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>11</Id>
      <OldPtr>44140</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>47084</PointerOffset>
      <VoiceId>&lt;audio:VCT_006_210_012&gt;</VoiceId>
      <JapaneseText>なんてね……ウソウソ。
だって滋養強壮薬だし？　抗体なんてできないって</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>12</Id>
      <OldPtr>44448</OldPtr>
      <Status>To Do</Status>
    </Entry>
