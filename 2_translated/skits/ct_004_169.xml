    <Entry>
      <PointerOffset>46864</PointerOffset>
      <VoiceId>&lt;audio:VCT_004_169_001&gt;</VoiceId>
      <JapaneseText>うふふ、うふふふ……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>1</Id>
      <OldPtr>37376</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>46948</PointerOffset>
      <VoiceId>&lt;audio:VCT_004_169_002&gt;</VoiceId>
      <JapaneseText>&lt;Mel&gt;……ずいぶんとご機嫌だね？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>2</Id>
      <OldPtr>37860</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>47056</PointerOffset>
      <VoiceId>&lt;audio:VCT_004_169_003&gt;</VoiceId>
      <JapaneseText>だって、楽しいんだもん。
いろんなコスチューム着られて</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>3</Id>
      <OldPtr>38028</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>47180</PointerOffset>
      <VoiceId>&lt;audio:VCT_004_169_004&gt;</VoiceId>
      <JapaneseText>女の子だもんね。やっぱたくさん服があって
いろいろ試すのって楽しいよね</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>4</Id>
      <OldPtr>38616</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>47268</PointerOffset>
      <VoiceId>&lt;audio:VCT_004_169_005&gt;</VoiceId>
      <JapaneseText>うん、『なりきり士』って楽しいよ？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>5</Id>
      <OldPtr>39228</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>47376</PointerOffset>
      <VoiceId>&lt;audio:VCT_004_169_006&gt;</VoiceId>
      <JapaneseText>なんで着替えんのがそんな楽しいんだ？
めんどくせーってば</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>6</Id>
      <OldPtr>39628</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>47516</PointerOffset>
      <VoiceId>&lt;audio:VCT_004_169_007&gt;</VoiceId>
      <JapaneseText>まったくこれだからこのハゲぼうずは……
いいか、着替えっつーのも男のロマンなんだど</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>4</SpeakerId>
      <Id>7</Id>
      <OldPtr>40084</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>47612</PointerOffset>
      <VoiceId>&lt;audio:VCT_004_169_008&gt;</VoiceId>
      <JapaneseText>何言ってんだ？
んなもん、さっぱりわかんねよ</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>8</Id>
      <OldPtr>41848</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>47764</PointerOffset>
      <VoiceId>&lt;audio:VCT_004_169_009&gt;</VoiceId>
      <JapaneseText>考えてもみるだ……うら若き乙女のお着替えシーン。
かすかに聞こえる布ずれの音……そして息遣い……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>4</SpeakerId>
      <Id>9</Id>
      <OldPtr>42136</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>47896</PointerOffset>
      <VoiceId>&lt;audio:VCT_004_169_010&gt;</VoiceId>
      <JapaneseText>間違ってうっかり着替えを除いてしまい
きゃー、エッチ！　のお約束イベント……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>4</SpeakerId>
      <Id>10</Id>
      <OldPtr>43092</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>48044</PointerOffset>
      <VoiceId>&lt;audio:VCT_004_169_011&gt;</VoiceId>
      <JapaneseText>わかるか、わかるだか！　こーんな感じで、
お着替えには、いーっぱい男の夢が詰まってるだーよ！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>4</SpeakerId>
      <Id>11</Id>
      <OldPtr>44252</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>48124</PointerOffset>
      <VoiceId>&lt;audio:VCT_004_169_012&gt;</VoiceId>
      <JapaneseText>家具のくせにおっさんくせっ</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>12</Id>
      <OldPtr>45400</OldPtr>
      <Status>To Do</Status>
    </Entry>
