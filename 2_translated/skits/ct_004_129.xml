  </Speakers>
  <Strings>
    <Section>Main</Section>
    <Entry>
      <PointerOffset>46360</PointerOffset>
      <VoiceId>&lt;audio:VCT_004_129_001&gt;</VoiceId>
      <JapaneseText>うへ～喉渇いたぁ～</JapaneseText>
      <EnglishText>Ugh~ I'm thirstyyyyy!</EnglishText>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>1</Id>
      <Status>Editing</Status>
    </Entry>
    <Entry>
      <PointerOffset>46432</PointerOffset>
      <VoiceId>&lt;audio:VCT_004_129_002&gt;</VoiceId>
      <JapaneseText>はい、&lt;Dio&gt;、お水</JapaneseText>
      <EnglishText>Here, &lt;Dio&gt;, water.</EnglishText>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>2</Id>
      <Status>Editing</Status>
    </Entry>
    <Entry>
      <PointerOffset>46508</PointerOffset>
      <VoiceId>&lt;audio:VCT_004_129_003&gt;</VoiceId>
      <JapaneseText>水……か、ま、いっか……</JapaneseText>
      <EnglishText>Water, huh? Well, alright...</EnglishText>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>3</Id>
      <Status>Editing</Status>
    </Entry>
    <Entry>
      <PointerOffset>46588</PointerOffset>
      <VoiceId>&lt;audio:VCT_004_129_004&gt;</VoiceId>
      <JapaneseText>んぐんぐ……くはぁあっ……！</JapaneseText>
      <EnglishText>*gulp* *gulp*... Puhaaaaaaah~</EnglishText>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>4</Id>
      <Status>Editing</Status>
    </Entry>
    <Entry>
      <PointerOffset>46704</PointerOffset>
      <VoiceId>&lt;audio:VCT_004_129_005&gt;</VoiceId>
      <JapaneseText>やっぱ&lt;Cless&gt;さんたちと比べると、
まだおれ、伸び足りないんだよな</JapaneseText>
      <EnglishText>Compared to &lt;Cless&gt; and everyone else, I've
still got a lot to catch up on.</EnglishText>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>5</Id>
      <Status>Editing</Status>
    </Entry>
    <Entry>
      <PointerOffset>46828</PointerOffset>
      <VoiceId>&lt;audio:VCT_004_129_006&gt;</VoiceId>
      <JapaneseText>そんなことないって！　時空戦士と
肩を並べて戦って、&lt;Dio&gt;すごいってば！</JapaneseText>
      <EnglishText>Oh, that's nonsense! To hold your own alongside
the Heroes of Time is no small feat!</EnglishText>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>6</Id>
      <Status>Editing</Status>
    </Entry>
    <Entry>
      <PointerOffset>46952</PointerOffset>
      <VoiceId>&lt;audio:VCT_004_129_007&gt;</VoiceId>
      <JapaneseText>エトは褒めすぎにしても……
お世辞抜きでもいいとこいってるんじゃないかな</JapaneseText>
      <EnglishText>Etho's definitely laying it on thick... But yeah,
flattery aside, you're doing pretty well.</EnglishText>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>7</Id>
      <Status>Editing</Status>
    </Entry>
    <Entry>
      <PointerOffset>47040</PointerOffset>
      <VoiceId>&lt;audio:VCT_004_129_008&gt;</VoiceId>
      <JapaneseText>さっきひとりで決めた連続攻撃とかさ</JapaneseText>
      <EnglishText>Like that combo you just managed to pull
off on your own?</EnglishText>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>8</Id>
      <Status>Editing</Status>
    </Entry>
    <Entry>
      <PointerOffset>47140</PointerOffset>
      <VoiceId>&lt;audio:VCT_004_129_009&gt;</VoiceId>
      <JapaneseText>いや、まだまだだって……
もうちょっと…こうっ！</JapaneseText>
      <EnglishText>No, definitely not there yet.
Maybe if I...</EnglishText>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>9</Id>
      <Status>Editing</Status>
    </Entry>
    <Entry>
      <PointerOffset>47212</PointerOffset>
      <VoiceId>&lt;audio:VCT_004_129_010&gt;</VoiceId>
      <JapaneseText>いや……まだまだ……</JapaneseText>
      <EnglishText>No...still not there.</EnglishText>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>10</Id>
      <Status>Editing</Status>
    </Entry>
    <Entry>
      <PointerOffset>47328</PointerOffset>
      <VoiceId>&lt;audio:VCT_004_129_011&gt;</VoiceId>
      <JapaneseText>こんなに真剣に伸び悩んでるなんて……
&lt;Dio&gt;も成長したんだね……</JapaneseText>
      <EnglishText>To think you'd take your training so seriously...
You truly are growing up, &lt;Dio&gt;.</EnglishText>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>11</Id>
      <Status>Editing</Status>
    </Entry>
    <Entry>
      <PointerOffset>47400</PointerOffset>
      <VoiceId>&lt;audio:VCT_004_129_012&gt;</VoiceId>
      <JapaneseText>やっぱあれだよな……</JapaneseText>
      <EnglishText>As I thought...</EnglishText>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>12</Id>
      <Status>Editing</Status>
    </Entry>
    <Entry>
      <PointerOffset>47476</PointerOffset>
      <VoiceId>&lt;audio:VCT_004_129_013&gt;</VoiceId>
      <JapaneseText>やっぱ、水より牛乳だな</JapaneseText>
      <EnglishText>Milk's much better than water.</EnglishText>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>13</Id>
      <Status>Editing</Status>
    </Entry>
    <Entry>
      <PointerOffset>47564</PointerOffset>
      <VoiceId>&lt;audio:VCT_004_129_014&gt;</VoiceId>
      <JapaneseText>伸び悩んでるって……
背のこと……？</JapaneseText>
      <EnglishText>Wait, when you were talking about catching up...
Did you mean height?</EnglishText>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>14</Id>
      <Status>Editing</Status>
    </Entry>
  </Strings>
</SceneText>
