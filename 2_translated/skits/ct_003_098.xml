    <Entry>
      <PointerOffset>46444</PointerOffset>
      <VoiceId>&lt;audio:VCT_003_098_001&gt;</VoiceId>
      <JapaneseText>アルベルトさんの体って、木でできてるんですよね？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>1</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>46580</PointerOffset>
      <VoiceId>&lt;audio:VCT_003_098_002&gt;</VoiceId>
      <JapaneseText>&lt;Mel&gt;&lt;Mel&gt;おぉ、そうだど、。
ただ木っつても、そんじょそこらの木とは違うだよ</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>2</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>46660</PointerOffset>
      <VoiceId>&lt;audio:VCT_003_098_003&gt;</VoiceId>
      <JapaneseText>それは、材質が特別ってこと？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>3</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>46780</PointerOffset>
      <VoiceId>&lt;audio:VCT_003_098_004&gt;</VoiceId>
      <JapaneseText>そーいうこった。
おらの体は世界樹のご神木からできてるだーよ。</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>4</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>46848</PointerOffset>
      <VoiceId>&lt;audio:VCT_003_098_005&gt;</VoiceId>
      <JapaneseText>え？　うソ！？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>5</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>46992</PointerOffset>
      <VoiceId>&lt;audio:VCT_003_098_006&gt;</VoiceId>
      <JapaneseText>ま、ほんとかどうかは、おらも知らんが。
た～ぶん、そんぐらい貴重なもんを使ってるはずだ</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>6</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>47132</PointerOffset>
      <VoiceId>&lt;audio:VCT_003_098_007&gt;</VoiceId>
      <JapaneseText>んで、そのたいそう立派なご神木使って、
ノルン様が日曜大工して、おらを作っただーよ</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>7</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>47196</PointerOffset>
      <VoiceId>&lt;audio:VCT_003_098_008&gt;</VoiceId>
      <JapaneseText>日曜大工ー！？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>4</SpeakerId>
      <Id>8</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>47392</PointerOffset>
      <VoiceId>&lt;audio:VCT_003_098_011&gt;</VoiceId>
      <JapaneseText>クルゥ？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>5</SpeakerId>
      <Id>9</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>47464</PointerOffset>
      <VoiceId>&lt;audio:VCT_003_098_012&gt;</VoiceId>
      <JapaneseText>ほんとかよ、それ？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>6</SpeakerId>
      <Id>10</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>47596</PointerOffset>
      <VoiceId>&lt;audio:VCT_003_098_013&gt;</VoiceId>
      <JapaneseText>アホかぁ？　作るところ見たわけじゃねぇから、
おらだって、わかるわけねぇべ</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>11</Id>
      <Status>To Do</Status>
    </Entry>
