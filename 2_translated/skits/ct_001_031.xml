    <Entry>
      <PointerOffset>44164</PointerOffset>
      <VoiceId>&lt;audio:VCT_001_031_001&gt;</VoiceId>
      <JapaneseText>…………</JapaneseText>
      <EnglishText>...</EnglishText>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>1</Id>
      <Status>Editing</Status>
    </Entry>
    <Entry>
      <PointerOffset>44288</PointerOffset>
      <VoiceId>&lt;audio:VCT_001_031_003&gt;</VoiceId>
      <JapaneseText>あの、さ……</JapaneseText>
      <EnglishText>Hey, um...</EnglishText>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>2</Id>
      <Status>Editing</Status>
    </Entry>
    <Entry>
      <PointerOffset>44348</PointerOffset>
      <VoiceId>&lt;audio:VCT_001_031_004&gt;</VoiceId>
      <JapaneseText>なんだよ</JapaneseText>
      <EnglishText>What?</EnglishText>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>3</Id>
      <Status>Editing</Status>
    </Entry>
    <Entry>
      <PointerOffset>44420</PointerOffset>
      <VoiceId>&lt;audio:VCT_001_031_005&gt;</VoiceId>
      <JapaneseText>……何怒ってんの？</JapaneseText>
      <EnglishText>...Why are you angry, now?</EnglishText>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>4</Id>
      <Status>Editing</Status>
    </Entry>
    <Entry>
      <PointerOffset>44500</PointerOffset>
      <VoiceId>&lt;audio:VCT_001_031_006&gt;</VoiceId>
      <JapaneseText>別に。怒ってなんかねーって</JapaneseText>
      <EnglishText>Nope. I'm not mad at all.</EnglishText>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>5</Id>
      <Status>Editing</Status>
    </Entry>
    <Entry>
      <PointerOffset>44564</PointerOffset>
      <VoiceId>&lt;audio:VCT_001_031_007&gt;</VoiceId>
      <JapaneseText>……ゴメン</JapaneseText>
      <EnglishText>...Sorry.</EnglishText>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>6</Id>
      <Status>Editing</Status>
    </Entry>
    <Entry>
      <PointerOffset>44640</PointerOffset>
      <VoiceId>&lt;audio:VCT_001_031_008&gt;</VoiceId>
      <JapaneseText>怒ってねーってんだろ？</JapaneseText>
      <EnglishText>Are YOU angry?</EnglishText>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>7</Id>
      <Status>Editing</Status>
    </Entry>
    <Entry>
      <PointerOffset>44720</PointerOffset>
      <VoiceId>&lt;audio:VCT_001_031_009&gt;</VoiceId>
      <JapaneseText>謝ってるのに、何で怒んの？</JapaneseText>
      <EnglishText>I'm apologizing! Why are you angry now?</EnglishText>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>8</Id>
      <Status>Editing</Status>
    </Entry>
    <Entry>
      <PointerOffset>44792</PointerOffset>
      <VoiceId>&lt;audio:VCT_001_031_010&gt;</VoiceId>
      <JapaneseText>怒ってねーっての！</JapaneseText>
      <EnglishText>I'm NOT angry!</EnglishText>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>9</Id>
      <Status>Editing</Status>
    </Entry>
    <Entry>
      <PointerOffset>44860</PointerOffset>
      <VoiceId>&lt;audio:VCT_001_031_011&gt;</VoiceId>
      <JapaneseText>じゃあ、笑って</JapaneseText>
      <EnglishText>Then smile.</EnglishText>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>10</Id>
      <Status>Editing</Status>
    </Entry>
    <Entry>
      <PointerOffset>44940</PointerOffset>
      <VoiceId>&lt;audio:VCT_001_031_012&gt;</VoiceId>
      <JapaneseText>突然言われて、笑えるかって</JapaneseText>
      <EnglishText>Just telling me to smile won't make me smile.</EnglishText>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>11</Id>
      <Status>Editing</Status>
    </Entry>
    <Entry>
      <PointerOffset>45016</PointerOffset>
      <VoiceId>&lt;audio:VCT_001_031_013&gt;</VoiceId>
      <JapaneseText>やっぱり、怒ってるんだ</JapaneseText>
      <EnglishText>I knew it, you're mad!</EnglishText>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>12</Id>
      <Status>Editing</Status>
    </Entry>
    <Entry>
      <PointerOffset>45084</PointerOffset>
      <VoiceId>&lt;audio:VCT_001_031_014&gt;</VoiceId>
      <JapaneseText>……んだよ、もう</JapaneseText>
      <EnglishText>Ugh...</EnglishText>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>13</Id>
      <Status>Editing</Status>
    </Entry>
    <Entry>
      <PointerOffset>45148</PointerOffset>
      <VoiceId>&lt;audio:VCT_001_031_015&gt;</VoiceId>
      <JapaneseText>気持ち悪い</JapaneseText>
      <EnglishText>That's just creepy...</EnglishText>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>14</Id>
      <Status>Editing</Status>
    </Entry>
    <Entry>
      <PointerOffset>45236</PointerOffset>
      <VoiceId>&lt;audio:VCT_001_031_016&gt;</VoiceId>
      <JapaneseText>んだよ、どうすりゃいいってんだ！？</JapaneseText>
      <EnglishText>God, what do you want me to do!?</EnglishText>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>15</Id>
      <Status>Editing</Status>
    </Entry>
    <Entry>
      <PointerOffset>45320</PointerOffset>
      <VoiceId>&lt;audio:VCT_001_031_017&gt;</VoiceId>
      <JapaneseText>乙女心は難しいんだよ、&lt;Dio&gt;くん</JapaneseText>
      <EnglishText>A young girl's heart is like a web of complexities, &lt;Dio&gt;!</EnglishText>
      <Notes/>
      <SpeakerId>4</SpeakerId>
      <Id>16</Id>
      <Status>Editing</Status>
    </Entry>
