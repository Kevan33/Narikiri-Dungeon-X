    <Entry>
      <PointerOffset>42388</PointerOffset>
      <VoiceId>&lt;audio:VCT_003_109_001&gt;</VoiceId>
      <JapaneseText>なんかヘンテコなとこに
出ちゃったよな</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>1</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>42472</PointerOffset>
      <VoiceId>&lt;audio:VCT_003_109_002&gt;</VoiceId>
      <JapaneseText>不思議……空の上にいるみたい……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>2</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>42560</PointerOffset>
      <VoiceId>&lt;audio:VCT_003_109_003&gt;</VoiceId>
      <JapaneseText>この洞窟、
どこまで続いてるの……？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>3</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>42668</PointerOffset>
      <VoiceId>&lt;audio:VCT_003_109_004&gt;</VoiceId>
      <JapaneseText>一体……きみたち、どこまで
行かなきゃいけないの……？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>4</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>42764</PointerOffset>
      <VoiceId>&lt;audio:VCT_003_109_005&gt;</VoiceId>
      <JapaneseText>わかんないけど……
ノルンがいるところまで</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>5</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>42832</PointerOffset>
      <VoiceId>&lt;audio:VCT_003_109_006&gt;</VoiceId>
      <JapaneseText>帰るか？　エト</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>6</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>42940</PointerOffset>
      <VoiceId>&lt;audio:VCT_003_109_007&gt;</VoiceId>
      <JapaneseText>行く……！！
きみたちが行くなら、ぼくもどこまでも……！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>7</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>43048</PointerOffset>
      <VoiceId>&lt;audio:VCT_003_109_008&gt;</VoiceId>
      <JapaneseText>うん……帰るなんて言わないで……
これが最後だから……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>8</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>43124</PointerOffset>
      <VoiceId>&lt;audio:VCT_003_109_009&gt;</VoiceId>
      <JapaneseText>……最後って、そんな……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>9</Id>
      <Status>To Do</Status>
    </Entry>
