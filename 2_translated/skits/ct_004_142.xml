    <Section>Main</Section>
    <Entry>
      <PointerOffset>43660</PointerOffset>
      <VoiceId>&lt;audio:VCT_004_142_001&gt;</VoiceId>
      <JapaneseText>ホウキってすごーい。
空飛んでる。気持ちいい</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>1</Id>
      <OldPtr>37872</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>43764</PointerOffset>
      <VoiceId>&lt;audio:VCT_004_142_002&gt;</VoiceId>
      <JapaneseText>なんだよ。&lt;Mel&gt;も
簡単にホウキに乗れてるじゃねぇか</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>2</Id>
      <OldPtr>38196</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>43868</PointerOffset>
      <VoiceId>&lt;audio:VCT_004_142_003&gt;</VoiceId>
      <JapaneseText>ちっちっち。
&lt;Mel&gt;ちゃんも素質を持っているのだよ</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>3</Id>
      <OldPtr>38520</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>43996</PointerOffset>
      <VoiceId>&lt;audio:VCT_004_142_004&gt;</VoiceId>
      <JapaneseText>ねえ&lt;Mel&gt;ちゃん。ホウキ仲間になったところで
一緒にいいトコロいっちゃう？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>4</Id>
      <OldPtr>39060</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>44088</PointerOffset>
      <VoiceId>&lt;audio:VCT_004_142_005&gt;</VoiceId>
      <JapaneseText>敵をいっぱい
打ち落としちゃったりして～</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>5</Id>
      <OldPtr>39668</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>44200</PointerOffset>
      <VoiceId>&lt;audio:VCT_004_142_006&gt;</VoiceId>
      <JapaneseText>楽しそうですね。
でもまだホウキに慣れてなくて、そこまで……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>6</Id>
      <OldPtr>39836</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>44296</PointerOffset>
      <VoiceId>&lt;audio:VCT_004_142_007&gt;</VoiceId>
      <JapaneseText>いいから、いいから。
見学だけでも楽しいよ</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>7</Id>
      <OldPtr>40068</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>44368</PointerOffset>
      <VoiceId>&lt;audio:VCT_004_142_008&gt;</VoiceId>
      <JapaneseText>ついて行きます！！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>8</Id>
      <OldPtr>40856</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>44476</PointerOffset>
      <VoiceId>&lt;audio:VCT_004_142_009&gt;</VoiceId>
      <JapaneseText>んじゃ、&lt;Chester&gt;
ちょっとだけ『ぐるぅびぃ』してくるねー</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>9</Id>
      <OldPtr>41092</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>44596</PointerOffset>
      <VoiceId>&lt;audio:VCT_004_142_010&gt;</VoiceId>
      <JapaneseText>おい、&lt;Arche&gt;どこいくんだよ。
ていうか『ぐるぅびぃ』ってなんだよ！！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>10</Id>
      <OldPtr>42224</OldPtr>
      <Status>To Do</Status>
    </Entry>
