    <Entry>
      <PointerOffset>45512</PointerOffset>
      <VoiceId>&lt;audio:VCT_004_124_001&gt;</VoiceId>
      <JapaneseText>新記録達成だっ！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>1</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>45580</PointerOffset>
      <VoiceId>&lt;audio:VCT_004_124_002&gt;</VoiceId>
      <JapaneseText>新記録って何が？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>2</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>45700</PointerOffset>
      <VoiceId>&lt;audio:VCT_004_124_003&gt;</VoiceId>
      <JapaneseText>さっきの戦い、オレら、今までで
一番多く連続攻撃叩き込んだんだぜ？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>3</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>45796</PointerOffset>
      <VoiceId>&lt;audio:VCT_004_124_004&gt;</VoiceId>
      <JapaneseText>ブツブツ数えてたのそれなんだ……
でも……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>4</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>45860</PointerOffset>
      <VoiceId>&lt;audio:VCT_004_124_005&gt;</VoiceId>
      <JapaneseText>なんだよ？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>5</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>45984</PointerOffset>
      <VoiceId>&lt;audio:VCT_004_124_006&gt;</VoiceId>
      <JapaneseText>ふたりがかりで攻撃してると、
一方的にいじめてるみたいで……かわいそう</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>6</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>46136</PointerOffset>
      <VoiceId>&lt;audio:VCT_004_124_007&gt;</VoiceId>
      <JapaneseText>&lt;Mel&gt;&lt;Mel&gt;は誰に対しても、ほんとに優しい娘っ子だよ。
それに引き換え、そこのハゲぼうずはよ……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>7</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>46224</PointerOffset>
      <VoiceId>&lt;audio:VCT_004_124_008&gt;</VoiceId>
      <JapaneseText>んだと、このタンス野郎！　砕くぞ！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>8</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>46288</PointerOffset>
      <VoiceId>&lt;audio:VCT_004_124_009&gt;</VoiceId>
      <JapaneseText>やめなさい！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>9</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>46384</PointerOffset>
      <VoiceId>&lt;audio:VCT_004_124_010&gt;</VoiceId>
      <JapaneseText>へへ～へっ、&lt;Mel&gt;&lt;Mel&gt;に殴られてる～</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>10</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>46480</PointerOffset>
      <VoiceId>&lt;audio:VCT_004_124_011&gt;</VoiceId>
      <JapaneseText>……魔物に優しい前に
オレに優しくしろよ……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>11</Id>
      <Status>To Do</Status>
    </Entry>
