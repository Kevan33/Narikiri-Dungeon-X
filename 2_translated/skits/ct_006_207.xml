  </Speakers>
  <Strings>
    <Section>Main</Section>
    <Entry>
      <PointerOffset>44468</PointerOffset>
      <VoiceId>&lt;audio:VCT_006_207_001&gt;</VoiceId>
      <JapaneseText>なぁなぁなぁ、
オレら大金持ちなんじゃねか！？</JapaneseText>
      <EnglishText>Hey, hey, aren't we rich?</EnglishText>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>1</Id>
      <Status>Editing</Status>
    </Entry>
    <Entry>
      <PointerOffset>44572</PointerOffset>
      <VoiceId>&lt;audio:VCT_006_207_002&gt;</VoiceId>
      <JapaneseText>たくさん貯まったね。
でも、無駄遣いしちゃダメだよ</JapaneseText>
      <EnglishText>We've definitely saved a lot.
We can't just squander this though!</EnglishText>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>2</Id>
      <Status>Editing</Status>
    </Entry>
    <Entry>
      <PointerOffset>44648</PointerOffset>
      <VoiceId>&lt;audio:VCT_006_207_003&gt;</VoiceId>
      <JapaneseText>……わ、わかってるよ！</JapaneseText>
      <EnglishText>...I-I know that!</EnglishText>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>3</Id>
      <Status>Editing</Status>
    </Entry>
    <Entry>
      <PointerOffset>44784</PointerOffset>
      <VoiceId>&lt;audio:VCT_006_207_004&gt;</VoiceId>
      <JapaneseText>お金は計画的に使わないと。アレもこれもって
買ってたらすぐに無くなっちゃうんだから</JapaneseText>
      <EnglishText>We have to carefully plan how we're going to save money.
If we keep buying this and that, we'll lose it all in no time!</EnglishText>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>4</Id>
      <Status>Editing</Status>
    </Entry>
    <Entry>
      <PointerOffset>44900</PointerOffset>
      <VoiceId>&lt;audio:VCT_006_207_005&gt;</VoiceId>
      <JapaneseText>でもちょっとだけいいか？
どーしても欲しいものがあんだけど……</JapaneseText>
      <EnglishText>Okay, but how about just a teeny tiny bit?
I have something I have an eye on...</EnglishText>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>5</Id>
      <Status>Editing</Status>
    </Entry>
    <Entry>
      <PointerOffset>45000</PointerOffset>
      <VoiceId>&lt;audio:VCT_006_207_006&gt;</VoiceId>
      <JapaneseText>物と値段によっては少しはいいけど……
……なに？</JapaneseText>
      <EnglishText>Well, if it doesn't cost that much, I don't
see why not...&lt;Dio&gt;?</EnglishText>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>6</Id>
      <Status>Editing</Status>
    </Entry>
    <Entry>
      <PointerOffset>45140</PointerOffset>
      <VoiceId>&lt;audio:VCT_006_207_007&gt;</VoiceId>
      <JapaneseText>オンドゥオオカブトと、ダディヤオオクワガタ。
これでリアル『バトル昆虫ファイト』したい</JapaneseText>
      <EnglishText>I want a Hercules Beetle and a Great Stag Beetle.
I want to see them face off in a real hardy battle!</EnglishText>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>7</Id>
      <Status>Editing</Status>
    </Entry>
    <Entry>
      <PointerOffset>45204</PointerOffset>
      <VoiceId>&lt;audio:VCT_006_207_008&gt;</VoiceId>
      <JapaneseText>いくら……？</JapaneseText>
      <EnglishText>So...how much?</EnglishText>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>8</Id>
      <Status>Editing</Status>
    </Entry>
    <Entry>
      <PointerOffset>45288</PointerOffset>
      <VoiceId>&lt;audio:VCT_006_207_009&gt;</VoiceId>
      <JapaneseText>……合わせて、に、２５万ガルド</JapaneseText>
      <EnglishText>All together...250 thousand gald...</EnglishText>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>9</Id>
      <Status>Editing</Status>
    </Entry>
    <Entry>
      <PointerOffset>45356</PointerOffset>
      <VoiceId>&lt;audio:VCT_006_207_010&gt;</VoiceId>
      <JapaneseText>……………………</JapaneseText>
      <EnglishText>...</EnglishText>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>10</Id>
      <Status>Editing</Status>
    </Entry>
    <Entry>
      <PointerOffset>45424</PointerOffset>
      <VoiceId>&lt;audio:VCT_006_207_011&gt;</VoiceId>
      <JapaneseText>……………………</JapaneseText>
      <EnglishText>...</EnglishText>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>11</Id>
      <Status>Editing</Status>
    </Entry>
    <Entry>
      <PointerOffset>45492</PointerOffset>
      <VoiceId>&lt;audio:VCT_006_207_012&gt;</VoiceId>
      <JapaneseText>……………………</JapaneseText>
      <EnglishText>...</EnglishText>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>12</Id>
      <Status>Editing</Status>
    </Entry>
    <Entry>
      <PointerOffset>45564</PointerOffset>
      <VoiceId>&lt;audio:VCT_006_207_013&gt;</VoiceId>
      <JapaneseText>……やっぱ、いいです</JapaneseText>
      <EnglishText>Nevermind.</EnglishText>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>13</Id>
      <Status>Editing</Status>
    </Entry>
  </Strings>
