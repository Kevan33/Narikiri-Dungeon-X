    <Entry>
      <PointerOffset>41308</PointerOffset>
      <VoiceId>&lt;audio:VCT_005_184_001&gt;</VoiceId>
      <JapaneseText>&lt;Rody&gt;さんの包丁さばき、
すごく鮮やかですね</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>1</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>41396</PointerOffset>
      <VoiceId>&lt;audio:VCT_005_184_002&gt;</VoiceId>
      <JapaneseText>刃物の扱いは、
父さん直伝だからね</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>2</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>41496</PointerOffset>
      <VoiceId>&lt;audio:VCT_005_184_003&gt;</VoiceId>
      <JapaneseText>&lt;Rody&gt;の父ちゃんって
コックさんだったのか？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>3</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>41584</PointerOffset>
      <VoiceId>&lt;audio:VCT_005_184_004&gt;</VoiceId>
      <JapaneseText>ううん。お城に仕えてたんだけど……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>4</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>41692</PointerOffset>
      <VoiceId>&lt;audio:VCT_005_184_005&gt;</VoiceId>
      <JapaneseText>お城に仕えてたってことは
やっぱコックさんじゃねのか？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>5</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>41808</PointerOffset>
      <VoiceId>&lt;audio:VCT_005_184_006&gt;</VoiceId>
      <JapaneseText>お城だったら、兵士とかでしょ。
剣とか槍とか使い慣れてるわけだし</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>6</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>41884</PointerOffset>
      <VoiceId>&lt;audio:VCT_005_184_007&gt;</VoiceId>
      <JapaneseText>剣と包丁は違くないか？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>7</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>41948</PointerOffset>
      <VoiceId>&lt;audio:VCT_005_184_008&gt;</VoiceId>
      <JapaneseText>そっかな？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>8</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>42056</PointerOffset>
      <VoiceId>&lt;audio:VCT_005_184_009&gt;</VoiceId>
      <JapaneseText>そう言えば、包丁だけじゃなく、
料理の手際もいいですよね</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>9</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>42148</PointerOffset>
      <VoiceId>&lt;audio:VCT_005_184_010&gt;</VoiceId>
      <JapaneseText>いつも父さんと交代で
料理当番だったしね</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>10</Id>
      <Status>To Do</Status>
    </Entry>
