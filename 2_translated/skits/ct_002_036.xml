    <Entry>
      <PointerOffset>44480</PointerOffset>
      <VoiceId>&lt;audio:VCT_002_036_001&gt;</VoiceId>
      <JapaneseText>それにしても、さっきはびっくりしたね</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>1</Id>
      <OldPtr>37320</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>44572</PointerOffset>
      <VoiceId>&lt;audio:VCT_002_036_002&gt;</VoiceId>
      <JapaneseText>まさか、あのダオスが出てくるなんて……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>2</Id>
      <OldPtr>37688</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>44680</PointerOffset>
      <VoiceId>&lt;audio:VCT_002_036_003&gt;</VoiceId>
      <JapaneseText>なんだってんだよ、まったく。
オレら襲ってどうすんだって</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>3</Id>
      <OldPtr>37856</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>44828</PointerOffset>
      <VoiceId>&lt;audio:VCT_002_036_004&gt;</VoiceId>
      <JapaneseText>んだんだ！　突然現われて、突然襲ってくるなんて、
穏やかじゃねぇだーよ。ただの、卑怯もんだ</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>4</SpeakerId>
      <Id>4</Id>
      <OldPtr>38604</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>44980</PointerOffset>
      <VoiceId>&lt;audio:VCT_002_036_005&gt;</VoiceId>
      <JapaneseText>もし、大怪我でもしたら、おら絶対に許さなかったど！
金髪チャラチャラ、クールにすかしよってからに</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>4</SpeakerId>
      <Id>5</Id>
      <OldPtr>39560</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>45104</PointerOffset>
      <VoiceId>&lt;audio:VCT_002_036_006&gt;</VoiceId>
      <JapaneseText>なんだよ、珍しくオレらの心配してくれてんのか。
たまにはいいとこあんな</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>6</Id>
      <OldPtr>40516</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>45264</PointerOffset>
      <VoiceId>&lt;audio:VCT_002_036_007&gt;</VoiceId>
      <JapaneseText>何言ってるだ？　おらが心配なのは&lt;Mel&gt;&lt;Mel&gt;だけだど。
チビ助やエト助がどうなろうと、おらの知ったことか</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>4</SpeakerId>
      <Id>7</Id>
      <OldPtr>41340</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>45336</PointerOffset>
      <VoiceId>&lt;audio:VCT_002_036_008&gt;</VoiceId>
      <JapaneseText>何期待してたの……？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>8</Id>
      <OldPtr>42408</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>45460</PointerOffset>
      <VoiceId>&lt;audio:VCT_002_036_009&gt;</VoiceId>
      <JapaneseText>別にあんなヤツなんかに期待してねー……
期待なんてしてねーからな……っ！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>9</Id>
      <OldPtr>42936</OldPtr>
      <Status>To Do</Status>
    </Entry>
