    <Section>Main</Section>
    <Entry>
      <PointerOffset>48060</PointerOffset>
      <VoiceId>&lt;audio:VCT_001_012_001&gt;</VoiceId>
      <JapaneseText>うっはー！　この指輪すっげーな！
炎が打てるなんてさ</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>1</Id>
      <OldPtr>38052</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>48140</PointerOffset>
      <VoiceId>&lt;audio:VCT_001_012_002&gt;</VoiceId>
      <JapaneseText>クルール！　クルクルール！！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>2</Id>
      <OldPtr>39160</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>48260</PointerOffset>
      <VoiceId>&lt;audio:VCT_001_012_003&gt;</VoiceId>
      <JapaneseText>&lt;Dio&gt;！　そんなむやみに打ったら、
周りのもの、燃えちゃうでしょ！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>3</Id>
      <OldPtr>39864</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>48356</PointerOffset>
      <VoiceId>&lt;audio:VCT_001_012_004&gt;</VoiceId>
      <JapaneseText>そうだよ。それに人に向けちゃダメだからね！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>4</SpeakerId>
      <Id>4</Id>
      <OldPtr>40676</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>48480</PointerOffset>
      <VoiceId>&lt;audio:VCT_001_012_005&gt;</VoiceId>
      <JapaneseText>わかってるって、全然だいじょーぶ！
燃えるもんなんて、そうそうないしさ</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>5</Id>
      <OldPtr>41304</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>48604</PointerOffset>
      <VoiceId>&lt;audio:VCT_001_012_006&gt;</VoiceId>
      <JapaneseText>ほ、炎……簡単に、も、燃えてしまうだ……。
おら、高級素材だから……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>5</SpeakerId>
      <Id>6</Id>
      <OldPtr>42640</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>48720</PointerOffset>
      <VoiceId>&lt;audio:VCT_001_012_007&gt;</VoiceId>
      <JapaneseText>アルベルトさんが怖がってるじゃない！
必要のない時は打たないの</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>7</Id>
      <OldPtr>44260</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>48844</PointerOffset>
      <VoiceId>&lt;audio:VCT_001_012_008&gt;</VoiceId>
      <JapaneseText>燃える……、燃えるだ……
真っ赤になって、パチパチ火の粉上げて……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>5</SpeakerId>
      <Id>8</Id>
      <OldPtr>44896</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>48948</PointerOffset>
      <VoiceId>&lt;audio:VCT_001_012_009&gt;</VoiceId>
      <JapaneseText>しまいにゃ、真っ黒になって、
消し炭のように……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>5</SpeakerId>
      <Id>9</Id>
      <OldPtr>45060</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>49068</PointerOffset>
      <VoiceId>&lt;audio:VCT_001_012_010&gt;</VoiceId>
      <JapaneseText>いやーーーー！　怖い！　炎、怖い、
おら、燃えたくねぇだーー！！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>5</SpeakerId>
      <Id>10</Id>
      <OldPtr>45680</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>49140</PointerOffset>
      <VoiceId>&lt;audio:VCT_001_012_011&gt;</VoiceId>
      <JapaneseText>ア、アルベルトさん？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>11</Id>
      <OldPtr>47000</OldPtr>
      <Status>To Do</Status>
    </Entry>
