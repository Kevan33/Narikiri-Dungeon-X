  <Strings>
    <Section>Main</Section>
    <Entry>
      <PointerOffset>44780</PointerOffset>
      <VoiceId>&lt;audio:VCT_001_032_001&gt;</VoiceId>
      <JapaneseText>剣士に魔法使いに……
なんでもなれるんだな、オレら</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>1</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>44896</PointerOffset>
      <VoiceId>&lt;audio:VCT_001_032_002&gt;</VoiceId>
      <JapaneseText>そりゃ『なりきり士』だし
服があれば、なんにでもなれるけど……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>2</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>45028</PointerOffset>
      <VoiceId>&lt;audio:VCT_001_032_003&gt;</VoiceId>
      <JapaneseText>別に服なんてなくてもなれるんだよ。
バジルさん言ってた、オレら真っ白なんだって</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>3</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>45140</PointerOffset>
      <VoiceId>&lt;audio:VCT_001_032_004&gt;</VoiceId>
      <JapaneseText>だったら『なりきり士』の力に
頼らない方がいいんじゃない？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>4</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>45276</PointerOffset>
      <VoiceId>&lt;audio:VCT_001_032_005&gt;</VoiceId>
      <JapaneseText>&lt;Mel&gt;&lt;Mel&gt;そっだらことは、ダメだ、！
なーんかあって、ケガでもしたら大事だど！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>5</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>45384</PointerOffset>
      <VoiceId>&lt;audio:VCT_001_032_006&gt;</VoiceId>
      <JapaneseText>大体、服ないとダメって、
便利なようで、めんどくさいぜ</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>6</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>45496</PointerOffset>
      <VoiceId>&lt;audio:VCT_001_032_007&gt;</VoiceId>
      <JapaneseText>着替えなきゃだし、
このヘンテコタンス野郎もいつも一緒だしさ</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>7</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>45640</PointerOffset>
      <VoiceId>&lt;audio:VCT_001_032_008&gt;</VoiceId>
      <JapaneseText>おめぇの、そのマヌケヅラは、魔物に殴られた方が
ちっとはマシになるかもしんねーな。へへへ</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>8</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>45704</PointerOffset>
      <VoiceId>&lt;audio:VCT_001_032_009&gt;</VoiceId>
      <JapaneseText>てめぇは……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>9</Id>
      <Status>To Do</Status>
    </Entry>
