  <Strings>
    <Section>Main</Section>
    <Entry>
      <PointerOffset>41856</PointerOffset>
      <VoiceId>&lt;audio:VCT_002_083_000&gt;</VoiceId>
      <JapaneseText>しかし、まさかこの地上を
魔族が支配していたなんてな</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>1</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>41940</PointerOffset>
      <VoiceId>&lt;audio:VCT_002_083_001&gt;</VoiceId>
      <JapaneseText>それってそんなに大変なことか？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>2</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>42072</PointerOffset>
      <VoiceId>&lt;audio:VCT_002_083_002&gt;</VoiceId>
      <JapaneseText>だって、人間じゃない人たちが世界に
たくさんいたなんてなんか変な感じがして……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>3</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>42200</PointerOffset>
      <VoiceId>&lt;audio:VCT_002_083_003&gt;</VoiceId>
      <JapaneseText>でも、今は人間がこの世界の一番だけど、
そうじゃない時代とかもあったんだぜ</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>4</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>42268</PointerOffset>
      <VoiceId>&lt;audio:VCT_002_083_004&gt;</VoiceId>
      <JapaneseText>どういうこと？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>5</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>42392</PointerOffset>
      <VoiceId>&lt;audio:VCT_002_083_005&gt;</VoiceId>
      <JapaneseText>何億年も前はまだ形のないマナ生物とかが
海の中にうようよしてただけだし</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>6</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>42532</PointerOffset>
      <VoiceId>&lt;audio:VCT_002_083_006&gt;</VoiceId>
      <JapaneseText>その後のすっげー長い間は地上を何千メートルもある
でっけードラゴンが支配してたんだぜ？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>7</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>42668</PointerOffset>
      <VoiceId>&lt;audio:VCT_002_083_007&gt;</VoiceId>
      <JapaneseText>だから、例え一時期でも、魔族が世界を
支配していた時期があってもおかしくない、か……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>8</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>42768</PointerOffset>
      <VoiceId>&lt;audio:VCT_002_083_008&gt;</VoiceId>
      <JapaneseText>&lt;Dio&gt;の考え方もある意味、
正しいとも言えるな</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>9</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>42880</PointerOffset>
      <VoiceId>&lt;audio:VCT_002_083_009&gt;</VoiceId>
      <JapaneseText>そう、なのかな……
わたしはなんか違う気がするんですけど……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>10</Id>
      <Status>To Do</Status>
    </Entry>
  </Strings>
