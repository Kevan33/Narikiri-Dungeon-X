  </Speakers>
  <Strings>
    <Section>Main</Section>
    <Entry>
      <PointerOffset>46432</PointerOffset>
      <VoiceId>&lt;audio:VCT_002_061_001&gt;</VoiceId>
      <JapaneseText>&lt;Mel&gt;&lt;Mel&gt;へっへ～ん。にゲンコツ喰らってる～</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>1</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>46552</PointerOffset>
      <VoiceId>&lt;audio:VCT_002_061_002&gt;</VoiceId>
      <JapaneseText>うるせーな！　……いつつっ。
あいつ手加減しないで殴りやがって……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>2</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>46660</PointerOffset>
      <VoiceId>&lt;audio:VCT_002_061_003&gt;</VoiceId>
      <JapaneseText>&lt;Rody&gt;たんのおっぱいで、浮かれてるおめぇが悪いだ</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>3</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>46768</PointerOffset>
      <VoiceId>&lt;audio:VCT_002_061_004&gt;</VoiceId>
      <JapaneseText>しょ、しょうがねだろ。
あんなおっきいの当たったら……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>4</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>46912</PointerOffset>
      <VoiceId>&lt;audio:VCT_002_061_005&gt;</VoiceId>
      <JapaneseText>&lt;Mel&gt;&lt;Mel&gt;そったらこっだから、に怒られるだ。
ええか！　男のロマンは大きさだけでねーよ</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>5</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>47072</PointerOffset>
      <VoiceId>&lt;audio:VCT_002_061_006&gt;</VoiceId>
      <JapaneseText>&lt;Rody&gt;&lt;Mel&gt;&lt;Mel&gt;たんがええっちゅーのは、子どもの言う事だ。
本当の男なら、ぐらいのが一番と言うだよ</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>6</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>47156</PointerOffset>
      <VoiceId>&lt;audio:VCT_002_061_007&gt;</VoiceId>
      <JapaneseText>なんで、そんなこと言えんだよ？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>7</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>47248</PointerOffset>
      <VoiceId>&lt;audio:VCT_002_061_008&gt;</VoiceId>
      <JapaneseText>そりゃ、おめぇ、いくらでも、さ………</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>8</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>47312</PointerOffset>
      <VoiceId>&lt;audio:VCT_002_061_009&gt;</VoiceId>
      <JapaneseText>いくらでも？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>9</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>47444</PointerOffset>
      <VoiceId>&lt;audio:VCT_002_061_010&gt;</VoiceId>
      <JapaneseText>いやいや、なんでもねぇーだ。
おらだけの特権を教えてやる義理はねぇだ、うん</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>10</Id>
      <Status>To Do</Status>
    </Entry>
  </Strings>
