  </Speakers>
  <Strings>
    <Section>Main</Section>
    <Entry>
      <PointerOffset>48080</PointerOffset>
      <VoiceId>&lt;audio:VCT_006_194_000&gt;</VoiceId>
      <JapaneseText>なー、なんでそんな何回も温泉に入んだ？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>1</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>48160</PointerOffset>
      <VoiceId>&lt;audio:VCT_006_194_001&gt;</VoiceId>
      <JapaneseText>え？　だって気持ちいいよ？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>2</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>48244</PointerOffset>
      <VoiceId>&lt;audio:VCT_006_194_002&gt;</VoiceId>
      <JapaneseText>そっかー？　めんどくせーじゃん</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>3</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>48328</PointerOffset>
      <VoiceId>&lt;audio:VCT_006_194_003&gt;</VoiceId>
      <JapaneseText>&lt;Dio&gt;は昔からお風呂嫌いだもんね</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>4</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>48464</PointerOffset>
      <VoiceId>&lt;audio:VCT_006_194_004&gt;</VoiceId>
      <JapaneseText>そりゃ汚れたり、汗でベトベトすりゃ
入っけど、意味もなく何度も入んのはワケわかんね</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>5</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>48548</PointerOffset>
      <VoiceId>&lt;audio:VCT_006_194_005&gt;</VoiceId>
      <JapaneseText>そう？　でも温泉は体にいいんだよ</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>6</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>48624</PointerOffset>
      <VoiceId>&lt;audio:VCT_006_194_006&gt;</VoiceId>
      <JapaneseText>それってなんかじじくせー</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>7</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>48752</PointerOffset>
      <VoiceId>&lt;audio:VCT_006_194_007&gt;</VoiceId>
      <JapaneseText>ま～ったく、この毛無しのハゲぼうずは、
本当にロマンがわかってねーやつだ</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>4</SpeakerId>
      <Id>8</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>48848</PointerOffset>
      <VoiceId>&lt;audio:VCT_006_194_008&gt;</VoiceId>
      <JapaneseText>ロマン、ロマンうるせー！
このタンス野郎が！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>9</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>48956</PointerOffset>
      <VoiceId>&lt;audio:VCT_006_194_009&gt;</VoiceId>
      <JapaneseText>温泉といえば覗きイベントだべ。
混浴って手もあるだよ</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>4</SpeakerId>
      <Id>10</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>49052</PointerOffset>
      <VoiceId>&lt;audio:VCT_006_194_010&gt;</VoiceId>
      <JapaneseText>……おまえ……男とか女とかわかってんのか？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>11</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>49200</PointerOffset>
      <VoiceId>&lt;audio:VCT_006_194_011&gt;</VoiceId>
      <JapaneseText>男湯には男しか入れない、女湯には女しか入れない！
だからタンス、おまえに入れる『湯』は、ない！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>12</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>49344</PointerOffset>
      <VoiceId>&lt;audio:VCT_006_194_012&gt;</VoiceId>
      <JapaneseText>……『タンス湯』とかありゃ、おまえも入れたのにな。
いやそもそも、湯に浸かったらマズイだろ？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>13</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>49476</PointerOffset>
      <VoiceId>&lt;audio:VCT_006_194_013&gt;</VoiceId>
      <JapaneseText>あ～、んなもん関係ねーだ～。
おらはどこにでも行ける、自由な小鳥さんだーよ</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>4</SpeakerId>
      <Id>14</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>49632</PointerOffset>
      <VoiceId>&lt;audio:VCT_006_194_014&gt;</VoiceId>
      <JapaneseText>&lt;Mel&gt;&lt;Mel&gt;ぬはっ！　そ、そうだ、そうだよ。おらが温泉に入っだら
のだ～いじな衣装がびしょ濡れに……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>4</SpeakerId>
      <Id>15</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>49720</PointerOffset>
      <VoiceId>&lt;audio:VCT_006_194_015&gt;</VoiceId>
      <JapaneseText>……なんか知んねーけど、勝った……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>16</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>49816</PointerOffset>
      <VoiceId>&lt;audio:VCT_006_194_016&gt;</VoiceId>
      <JapaneseText>……ばかなことやってないで、ほら、行くよ……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>17</Id>
      <Status>To Do</Status>
    </Entry>
  </Strings>
