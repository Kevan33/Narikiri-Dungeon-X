  </Speakers>
  <Strings>
    <Section>Main</Section>
    <Entry>
      <PointerOffset>46692</PointerOffset>
      <VoiceId>&lt;audio:VCT_006_200_001&gt;</VoiceId>
      <JapaneseText>う～～～～～ん……
………ん～～～～～～</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>1</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>46808</PointerOffset>
      <VoiceId>&lt;audio:VCT_006_200_002&gt;</VoiceId>
      <JapaneseText>困っただぁ、あ～、困っただ……
おらはどしたら、よかんべ？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>2</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>46944</PointerOffset>
      <VoiceId>&lt;audio:VCT_006_200_003&gt;</VoiceId>
      <JapaneseText>やっぱ選べねぇだ！　こっだら娘っ子揃ったら、
おら、ひとりに絞るのは難しいだ！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>3</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>47072</PointerOffset>
      <VoiceId>&lt;audio:VCT_006_200_004&gt;</VoiceId>
      <JapaneseText>&lt;Mel&gt;&lt;Mel&gt;&lt;Suzu&gt;が一番なのは当然だが、
ちんもなかなか捨てがたいだーな</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>4</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>47212</PointerOffset>
      <VoiceId>&lt;audio:VCT_006_200_005&gt;</VoiceId>
      <JapaneseText>&lt;Rody&gt;たんもあのボディは群を抜いてるだが、
ミーたまもなかなかの物を持ってるだで</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>5</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>47360</PointerOffset>
      <VoiceId>&lt;audio:VCT_006_200_006&gt;</VoiceId>
      <JapaneseText>いんや～～おら選べね！　誰かひとりにするなんて、
選ばれなかった娘っ子がかわいそうだーよ……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>6</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>47484</PointerOffset>
      <VoiceId>&lt;audio:VCT_006_200_007&gt;</VoiceId>
      <JapaneseText>ん？　まだ他にも娘っ子がいるっでが？
あー、ほうき女とエト助かい？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>7</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>47556</PointerOffset>
      <VoiceId>&lt;audio:VCT_006_200_008&gt;</VoiceId>
      <JapaneseText>ありゃボール球だ</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>8</Id>
      <Status>To Do</Status>
    </Entry>
  </Strings>
