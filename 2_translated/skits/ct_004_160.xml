      <PointerOffset>45624</PointerOffset>
      <VoiceId>&lt;audio:VCT_004_160_001&gt;</VoiceId>
      <JapaneseText>手を上げろ！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>1</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>45684</PointerOffset>
      <VoiceId>&lt;audio:VCT_004_160_002&gt;</VoiceId>
      <JapaneseText>……え？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>2</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>45760</PointerOffset>
      <VoiceId>&lt;audio:VCT_004_160_003&gt;</VoiceId>
      <JapaneseText>三つ数えるまで待ってやる</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>3</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>45824</PointerOffset>
      <VoiceId>&lt;audio:VCT_004_160_004&gt;</VoiceId>
      <JapaneseText>……なに？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>4</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>45920</PointerOffset>
      <VoiceId>&lt;audio:VCT_004_160_005&gt;</VoiceId>
      <JapaneseText>ぬきな！　どっちが早いか、試してみようぜ……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>5</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>46012</PointerOffset>
      <VoiceId>&lt;audio:VCT_004_160_006&gt;</VoiceId>
      <JapaneseText>……、あ～、今日も天気が良いだ～よ</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>4</SpeakerId>
      <Id>6</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>46144</PointerOffset>
      <VoiceId>&lt;audio:VCT_004_160_007&gt;</VoiceId>
      <JapaneseText>んだよ！　みんなノリわりーな！
見ろよ、このカウボーイハット！　かっこいいだろ！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>7</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>46220</PointerOffset>
      <VoiceId>&lt;audio:VCT_004_160_008&gt;</VoiceId>
      <JapaneseText>……え、うん、いや、まぁ</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>8</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>46348</PointerOffset>
      <VoiceId>&lt;audio:VCT_004_160_009&gt;</VoiceId>
      <JapaneseText>男なら、カウボーイハットとくれば
言ってみたくなるセリフってもんがあるだろ！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>9</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>46408</PointerOffset>
      <VoiceId>&lt;audio:VCT_004_160_010&gt;</VoiceId>
      <JapaneseText>女だし</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>10</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>46468</PointerOffset>
      <VoiceId>&lt;audio:VCT_004_160_011&gt;</VoiceId>
      <JapaneseText>ぼくも</JapaneseText>
      <EnglishText/>
