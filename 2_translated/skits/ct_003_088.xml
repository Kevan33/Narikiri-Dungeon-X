    <Entry>
      <PointerOffset>51604,51832,52120,52280,52548</PointerOffset>
      <JapaneseText>アルベルト</JapaneseText>
      <EnglishText/>
      <Notes/>
      <Id>3</Id>
      <Status>To Do</Status>
    </Entry>
  </Speakers>
  <Strings>
    <Section>Main</Section>
    <Entry>
      <PointerOffset>51372</PointerOffset>
      <VoiceId>&lt;audio:VCT_003_088_001&gt;</VoiceId>
      <JapaneseText>あちち！　床のあちこちからなんか漏れてんぞ！？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>1</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>51508</PointerOffset>
      <VoiceId>&lt;audio:VCT_003_088_002&gt;</VoiceId>
      <JapaneseText>&lt;Dio&gt;、気をつけて！　むやみにそのへん走り回ってると
どんどん体力が削られちゃうよ！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>2</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>51608</PointerOffset>
      <VoiceId>&lt;audio:VCT_003_088_003&gt;</VoiceId>
      <JapaneseText>&lt;Dio&gt;&lt;Dio&gt;さん、さん、少々よろしいですか？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>3</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>51680</PointerOffset>
      <VoiceId>&lt;audio:VCT_003_088_004&gt;</VoiceId>
      <JapaneseText>……な、なんだよ……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>4</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>51836</PointerOffset>
      <VoiceId>&lt;audio:VCT_003_088_005&gt;</VoiceId>
      <JapaneseText>私、炎嫌いなんです、弱いんです、燃えちゃうんです。
だから、もう少し、気をつけてもらえないですかね？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>5</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>51968</PointerOffset>
      <VoiceId>&lt;audio:VCT_003_088_006&gt;</VoiceId>
      <JapaneseText>気ぃつけても、通んなきゃ先進めねんだって！
少し我慢しろよ、この書き割り野郎！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>6</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>52124</PointerOffset>
      <VoiceId>&lt;audio:VCT_003_088_007&gt;</VoiceId>
      <JapaneseText>ぬあぁぁぁあぁ！　人が下手に出てりゃ調子に乗って！
おら、もう許せねぇだ、絶対、こいつ許せねぇだ！！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>7</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>52284</PointerOffset>
      <VoiceId>&lt;audio:VCT_003_088_008&gt;</VoiceId>
      <JapaneseText>おめぇの服だけ放り出して、ぜぇ～んぶ燃やしてやるだ。
記録も記憶も、ぜぇ～～～んぶ消し炭にしてやるだよ！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>8</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>52404</PointerOffset>
      <VoiceId>&lt;audio:VCT_003_088_009&gt;</VoiceId>
      <JapaneseText>&lt;Dio&gt;もアルベルトさんも、やめよ、ね？
気をつけて歩けばいいんだから</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>9</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>52552</PointerOffset>
      <VoiceId>&lt;audio:VCT_003_088_010&gt;</VoiceId>
      <JapaneseText>&lt;Mel&gt;&lt;Mel&gt;&lt;Mel&gt;&lt;Mel&gt;あうあう！　、！
おらの事心配してくれてるぅ～、おらも好きだどぉ！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>10</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>52652</PointerOffset>
      <VoiceId>&lt;audio:VCT_003_088_011&gt;</VoiceId>
      <JapaneseText>……こいつ……
サラッとすげぇ事言いやがった……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>11</Id>
      <Status>To Do</Status>
    </Entry>
  </Strings>
  <Strings>
