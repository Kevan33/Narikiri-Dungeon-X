    <Entry>
      <PointerOffset>48608</PointerOffset>
      <VoiceId>&lt;audio:VCT_006_203_001&gt;</VoiceId>
      <JapaneseText>あー、サッパリしたぁ</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>1</Id>
      <OldPtr>37824</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>48688</PointerOffset>
      <VoiceId>&lt;audio:VCT_006_203_002&gt;</VoiceId>
      <JapaneseText>肌がツルツルになったみたい</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>2</Id>
      <OldPtr>38016</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>48808</PointerOffset>
      <VoiceId>&lt;audio:VCT_006_203_003&gt;</VoiceId>
      <JapaneseText>それは温泉の効能ですね。
他にも腰痛や肩こり、擦り傷などにも効きます</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>3</Id>
      <OldPtr>38452</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>48928</PointerOffset>
      <VoiceId>&lt;audio:VCT_006_203_004&gt;</VoiceId>
      <JapaneseText>胸が大きくなる効能はないの～？
&lt;Mint&gt;と&lt;Rody&gt;だけズルイじゃん！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>4</SpeakerId>
      <Id>4</Id>
      <OldPtr>39276</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>49016</PointerOffset>
      <VoiceId>&lt;audio:VCT_006_203_005&gt;</VoiceId>
      <JapaneseText>わ、私はこれ以上大きくなっても……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>5</SpeakerId>
      <Id>5</Id>
      <OldPtr>39756</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>49140</PointerOffset>
      <VoiceId>&lt;audio:VCT_006_203_006&gt;</VoiceId>
      <JapaneseText>だよねぇ、&lt;Mint&gt;は&lt;Cless&gt;だけが
喜んでくれれば、それでいいんだもんね∀</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>6</Id>
      <OldPtr>40136</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>49264</PointerOffset>
      <VoiceId>&lt;audio:VCT_006_203_007&gt;</VoiceId>
      <JapaneseText>………あぁ………あぁぁ……
あーーーーーー！！！　ズルイだぁ！！！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>6</SpeakerId>
      <Id>7</Id>
      <OldPtr>41008</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>49356</PointerOffset>
      <VoiceId>&lt;audio:VCT_006_203_008&gt;</VoiceId>
      <JapaneseText>ど、どうしたんですか、アルベルトさん！？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>8</Id>
      <OldPtr>43552</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>49456</PointerOffset>
      <VoiceId>&lt;audio:VCT_006_203_009&gt;</VoiceId>
      <JapaneseText>……おらも、おらも……温泉入りてぇだーよ！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>6</SpeakerId>
      <Id>9</Id>
      <OldPtr>43784</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>49592</PointerOffset>
      <VoiceId>&lt;audio:VCT_006_203_010&gt;</VoiceId>
      <JapaneseText>入りたいって言っても、あんたタンスじゃん。
中の服がビショビショになっちゃうじゃんよ</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>4</SpeakerId>
      <Id>10</Id>
      <OldPtr>44692</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>49740</PointerOffset>
      <VoiceId>&lt;audio:VCT_006_203_011&gt;</VoiceId>
      <JapaneseText>だって、ズルイだ！　さっきから話聞いてっと、
誰もが夢見る桃源郷が、すぐそこにあるだーよ！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>6</SpeakerId>
      <Id>11</Id>
      <OldPtr>45268</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>49864</PointerOffset>
      <VoiceId>&lt;audio:VCT_006_203_012&gt;</VoiceId>
      <JapaneseText>これが悔しくなくて、何が悔しいだか！！
うぅ……、うぅぅぅ…………</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>6</SpeakerId>
      <Id>12</Id>
      <OldPtr>46636</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>49952</PointerOffset>
      <VoiceId>&lt;audio:VCT_006_203_013&gt;</VoiceId>
      <JapaneseText>君、どっちにしろ女湯には入れないから</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>13</Id>
      <OldPtr>47672</OldPtr>
      <Status>To Do</Status>
    </Entry>
