    <Entry>
      <PointerOffset>49384</PointerOffset>
      <VoiceId>&lt;audio:VCT_004_150_000&gt;</VoiceId>
      <JapaneseText>すごいです、&lt;Rody&gt;さん、優勝するなんて！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>1</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>49452</PointerOffset>
      <VoiceId>&lt;audio:VCT_004_150_001&gt;</VoiceId>
      <JapaneseText>ふふっ、あんがと</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>2</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>49560</PointerOffset>
      <VoiceId>&lt;audio:VCT_004_150_002&gt;</VoiceId>
      <JapaneseText>群がる相手をバッタバッタと……
すげーカッコよかった！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>3</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>49624</PointerOffset>
      <VoiceId>&lt;audio:VCT_004_150_003&gt;</VoiceId>
      <JapaneseText>クルール！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>4</SpeakerId>
      <Id>4</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>49696</PointerOffset>
      <VoiceId>&lt;audio:VCT_004_150_004&gt;</VoiceId>
      <JapaneseText>これも鍛錬の賜物かな</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>5</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>49816</PointerOffset>
      <VoiceId>&lt;audio:VCT_004_150_005&gt;</VoiceId>
      <JapaneseText>たんれん？　修行みたいなもんか！？
どんな修行してたか教えてくれよ</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>6</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>49944</PointerOffset>
      <VoiceId>&lt;audio:VCT_004_150_006&gt;</VoiceId>
      <JapaneseText>えっとね、毎日寝る前にパンチとキックの
練習をしたよ、&lt;Couleur&gt;くんを相手にね</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>7</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>50008</PointerOffset>
      <VoiceId>&lt;audio:VCT_004_150_007&gt;</VoiceId>
      <JapaneseText>クルール？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>4</SpeakerId>
      <Id>8</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>50080</PointerOffset>
      <VoiceId>&lt;audio:VCT_004_150_008&gt;</VoiceId>
      <JapaneseText>そ、それって……？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>9</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>50216</PointerOffset>
      <VoiceId>&lt;audio:VCT_004_150_009&gt;</VoiceId>
      <JapaneseText>ほら、彼って的としてちっちゃいから、
打撃を正確に当てる練習にもってこいなんだよね～</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>10</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>50292</PointerOffset>
      <VoiceId>&lt;audio:VCT_004_150_010&gt;</VoiceId>
      <JapaneseText>マ、マジか、&lt;Couleur&gt;！？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>11</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>50396</PointerOffset>
      <VoiceId>&lt;audio:VCT_004_150_011&gt;</VoiceId>
      <JapaneseText>クルール？　ル？　ル？　クルール！　クルルルルーン！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>4</SpeakerId>
      <Id>12</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>50516</PointerOffset>
      <VoiceId>&lt;audio:VCT_004_150_012&gt;</VoiceId>
      <JapaneseText>さて……そろそろもう少し大きな的が
ほしかったところなんだけど……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>13</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>50620</PointerOffset>
      <VoiceId>&lt;audio:VCT_004_150_013&gt;</VoiceId>
      <JapaneseText>え？　オ、オレ……？
……ちょっ……い、いやだ～！！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>14</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>50696</PointerOffset>
      <VoiceId>&lt;audio:VCT_004_150_014&gt;</VoiceId>
      <JapaneseText>もう&lt;Rody&gt;さん……！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>15</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>50760</PointerOffset>
      <VoiceId>&lt;audio:VCT_004_150_015&gt;</VoiceId>
      <JapaneseText>クルール！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>4</SpeakerId>
      <Id>16</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>50880</PointerOffset>
      <VoiceId>&lt;audio:VCT_004_150_016&gt;</VoiceId>
      <JapaneseText>いや～、めんごめんご。
&lt;Dio&gt;くんだまされやすいからさ～、つい……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>17</Id>
      <Status>To Do</Status>
    </Entry>
