    <Entry>
      <PointerOffset>45696</PointerOffset>
      <VoiceId>&lt;audio:VCT_002_082_001&gt;</VoiceId>
      <JapaneseText>なぁ、乙女のヒミツって何だ？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>1</Id>
      <OldPtr>37468</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>45776</PointerOffset>
      <VoiceId>&lt;audio:VCT_002_082_002&gt;</VoiceId>
      <JapaneseText>ちょっと黙ってなさい、&lt;Dio&gt;</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>2</Id>
      <OldPtr>38028</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>45868</PointerOffset>
      <VoiceId>&lt;audio:VCT_002_082_003&gt;</VoiceId>
      <JapaneseText>なぁ、&lt;Rody&gt;、
乙女のヒミツって何だ？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>3</Id>
      <OldPtr>38528</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>45940</PointerOffset>
      <VoiceId>&lt;audio:VCT_002_082_004&gt;</VoiceId>
      <JapaneseText>&lt;Chester&gt;さんまで……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>4</Id>
      <OldPtr>39252</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>46004</PointerOffset>
      <VoiceId>&lt;audio:VCT_002_082_005&gt;</VoiceId>
      <JapaneseText>知りたい？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>4</SpeakerId>
      <Id>5</Id>
      <OldPtr>39444</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>46096</PointerOffset>
      <VoiceId>&lt;audio:VCT_002_082_006&gt;</VoiceId>
      <JapaneseText>知りたいってか、
なんか気になるってか</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>6</Id>
      <OldPtr>40108</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>46160</PointerOffset>
      <VoiceId>&lt;audio:VCT_002_082_007&gt;</VoiceId>
      <JapaneseText>知りたいの？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>5</SpeakerId>
      <Id>7</Id>
      <OldPtr>40724</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>46232</PointerOffset>
      <VoiceId>&lt;audio:VCT_002_082_008&gt;</VoiceId>
      <JapaneseText>え？　あ、いや……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>8</Id>
      <OldPtr>40940</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>46320</PointerOffset>
      <VoiceId>&lt;audio:VCT_002_082_009&gt;</VoiceId>
      <JapaneseText>知るといろいろ後戻りできなくなるよ？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>4</SpeakerId>
      <Id>9</Id>
      <OldPtr>41604</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>46404</PointerOffset>
      <VoiceId>&lt;audio:VCT_002_082_010&gt;</VoiceId>
      <JapaneseText>え？　そ、それってどういうことだ</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>10</Id>
      <OldPtr>42196</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>46504</PointerOffset>
      <VoiceId>&lt;audio:VCT_002_082_011&gt;</VoiceId>
      <JapaneseText>なんでヒミツなのかってこと……
わかってる……？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>4</SpeakerId>
      <Id>11</Id>
      <OldPtr>42800</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>46624</PointerOffset>
      <VoiceId>&lt;audio:VCT_002_082_012&gt;</VoiceId>
      <JapaneseText>ヒミツは知らないでいた方がいいから、
ヒミツなのよ。ねぇ、&lt;Rody&gt;？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>5</SpeakerId>
      <Id>12</Id>
      <OldPtr>43480</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>46688</PointerOffset>
      <VoiceId>&lt;audio:VCT_002_082_013&gt;</VoiceId>
      <JapaneseText>そうそう……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>4</SpeakerId>
      <Id>13</Id>
      <OldPtr>43996</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>46780</PointerOffset>
      <VoiceId>&lt;audio:VCT_002_082_014&gt;</VoiceId>
      <JapaneseText>オ、オレ、いい……
知らないままで……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>14</Id>
      <OldPtr>44252</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>46844</PointerOffset>
      <VoiceId>&lt;audio:VCT_002_082_015&gt;</VoiceId>
      <JapaneseText>オレ、も……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>15</Id>
      <OldPtr>44616</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>46944</PointerOffset>
      <VoiceId>&lt;audio:VCT_002_082_016&gt;</VoiceId>
      <JapaneseText>……わたしは逆に
知りたくなっちゃったかも……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>16</Id>
      <OldPtr>44864</OldPtr>
      <Status>To Do</Status>
    </Entry>
