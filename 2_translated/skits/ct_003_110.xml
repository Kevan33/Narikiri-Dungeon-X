    <Entry>
      <PointerOffset>41736</PointerOffset>
      <VoiceId>&lt;audio:VCT_003_110_001&gt;</VoiceId>
      <JapaneseText>この先にノルンがいるんだね</JapaneseText>
      <EnglishText>Norn is just a little bit ahead...</EnglishText>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>1</Id>
      <Status>Editing</Status>
    </Entry>
    <Entry>
      <PointerOffset>41808</PointerOffset>
      <VoiceId>&lt;audio:VCT_003_110_002&gt;</VoiceId>
      <JapaneseText>そこで試練が終わんだ</JapaneseText>
      <EnglishText>And once we reach there the trial will end...</EnglishText>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>2</Id>
      <Status>Editing</Status>
    </Entry>
    <Entry>
      <PointerOffset>41884</PointerOffset>
      <VoiceId>&lt;audio:VCT_003_110_003&gt;</VoiceId>
      <JapaneseText>これでよかったんだよね？</JapaneseText>
      <EnglishText>...Are we doing the right thing?</EnglishText>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>3</Id>
      <Status>Editing</Status>
    </Entry>
    <Entry>
      <PointerOffset>41984</PointerOffset>
      <VoiceId>&lt;audio:VCT_003_110_004&gt;</VoiceId>
      <JapaneseText>もしかして……
&lt;Mel&gt;はイヤだったか、こんなの</JapaneseText>
      <EnglishText>Maybe...you aren't getting cold feet now, are you?</EnglishText>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>4</Id>
      <Status>Editing</Status>
    </Entry>
    <Entry>
      <PointerOffset>42060</PointerOffset>
      <VoiceId>&lt;audio:VCT_003_110_005&gt;</VoiceId>
      <JapaneseText>ううん……&lt;Dio&gt;の方こそ</JapaneseText>
      <EnglishText>Nah, you're the one doubting this.</EnglishText>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>5</Id>
      <Status>Editing</Status>
    </Entry>
    <Entry>
      <PointerOffset>42132</PointerOffset>
      <VoiceId>&lt;audio:VCT_003_110_006&gt;</VoiceId>
      <JapaneseText>オレを見くびんなよ</JapaneseText>
      <EnglishText>Don't you belittle me, now!</EnglishText>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>6</Id>
      <Status>Editing</Status>
    </Entry>
    <Entry>
      <PointerOffset>42196</PointerOffset>
      <VoiceId>&lt;audio:VCT_003_110_007&gt;</VoiceId>
      <JapaneseText>そっちこそ</JapaneseText>
      <EnglishText>Hehe, that goes to you too!</EnglishText>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>7</Id>
      <Status>Editing</Status>
    </Entry>
    <Entry>
      <PointerOffset>42280</PointerOffset>
      <VoiceId>&lt;audio:VCT_003_110_008&gt;</VoiceId>
      <JapaneseText>あはは……
うふふ……</JapaneseText>
      <EnglishText>Hahahahahaha!</EnglishText>
