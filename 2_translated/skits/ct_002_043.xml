    <Entry>
      <PointerOffset>43000</PointerOffset>
      <VoiceId>&lt;audio:VCT_002_043_001&gt;</VoiceId>
      <JapaneseText>&lt;Chester&gt;はどうして
こんな子ども用の服持ってんだ</JapaneseText>
      <EnglishText>&lt;Chester&gt;, I just remembered to ask you. How come you got these children-sized clothes?</EnglishText>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>1</Id>
      <Status>Editing</Status>
    </Entry>
    <Entry>
      <PointerOffset>43092</PointerOffset>
      <VoiceId>&lt;audio:VCT_002_043_002&gt;</VoiceId>
      <JapaneseText>ああ、妹のために
用意した服なんだけどな</JapaneseText>
      <EnglishText>Oh, these? I made them for my little sister, way back.</EnglishText>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>2</Id>
      <Status>Editing</Status>
    </Entry>
    <Entry>
      <PointerOffset>43192</PointerOffset>
      <VoiceId>&lt;audio:VCT_002_043_003&gt;</VoiceId>
      <JapaneseText>でもさ、そんなのいらないって
言われちゃってさ</JapaneseText>
      <EnglishText>But, you know... I didn't really want to mention that.</EnglishText>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>3</Id>
      <Status>Editing</Status>
    </Entry>
    <Entry>
      <PointerOffset>43252</PointerOffset>
      <VoiceId>&lt;audio:VCT_002_043_004&gt;</VoiceId>
      <JapaneseText>ああ……</JapaneseText>
      <EnglishText>Um...</EnglishText>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>4</Id>
      <Status>Editing</Status>
    </Entry>
    <Entry>
      <PointerOffset>43344</PointerOffset>
      <VoiceId>&lt;audio:VCT_002_043_005&gt;</VoiceId>
      <JapaneseText>ああって何だよ。
かっこいいだろ、これ</JapaneseText>
      <EnglishText>Aw, whatever. They're pretty damn cool!</EnglishText>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>5</Id>
      <Status>Editing</Status>
    </Entry>
    <Entry>
      <PointerOffset>43440</PointerOffset>
      <VoiceId>&lt;audio:VCT_002_043_006&gt;</VoiceId>
      <JapaneseText>だって、それは&lt;Dio&gt;が
男の子だからでしょ</JapaneseText>
      <EnglishText>But &lt;Chester&gt;, &lt;Dio&gt;'s a boy.</EnglishText>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>6</Id>
      <Status>Editing</Status>
    </Entry>
    <Entry>
      <PointerOffset>43544</PointerOffset>
      <VoiceId>&lt;audio:VCT_002_043_007&gt;</VoiceId>
      <JapaneseText>大体、年頃の女の子に
魔物使いとかそれはちょっと……</JapaneseText>
      <EnglishText>To give a Monster Tamer costume to a girl about our age is usually considered a little...</EnglishText>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>7</Id>
      <Status>Editing</Status>
    </Entry>
    <Entry>
      <PointerOffset>43616</PointerOffset>
      <VoiceId>&lt;audio:VCT_002_043_008&gt;</VoiceId>
      <JapaneseText>&lt;Mel&gt;、ちょっと……</JapaneseText>
      <EnglishText>&lt;Mel&gt;...Be careful what you say...</EnglishText>
      <Notes/>
      <SpeakerId>4</SpeakerId>
      <Id>8</Id>
      <Status>Editing</Status>
    </Entry>
    <Entry>
      <PointerOffset>43688</PointerOffset>
      <VoiceId>&lt;audio:VCT_002_043_009&gt;</VoiceId>
      <JapaneseText>あ、ご、ごめんなさい</JapaneseText>
      <EnglishText>Ah! Please forgive my rudeness!</EnglishText>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>9</Id>
      <Status>Editing</Status>
    </Entry>
    <Entry>
      <PointerOffset>43764</PointerOffset>
      <VoiceId>&lt;audio:VCT_002_043_010&gt;</VoiceId>
      <JapaneseText>いや、いいっていいって</JapaneseText>
      <EnglishText>N-no it's okay, it's okay!</EnglishText>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>10</Id>
      <Status>Editing</Status>
    </Entry>
    <Entry>
      <PointerOffset>43896</PointerOffset>
      <VoiceId>&lt;audio:VCT_002_043_011&gt;</VoiceId>
      <JapaneseText>……うーん、&lt;Arche&gt;の言ってた、
女心がわかってないってこういうことなのか……？</JapaneseText>
      <EnglishText>Dammit...when &lt;Arche&gt; said I didn't understand a woman's heart...is this what she meant?</EnglishText>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>11</Id>
      <Status>Editing</Status>
    </Entry>
