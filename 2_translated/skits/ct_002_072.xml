  </Speakers>
  <Strings>
    <Section>Main</Section>
    <Entry>
      <PointerOffset>46996</PointerOffset>
      <VoiceId>&lt;audio:VCT_002_072_001&gt;</VoiceId>
      <JapaneseText>……なんか好きな人がいるとか、
そういうのいいですね</JapaneseText>
      <EnglishText>...To have someone you love in your mind... That sounds really nice.</EnglishText>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>1</Id>
      <Status>Editing</Status>
    </Entry>
    <Entry>
      <PointerOffset>47072</PointerOffset>
      <VoiceId>&lt;audio:VCT_002_072_002&gt;</VoiceId>
      <JapaneseText>&lt;Mel&gt;ちゃんはいないの？</JapaneseText>
      <EnglishText>Could it be our little &lt;Mel&gt; has someone in mind?</EnglishText>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>2</Id>
      <Status>Editing</Status>
    </Entry>
    <Entry>
      <PointerOffset>47180</PointerOffset>
      <VoiceId>&lt;audio:VCT_002_072_003&gt;</VoiceId>
      <JapaneseText>残念ながら……
今まで外に出たことなかったですから……</JapaneseText>
      <EnglishText>I'm afraid not... I've not gone out of home until now, really.</EnglishText>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>3</Id>
      <Status>Editing</Status>
    </Entry>
    <Entry>
      <PointerOffset>47276</PointerOffset>
      <VoiceId>&lt;audio:VCT_002_072_004&gt;</VoiceId>
      <JapaneseText>&lt;Cless&gt;とか、&lt;Chester&gt;とかには
会ったんでしょ？</JapaneseText>
      <EnglishText>What about &lt;Cless&gt;!? Or &lt;Chester&gt;!? Don't you want me to set you up!?</EnglishText>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>4</Id>
      <Status>Editing</Status>
    </Entry>
    <Entry>
      <PointerOffset>47356</PointerOffset>
      <VoiceId>&lt;audio:VCT_002_072_005&gt;</VoiceId>
      <JapaneseText>お兄さんって感じ、でしょうか</JapaneseText>
      <EnglishText>They are more like older brothers to me...</EnglishText>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>5</Id>
      <Status>Editing</Status>
    </Entry>
    <Entry>
      <PointerOffset>47436</PointerOffset>
      <VoiceId>&lt;audio:VCT_002_072_006&gt;</VoiceId>
      <JapaneseText>&lt;Klarth&gt;は……おじさんだしね</JapaneseText>
      <EnglishText>...And &lt;Klarth&gt; is like our grandpa.</EnglishText>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>6</Id>
      <Status>Editing</Status>
    </Entry>
    <Entry>
      <PointerOffset>47548</PointerOffset>
      <VoiceId>&lt;audio:VCT_002_072_007&gt;</VoiceId>
      <JapaneseText>やっぱ同世代の男の子で……
うーん……&lt;Dio&gt;くんは兄弟だし</JapaneseText>
      <EnglishText>So it has to be a guy around your age... Mmm...And &lt;Dio&gt; is out of the picture...</EnglishText>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>7</Id>
      <Status>Editing</Status>
    </Entry>
    <Entry>
      <PointerOffset>47620</PointerOffset>
      <VoiceId>&lt;audio:VCT_002_072_008&gt;</VoiceId>
      <JapaneseText>ノームさん、とか？</JapaneseText>
      <EnglishText>How about Gnome?</EnglishText>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>8</Id>
      <Status>Editing</Status>
    </Entry>
    <Entry>
      <PointerOffset>47700</PointerOffset>
      <VoiceId>&lt;audio:VCT_002_072_009&gt;</VoiceId>
      <JapaneseText>え？　ああいうのが好みなの？</JapaneseText>
      <EnglishText>Wh-What!? You are into that sort of thing!?</EnglishText>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>9</Id>
      <Status>Editing</Status>
    </Entry>
    <Entry>
      <PointerOffset>47820</PointerOffset>
      <VoiceId>&lt;audio:VCT_002_072_010&gt;</VoiceId>
      <JapaneseText>ダメーっ！　絶対ダメ！
ノームとなんて、ぼくが絶対許さないからね！</JapaneseText>
      <EnglishText>NO! DEFINITELY NO! I'm never forgiving Gnome!</EnglishText>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>10</Id>
      <Status>Editing</Status>
    </Entry>
    <Entry>
      <PointerOffset>47900</PointerOffset>
      <VoiceId>&lt;audio:VCT_002_072_011&gt;</VoiceId>
      <JapaneseText>……ノームのどこが好きなの？</JapaneseText>
      <EnglishText>...Um, what sort of place would you choose for your date?</EnglishText>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>11</Id>
      <Status>Editing</Status>
    </Entry>
    <Entry>
      <PointerOffset>48012</PointerOffset>
      <VoiceId>&lt;audio:VCT_002_072_012&gt;</VoiceId>
      <JapaneseText>えっと……なんかぽあぽあしてて
カワイイところ？　かな……</JapaneseText>
      <EnglishText>Um... Somewhere full of cute things and plushies...maybe?</EnglishText>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>12</Id>
      <Status>Editing</Status>
    </Entry>
    <Entry>
      <PointerOffset>48144</PointerOffset>
      <VoiceId>&lt;audio:VCT_002_072_013&gt;</VoiceId>
      <JapaneseText>エトちゃん、心配しなくていいよ……
&lt;Mel&gt;ちゃんの恋愛エンジン回転してないから</JapaneseText>
      <EnglishText>Don't you worry Miss Eto... I think little &lt;Mel&gt;'s love engine is still not quite fired up.</EnglishText>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>13</Id>
      <Status>Editing</Status>
    </Entry>
  </Strings>
</SceneText>
