  <Strings>
    <Section>Main</Section>
    <Entry>
      <PointerOffset>45348</PointerOffset>
      <VoiceId>&lt;audio:VCT_004_118_001&gt;</VoiceId>
      <JapaneseText>どーよ！　オレの秘奥義！
かっこいいだろ強いだろ～</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>1</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>45448</PointerOffset>
      <VoiceId>&lt;audio:VCT_004_118_002&gt;</VoiceId>
      <JapaneseText>調子に乗らないの！
もう！　すぐこれなんだから</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>2</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>45596</PointerOffset>
      <VoiceId>&lt;audio:VCT_004_118_003&gt;</VoiceId>
      <JapaneseText>ぷぷぷ。あの程度で秘奥義とか言っちまう辺り、
チビ助のしょぼさが滲み出てて、笑っちまうだーよ</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>3</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>45664</PointerOffset>
      <VoiceId>&lt;audio:VCT_004_118_004&gt;</VoiceId>
      <JapaneseText>そこ、うるせー！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>4</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>45780</PointerOffset>
      <VoiceId>&lt;audio:VCT_004_118_005&gt;</VoiceId>
      <JapaneseText>……あっ！　さては
オレのあんまりのかっこよさに嫉妬してんな？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>5</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>45876</PointerOffset>
      <VoiceId>&lt;audio:VCT_004_118_006&gt;</VoiceId>
      <JapaneseText>……使いこなせたら便利だなって、
思ったけど</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>6</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>46004</PointerOffset>
      <VoiceId>&lt;audio:VCT_004_118_007&gt;</VoiceId>
      <JapaneseText>そうだなやー、あの技を使えば、
アリの大群ぐらいなら吹っ飛ばせそうだ～よ</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>7</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>46092</PointerOffset>
      <VoiceId>&lt;audio:VCT_004_118_008&gt;</VoiceId>
      <JapaneseText>ふふふ……ほめろ！　もっとほめろ！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>8</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>46188</PointerOffset>
      <VoiceId>&lt;audio:VCT_004_118_009&gt;</VoiceId>
      <JapaneseText>皮肉もわからんとは、ほんまもんのアホだ</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>9</Id>
      <Status>To Do</Status>
    </Entry>
  </Strings>
