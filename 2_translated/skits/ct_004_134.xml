    <Entry>
      <PointerOffset>45996</PointerOffset>
      <VoiceId>&lt;audio:VCT_004_134_001&gt;</VoiceId>
      <JapaneseText>&lt;Mel&gt;&lt;Mel&gt;～！　すんばらしい、すんばらしい一撃だど！
おら、惚れ直しただ、猛烈に惚れ直しただー∀</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>1</Id>
      <OldPtr>37244</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>46076</PointerOffset>
      <VoiceId>&lt;audio:VCT_004_134_002&gt;</VoiceId>
      <JapaneseText>え、あ、ありがとうございます</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>2</Id>
      <OldPtr>39468</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>46192</PointerOffset>
      <VoiceId>&lt;audio:VCT_004_134_003&gt;</VoiceId>
      <JapaneseText>つーか、よくあんなむずいのできんのな。
やるの大変じゃねーか？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>3</Id>
      <OldPtr>40964</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>46288</PointerOffset>
      <VoiceId>&lt;audio:VCT_004_134_004&gt;</VoiceId>
      <JapaneseText>そう、かな……
そうでもない、と思うけど……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>4</Id>
      <OldPtr>41196</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>46364</PointerOffset>
      <VoiceId>&lt;audio:VCT_004_134_005&gt;</VoiceId>
      <JapaneseText>なんかコツとかあんのか？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>5</Id>
      <OldPtr>41556</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>46484</PointerOffset>
      <VoiceId>&lt;audio:VCT_004_134_006&gt;</VoiceId>
      <JapaneseText>あんま難しく考えないで、
ガチャガチャってやればいいんだと思う、うん</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>6</Id>
      <OldPtr>41916</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>46568</PointerOffset>
      <VoiceId>&lt;audio:VCT_004_134_007&gt;</VoiceId>
      <JapaneseText>ガチャガチャ？　なんだ、そりゃ</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>7</Id>
      <OldPtr>42592</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>46640</PointerOffset>
      <VoiceId>&lt;audio:VCT_004_134_008&gt;</VoiceId>
      <JapaneseText>ガチャガチャって感じ</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>8</Id>
      <OldPtr>42984</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>46708</PointerOffset>
      <VoiceId>&lt;audio:VCT_004_134_009&gt;</VoiceId>
      <JapaneseText>よくわかんね……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>9</Id>
      <OldPtr>43296</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>46856</PointerOffset>
      <VoiceId>&lt;audio:VCT_004_134_010&gt;</VoiceId>
      <JapaneseText>ガチャガチャっつーのはな、こう、スーっときて
ダーッときてポンって事だ！　な～、&lt;Mel&gt;&lt;Mel&gt;</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>10</Id>
      <OldPtr>43464</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>46936</PointerOffset>
      <VoiceId>&lt;audio:VCT_004_134_011&gt;</VoiceId>
      <JapaneseText>てめぇもわかってねーだろ！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>11</Id>
