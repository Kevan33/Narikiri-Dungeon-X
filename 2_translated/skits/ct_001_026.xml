    <Entry>
      <PointerOffset>43664</PointerOffset>
      <VoiceId>&lt;audio:VCT_001_026_001&gt;</VoiceId>
      <JapaneseText>続・エトちゃん奪還、
ウルトラローリングアタックミッション！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>1</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>43752</PointerOffset>
      <VoiceId>&lt;audio:VCT_001_026_002&gt;</VoiceId>
      <JapaneseText>その計画の名前、決定なんですか……？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>2</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>43816</PointerOffset>
      <VoiceId>&lt;audio:VCT_001_026_003&gt;</VoiceId>
      <JapaneseText>決定だろ？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>3</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>43936</PointerOffset>
      <VoiceId>&lt;audio:VCT_001_026_004&gt;</VoiceId>
      <JapaneseText>名前はさておき、どうやってエトちゃんを
救うか、ってことだけど……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>4</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>44012</PointerOffset>
      <VoiceId>&lt;audio:VCT_001_026_005&gt;</VoiceId>
      <JapaneseText>ノームの穴に水流そうぜ！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>5</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>44096</PointerOffset>
      <VoiceId>&lt;audio:VCT_001_026_006&gt;</VoiceId>
      <JapaneseText>エトも一緒におぼれちゃうってば</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>6</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>44192</PointerOffset>
      <VoiceId>&lt;audio:VCT_001_026_007&gt;</VoiceId>
      <JapaneseText>じゃあ、穴を掘り返して、
ほじくりだすとか</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>7</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>44268</PointerOffset>
      <VoiceId>&lt;audio:VCT_001_026_008&gt;</VoiceId>
      <JapaneseText>ドロンコになっちゃうよ？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>8</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>44368</PointerOffset>
      <VoiceId>&lt;audio:VCT_001_026_009&gt;</VoiceId>
      <JapaneseText>エトを助けるためなら、それくらい。
平気です！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>9</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>44436</PointerOffset>
      <VoiceId>&lt;audio:VCT_001_026_010&gt;</VoiceId>
      <JapaneseText>その覚悟やよし！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>10</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>44564</PointerOffset>
      <VoiceId>&lt;audio:VCT_001_026_011&gt;</VoiceId>
      <JapaneseText>じゃあ、今度逃げたら、その
ゴーゴーアンダーグラウンド作戦で追いかけようぜ！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>11</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>44636</PointerOffset>
      <VoiceId>&lt;audio:VCT_001_026_012&gt;</VoiceId>
      <JapaneseText>あはは、それいいね</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>12</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>44716</PointerOffset>
      <VoiceId>&lt;audio:VCT_001_026_013&gt;</VoiceId>
      <JapaneseText>名前なんてどうでもいいってば</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>13</Id>
      <Status>To Do</Status>
    </Entry>
  </Strings>
