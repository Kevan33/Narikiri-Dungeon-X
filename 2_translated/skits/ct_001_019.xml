  <Strings>
    <Section>Main</Section>
    <Entry>
      <PointerOffset>45268</PointerOffset>
      <VoiceId>&lt;audio:VCT_001_019_001&gt;</VoiceId>
      <JapaneseText>&lt;Claus&gt;ミラルドさんは
さんの奥さんなんですか？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>1</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>45364</PointerOffset>
      <VoiceId>&lt;audio:VCT_001_019_002&gt;</VoiceId>
      <JapaneseText>あいつは単なる助手だ、
そういうのとは違う</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>2</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>45464</PointerOffset>
      <VoiceId>&lt;audio:VCT_001_019_003&gt;</VoiceId>
      <JapaneseText>……え？　でも恋人同士みたいな
話だったし……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>3</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>45532</PointerOffset>
      <VoiceId>&lt;audio:VCT_001_019_004&gt;</VoiceId>
      <JapaneseText>違う。断じて違う</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>4</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>45624</PointerOffset>
      <VoiceId>&lt;audio:VCT_001_019_005&gt;</VoiceId>
      <JapaneseText>……どうしてそんな
むきになるんですか？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>5</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>45720</PointerOffset>
      <VoiceId>&lt;audio:VCT_001_019_006&gt;</VoiceId>
      <JapaneseText>&lt;Mel&gt;、興味本位で
そういうこと聞かないの</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>6</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>45808</PointerOffset>
      <VoiceId>&lt;audio:VCT_001_019_007&gt;</VoiceId>
      <JapaneseText>そうだ。君にはまだ
こういう話は早い</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>7</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>45892</PointerOffset>
      <VoiceId>&lt;audio:VCT_001_019_008&gt;</VoiceId>
      <JapaneseText>早くはないと、思いますけど……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>8</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>46000</PointerOffset>
      <VoiceId>&lt;audio:VCT_001_019_009&gt;</VoiceId>
      <JapaneseText>あ……ってことはやっぱり、
おふたりは恋人同士なんですね</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>9</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>46096</PointerOffset>
      <VoiceId>&lt;audio:VCT_001_019_010&gt;</VoiceId>
      <JapaneseText>どうしてそうなるんだ。
違うと言ったら、違う</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>10</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>46176</PointerOffset>
      <VoiceId>&lt;audio:VCT_001_019_011&gt;</VoiceId>
      <JapaneseText>じゃあ、どういう関係ですか？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>11</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>46248</PointerOffset>
      <VoiceId>&lt;audio:VCT_001_019_012&gt;</VoiceId>
      <JapaneseText>&lt;Mel&gt;あ、ってば……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>12</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>46324</PointerOffset>
      <VoiceId>&lt;audio:VCT_001_019_013&gt;</VoiceId>
      <JapaneseText>もう……女の子なんだかラ</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>13</Id>
      <Status>To Do</Status>
    </Entry>
  </Strings>
