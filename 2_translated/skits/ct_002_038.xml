  </Speakers>
  <Strings>
    <Section>Main</Section>
    <Entry>
      <PointerOffset>44724</PointerOffset>
      <VoiceId>&lt;audio:VCT_002_038_001&gt;</VoiceId>
      <JapaneseText>ノルンさんはどうしてわたしたちのところへ
アルベルトさんを？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>1</Id>
      <OldPtr>37280</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>44856</PointerOffset>
      <VoiceId>&lt;audio:VCT_002_038_002&gt;</VoiceId>
      <JapaneseText>それは、&lt;Mel&gt;&lt;Mel&gt;が一人前の大人として、
成長できるようにするためだ～よ</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>2</Id>
      <OldPtr>37588</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>44948</PointerOffset>
      <VoiceId>&lt;audio:VCT_002_038_003&gt;</VoiceId>
      <JapaneseText>ノルン様も、さっき、そう言ってただ</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>3</Id>
      <OldPtr>38416</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>45068</PointerOffset>
      <VoiceId>&lt;audio:VCT_002_038_004&gt;</VoiceId>
      <JapaneseText>そうじゃなくて、ノルンさんは
どうしてわたしたちに親切なんですか？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>4</Id>
      <OldPtr>38760</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>45180</PointerOffset>
      <VoiceId>&lt;audio:VCT_002_038_005&gt;</VoiceId>
      <JapaneseText>そう聞いたのに、ノルンさんに
質問をそらされた気がして……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>5</Id>
      <OldPtr>39356</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>45320</PointerOffset>
      <VoiceId>&lt;audio:VCT_002_038_006&gt;</VoiceId>
      <JapaneseText>むはは、大丈夫だよ。ノルン様がどったらつもりでも、
きっと、悪い事にはならないはずだ</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>6</Id>
      <OldPtr>39468</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>45460</PointerOffset>
      <VoiceId>&lt;audio:VCT_002_038_007&gt;</VoiceId>
      <JapaneseText>そういうこって、今だって『なりきり士』の力が、
&lt;Mel&gt;&lt;Mel&gt;の役に立ってるはずだど？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>7</Id>
      <OldPtr>40604</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>45540</PointerOffset>
      <VoiceId>&lt;audio:VCT_002_038_008&gt;</VoiceId>
      <JapaneseText>それはそうなんですけど……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>8</Id>
      <OldPtr>41660</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>45700</PointerOffset>
      <VoiceId>&lt;audio:VCT_002_038_009&gt;</VoiceId>
      <JapaneseText>そんだけわかればだいじょぶだぁ。ほれ、&lt;Mel&gt;&lt;Mel&gt;、
ここで、新しい衣装に着替えて、また役に立って……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>9</Id>
      <OldPtr>41892</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>45804</PointerOffset>
      <VoiceId>&lt;audio:VCT_002_038_010&gt;</VoiceId>
      <JapaneseText>このエロタンス！
&lt;Mel&gt;の着替えが見たいだけだろ！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>10</Id>
      <OldPtr>43044</OldPtr>
      <Status>To Do</Status>
    </Entry>
  </Strings>
  <Strings>
