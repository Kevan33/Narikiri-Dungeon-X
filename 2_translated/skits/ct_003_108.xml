    <Entry>
      <PointerOffset>41352</PointerOffset>
      <VoiceId>&lt;audio:VCT_003_108_001&gt;</VoiceId>
      <JapaneseText>……そう言や、ここ来たのって、
あいつらぶっ叩くためだっけ</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>1</Id>
      <OldPtr>37120</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>41428</PointerOffset>
      <VoiceId>&lt;audio:VCT_003_108_002&gt;</VoiceId>
      <JapaneseText>オレ、すっかり忘れてた</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>2</Id>
      <OldPtr>37440</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>41524</PointerOffset>
      <VoiceId>&lt;audio:VCT_003_108_003&gt;</VoiceId>
      <JapaneseText>するべきことが
すっきりと見えたからかな？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>3</Id>
      <OldPtr>37668</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>41620</PointerOffset>
      <VoiceId>&lt;audio:VCT_003_108_004&gt;</VoiceId>
      <JapaneseText>んだな、それにあいつらにも
もう怒ってないし</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>4</Id>
      <OldPtr>38044</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>41696</PointerOffset>
      <VoiceId>&lt;audio:VCT_003_108_005&gt;</VoiceId>
      <JapaneseText>自分に怒っても仕方ないよ</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>5</Id>
      <OldPtr>38632</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>41772</PointerOffset>
      <VoiceId>&lt;audio:VCT_003_108_006&gt;</VoiceId>
      <JapaneseText>あいつらはオレらだもんな</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>6</Id>
      <OldPtr>39160</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>41872</PointerOffset>
      <VoiceId>&lt;audio:VCT_003_108_007&gt;</VoiceId>
      <JapaneseText>ふふ、なんか、&lt;Dio&gt;、
すっきりした顔してるね</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>7</Id>
      <OldPtr>39592</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>41936</PointerOffset>
      <VoiceId>&lt;audio:VCT_003_108_008&gt;</VoiceId>
      <JapaneseText>おまえもな</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>8</Id>
      <OldPtr>40036</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>42004</PointerOffset>
      <VoiceId>&lt;audio:VCT_003_108_009&gt;</VoiceId>
      <JapaneseText>よし……行こ！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>9</Id>
      <OldPtr>40348</OldPtr>
      <Status>To Do</Status>
    </Entry>
