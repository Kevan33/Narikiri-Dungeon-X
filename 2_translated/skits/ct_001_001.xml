  </Speakers>
  <Strings>
    <Section>Main</Section>
    <Entry>
      <PointerOffset>44860</PointerOffset>
      <VoiceId>&lt;audio:VCT_001_001_001&gt;</VoiceId>
      <JapaneseText>ちょっと&lt;Dio&gt;、
バタバタしないの</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>1</Id>
      <OldPtr>37612</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>44940</PointerOffset>
      <VoiceId>&lt;audio:VCT_001_001_002&gt;</VoiceId>
      <JapaneseText>妹が、兄貴に命令すんなよ！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>2</Id>
      <OldPtr>38484</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>45040</PointerOffset>
      <VoiceId>&lt;audio:VCT_001_001_003&gt;</VoiceId>
      <JapaneseText>何言ってんの？
私がお姉ちゃん、&lt;Dio&gt;は弟でしょ</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>3</Id>
      <OldPtr>38932</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>45108</PointerOffset>
      <VoiceId>&lt;audio:VCT_001_001_004&gt;</VoiceId>
      <JapaneseText>オレの方が上だ！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>4</Id>
      <OldPtr>39648</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>45204</PointerOffset>
      <VoiceId>&lt;audio:VCT_001_001_005&gt;</VoiceId>
      <JapaneseText>もう……エトぉ！
お姉ちゃんはわたしだよね？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>5</Id>
      <OldPtr>40060</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>45280</PointerOffset>
      <VoiceId>&lt;audio:VCT_001_001_006&gt;</VoiceId>
      <JapaneseText>だから、わかんないってば</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>6</Id>
      <OldPtr>41056</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>45400</PointerOffset>
      <VoiceId>&lt;audio:VCT_001_001_007&gt;</VoiceId>
      <JapaneseText>ふたり一緒にぼくんとこに来たんだって。
前から何度も言ってるでしょ</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>7</Id>
      <OldPtr>41488</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>45468</PointerOffset>
      <VoiceId>&lt;audio:VCT_001_001_008&gt;</VoiceId>
      <JapaneseText>んだよ、もう……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>8</Id>
      <OldPtr>42096</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>45584</PointerOffset>
      <VoiceId>&lt;audio:VCT_001_001_009&gt;</VoiceId>
      <JapaneseText>よーし！　今日こそ虫とり対決で、
白黒はっきりつけるぞ、&lt;Mel&gt;！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>9</Id>
      <OldPtr>42384</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>45660</PointerOffset>
      <VoiceId>&lt;audio:VCT_001_001_010&gt;</VoiceId>
      <JapaneseText>もうっ！　お子ちゃまっ！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>10</Id>
      <OldPtr>43600</OldPtr>
      <Status>To Do</Status>
    </Entry>
