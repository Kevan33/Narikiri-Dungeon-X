    <Entry>
      <PointerOffset>40180</PointerOffset>
      <VoiceId>&lt;audio:VCT_003_096_001&gt;</VoiceId>
      <JapaneseText>&lt;Dio&gt;。全部……思い出した？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>1</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>40292</PointerOffset>
      <VoiceId>&lt;audio:VCT_003_096_002&gt;</VoiceId>
      <JapaneseText>いや……まだ。
なんかひとつにつながりそうでつながらないんだ</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>2</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>40360</PointerOffset>
      <VoiceId>&lt;audio:VCT_003_096_003&gt;</VoiceId>
      <JapaneseText>……おまえは？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>3</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>40456</PointerOffset>
      <VoiceId>&lt;audio:VCT_003_096_004&gt;</VoiceId>
      <JapaneseText>わたしもまだところどころ
欠けてる感じ……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>4</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>40560</PointerOffset>
      <VoiceId>&lt;audio:VCT_003_096_005&gt;</VoiceId>
      <JapaneseText>イヤなことだから思い出したくない
ことがあんのかな</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>5</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>40664</PointerOffset>
      <VoiceId>&lt;audio:VCT_003_096_006&gt;</VoiceId>
      <JapaneseText>どうでもいいことだから、
思い出せないんだよ、きっと</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>6</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>40724</PointerOffset>
      <VoiceId>&lt;audio:VCT_003_096_007&gt;</VoiceId>
      <JapaneseText>そうか？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>7</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>40828</PointerOffset>
      <VoiceId>&lt;audio:VCT_003_096_008&gt;</VoiceId>
      <JapaneseText>だって……これ以上、
イヤな思い出はいらないよ……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>8</Id>
      <Status>To Do</Status>
    </Entry>
