    <Entry>
      <PointerOffset>43568</PointerOffset>
      <VoiceId>&lt;audio:VCT_003_104_001&gt;</VoiceId>
      <JapaneseText>そっか、だから双子ちゃんは
魔法が使えたんだね</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>1</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>43648</PointerOffset>
      <VoiceId>&lt;audio:VCT_003_104_002&gt;</VoiceId>
      <JapaneseText>&lt;Rody&gt;どうしたの、、突然</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>2</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>43752</PointerOffset>
      <VoiceId>&lt;audio:VCT_003_104_003&gt;</VoiceId>
      <JapaneseText>オレらが魔法を使えるのは、
『なりきり士』だからだよ</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>3</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>43840</PointerOffset>
      <VoiceId>&lt;audio:VCT_003_104_004&gt;</VoiceId>
      <JapaneseText>この地上でマナを紡げるのはエルフだけ</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>4</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>43960</PointerOffset>
      <VoiceId>&lt;audio:VCT_003_104_005&gt;</VoiceId>
      <JapaneseText>『なりきり士』でも、エルフが
生まれつき持ってる力まではマネできない</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>5</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>44032</PointerOffset>
      <VoiceId>&lt;audio:VCT_003_104_006&gt;</VoiceId>
      <JapaneseText>それじゃあなんで？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>4</SpeakerId>
      <Id>6</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>44120</PointerOffset>
      <VoiceId>&lt;audio:VCT_003_104_007&gt;</VoiceId>
      <JapaneseText>君たちがデリス・カーラーン人だから</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>7</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>44188</PointerOffset>
      <VoiceId>&lt;audio:VCT_003_104_008&gt;</VoiceId>
      <JapaneseText>そ、そんな……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>8</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>44248</PointerOffset>
      <VoiceId>&lt;audio:VCT_003_104_009&gt;</VoiceId>
      <JapaneseText>残念？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>9</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>44320</PointerOffset>
      <VoiceId>&lt;audio:VCT_003_104_010&gt;</VoiceId>
      <JapaneseText>残念とかと違くて……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>10</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>44460</PointerOffset>
      <VoiceId>&lt;audio:VCT_003_104_011&gt;</VoiceId>
      <JapaneseText>&lt;Mel&gt;じゃあ、オレの魔法がよりもしょぼいのは
服装の差じゃなくて、もともとなのかっ！？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>11</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>44524</PointerOffset>
      <VoiceId>&lt;audio:VCT_003_104_012&gt;</VoiceId>
      <JapaneseText>才能の差？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>12</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>44592</PointerOffset>
      <VoiceId>&lt;audio:VCT_003_104_013&gt;</VoiceId>
      <JapaneseText>才能の差だよね</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>4</SpeakerId>
      <Id>13</Id>
      <Status>To Do</Status>
    </Entry>
