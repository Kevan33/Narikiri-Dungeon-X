    <Entry>
      <PointerOffset>43756</PointerOffset>
      <VoiceId>&lt;audio:VCT_001_016_001&gt;</VoiceId>
      <JapaneseText>君は妖精なのか？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>1</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>43828</PointerOffset>
      <VoiceId>&lt;audio:VCT_001_016_002&gt;</VoiceId>
      <JapaneseText>え？　あ、うん……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>2</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>43936</PointerOffset>
      <VoiceId>&lt;audio:VCT_001_016_003&gt;</VoiceId>
      <JapaneseText>妖精ってのはラグナロクの時に
滅びたと聞いたのだが……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>3</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>44024</PointerOffset>
      <VoiceId>&lt;audio:VCT_001_016_004&gt;</VoiceId>
      <JapaneseText>ぼくもそんな話、
聞いたことあるよ</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>4</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>44116</PointerOffset>
      <VoiceId>&lt;audio:VCT_001_016_005&gt;</VoiceId>
      <JapaneseText>当の妖精の口から
そんな言葉を聞くとはな</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>5</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>44236</PointerOffset>
      <VoiceId>&lt;audio:VCT_001_016_006&gt;</VoiceId>
      <JapaneseText>君のような稀少な存在を狙う悪い魔術師もいる。
気をつけた方がいいぞ</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>6</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>44316</PointerOffset>
      <VoiceId>&lt;audio:VCT_001_016_007&gt;</VoiceId>
      <JapaneseText>え、う、うん、そうだね……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>7</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>44380</PointerOffset>
      <VoiceId>&lt;audio:VCT_001_016_008&gt;</VoiceId>
      <JapaneseText>クルール！！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>8</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>44444</PointerOffset>
      <VoiceId>&lt;audio:VCT_001_016_009&gt;</VoiceId>
      <JapaneseText>うわっ！！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>9</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>44520</PointerOffset>
      <VoiceId>&lt;audio:VCT_001_016_010&gt;</VoiceId>
      <JapaneseText>クルール！　クルール！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>10</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>44612</PointerOffset>
      <VoiceId>&lt;audio:VCT_001_016_011&gt;</VoiceId>
      <JapaneseText>&lt;Couleur&gt;、ダメ！
エトにじゃれついちゃ！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>4</SpeakerId>
      <Id>11</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>44708</PointerOffset>
      <VoiceId>&lt;audio:VCT_001_016_012&gt;</VoiceId>
      <JapaneseText>なるほど、敵は身近にいる、
というわけか……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>12</Id>
      <Status>To Do</Status>
    </Entry>
