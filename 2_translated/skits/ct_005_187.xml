    <Section>Main</Section>
    <Entry>
      <PointerOffset>45680</PointerOffset>
      <VoiceId>&lt;audio:VCT_005_187_001&gt;</VoiceId>
      <JapaneseText>んくんく……ぷはぁっ！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>1</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>45808</PointerOffset>
      <VoiceId>&lt;audio:VCT_005_187_002&gt;</VoiceId>
      <JapaneseText>あーっ！　そのミルク、今夜のご飯の材料なのに、
勝手に飲んじゃダメじゃん！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>2</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>45940</PointerOffset>
      <VoiceId>&lt;audio:VCT_005_187_003&gt;</VoiceId>
      <JapaneseText>え？　そーだったの？　ゴメンゴメン、
なんか一日一杯飲まないと調子出ないんだよね</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>3</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>46072</PointerOffset>
      <VoiceId>&lt;audio:VCT_005_187_004&gt;</VoiceId>
      <JapaneseText>ミルクに含まれるカルシウムは体を丈夫にしますし、
お通じを促す役目もあるそうです</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>4</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>46156</PointerOffset>
      <VoiceId>&lt;audio:VCT_005_187_005&gt;</VoiceId>
      <JapaneseText>人間の成長も助けるって言うしね</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>5</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>46256</PointerOffset>
      <VoiceId>&lt;audio:VCT_005_187_006&gt;</VoiceId>
      <JapaneseText>&lt;Arche&gt;成長不足のは、
たくさん飲んだ方がいいな</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>4</SpeakerId>
      <Id>6</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>46324</PointerOffset>
      <VoiceId>&lt;audio:VCT_005_187_007&gt;</VoiceId>
      <JapaneseText>誰が成長不足よ！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>7</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>46448</PointerOffset>
      <VoiceId>&lt;audio:VCT_005_187_008&gt;</VoiceId>
      <JapaneseText>落ち着けよ、イライラしやすいのは
カルシウムが足りないから、とも言うぜ</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>4</SpeakerId>
      <Id>8</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>46512</PointerOffset>
      <VoiceId>&lt;audio:VCT_005_187_009&gt;</VoiceId>
      <JapaneseText>うるさいっ！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>9</Id>
      <Status>To Do</Status>
    </Entry>
