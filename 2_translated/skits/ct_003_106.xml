<SceneText>
  <Speakers>
    <Section>Speaker</Section>
    <Entry>
      <PointerOffset>45292,45524,45792,46020</PointerOffset>
      <JapaneseText>アルベルト</JapaneseText>
      <EnglishText/>
      <Notes/>
      <Id>1</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>45368,45640,45880,46096</PointerOffset>
      <JapaneseText>&lt;Rondoline&gt;</JapaneseText>
      <EnglishText/>
      <Notes/>
      <Id>2</Id>
      <Status>To Do</Status>
    </Entry>
  </Speakers>
  <Strings>
    <Section>Main</Section>
    <Entry>
      <PointerOffset>45296</PointerOffset>
      <VoiceId>&lt;audio:VCT_003_106_001&gt;</VoiceId>
      <JapaneseText>&lt;Rody&gt;うぅ……、ズルイ、ズルイだ、たん……。
おらを置いてけぼりにして</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>1</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>45372</PointerOffset>
      <VoiceId>&lt;audio:VCT_003_106_002&gt;</VoiceId>
      <JapaneseText>え、私？　何かしたっけ？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>2</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>45528</PointerOffset>
      <VoiceId>&lt;audio:VCT_003_106_003&gt;</VoiceId>
      <JapaneseText>&lt;Mel&gt;&lt;Mel&gt;おらよりも先に、に呼び捨てにされただ！
これをズルイと言わずして、なんと言うだーよ！！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>3</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>45644</PointerOffset>
      <VoiceId>&lt;audio:VCT_003_106_004&gt;</VoiceId>
      <JapaneseText>あれ？　そうだっけ？
そんだけ、距離感が縮まったってことかな～？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>4</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>45796</PointerOffset>
      <VoiceId>&lt;audio:VCT_003_106_005&gt;</VoiceId>
      <JapaneseText>&lt;Mel&gt;&lt;Mel&gt;おらも、もっとと距離を縮めてーだ！
早く呼び捨てにされたり、あだ名で呼んでほしいだよ</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>5</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>45884</PointerOffset>
      <VoiceId>&lt;audio:VCT_003_106_006&gt;</VoiceId>
      <JapaneseText>あだ名？　例えばどんなのがいいの？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>6</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>46024</PointerOffset>
      <VoiceId>&lt;audio:VCT_003_106_007&gt;</VoiceId>
      <JapaneseText>そら、『アルちゃん』とか『アルベっち』とか？
あとは、『アルルン』なんてのもいいなー</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>7</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>46100</PointerOffset>
      <VoiceId>&lt;audio:VCT_003_106_008&gt;</VoiceId>
      <JapaneseText>ざんね～ん、一生無理！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>8</Id>
      <Status>To Do</Status>
    </Entry>
  </Strings>
  <Strings>
    <Section>Notice</Section>
  </Strings>
</SceneText>
