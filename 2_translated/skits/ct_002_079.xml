    <Entry>
      <PointerOffset>43628</PointerOffset>
      <VoiceId>&lt;audio:VCT_002_079_001&gt;</VoiceId>
      <JapaneseText>オレ、思う、&lt;Mel&gt;
もっと、優しく</JapaneseText>
      <EnglishText>I...think...&lt;Mel&gt;...kinder...should...</EnglishText>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>1</Id>
      <Status>Editing</Status>
    </Entry>
    <Entry>
      <PointerOffset>43700</PointerOffset>
      <VoiceId>&lt;audio:VCT_002_079_002&gt;</VoiceId>
      <JapaneseText>わたし、優しい、充分</JapaneseText>
      <EnglishText>I...kind...enough...</EnglishText>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>2</Id>
      <Status>Editing</Status>
    </Entry>
    <Entry>
      <PointerOffset>43776</PointerOffset>
      <VoiceId>&lt;audio:VCT_002_079_003&gt;</VoiceId>
      <JapaneseText>ふたり、ケンカ、やめる</JapaneseText>
      <EnglishText>You...fight...stop...</EnglishText>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>3</Id>
      <Status>Editing</Status>
    </Entry>
    <Entry>
      <PointerOffset>43848</PointerOffset>
      <VoiceId>&lt;audio:VCT_002_079_004&gt;</VoiceId>
      <JapaneseText>みんな、話し方、変</JapaneseText>
      <EnglishText>Everyone...speaking...weird...</EnglishText>
      <Notes/>
      <SpeakerId>4</SpeakerId>
      <Id>4</Id>
      <Status>Editing</Status>
    </Entry>
    <Entry>
      <PointerOffset>43912</PointerOffset>
      <VoiceId>&lt;audio:VCT_002_079_005&gt;</VoiceId>
      <JapaneseText>クルルル～？</JapaneseText>
      <EnglishText>Kururu~?</EnglishText>
      <Notes/>
      <SpeakerId>5</SpeakerId>
      <Id>5</Id>
      <Status>Editing</Status>
    </Entry>
    <Entry>
      <PointerOffset>44012</PointerOffset>
      <VoiceId>&lt;audio:VCT_002_079_006&gt;</VoiceId>
      <JapaneseText>おっ、シャドウごっこか？
オレたちもやったよな</JapaneseText>
      <EnglishText>Oh, it's the Shadow talk game! We did that too back then.</EnglishText>
      <Notes/>
      <SpeakerId>6</SpeakerId>
      <Id>6</Id>
      <Status>Editing</Status>
    </Entry>
    <Entry>
      <PointerOffset>44104</PointerOffset>
      <VoiceId>&lt;audio:VCT_002_079_007&gt;</VoiceId>
      <JapaneseText>いや、ごっこはしてなかった
と思うけど</JapaneseText>
      <EnglishText>Err, I never thought of it as a game.</EnglishText>
      <Notes/>
      <SpeakerId>7</SpeakerId>
      <Id>7</Id>
      <Status>Editing</Status>
    </Entry>
    <Entry>
      <PointerOffset>44200</PointerOffset>
      <VoiceId>&lt;audio:VCT_002_079_008&gt;</VoiceId>
      <JapaneseText>シャドウの喋り方が
うつってしまったんですね</JapaneseText>
      <EnglishText>We really couldn't help but talk like Shadow.</EnglishText>
      <Notes/>
      <SpeakerId>8</SpeakerId>
      <Id>8</Id>
      <Status>Editing</Status>
