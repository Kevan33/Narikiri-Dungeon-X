    <Entry>
      <PointerOffset>51584</PointerOffset>
      <VoiceId>&lt;audio:VCT_004_141_001&gt;</VoiceId>
      <JapaneseText>よっしゃー勝ったぜ</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>1</Id>
      <OldPtr>37748</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>51676</PointerOffset>
      <VoiceId>&lt;audio:VCT_004_141_002&gt;</VoiceId>
      <JapaneseText>魔物をポイポイっと、
今回も楽勝、楽勝～</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>2</Id>
      <OldPtr>38248</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>51776</PointerOffset>
      <VoiceId>&lt;audio:VCT_004_141_003&gt;</VoiceId>
      <JapaneseText>何が楽勝だ。
こっちは走り回って疲れてるってのに</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>3</Id>
      <OldPtr>38780</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>51880</PointerOffset>
      <VoiceId>&lt;audio:VCT_004_141_004&gt;</VoiceId>
      <JapaneseText>後ろを守ってる&lt;Chester&gt;は
&lt;Dio&gt;より走ってないじゃん</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>4</Id>
      <OldPtr>39576</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>52008</PointerOffset>
      <VoiceId>&lt;audio:VCT_004_141_005&gt;</VoiceId>
      <JapaneseText>程度の問題じゃねぇ。ホウキにまたがって
飛んでるだけのおまえとは違うんだよ</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>5</Id>
      <OldPtr>40232</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>52120</PointerOffset>
      <VoiceId>&lt;audio:VCT_004_141_006&gt;</VoiceId>
      <JapaneseText>何言ってんのよ！
ホウキで飛ぶのってすっごい難しいんだから</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>6</Id>
      <OldPtr>41264</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>52220</PointerOffset>
      <VoiceId>&lt;audio:VCT_004_141_007&gt;</VoiceId>
      <JapaneseText>この、あ・た・し∀だから上手に飛べるんだからね</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>7</Id>
      <OldPtr>42404</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>52352</PointerOffset>
      <VoiceId>&lt;audio:VCT_004_141_008&gt;</VoiceId>
      <JapaneseText>ホウキの機嫌を損ねないように、やさしーく
乗ってあげるってわけ。わかったかなぁ？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>8</Id>
      <OldPtr>43612</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>52424</PointerOffset>
      <VoiceId>&lt;audio:VCT_004_141_009&gt;</VoiceId>
      <JapaneseText>そんなんわかんねぇよ</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>9</Id>
      <OldPtr>44580</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>52492</PointerOffset>
      <VoiceId>&lt;audio:VCT_004_141_010&gt;</VoiceId>
      <JapaneseText>なんだってー！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>10</Id>
      <OldPtr>44880</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>52580</PointerOffset>
      <VoiceId>&lt;audio:VCT_004_141_011&gt;</VoiceId>
      <JapaneseText>&lt;Arche&gt;さんと&lt;Chester&gt;さんって仲いいね</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>4</SpeakerId>
      <Id>11</Id>
      <OldPtr>45632</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>52664</PointerOffset>
      <VoiceId>&lt;audio:VCT_004_141_012&gt;</VoiceId>
      <JapaneseText>オレ、仲いいように見えねけど……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>12</Id>
      <OldPtr>46036</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>52760</PointerOffset>
      <VoiceId>&lt;audio:VCT_004_141_013&gt;</VoiceId>
      <JapaneseText>&lt;Dio&gt;ってば気づかないの？
……お子ちゃま</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>4</SpeakerId>
      <Id>13</Id>
      <OldPtr>46488</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>52852</PointerOffset>
      <VoiceId>&lt;audio:VCT_004_141_014&gt;</VoiceId>
      <JapaneseText>もっとお子ちゃまの&lt;Mel&gt;に言われたくねー</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>14</Id>
      <OldPtr>46892</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>52948</PointerOffset>
      <VoiceId>&lt;audio:VCT_004_141_015&gt;</VoiceId>
      <JapaneseText>&lt;Dio&gt;なんて、お子ちゃまのお子ちゃまでしょ</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>4</SpeakerId>
      <Id>15</Id>
      <OldPtr>47748</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>53064</PointerOffset>
      <VoiceId>&lt;audio:VCT_004_141_016&gt;</VoiceId>
      <JapaneseText>へへぇ∀　あの子たち仲いーね
ははは、あいつら仲いいな</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>5</SpeakerId>
      <Id>16</Id>
      <OldPtr>48936</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>53332</PointerOffset>
      <VoiceId>&lt;audio:VCT_004_141_019&gt;</VoiceId>
      <JapaneseText>イーだ
けっ！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>5</SpeakerId>
      <Id>17</Id>
      <OldPtr>50324</OldPtr>
      <Status>To Do</Status>
    </Entry>
