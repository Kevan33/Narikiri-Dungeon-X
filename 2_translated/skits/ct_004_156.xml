    <Entry>
      <PointerOffset>47564</PointerOffset>
      <VoiceId>&lt;audio:VCT_004_156_001&gt;</VoiceId>
      <JapaneseText>このメンバーでの戦闘も、だいぶ慣れてきましたね</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>1</Id>
      <OldPtr>37640</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>47684</PointerOffset>
      <VoiceId>&lt;audio:VCT_004_156_002&gt;</VoiceId>
      <JapaneseText>うんうん、やっぱり&lt;Mint&gt;の法術があると、
安心して攻撃に集中できるよ</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>2</Id>
      <OldPtr>38016</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>47836</PointerOffset>
      <VoiceId>&lt;audio:VCT_004_156_003&gt;</VoiceId>
      <JapaneseText>そんなことありません。&lt;Mel&gt;ちゃんや&lt;Suzu&gt;ちゃんが
頑張ってくれているので、詠唱に集中できるだけです</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>3</Id>
      <OldPtr>38672</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>47988</PointerOffset>
      <VoiceId>&lt;audio:VCT_004_156_004&gt;</VoiceId>
      <JapaneseText>&lt;Rody&gt;さんの動きに比べれば、私などまだまだです。
もっと修行して、&lt;Rody&gt;さんのようになりたいです</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>4</SpeakerId>
      <Id>4</Id>
      <OldPtr>39496</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>48100</PointerOffset>
      <VoiceId>&lt;audio:VCT_004_156_005&gt;</VoiceId>
      <JapaneseText>あれ～&lt;Suzu&gt;ちゃん？
そんなに褒めても、なんも出ないよ？∀</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>5</Id>
      <OldPtr>40508</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>48248</PointerOffset>
      <VoiceId>&lt;audio:VCT_004_156_006&gt;</VoiceId>
      <JapaneseText>おらは今、歴史の生き証人になってるだ。
強さだけでなく、美しさも兼ね備えているパーティだよ</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>5</SpeakerId>
      <Id>6</Id>
      <OldPtr>42616</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>48404</PointerOffset>
      <VoiceId>&lt;audio:VCT_004_156_007&gt;</VoiceId>
      <JapaneseText>戦う女性は、すんばらしい！　すんばらしいだぁ！
このパーティのまんま、最後まで突っ切って行くだーよ！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>5</SpeakerId>
      <Id>7</Id>
      <OldPtr>43376</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>48500</PointerOffset>
      <VoiceId>&lt;audio:VCT_004_156_008&gt;</VoiceId>
      <JapaneseText>つんつん。あのー、あたしもいるんですけど？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>6</SpeakerId>
      <Id>8</Id>
      <OldPtr>44560</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>48604</PointerOffset>
      <VoiceId>&lt;audio:VCT_004_156_009&gt;</VoiceId>
      <JapaneseText>ん？　あら？　おんやぁ？　おめぇも入りてぇだが？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>5</SpeakerId>
      <Id>9</Id>
      <OldPtr>45580</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>48708</PointerOffset>
      <VoiceId>&lt;audio:VCT_004_156_010&gt;</VoiceId>
      <JapaneseText>…………いやぁ、ああ、すまんこってや、無理だど</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>5</SpeakerId>
      <Id>10</Id>
      <OldPtr>46000</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>48780</PointerOffset>
      <VoiceId>&lt;audio:VCT_004_156_011&gt;</VoiceId>
      <JapaneseText>あんたが決めんの！？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>6</SpeakerId>
      <Id>11</Id>
      <OldPtr>46748</OldPtr>
      <Status>To Do</Status>
    </Entry>
