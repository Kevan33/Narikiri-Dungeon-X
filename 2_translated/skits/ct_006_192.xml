    </Entry>
    <Entry>
      <PointerOffset>43072</PointerOffset>
      <VoiceId>&lt;audio:VCT_006_192_002&gt;</VoiceId>
      <JapaneseText>どうしたの？　何かいいこと、あったの？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>2</Id>
      <OldPtr>38140</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>43192</PointerOffset>
      <VoiceId>&lt;audio:VCT_006_192_003&gt;</VoiceId>
      <JapaneseText>うん！　ずっと書きためてたモンスター図鑑が
いっぱいになったんだ！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>3</Id>
      <OldPtr>38516</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>43276</PointerOffset>
      <VoiceId>&lt;audio:VCT_006_192_004&gt;</VoiceId>
      <JapaneseText>すごいや、&lt;Mel&gt;！　おめでとう</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>4</Id>
      <OldPtr>39280</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>43348</PointerOffset>
      <VoiceId>&lt;audio:VCT_006_192_005&gt;</VoiceId>
      <JapaneseText>ありがと♪　えへへ</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>5</Id>
      <OldPtr>39792</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>43468</PointerOffset>
      <VoiceId>&lt;audio:VCT_006_192_006&gt;</VoiceId>
      <JapaneseText>これで魔物の弱点が丸わかりだね！
これで楽になるよ！　大手柄だね！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>6</Id>
      <OldPtr>40408</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>43532</PointerOffset>
      <VoiceId>&lt;audio:VCT_006_192_007&gt;</VoiceId>
      <JapaneseText>えへへ……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>7</Id>
      <OldPtr>41540</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>43652</PointerOffset>
      <VoiceId>&lt;audio:VCT_006_192_008&gt;</VoiceId>
      <JapaneseText>……苦労しないでも、ほとんどの魔物に
勝てるくらい強くなってるし……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>8</Id>
