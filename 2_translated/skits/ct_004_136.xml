    <Entry>
      <PointerOffset>45076,45300,45384,45708,45804,45936,46064</PointerOffset>
      <JapaneseText>&lt;Cless&gt;</JapaneseText>
      <EnglishText>&lt;Cless&gt;</EnglishText>
      <Notes/>
