      <Status>Done</Status>
    </Entry>
  </Speakers>
  <Strings>
    <Section>Main</Section>
    <Entry>
      <PointerOffset>44960</PointerOffset>
      <VoiceId>&lt;audio:VCT_004_136_001&gt;</VoiceId>
      <JapaneseText>すげー！！
&lt;Cless&gt;さんめちゃめちゃ素振りはえーな</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>1</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>45080</PointerOffset>
      <VoiceId>&lt;audio:VCT_004_136_002&gt;</VoiceId>
      <JapaneseText>毎日最低三千回素振りすれば、
&lt;Dio&gt;もこれくらい振れるようになるよ</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>2</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>45192</PointerOffset>
      <VoiceId>&lt;audio:VCT_004_136_003&gt;</VoiceId>
      <JapaneseText>えっ。三千回って……
&lt;Cless&gt;さん毎日そんな素振りしてんのか？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>3</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>45304</PointerOffset>
      <VoiceId>&lt;audio:VCT_004_136_004&gt;</VoiceId>
      <JapaneseText>もちろんさ。これだけやっても腕はなまる。
全然足りないんだ</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>4</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>45388</PointerOffset>
      <VoiceId>&lt;audio:VCT_004_136_005&gt;</VoiceId>
      <JapaneseText>だから、素振りは毎日やらないと</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>5</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>45508</PointerOffset>
      <VoiceId>&lt;audio:VCT_004_136_006&gt;</VoiceId>
      <JapaneseText>訓練なんかしないでパーッと派手でカッコイー技、
出したいんだけどな</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>6</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>45612</PointerOffset>
      <VoiceId>&lt;audio:VCT_004_136_007&gt;</VoiceId>
      <JapaneseText>ほら奥義ってゆーの！　魔物をボコボコにできるやつ！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>7</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>45712</PointerOffset>
      <VoiceId>&lt;audio:VCT_004_136_008&gt;</VoiceId>
      <JapaneseText>奥義を出したいんだったら
なおさら基本が大事だよ</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>8</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>45808</PointerOffset>
      <VoiceId>&lt;audio:VCT_004_136_009&gt;</VoiceId>
      <JapaneseText>よし、今から特訓しよう！！
準備はいいかい</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>9</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>45880</PointerOffset>
      <VoiceId>&lt;audio:VCT_004_136_010&gt;</VoiceId>
      <JapaneseText>ちょっ……&lt;Cless&gt;さん</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>10</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>45940</PointerOffset>
      <VoiceId>&lt;audio:VCT_004_136_011&gt;</VoiceId>
      <JapaneseText>いちっ</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>11</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>46000</PointerOffset>
      <VoiceId>&lt;audio:VCT_004_136_012&gt;</VoiceId>
      <JapaneseText>……いち</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>12</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>46068</PointerOffset>
      <VoiceId>&lt;audio:VCT_004_136_013&gt;</VoiceId>
      <JapaneseText>声が小さい！！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>13</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>46164</PointerOffset>
      <VoiceId>&lt;audio:VCT_004_136_014&gt;</VoiceId>
      <JapaneseText>……あーあ……
こんなことになるなんて……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>14</Id>
      <Status>To Do</Status>
    </Entry>
  </Strings>
</SceneText>
