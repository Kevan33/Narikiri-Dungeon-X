    <Entry>
      <PointerOffset>46984</PointerOffset>
      <VoiceId>&lt;audio:VCT_002_037_001&gt;</VoiceId>
      <JapaneseText>&lt;Chester&gt;って、
あんなに気さくな人なんだな</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>1</Id>
      <OldPtr>37432</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>47048</PointerOffset>
      <VoiceId>&lt;audio:VCT_002_037_002&gt;</VoiceId>
      <JapaneseText>どうして？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>2</Id>
      <OldPtr>37648</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>47176</PointerOffset>
      <VoiceId>&lt;audio:VCT_002_037_003&gt;</VoiceId>
      <JapaneseText>目つきが悪くてすごく性格ねじ曲がってて意地悪で、
文句ばっか言ってる人で……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>3</Id>
      <OldPtr>37888</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>47256</PointerOffset>
      <VoiceId>&lt;audio:VCT_002_037_004&gt;</VoiceId>
      <JapaneseText>おいおい、誰のことだよ、それ</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>4</Id>
      <OldPtr>39004</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>47340</PointerOffset>
      <VoiceId>&lt;audio:VCT_002_037_005&gt;</VoiceId>
      <JapaneseText>&lt;Chester&gt;だよ……って、
おわっ！！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>5</Id>
      <OldPtr>39348</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>47428</PointerOffset>
      <VoiceId>&lt;audio:VCT_002_037_006&gt;</VoiceId>
      <JapaneseText>ヒドいな、誰だよ、んなこと言ってんの</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>6</Id>
      <OldPtr>40304</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>47540</PointerOffset>
      <VoiceId>&lt;audio:VCT_002_037_007&gt;</VoiceId>
      <JapaneseText>え？　読んだ本に書いてたぜ。
……おい、出て来いタンス野郎！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>7</Id>
      <OldPtr>40880</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>47684</PointerOffset>
      <VoiceId>&lt;audio:VCT_002_037_008&gt;</VoiceId>
      <JapaneseText>ぬわー！　誰に向かってタンスとか言ってんだ！
いい加減、どつきまわして、ひぃひぃ言わ……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>4</SpeakerId>
      <Id>8</Id>
      <OldPtr>41924</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>47768</PointerOffset>
      <VoiceId>&lt;audio:VCT_002_037_009&gt;</VoiceId>
      <JapaneseText>このへんにあの本しまったよな……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>9</Id>
      <OldPtr>43272</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>47924</PointerOffset>
      <VoiceId>&lt;audio:VCT_002_037_010&gt;</VoiceId>
      <JapaneseText>ぬひゃ……。こ、こら、おめぇ……、何すっだ！　ぐ。
お、おらの……、ひゃは……体ん中、まさぐるでね！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>4</SpeakerId>
      <Id>10</Id>
      <OldPtr>43828</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>48036</PointerOffset>
      <VoiceId>&lt;audio:VCT_002_037_011&gt;</VoiceId>
      <JapaneseText>あったあった、この本……
えっと……作者はＡ・クライン……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>11</Id>
      <OldPtr>45076</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>48128</PointerOffset>
      <VoiceId>&lt;audio:VCT_002_037_012&gt;</VoiceId>
      <JapaneseText>……&lt;Arche&gt;じゃねぇか！　あのヤローっ！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>12</Id>
      <OldPtr>45892</OldPtr>
      <Status>To Do</Status>
    </Entry>
