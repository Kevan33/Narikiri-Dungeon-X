    <Entry>
      <PointerOffset>42580</PointerOffset>
      <VoiceId>&lt;audio:VCT_002_041_001&gt;</VoiceId>
      <JapaneseText>ぼく妖精じゃないのかな……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>1</Id>
      <OldPtr>37320</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>42680</PointerOffset>
      <VoiceId>&lt;audio:VCT_002_041_002&gt;</VoiceId>
      <JapaneseText>オレも妖精ってのは
初めてだからよくわからないな</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>2</Id>
      <OldPtr>37696</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>42768</PointerOffset>
      <VoiceId>&lt;audio:VCT_002_041_003&gt;</VoiceId>
      <JapaneseText>さっきの子が妖精じゃなかったのかも</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>3</Id>
      <OldPtr>37928</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>42888</PointerOffset>
      <VoiceId>&lt;audio:VCT_002_041_004&gt;</VoiceId>
      <JapaneseText>大体、妖精なんて伝説だけで、誰も見た時ねんだろ？
本に書いてあったぜ</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>4</SpeakerId>
      <Id>4</Id>
      <OldPtr>38164</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>42996</PointerOffset>
      <VoiceId>&lt;audio:VCT_002_041_005&gt;</VoiceId>
      <JapaneseText>人よりちっこくて、羽根が生えてるってしか
わかんないって</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>4</SpeakerId>
      <Id>5</Id>
      <OldPtr>38568</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>43112</PointerOffset>
      <VoiceId>&lt;audio:VCT_002_041_006&gt;</VoiceId>
      <JapaneseText>じゃあ、小さくて羽根があったら、
全部妖精に当てはまるってこと？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>6</Id>
      <OldPtr>39384</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>43220</PointerOffset>
      <VoiceId>&lt;audio:VCT_002_041_007&gt;</VoiceId>
      <JapaneseText>それって妖精って結局、
何なのかわかんないってことだよな</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>7</Id>
      <OldPtr>40200</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>43332</PointerOffset>
      <VoiceId>&lt;audio:VCT_002_041_008&gt;</VoiceId>
      <JapaneseText>じゃあ、エトもさっきの子も
妖精じゃない可能性があるんだ……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>8</Id>
      <OldPtr>40968</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>43448</PointerOffset>
      <VoiceId>&lt;audio:VCT_002_041_009&gt;</VoiceId>
      <JapaneseText>だから、エトが妖精じゃなくても
何も変わんないって、言ってんだろ</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>4</SpeakerId>
      <Id>9</Id>
      <OldPtr>41372</OldPtr>
      <Status>To Do</Status>
    </Entry>
