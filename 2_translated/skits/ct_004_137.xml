    </Entry>
    <Entry>
      <PointerOffset>45732</PointerOffset>
      <VoiceId>&lt;audio:VCT_004_137_002&gt;</VoiceId>
      <JapaneseText>やあっ！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>2</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>45800</PointerOffset>
      <VoiceId>&lt;audio:VCT_004_137_003&gt;</VoiceId>
      <JapaneseText>もっと左か……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>3</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>45884</PointerOffset>
      <VoiceId>&lt;audio:VCT_004_137_004&gt;</VoiceId>
      <JapaneseText>&lt;Chester&gt;さん一生懸命練習してるね</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>4</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>45952</PointerOffset>
      <VoiceId>&lt;audio:VCT_004_137_005&gt;</VoiceId>
      <JapaneseText>クルルール！！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>5</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>46044</PointerOffset>
      <VoiceId>&lt;audio:VCT_004_137_006&gt;</VoiceId>
      <JapaneseText>時空戦士なのに、いまだに特訓してんだな</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>4</SpeakerId>
      <Id>6</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>46136</PointerOffset>
      <VoiceId>&lt;audio:VCT_004_137_007&gt;</VoiceId>
      <JapaneseText>&lt;Chester&gt;……は自分が弱いって思ってるんだ</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>5</SpeakerId>
      <Id>7</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>46224</PointerOffset>
      <VoiceId>&lt;audio:VCT_004_137_008&gt;</VoiceId>
      <JapaneseText>もちろん、そんなことはないんだけどね</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>5</SpeakerId>
      <Id>8</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>46312</PointerOffset>
      <VoiceId>&lt;audio:VCT_004_137_009&gt;</VoiceId>
      <JapaneseText>&lt;Chester&gt;さんには何度も助けられました</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>6</SpeakerId>
      <Id>9</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>46436</PointerOffset>
      <VoiceId>&lt;audio:VCT_004_137_010&gt;</VoiceId>
      <JapaneseText>&lt;Chester&gt;そっかー。見てたらやる気になってきた。
オレもなんかやってやるぞ！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>4</SpeakerId>
      <Id>10</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>46500</PointerOffset>
      <VoiceId>&lt;audio:VCT_004_137_011&gt;</VoiceId>
      <JapaneseText>クルール！！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>11</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>46608</PointerOffset>
      <VoiceId>&lt;audio:VCT_004_137_012&gt;</VoiceId>
      <JapaneseText>&lt;Dio&gt;なんかって何するの。
もうったら！　待ってってば！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>12</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>46688</PointerOffset>
      <VoiceId>&lt;audio:VCT_004_137_013&gt;</VoiceId>
      <JapaneseText>あの子たちの今後が楽しみだね</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>5</SpeakerId>
      <Id>13</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>46756</PointerOffset>
      <VoiceId>&lt;audio:VCT_004_137_014&gt;</VoiceId>
      <JapaneseText>ええ、そうですね</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>6</SpeakerId>
      <Id>14</Id>
      <Status>To Do</Status>
    </Entry>
