    <Entry>
      <PointerOffset>44716</PointerOffset>
      <VoiceId>&lt;audio:VCT_005_175_001&gt;</VoiceId>
      <JapaneseText>はぐはぐはぐ……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>1</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>44824</PointerOffset>
      <VoiceId>&lt;audio:VCT_005_175_002&gt;</VoiceId>
      <JapaneseText>また食ってんのか、おまえ。
さっき昼飯食ったばっかだろ？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>2</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>44900</PointerOffset>
      <VoiceId>&lt;audio:VCT_005_175_003&gt;</VoiceId>
      <JapaneseText>これはデザートなの、ね？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>3</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>45008</PointerOffset>
      <VoiceId>&lt;audio:VCT_005_175_004&gt;</VoiceId>
      <JapaneseText>そうそう、甘いものはお昼ご飯とは
別のところに入るんだよ</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>4</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>45112</PointerOffset>
      <VoiceId>&lt;audio:VCT_005_175_005&gt;</VoiceId>
      <JapaneseText>だから、少しくらいおなかいっぱいでも
食べられるんだ</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>5</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>45204</PointerOffset>
      <VoiceId>&lt;audio:VCT_005_175_006&gt;</VoiceId>
      <JapaneseText>食えるとか食えないとかってよりさあ……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>6</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>45276</PointerOffset>
      <VoiceId>&lt;audio:VCT_005_175_007&gt;</VoiceId>
      <JapaneseText>……また体重増えるぜ</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>7</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>45352</PointerOffset>
      <VoiceId>&lt;audio:VCT_005_175_008&gt;</VoiceId>
      <JapaneseText>……あ、いってぇ……！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>8</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>45448</PointerOffset>
      <VoiceId>&lt;audio:VCT_005_175_009&gt;</VoiceId>
      <JapaneseText>だから、それは繊細な乙女には
禁句だってば</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>4</SpeakerId>
      <Id>9</Id>
      <Status>To Do</Status>
    </Entry>
