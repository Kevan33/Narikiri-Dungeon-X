    <Entry>
      <PointerOffset>54368</PointerOffset>
      <VoiceId>&lt;audio:VCT_002_076_001&gt;</VoiceId>
      <JapaneseText>はっ……今気付いたんだけど、
なんか今オレらすげーこと経験してねーか？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>1</Id>
      <OldPtr>38216</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>54436</PointerOffset>
      <VoiceId>&lt;audio:VCT_002_076_002&gt;</VoiceId>
      <JapaneseText>すごい、こと？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>2</Id>
      <OldPtr>38888</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>54552</PointerOffset>
      <VoiceId>&lt;audio:VCT_002_076_003&gt;</VoiceId>
      <JapaneseText>時空戦士全員と一緒に旅してるんだぜ。
これってすごいことだよ！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>3</Id>
      <OldPtr>39196</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>54668</PointerOffset>
      <VoiceId>&lt;audio:VCT_002_076_004&gt;</VoiceId>
      <JapaneseText>僕たちはずっとみんなで
一緒に旅してたからそうでもないけど……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>4</Id>
      <OldPtr>40060</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>54792</PointerOffset>
      <VoiceId>&lt;audio:VCT_002_076_005&gt;</VoiceId>
      <JapaneseText>でもそう言われてみると、感動が、
心の奥から少しずつ湧いてくる気がするね</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>4</SpeakerId>
      <Id>5</Id>
      <OldPtr>40172</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>54908</PointerOffset>
      <VoiceId>&lt;audio:VCT_002_076_006&gt;</VoiceId>
      <JapaneseText>ユニット『美女魔女&lt;Arche&gt;とその仲間たちと
小さな英雄たち』だね</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>5</SpeakerId>
      <Id>6</Id>
      <OldPtr>40996</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>54992</PointerOffset>
      <VoiceId>&lt;audio:VCT_002_076_007&gt;</VoiceId>
      <JapaneseText>異議あり！！　アホか、おまえは！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>6</SpeakerId>
      <Id>7</Id>
      <OldPtr>42092</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>55068</PointerOffset>
      <VoiceId>&lt;audio:VCT_002_076_008&gt;</VoiceId>
      <JapaneseText>アホとは何よ、アホとは！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>5</SpeakerId>
      <Id>8</Id>
      <OldPtr>43748</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>55172</PointerOffset>
      <VoiceId>&lt;audio:VCT_002_076_009&gt;</VoiceId>
      <JapaneseText>でも、びしっと決まるチーム名みたいなのが
ほしいよね</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>9</Id>
      <OldPtr>44452</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>55260</PointerOffset>
      <VoiceId>&lt;audio:VCT_002_076_010&gt;</VoiceId>
      <JapaneseText>チーム名ね……ま、私は何でもいいが</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>7</SpeakerId>
      <Id>10</Id>
      <OldPtr>45176</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>55344</PointerOffset>
      <VoiceId>&lt;audio:VCT_002_076_011&gt;</VoiceId>
      <JapaneseText>『時空戦士』ではいけませんか？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>8</SpeakerId>
      <Id>11</Id>
      <OldPtr>45972</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>55448</PointerOffset>
      <VoiceId>&lt;audio:VCT_002_076_012&gt;</VoiceId>
      <JapaneseText>時間を移動していない私も
時空戦士でいいのでしょうか</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>9</SpeakerId>
      <Id>12</Id>
      <OldPtr>46304</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>55520</PointerOffset>
      <VoiceId>&lt;audio:VCT_002_076_013&gt;</VoiceId>
      <JapaneseText>そう言えばそうだね</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>13</Id>
      <OldPtr>47132</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>55632</PointerOffset>
      <VoiceId>&lt;audio:VCT_002_076_014&gt;</VoiceId>
      <JapaneseText>それじゃあ、ここはその双子ちゃんに
決めてもらおうじゃないの</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>10</SpeakerId>
      <Id>14</Id>
      <OldPtr>47244</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>55716</PointerOffset>
      <VoiceId>&lt;audio:VCT_002_076_015&gt;</VoiceId>
      <JapaneseText>え？　わ、わたしたちにですか？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>4</SpeakerId>
      <Id>15</Id>
      <OldPtr>48256</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>55800</PointerOffset>
      <VoiceId>&lt;audio:VCT_002_076_016&gt;</VoiceId>
      <JapaneseText>オレら、勇気凛々胸いっぱい団だ！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>16</Id>
      <OldPtr>48860</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>55920</PointerOffset>
      <VoiceId>&lt;audio:VCT_002_076_017&gt;</VoiceId>
      <JapaneseText>それじゃダメだよ、名乗りをあげるときに、
ずばっと言いやすくないと！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>4</SpeakerId>
      <Id>17</Id>
      <OldPtr>49476</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>56004</PointerOffset>
      <VoiceId>&lt;audio:VCT_002_076_018&gt;</VoiceId>
      <JapaneseText>それじゃあ、どんなのにするんだよ</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>18</Id>
      <OldPtr>50300</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>56104</PointerOffset>
      <VoiceId>&lt;audio:VCT_002_076_019&gt;</VoiceId>
      <JapaneseText>え、えっと……
フェアリー☆サークル、とか……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>4</SpeakerId>
      <Id>19</Id>
      <OldPtr>50608</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>56184</PointerOffset>
      <VoiceId>&lt;audio:VCT_002_076_020&gt;</VoiceId>
      <JapaneseText>なんだよ、サークルって……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>20</Id>
      <OldPtr>51752</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>56276</PointerOffset>
      <VoiceId>&lt;audio:VCT_002_076_021&gt;</VoiceId>
      <JapaneseText>んじゃあ、次の会議まで
決めておくこと！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>10</SpeakerId>
      <Id>21</Id>
      <OldPtr>51984</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>56352</PointerOffset>
      <VoiceId>&lt;audio:VCT_002_076_022&gt;</VoiceId>
      <JapaneseText>……次の会議って何だ……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>6</SpeakerId>
      <Id>22</Id>
      <OldPtr>52824</OldPtr>
      <Status>To Do</Status>
    </Entry>
