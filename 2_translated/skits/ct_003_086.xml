  <Strings>
    <Section>Main</Section>
    <Entry>
      <PointerOffset>43440</PointerOffset>
      <VoiceId>&lt;audio:VCT_003_086_001&gt;</VoiceId>
      <JapaneseText>街もないし、人もいない……
なんか気味が悪いね、暗黒時空って……</JapaneseText>
      <EnglishText>There are no towns or people... I sense a strong feeling of enmity everywhere... So this is the Darkened Time-Space...</EnglishText>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>1</Id>
      <Status>Editing</Status>
    </Entry>
    <Entry>
      <PointerOffset>43508</PointerOffset>
      <VoiceId>&lt;audio:VCT_003_086_002&gt;</VoiceId>
      <JapaneseText>真っ暗だしな……</JapaneseText>
      <EnglishText>It's so damn pitch-black everywhere...</EnglishText>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>2</Id>
      <Status>Editing</Status>
    </Entry>
    <Entry>
      <PointerOffset>43576</PointerOffset>
      <VoiceId>&lt;audio:VCT_003_086_003&gt;</VoiceId>
      <JapaneseText>暗いの、怖いの？</JapaneseText>
      <EnglishText>Are you scared of the dark?</EnglishText>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>3</Id>
      <Status>Editing</Status>
    </Entry>
    <Entry>
      <PointerOffset>43648</PointerOffset>
      <VoiceId>&lt;audio:VCT_003_086_004&gt;</VoiceId>
      <JapaneseText>怖くなんてねーよ？</JapaneseText>
      <EnglishText>I'm not scared!!</EnglishText>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>4</Id>
      <Status>Editing</Status>
    </Entry>
    <Entry>
      <PointerOffset>43712</PointerOffset>
      <VoiceId>&lt;audio:VCT_003_086_005&gt;</VoiceId>
      <JapaneseText>うふふ……</JapaneseText>
      <EnglishText>Hehehe...</EnglishText>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>5</Id>
      <Status>Editing</Status>
    </Entry>
    <Entry>
      <PointerOffset>43780</PointerOffset>
      <VoiceId>&lt;audio:VCT_003_086_006&gt;</VoiceId>
      <JapaneseText>な、なんだよ……</JapaneseText>
      <EnglishText>What's so funny?</EnglishText>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>6</Id>
      <Status>Editing</Status>
    </Entry>
    <Entry>
      <PointerOffset>43896</PointerOffset>
      <VoiceId>&lt;audio:VCT_003_086_007&gt;</VoiceId>
      <JapaneseText>夜中に一人じゃトイレに行けない
って言ってたのを思い出しちゃった</JapaneseText>
      <EnglishText>I just remembered when you couldn't go to the bathroom by yourself at night.</EnglishText>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>7</Id>
      <Status>Editing</Status>
    </Entry>
    <Entry>
      <PointerOffset>43968</PointerOffset>
      <VoiceId>&lt;audio:VCT_003_086_008&gt;</VoiceId>
      <JapaneseText>メ、&lt;Mel&gt;だろ、それ</JapaneseText>
      <EnglishText>T-that was &lt;Mel&gt;!</EnglishText>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>8</Id>
      <Status>Editing</Status>
    </Entry>
    <Entry>
      <PointerOffset>44040</PointerOffset>
      <VoiceId>&lt;audio:VCT_003_086_009&gt;</VoiceId>
      <JapaneseText>わたしじゃないよ？</JapaneseText>
      <EnglishText>No it wasn't!</EnglishText>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>9</Id>
      <Status>Editing</Status>
    </Entry>
    <Entry>
      <PointerOffset>44144</PointerOffset>
      <VoiceId>&lt;audio:VCT_003_086_010&gt;</VoiceId>
      <JapaneseText>&lt;Mel&gt;は暗くなると興奮して
寝つけなかった方だもんね</JapaneseText>
      <EnglishText>&lt;Mel&gt; couldn't sleep at night sometimes because she'd be too agitated.</EnglishText>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>10</Id>
      <Status>Editing</Status>
    </Entry>
    <Entry>
      <PointerOffset>44228</PointerOffset>
      <VoiceId>&lt;audio:VCT_003_086_011&gt;</VoiceId>
      <JapaneseText>え？　え？
そ、そうだったかな？</JapaneseText>
      <EnglishText>W-what!? That can't be true!</EnglishText>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>11</Id>
      <Status>Editing</Status>
    </Entry>
  </Strings>
