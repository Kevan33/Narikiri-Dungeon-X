  <Strings>
    <Section>Main</Section>
    <Entry>
      <PointerOffset>46960</PointerOffset>
      <VoiceId>&lt;audio:VCT_004_167_001&gt;</VoiceId>
      <JapaneseText>やった！　やったぜ、ついに！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>1</Id>
      <OldPtr>37360</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>47036</PointerOffset>
      <VoiceId>&lt;audio:VCT_004_167_002&gt;</VoiceId>
      <JapaneseText>クルルン！　クルルン！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>2</Id>
      <OldPtr>38024</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>47144</PointerOffset>
      <VoiceId>&lt;audio:VCT_004_167_003&gt;</VoiceId>
      <JapaneseText>すごいね、&lt;Dio&gt;！
全コスチュームをマスターするなんて！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>3</Id>
      <OldPtr>38364</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>47244</PointerOffset>
      <VoiceId>&lt;audio:VCT_004_167_004&gt;</VoiceId>
      <JapaneseText>へへ～～～ん、オレに掛かりゃ、こんなもんだっての</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>4</Id>
      <OldPtr>38960</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>47324</PointerOffset>
      <VoiceId>&lt;audio:VCT_004_167_005&gt;</VoiceId>
      <JapaneseText>見たか！　このタンス野郎が！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>5</Id>
      <OldPtr>39476</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>47412</PointerOffset>
      <VoiceId>&lt;audio:VCT_004_167_006&gt;</VoiceId>
      <JapaneseText>へん、すごすぎて、言葉もないってか？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>6</Id>
      <OldPtr>40288</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>47560</PointerOffset>
      <VoiceId>&lt;audio:VCT_004_167_007&gt;</VoiceId>
      <JapaneseText>ったく、ギャーギャーうるせーのがおるだ。
そったらことで大騒ぎするなんて、器が小せぇ証拠だど</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>4</SpeakerId>
      <Id>7</Id>
      <OldPtr>41024</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>47692</PointerOffset>
      <VoiceId>&lt;audio:VCT_004_167_008&gt;</VoiceId>
      <JapaneseText>おらだったら、サラッと流すだーよ。
大人っていうのは、そういうもんだ、ふん</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>4</SpeakerId>
      <Id>8</Id>
      <OldPtr>42788</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>47800</PointerOffset>
      <VoiceId>&lt;audio:VCT_004_167_009&gt;</VoiceId>
      <JapaneseText>へん！　くやしくてしょうがねーって、
顔に書いてあんぜ！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>9</Id>
      <OldPtr>43924</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>47968</PointerOffset>
      <VoiceId>&lt;audio:VCT_004_167_010&gt;</VoiceId>
      <JapaneseText>だ！　え？　ど、ど、どったらとこに、書いてあるだ！
け、け、け、消す、今すぐ消すだ！　早く、早く！　ど、どこ！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>4</SpeakerId>
      <Id>10</Id>
      <OldPtr>44528</OldPtr>
      <Status>To Do</Status>
    </Entry>
