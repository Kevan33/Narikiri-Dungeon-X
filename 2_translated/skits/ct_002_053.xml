    <Entry>
      <PointerOffset>45316</PointerOffset>
      <VoiceId>&lt;audio:VCT_002_053_001&gt;</VoiceId>
      <JapaneseText>声を聞いただけで、ルナ様の美しさはわかっただ。
戦わねーとわかって、覗いて見たおらは勝ち組だーよ</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>1</Id>
      <OldPtr>37832</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>45440</PointerOffset>
      <VoiceId>&lt;audio:VCT_002_053_002&gt;</VoiceId>
      <JapaneseText>いやー、この世界には、こったらべっぴんさんが
多いの多くねーのって</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>2</Id>
      <OldPtr>39184</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>45564</PointerOffset>
      <VoiceId>&lt;audio:VCT_002_053_003&gt;</VoiceId>
      <JapaneseText>ましてや精霊様だなんて神秘的過ぎて、
おらもう興奮のるつぼだーよ！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>3</Id>
      <OldPtr>39564</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>45720</PointerOffset>
      <VoiceId>&lt;audio:VCT_002_053_004&gt;</VoiceId>
      <JapaneseText>問題はあの、アルテなんちゃらってちっこいヤツだ。
あれはエト助に任せて、その間におらがルナ様に……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>4</Id>
      <OldPtr>40776</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>45840</PointerOffset>
      <VoiceId>&lt;audio:VCT_002_053_005&gt;</VoiceId>
      <JapaneseText>ぐふ……、ぐふふ……、ぐふふふ……。
ふふふ…………………、ふぅ</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>5</Id>
      <OldPtr>41976</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>45908</PointerOffset>
      <VoiceId>&lt;audio:VCT_002_053_006&gt;</VoiceId>
      <JapaneseText>どうしたのエト？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>6</Id>
      <OldPtr>43816</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>46000</PointerOffset>
      <VoiceId>&lt;audio:VCT_002_053_007&gt;</VoiceId>
      <JapaneseText>う……ううん……なんか寒気がしたかラ……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>7</Id>
      <OldPtr>44136</OldPtr>
      <Status>To Do</Status>
    </Entry>
