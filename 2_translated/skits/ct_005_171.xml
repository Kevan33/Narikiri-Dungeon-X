    <Entry>
      <PointerOffset>42904</PointerOffset>
      <VoiceId>&lt;audio:VCT_005_171_001&gt;</VoiceId>
      <JapaneseText>うぇ……トマト嫌い……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>1</Id>
      <OldPtr>37300</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>43008</PointerOffset>
      <VoiceId>&lt;audio:VCT_005_171_002&gt;</VoiceId>
      <JapaneseText>&lt;Dio&gt;、ちゃんと野菜も食べないと
大きくなれないよ</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>2</Id>
      <OldPtr>37764</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>43104</PointerOffset>
      <VoiceId>&lt;audio:VCT_005_171_003&gt;</VoiceId>
      <JapaneseText>野菜ばっか食ってたら
キリギリスになるっての</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>3</Id>
      <OldPtr>38064</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>43204</PointerOffset>
      <VoiceId>&lt;audio:VCT_005_171_004&gt;</VoiceId>
      <JapaneseText>肉ばっか食べてたら、
ハゲワシみたいになるよっ</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>4</Id>
      <OldPtr>38452</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>43324</PointerOffset>
      <VoiceId>&lt;audio:VCT_005_171_005&gt;</VoiceId>
      <JapaneseText>なんでだよ。なるんだったら、
トラとかライオンとかかっこいいヤツだろ</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>5</Id>
      <OldPtr>38840</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>43432</PointerOffset>
      <VoiceId>&lt;audio:VCT_005_171_006&gt;</VoiceId>
      <JapaneseText>草食べるのもキリンとかシカとか
かっこいいやついるでしょ</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>6</Id>
      <OldPtr>39428</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>43516</PointerOffset>
      <VoiceId>&lt;audio:VCT_005_171_007&gt;</VoiceId>
      <JapaneseText>キリンよりもなるならライオンだ！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>7</Id>
      <OldPtr>40004</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>43616</PointerOffset>
      <VoiceId>&lt;audio:VCT_005_171_008&gt;</VoiceId>
      <JapaneseText>なんでもいいから、
作ったものは最後まで食べて</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>8</Id>
      <OldPtr>40828</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>43676</PointerOffset>
      <VoiceId>&lt;audio:VCT_005_171_009&gt;</VoiceId>
      <JapaneseText>はい……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>9</Id>
      <OldPtr>42064</OldPtr>
      <Status>To Do</Status>
    </Entry>
