  <Strings>
    <Section>Main</Section>
    <Entry>
      <PointerOffset>42476</PointerOffset>
      <VoiceId>&lt;audio:VCT_001_011_001&gt;</VoiceId>
      <JapaneseText>&lt;Dio&gt;、初対面の人には
ちゃんと挨拶しなきゃ</JapaneseText>
      <EnglishText>&lt;Dio&gt;, you should always greet people when you first meet them.</EnglishText>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>1</Id>
      <Status>Editing</Status>
    </Entry>
    <Entry>
      <PointerOffset>42548</PointerOffset>
      <VoiceId>&lt;audio:VCT_001_011_002&gt;</VoiceId>
      <JapaneseText>え？　してるだろ？</JapaneseText>
      <EnglishText>Huh? I know that, already.</EnglishText>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>2</Id>
      <Status>Editing</Status>
    </Entry>
    <Entry>
      <PointerOffset>42612</PointerOffset>
      <VoiceId>&lt;audio:VCT_001_011_003&gt;</VoiceId>
      <JapaneseText>してないよ</JapaneseText>
      <EnglishText>No, you don't!</EnglishText>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>3</Id>
      <Status>Editing</Status>
    </Entry>
    <Entry>
      <PointerOffset>42688</PointerOffset>
      <VoiceId>&lt;audio:VCT_001_011_004&gt;</VoiceId>
      <JapaneseText>&lt;Klarth&gt;さんとこでもさ……</JapaneseText>
      <EnglishText>At &lt;Klarth&gt;'s place I, um...</EnglishText>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>4</Id>
      <Status>Editing</Status>
    </Entry>
    <Entry>
      <PointerOffset>42780</PointerOffset>
      <VoiceId>&lt;audio:VCT_001_011_005&gt;</VoiceId>
      <JapaneseText>ずっと&lt;Mel&gt;が&lt;Klarth&gt;さんと
話してたよね</JapaneseText>
      <EnglishText>&lt;Mel&gt; was the one who did all the talking.</EnglishText>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>5</Id>
      <Status>Editing</Status>
    </Entry>
    <Entry>
      <PointerOffset>42900</PointerOffset>
      <VoiceId>&lt;audio:VCT_001_011_006&gt;</VoiceId>
      <JapaneseText>さっき、&lt;Klarth&gt;さんちの前で会った人にも
『あんた誰』とか言ってたし</JapaneseText>
      <EnglishText>And then when we were outside Mister &lt;Klarth&gt;'s house we met someone. You really greeted him politely saying "And just who do you think you are?" don't you think?</EnglishText>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>6</Id>
      <Status>Editing</Status>
    </Entry>
    <Entry>
      <PointerOffset>42992</PointerOffset>
      <VoiceId>&lt;audio:VCT_001_011_007&gt;</VoiceId>
      <JapaneseText>あ、あれは
怪しいヤツだったから……！</JapaneseText>
      <EnglishText>W-well, he looked kinda suspicious so...</EnglishText>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>7</Id>
      <Status>Editing</Status>
    </Entry>
    <Entry>
      <PointerOffset>43092</PointerOffset>
      <VoiceId>&lt;audio:VCT_001_011_008&gt;</VoiceId>
      <JapaneseText>話をしないうちから、
怪しいとか決めつけないの</JapaneseText>
      <EnglishText>Didn't we agree you shouldn't try talking to suspicious people?</EnglishText>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>8</Id>
      <Status>Editing</Status>
    </Entry>
    <Entry>
      <PointerOffset>43152</PointerOffset>
      <VoiceId>&lt;audio:VCT_001_011_009&gt;</VoiceId>
      <JapaneseText>…………</JapaneseText>
      <EnglishText>...</EnglishText>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>9</Id>
      <Status>Editing</Status>
    </Entry>
    <Entry>
      <PointerOffset>43224</PointerOffset>
      <VoiceId>&lt;audio:VCT_001_011_010&gt;</VoiceId>
      <JapaneseText>なんで黙ってるの？</JapaneseText>
      <EnglishText>Why are you so silent?</EnglishText>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>10</Id>
      <Status>Editing</Status>
    </Entry>
    <Entry>
      <PointerOffset>43292</PointerOffset>
      <VoiceId>&lt;audio:VCT_001_011_011&gt;</VoiceId>
      <JapaneseText>なんでもねーよ</JapaneseText>
      <EnglishText>Nothing you should care about.</EnglishText>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>11</Id>
      <Status>Editing</Status>
    </Entry>
    <Entry>
      <PointerOffset>43352</PointerOffset>
      <VoiceId>&lt;audio:VCT_001_011_012&gt;</VoiceId>
      <JapaneseText>ヘンなの</JapaneseText>
      <EnglishText>What a weird kid!</EnglishText>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>12</Id>
      <Status>Editing</Status>
    </Entry>
    <Entry>
      <PointerOffset>43416</PointerOffset>
      <VoiceId>&lt;audio:VCT_001_011_013&gt;</VoiceId>
      <JapaneseText>お年頃だね</JapaneseText>
      <EnglishText>It looks he already hit puberty.</EnglishText>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>13</Id>
      <Status>Editing</Status>
    </Entry>
    <Entry>
      <PointerOffset>43492</PointerOffset>
      <VoiceId>&lt;audio:VCT_001_011_014&gt;</VoiceId>
      <JapaneseText>…………？　そうなの？</JapaneseText>
      <EnglishText>Eh? Really? I don't see it.</EnglishText>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>14</Id>
      <Status>Editing</Status>
    </Entry>
    <Entry>
      <PointerOffset>43560</PointerOffset>
      <VoiceId>&lt;audio:VCT_001_011_015&gt;</VoiceId>
      <JapaneseText>そういうお年頃</JapaneseText>
      <EnglishText>That's what puberty is like.</EnglishText>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>15</Id>
      <Status>Editing</Status>
    </Entry>
    <Entry>
      <PointerOffset>43624</PointerOffset>
      <VoiceId>&lt;audio:VCT_001_011_016&gt;</VoiceId>
      <JapaneseText>ふーん……？</JapaneseText>
      <EnglishText>Mmm...?</EnglishText>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>16</Id>
      <Status>Editing</Status>
    </Entry>
  </Strings>
</SceneText>
