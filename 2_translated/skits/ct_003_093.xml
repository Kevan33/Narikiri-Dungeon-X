    <Entry>
      <PointerOffset>43436</PointerOffset>
      <VoiceId>&lt;audio:VCT_003_093_001&gt;</VoiceId>
      <JapaneseText>&lt;Mel&gt;、さっき……何があったの？
あの地下の通路で……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>1</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>43540</PointerOffset>
      <VoiceId>&lt;audio:VCT_003_093_002&gt;</VoiceId>
      <JapaneseText>うん……でも今は自分でも
まだよくわかってないんだ</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>2</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>43620</PointerOffset>
      <VoiceId>&lt;audio:VCT_003_093_003&gt;</VoiceId>
      <JapaneseText>わかったら、ちゃんと話すね</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>3</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>43684</PointerOffset>
      <VoiceId>&lt;audio:VCT_003_093_004&gt;</VoiceId>
      <JapaneseText>……そっか</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>4</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>43748</PointerOffset>
      <VoiceId>&lt;audio:VCT_003_093_005&gt;</VoiceId>
      <JapaneseText>………………</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>5</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>43824</PointerOffset>
      <VoiceId>&lt;audio:VCT_003_093_006&gt;</VoiceId>
      <JapaneseText>エトちゃん、元気出して</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>6</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>43896</PointerOffset>
      <VoiceId>&lt;audio:VCT_003_093_007&gt;</VoiceId>
      <JapaneseText>ううん、大丈夫だよ</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>7</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>44036</PointerOffset>
      <VoiceId>&lt;audio:VCT_003_093_008&gt;</VoiceId>
      <JapaneseText>&lt;Mel&gt;前のなら、ぼくを心配させないように
こういう時、なんでもないよって言ってたんだけド</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>8</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>44108</PointerOffset>
      <VoiceId>&lt;audio:VCT_003_093_009&gt;</VoiceId>
      <JapaneseText>ちょっぴり成長した？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>9</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>44224</PointerOffset>
      <VoiceId>&lt;audio:VCT_003_093_010&gt;</VoiceId>
      <JapaneseText>うん、だから、ちょっぴり嬉しい。
けど、ちょっぴり寂しいよ……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>10</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>44316</PointerOffset>
      <VoiceId>&lt;audio:VCT_003_093_011&gt;</VoiceId>
      <JapaneseText>心配させてほしい？
『お母さん』としては</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>11</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>44380</PointerOffset>
      <VoiceId>&lt;audio:VCT_003_093_012&gt;</VoiceId>
      <JapaneseText>うーん……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>12</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>44444</PointerOffset>
      <VoiceId>&lt;audio:VCT_003_093_013&gt;</VoiceId>
      <JapaneseText>……微妙かも</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>13</Id>
      <Status>To Do</Status>
    </Entry>
