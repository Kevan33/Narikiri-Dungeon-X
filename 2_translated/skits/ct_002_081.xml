    <Entry>
      <PointerOffset>40556</PointerOffset>
      <VoiceId>&lt;audio:VCT_002_081_001&gt;</VoiceId>
      <JapaneseText>……『音』の精霊って
何ができるのかな？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>1</Id>
      <OldPtr>37020</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>40660</PointerOffset>
      <VoiceId>&lt;audio:VCT_002_081_002&gt;</VoiceId>
      <JapaneseText>『音』を操ったり……？
でも、ぼく音痴なんだけド……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>2</Id>
      <OldPtr>37252</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>40744</PointerOffset>
      <VoiceId>&lt;audio:VCT_002_081_003&gt;</VoiceId>
      <JapaneseText>あ、記憶が封印されてるからかな？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>3</Id>
      <OldPtr>37756</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>40872</PointerOffset>
      <VoiceId>&lt;audio:VCT_002_081_004&gt;</VoiceId>
      <JapaneseText>歌が上手くなったら、&lt;Dio&gt;と&lt;Mel&gt;に
すてきな子守唄を歌ってあげられるかも♪</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>4</Id>
      <OldPtr>38080</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>40964</PointerOffset>
      <VoiceId>&lt;audio:VCT_002_081_005&gt;</VoiceId>
      <JapaneseText>……ふたりとも子守唄って
歳でもないか</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>5</Id>
      <OldPtr>38812</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>41052</PointerOffset>
      <VoiceId>&lt;audio:VCT_002_081_006&gt;</VoiceId>
      <JapaneseText>……うーん……
全然、わかんないや</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>6</Id>
      <OldPtr>39044</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>41144</PointerOffset>
      <VoiceId>&lt;audio:VCT_002_081_007&gt;</VoiceId>
      <JapaneseText>……別に今のままでも
不便はないけド……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>7</Id>
      <OldPtr>39548</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>41220</PointerOffset>
      <VoiceId>&lt;audio:VCT_002_081_008&gt;</VoiceId>
      <JapaneseText>やっぱり、気になる、な</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>8</Id>
      <OldPtr>39780</OldPtr>
      <Status>To Do</Status>
