  </Speakers>
  <Strings>
    <Section>Main</Section>
    <Entry>
      <PointerOffset>46788</PointerOffset>
      <VoiceId>&lt;audio:VCT_002_040_001&gt;</VoiceId>
      <JapaneseText>アミィと間違えるなんてな……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>1</Id>
      <OldPtr>37132</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>46872</PointerOffset>
      <VoiceId>&lt;audio:VCT_002_040_002&gt;</VoiceId>
      <JapaneseText>アミィって、おめぇの妹だか？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>2</Id>
      <OldPtr>37336</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>46948</PointerOffset>
      <VoiceId>&lt;audio:VCT_002_040_003&gt;</VoiceId>
      <JapaneseText>あ、ああ、そうだよ……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>3</Id>
      <OldPtr>37880</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>47036</PointerOffset>
      <VoiceId>&lt;audio:VCT_002_040_004&gt;</VoiceId>
      <JapaneseText>ほぇ～～～、おめぇに妹がなぁ～～</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>4</Id>
      <OldPtr>38252</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>47124</PointerOffset>
      <VoiceId>&lt;audio:VCT_002_040_005&gt;</VoiceId>
      <JapaneseText>な、なんだよ！　人の顔ジロジロ見て</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>5</Id>
      <OldPtr>39116</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>47264</PointerOffset>
      <VoiceId>&lt;audio:VCT_002_040_006&gt;</VoiceId>
      <JapaneseText>おめぇみてーなキツネ目の妹っつーことは、
そのアミィっての、名前に合った顔なんだなや</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>6</Id>
      <OldPtr>39612</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>47372</PointerOffset>
      <VoiceId>&lt;audio:VCT_002_040_007&gt;</VoiceId>
      <JapaneseText>なんだよ、それ。
アミィが俺に似てるって言いたいのか？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>7</Id>
      <OldPtr>40504</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>47504</PointerOffset>
      <VoiceId>&lt;audio:VCT_002_040_008&gt;</VoiceId>
      <JapaneseText>みなまで言わんでええだ、ええだ。
おめぇの顔見てれば、ぜぇ～んぶわかるだよ</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>8</Id>
      <OldPtr>40884</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>47648</PointerOffset>
      <VoiceId>&lt;audio:VCT_002_040_009&gt;</VoiceId>
      <JapaneseText>おめぇはかわいい妹が欲しかったんだ。
だから、さっき&lt;Mel&gt;&lt;Mel&gt;をわざと間違えたんだど？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>9</Id>
      <OldPtr>42024</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>47728</PointerOffset>
      <VoiceId>&lt;audio:VCT_002_040_010&gt;</VoiceId>
      <JapaneseText>バカ言ってんじゃねぇっての</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>10</Id>
      <OldPtr>43288</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>47868</PointerOffset>
      <VoiceId>&lt;audio:VCT_002_040_011&gt;</VoiceId>
      <JapaneseText>あひゃえ！　当たっただ！　図星だ！！
こいつ、&lt;Mel&gt;&lt;Mel&gt;を狙ってる変態だーよ！！！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>11</Id>
      <OldPtr>43884</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>47956</PointerOffset>
      <VoiceId>&lt;audio:VCT_002_040_012&gt;</VoiceId>
      <JapaneseText>あのなぁ……そりゃ、おまえだろ……？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>12</Id>
      <OldPtr>45560</OldPtr>
      <Status>To Do</Status>
    </Entry>
  </Strings>
