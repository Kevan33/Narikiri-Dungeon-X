  </Speakers>
  <Strings>
    <Section>Main</Section>
    <Entry>
      <PointerOffset>43612</PointerOffset>
      <VoiceId>&lt;audio:VCT_005_191_001&gt;</VoiceId>
      <JapaneseText>なんだ、さっきの料理人みてーなの</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>1</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>43704</PointerOffset>
      <VoiceId>&lt;audio:VCT_005_191_002&gt;</VoiceId>
      <JapaneseText>びっくりした……爆発したかと思っちゃった</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>2</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>43792</PointerOffset>
      <VoiceId>&lt;audio:VCT_005_191_003&gt;</VoiceId>
      <JapaneseText>『素晴らしき青空の』……なんだっけ？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>3</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>43920</PointerOffset>
      <VoiceId>&lt;audio:VCT_005_191_004&gt;</VoiceId>
      <JapaneseText>『すばらしき味の世界』だって。
それってこの世界と違う別の世界ってことかな？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>4</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>44020</PointerOffset>
      <VoiceId>&lt;audio:VCT_005_191_005&gt;</VoiceId>
      <JapaneseText>んなもんねーよ。
ただの集まりだろ。料理同好会</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>5</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>44148</PointerOffset>
      <VoiceId>&lt;audio:VCT_005_191_006&gt;</VoiceId>
      <JapaneseText>そう、なのかな？　後、あの変身っていうか
変装っていうか、擬態っていうか……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>6</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>44252</PointerOffset>
      <VoiceId>&lt;audio:VCT_005_191_007&gt;</VoiceId>
      <JapaneseText>そうだ！　あれ、なんだよ？
いろいろおかしくないか？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>7</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>44324</PointerOffset>
      <VoiceId>&lt;audio:VCT_005_191_008&gt;</VoiceId>
      <JapaneseText>魔法……なのかな？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>8</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>44440</PointerOffset>
      <VoiceId>&lt;audio:VCT_005_191_009&gt;</VoiceId>
      <JapaneseText>そうだとしてもさ……
アレ、誰にも見つからなかったらどーすんだ？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>9</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>44512</PointerOffset>
      <VoiceId>&lt;audio:VCT_005_191_010&gt;</VoiceId>
      <JapaneseText>かなり悲惨だぞ……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>10</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>44640</PointerOffset>
      <VoiceId>&lt;audio:VCT_005_191_011&gt;</VoiceId>
      <JapaneseText>わからないことだらけだね……
まさに謎のシェフ……ワンダー……シェフ……？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>11</Id>
      <Status>To Do</Status>
    </Entry>
  </Strings>
  <Strings>
    <Section>Notice</Section>
  </Strings>
</SceneText>
