      <SpeakerId>1</SpeakerId>
      <Id>6</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>43804</PointerOffset>
      <VoiceId>&lt;audio:VCT_005_174_007&gt;</VoiceId>
      <JapaneseText>その分、戦ってるもん！
その分、歩いてるもん！</JapaneseText>
