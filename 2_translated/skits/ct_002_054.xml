    <Entry>
      <PointerOffset>42740</PointerOffset>
      <VoiceId>&lt;audio:VCT_002_054_001&gt;</VoiceId>
      <JapaneseText>エトはどうして自分のことを
妖精だなんて思ってたんだ？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>1</Id>
      <OldPtr>37320</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>42852</PointerOffset>
      <VoiceId>&lt;audio:VCT_002_054_002&gt;</VoiceId>
      <JapaneseText>ちっちゃな子どもがぼくのこと、
妖精だって言ってたかラ……？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>2</Id>
      <OldPtr>37432</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>42916</PointerOffset>
      <VoiceId>&lt;audio:VCT_002_054_003&gt;</VoiceId>
      <JapaneseText>それだけ？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>3</Id>
      <OldPtr>37876</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>43028</PointerOffset>
      <VoiceId>&lt;audio:VCT_002_054_004&gt;</VoiceId>
      <JapaneseText>変な人に捕まった時も、
ぼくのこと妖精だって言ってた人いたシ</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>4</Id>
      <OldPtr>38124</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>43124</PointerOffset>
      <VoiceId>&lt;audio:VCT_002_054_005&gt;</VoiceId>
      <JapaneseText>捕まってたって……
んなことあったのか！？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>5</Id>
      <OldPtr>38624</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>43264</PointerOffset>
      <VoiceId>&lt;audio:VCT_002_054_006&gt;</VoiceId>
      <JapaneseText>うん……それに魔物と一緒に踊ってたら、足跡が
妖精の輪とか言って大騒ぎされたこともあるよ</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>6</Id>
      <OldPtr>39196</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>43348</PointerOffset>
      <VoiceId>&lt;audio:VCT_002_054_007&gt;</VoiceId>
      <JapaneseText>それ、前読んだ本に書いてた……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>7</Id>
      <OldPtr>39928</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>43408</PointerOffset>
      <VoiceId>&lt;audio:VCT_002_054_008&gt;</VoiceId>
      <JapaneseText>クルル～</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>4</SpeakerId>
      <Id>8</Id>
      <OldPtr>40040</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>43524</PointerOffset>
      <VoiceId>&lt;audio:VCT_002_054_009&gt;</VoiceId>
      <JapaneseText>エネルギー核にされて、古代遺産の妖精兵器が
蘇ったこともあるかな</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>9</Id>
      <OldPtr>40352</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>43612</PointerOffset>
      <VoiceId>&lt;audio:VCT_002_054_010&gt;</VoiceId>
      <JapaneseText>妖精兵器って……なんかスゴそう……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>10</Id>
      <OldPtr>41060</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>43708</PointerOffset>
      <VoiceId>&lt;audio:VCT_002_054_011&gt;</VoiceId>
      <JapaneseText>なんだよ、やっぱエト、
妖精じゃねーのか？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>11</Id>
      <OldPtr>41384</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>43840</PointerOffset>
      <VoiceId>&lt;audio:VCT_002_054_012&gt;</VoiceId>
      <JapaneseText>それよりもわたしたちの知らない
エトの過去が次々と明らかになってるんだけど……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>12</Id>
      <OldPtr>41700</OldPtr>
      <Status>To Do</Status>
    </Entry>
