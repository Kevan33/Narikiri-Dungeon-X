  <Strings>
    <Section>Main</Section>
    <Entry>
      <PointerOffset>46860</PointerOffset>
      <VoiceId>&lt;audio:VCT_002_064_001&gt;</VoiceId>
      <JapaneseText>こ、これは？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>1</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>46972</PointerOffset>
      <VoiceId>&lt;audio:VCT_002_064_002&gt;</VoiceId>
      <JapaneseText>&lt;Suzu&gt;やーやーやー、どもども。
『ちん』はじめましてだど</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>2</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>47040</PointerOffset>
      <VoiceId>&lt;audio:VCT_002_064_003&gt;</VoiceId>
      <JapaneseText>は、はじめまして</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>3</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>47172</PointerOffset>
      <VoiceId>&lt;audio:VCT_002_064_004&gt;</VoiceId>
      <JapaneseText>&lt;Suzu&gt;&lt;Mel&gt;&lt;Mel&gt;いんやー、ちんはに劣らず
かわいいだな。すんばらしいだーよ</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>4</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>47264</PointerOffset>
      <VoiceId>&lt;audio:VCT_002_064_005&gt;</VoiceId>
      <JapaneseText>……そんなこと突然、言われても困ります</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>5</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>47368</PointerOffset>
      <VoiceId>&lt;audio:VCT_002_064_006&gt;</VoiceId>
      <JapaneseText>えーだ、えーだ。その照れてる顔もグッとくるだどー</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>6</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>47484</PointerOffset>
      <VoiceId>&lt;audio:VCT_002_064_007&gt;</VoiceId>
      <JapaneseText>アルベルトさん、
新しい女の人が来るたび同じこと言ってませんか？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>7</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>47624</PointerOffset>
      <VoiceId>&lt;audio:VCT_002_064_008&gt;</VoiceId>
      <JapaneseText>&lt;Mel&gt;&lt;Mel&gt;おんやー、、嫉妬だべかぁ～？
嫉妬かぁ？　いんや、モテる男は辛いだーな</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>8</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>47776</PointerOffset>
      <VoiceId>&lt;audio:VCT_002_064_009&gt;</VoiceId>
      <JapaneseText>&lt;Mel&gt;&lt;Mel&gt;&lt;Suzu&gt;んなもん、が一番に決まってるだーよ。
だども、ちんのあの恥じらい、捨てがてなぁ</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>9</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>47912</PointerOffset>
      <VoiceId>&lt;audio:VCT_002_064_010&gt;</VoiceId>
      <JapaneseText>どうすっかなぁ。あっちもいいけどこっちもええな。
贅沢な悩みだーな。ぶつぶつ……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>10</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>48012</PointerOffset>
      <VoiceId>&lt;audio:VCT_002_064_011&gt;</VoiceId>
      <JapaneseText>あまり、気にしないでね。いつも、あんな感じだから</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>11</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>48076</PointerOffset>
      <VoiceId>&lt;audio:VCT_002_064_012&gt;</VoiceId>
      <JapaneseText>は、はい……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>12</Id>
      <Status>To Do</Status>
    </Entry>
  </Strings>
