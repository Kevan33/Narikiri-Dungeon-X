    <Entry>
      <PointerOffset>49112</PointerOffset>
      <VoiceId>&lt;audio:VCT_002_052_001&gt;</VoiceId>
      <JapaneseText>なぁ、タンス野郎って寝る時、
ふつーに横になってんだろ？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>1</Id>
      <OldPtr>37492</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>49200</PointerOffset>
      <VoiceId>&lt;audio:VCT_002_052_002&gt;</VoiceId>
      <JapaneseText>でも起き上がるとこ、見たことなくね？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>2</Id>
      <OldPtr>37728</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>49276</PointerOffset>
      <VoiceId>&lt;audio:VCT_002_052_003&gt;</VoiceId>
      <JapaneseText>そう言えば、そうかも……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>3</Id>
      <OldPtr>38084</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>49408</PointerOffset>
      <VoiceId>&lt;audio:VCT_002_052_004&gt;</VoiceId>
      <JapaneseText>歩く時もちょこまかうぜーのに。
どうやってあの足で起き上がんか、気になんだよなー</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>4</Id>
      <OldPtr>38196</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>49492</PointerOffset>
      <VoiceId>&lt;audio:VCT_002_052_005&gt;</VoiceId>
      <JapaneseText>う～ん、確かに気になるけド……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>5</Id>
      <OldPtr>38688</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>49568</PointerOffset>
      <VoiceId>&lt;audio:VCT_002_052_006&gt;</VoiceId>
      <JapaneseText>……何たくらんでるの？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>6</Id>
      <OldPtr>39076</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>49648</PointerOffset>
      <VoiceId>&lt;audio:VCT_002_052_007&gt;</VoiceId>
      <JapaneseText>んなもん、実験あるのみだろ！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>7</Id>
      <OldPtr>39444</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>49752</PointerOffset>
      <VoiceId>&lt;audio:VCT_002_052_008&gt;</VoiceId>
      <JapaneseText>&lt;Mel&gt;&lt;Mel&gt;のために美味そうな花、見つけてきたど</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>4</SpeakerId>
      <Id>8</Id>
      <OldPtr>40048</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>49816</PointerOffset>
      <VoiceId>&lt;audio:VCT_002_052_009&gt;</VoiceId>
      <JapaneseText>やっ……！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>9</Id>
      <OldPtr>40744</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>49888</PointerOffset>
      <VoiceId>&lt;audio:VCT_002_052_010&gt;</VoiceId>
      <JapaneseText>な、何するだ！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>4</SpeakerId>
      <Id>10</Id>
      <OldPtr>41708</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>50016</PointerOffset>
      <VoiceId>&lt;audio:VCT_002_052_011&gt;</VoiceId>
      <JapaneseText>こーのクソぼうずが！　待ってるだよ！
こっぴどい目にあわせてやるだ……！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>4</SpeakerId>
      <Id>11</Id>
      <OldPtr>43364</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>50092</PointerOffset>
      <VoiceId>&lt;audio:VCT_002_052_012&gt;</VoiceId>
      <JapaneseText>ううう、うわわわ………</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>12</Id>
      <OldPtr>44828</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>50164</PointerOffset>
      <VoiceId>&lt;audio:VCT_002_052_013&gt;</VoiceId>
      <JapaneseText>こ、これって…………</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>13</Id>
      <OldPtr>45140</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>50244</PointerOffset>
      <VoiceId>&lt;audio:VCT_002_052_014&gt;</VoiceId>
      <JapaneseText>うわーーーーーーーー！！！！！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>5</SpeakerId>
      <Id>14</Id>
      <OldPtr>45396</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>50576</PointerOffset>
      <VoiceId>&lt;audio:VCT_002_052_018&gt;</VoiceId>
      <JapaneseText>このハゲぼうずが……！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>4</SpeakerId>
      <Id>15</Id>
      <OldPtr>47420</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>50644</PointerOffset>
      <VoiceId>&lt;audio:VCT_002_052_019&gt;</VoiceId>
      <JapaneseText>あ～ん……？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>4</SpeakerId>
      <Id>16</Id>
      <OldPtr>48020</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>50728</PointerOffset>
      <VoiceId>&lt;audio:VCT_002_052_020&gt;</VoiceId>
