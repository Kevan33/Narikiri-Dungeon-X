  <Strings>
    <Section>Main</Section>
    <Entry>
      <PointerOffset>46088</PointerOffset>
      <VoiceId>&lt;audio:VCT_002_080_001&gt;</VoiceId>
      <JapaneseText>&lt;Rody&gt;、さっき&lt;Cless&gt;さんたち
迎えに行った時さ</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>1</Id>
      <OldPtr>37244</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>46200</PointerOffset>
      <VoiceId>&lt;audio:VCT_002_080_002&gt;</VoiceId>
      <JapaneseText>行ってくるって言って、
戻ってきたの、あっという間だったぜ？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>2</Id>
      <OldPtr>37584</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>46296</PointerOffset>
      <VoiceId>&lt;audio:VCT_002_080_003&gt;</VoiceId>
      <JapaneseText>そりゃあ、戻ってくる時間も
自由自在だからね</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>3</Id>
      <OldPtr>38112</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>46372</PointerOffset>
      <VoiceId>&lt;audio:VCT_002_080_004&gt;</VoiceId>
      <JapaneseText>え？　どういうことだ？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>4</Id>
      <OldPtr>38400</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>46492</PointerOffset>
      <VoiceId>&lt;audio:VCT_002_080_005&gt;</VoiceId>
      <JapaneseText>だから、向こうに長くいても、
こっちの時間で少しだけ後に戻ってきたら</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>5</Id>
      <OldPtr>38708</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>46596</PointerOffset>
      <VoiceId>&lt;audio:VCT_002_080_006&gt;</VoiceId>
      <JapaneseText>あら不思議、戻ってくるのは
あっという間って感じかな</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>6</Id>
      <OldPtr>39084</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>46656</PointerOffset>
      <VoiceId>&lt;audio:VCT_002_080_007&gt;</VoiceId>
      <JapaneseText>え……？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>7</Id>
      <OldPtr>39660</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>46748</PointerOffset>
      <VoiceId>&lt;audio:VCT_002_080_008&gt;</VoiceId>
      <JapaneseText>ありゃ、わかんないかな？
つまりね……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>8</Id>
      <OldPtr>39828</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>46848</PointerOffset>
      <VoiceId>&lt;audio:VCT_002_080_009&gt;</VoiceId>
      <JapaneseText>指輪の力使えば、
全部速く動くことができるんだよ</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>9</Id>
      <OldPtr>40488</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>46924</PointerOffset>
      <VoiceId>&lt;audio:VCT_002_080_010&gt;</VoiceId>
      <JapaneseText>ちょっと、&lt;Mel&gt;ちゃん？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>10</Id>
      <OldPtr>41400</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>47012</PointerOffset>
      <VoiceId>&lt;audio:VCT_002_080_011&gt;</VoiceId>
      <JapaneseText>なんだよ、
今のそういうことなのか？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>11</Id>
      <OldPtr>41832</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>47072</PointerOffset>
      <VoiceId>&lt;audio:VCT_002_080_012&gt;</VoiceId>
      <JapaneseText>えっと？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>12</Id>
      <OldPtr>42416</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>47192</PointerOffset>
      <VoiceId>&lt;audio:VCT_002_080_013&gt;</VoiceId>
      <JapaneseText>そういうことにしといてください。
&lt;Dio&gt;に説明すると、長いですよ？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>13</Id>
      <OldPtr>42584</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>47256</PointerOffset>
      <VoiceId>&lt;audio:VCT_002_080_014&gt;</VoiceId>
      <JapaneseText>そう……？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>14</Id>
      <OldPtr>43312</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>47336</PointerOffset>
      <VoiceId>&lt;audio:VCT_002_080_015&gt;</VoiceId>
      <JapaneseText>んじゃあ、そういうことで～</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>15</Id>
      <OldPtr>43560</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>47436</PointerOffset>
      <VoiceId>&lt;audio:VCT_002_080_016&gt;</VoiceId>
      <JapaneseText>そういうことでって、
なんだよ、ちょっと待てよ！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>16</Id>
      <OldPtr>44432</OldPtr>
      <Status>To Do</Status>
    </Entry>
