    <Entry>
      <PointerOffset>42880</PointerOffset>
      <VoiceId>&lt;audio:VCT_002_045_001&gt;</VoiceId>
      <JapaneseText>エト、この文字のこことここ、
これ、どういう意味？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>1</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>42952</PointerOffset>
      <VoiceId>&lt;audio:VCT_002_045_002&gt;</VoiceId>
      <JapaneseText>え？　なに、この字？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>2</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>43064</PointerOffset>
      <VoiceId>&lt;audio:VCT_002_045_003&gt;</VoiceId>
      <JapaneseText>マクスウェルのところにあった
石盤の文字。メモっといたんだ</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>3</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>43152</PointerOffset>
      <VoiceId>&lt;audio:VCT_002_045_004&gt;</VoiceId>
      <JapaneseText>そんなん勉強してどんな得になんだ？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>4</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>43268</PointerOffset>
      <VoiceId>&lt;audio:VCT_002_045_005&gt;</VoiceId>
      <JapaneseText>わかんないけど……勉強しておけば、
いつか役に立つかもしれないよ</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>5</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>43364</PointerOffset>
      <VoiceId>&lt;audio:VCT_002_045_006&gt;</VoiceId>
      <JapaneseText>読めない、けど……
こんな文字だったっけ？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>6</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>43468</PointerOffset>
      <VoiceId>&lt;audio:VCT_002_045_007&gt;</VoiceId>
      <JapaneseText>あれ？　どこか間違ってる？
じゃあ、こっちの文字は？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>7</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>43532</PointerOffset>
      <VoiceId>&lt;audio:VCT_002_045_008&gt;</VoiceId>
      <JapaneseText>さぁ……？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>8</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>43624</PointerOffset>
      <VoiceId>&lt;audio:VCT_002_045_009&gt;</VoiceId>
      <JapaneseText>あれ？　やっぱり、
写し間違えたのかな</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>9</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>43712</PointerOffset>
      <VoiceId>&lt;audio:VCT_002_045_010&gt;</VoiceId>
      <JapaneseText>字が汚くて読めないだけじゃないのか</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>10</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>43776</PointerOffset>
      <VoiceId>&lt;audio:VCT_002_045_011&gt;</VoiceId>
      <JapaneseText>いてっ……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>11</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>43864</PointerOffset>
      <VoiceId>&lt;audio:VCT_002_045_012&gt;</VoiceId>
      <JapaneseText>汚いんじゃなくて、
タッピツなの！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>12</Id>
      <Status>To Do</Status>
    </Entry>
