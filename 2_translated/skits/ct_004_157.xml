  </Speakers>
  <Strings>
    <Section>Main</Section>
    <Entry>
      <PointerOffset>44500</PointerOffset>
      <VoiceId>&lt;audio:VCT_004_157_001&gt;</VoiceId>
      <JapaneseText>あーあ、つまんね！　オレも戦わせろっ！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>1</Id>
      <OldPtr>37184</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>44568</PointerOffset>
      <VoiceId>&lt;audio:VCT_004_157_002&gt;</VoiceId>
      <JapaneseText>ぷぷぷ、ぷぷ</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>2</Id>
      <OldPtr>38156</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>44640</PointerOffset>
      <VoiceId>&lt;audio:VCT_004_157_003&gt;</VoiceId>
      <JapaneseText>なに笑ってんだよ……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>3</Id>
      <OldPtr>38576</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>44792</PointerOffset>
      <VoiceId>&lt;audio:VCT_004_157_004&gt;</VoiceId>
      <JapaneseText>いやぁいやいや、笑うなんて、滅相もねーだーよ。
戦闘から外されて、傷心の&lt;Dio&gt;さんを笑うだなんて</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>4</Id>
      <OldPtr>38728</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>44912</PointerOffset>
      <VoiceId>&lt;audio:VCT_004_157_005&gt;</VoiceId>
      <JapaneseText>へん！　そうやって、バカにしてろよ。
どーせ、すぐ戻ってやっからさ</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>5</Id>
      <OldPtr>40168</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>45052</PointerOffset>
      <VoiceId>&lt;audio:VCT_004_157_006&gt;</VoiceId>
      <JapaneseText>甘い、甘い！　甘いんなー！！　そうやって
立場にあぐらかいてっから、外されるんだ！！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>6</Id>
      <OldPtr>41284</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>45172</PointerOffset>
      <VoiceId>&lt;audio:VCT_004_157_007&gt;</VoiceId>
      <JapaneseText>た、たしかに、オレ、主人公のはずなのに、
戦闘から外されるなんて……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>7</Id>
      <OldPtr>42376</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>45244</PointerOffset>
      <VoiceId>&lt;audio:VCT_004_157_008&gt;</VoiceId>
      <JapaneseText>ざまぁねぇだ、な</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>8</Id>
      <OldPtr>42872</OldPtr>
      <Status>To Do</Status>
    </Entry>
