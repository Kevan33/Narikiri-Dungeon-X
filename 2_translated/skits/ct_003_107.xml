    <Entry>
      <PointerOffset>40284</PointerOffset>
      <VoiceId>&lt;audio:VCT_003_107_001&gt;</VoiceId>
      <JapaneseText>デリス・カーラーンでの
戦争の原因って何だったの？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>1</Id>
      <OldPtr>37208</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>40372</PointerOffset>
      <VoiceId>&lt;audio:VCT_003_107_002&gt;</VoiceId>
      <JapaneseText>わかんない……
誰も知らなかったんだ</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>2</Id>
      <OldPtr>37664</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>40496</PointerOffset>
      <VoiceId>&lt;audio:VCT_003_107_003&gt;</VoiceId>
      <JapaneseText>ああ……積もりすぎた恨みとか憎しみとか……
原因はもう誰も覚えてなかった</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>3</Id>
      <OldPtr>38096</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>40576</PointerOffset>
      <VoiceId>&lt;audio:VCT_003_107_004&gt;</VoiceId>
      <JapaneseText>誰も原因を調べなかったの？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>4</Id>
      <OldPtr>38388</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>40696</PointerOffset>
      <VoiceId>&lt;audio:VCT_003_107_005&gt;</VoiceId>
      <JapaneseText>オレも親を敵に殺されて、
戦争の本当のとこなんてどうでもよくなってた</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>5</Id>
      <OldPtr>38724</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>40792</PointerOffset>
      <VoiceId>&lt;audio:VCT_003_107_006&gt;</VoiceId>
      <JapaneseText>わたしも……みんな誰もが
そうだったんだよ</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>6</Id>
      <OldPtr>39012</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>40904</PointerOffset>
      <VoiceId>&lt;audio:VCT_003_107_007&gt;</VoiceId>
      <JapaneseText>ダオスみたいな第三者は他人事のようにしか
捉えられなかった</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>7</Id>
      <OldPtr>39244</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>40980</PointerOffset>
      <VoiceId>&lt;audio:VCT_003_107_008&gt;</VoiceId>
      <JapaneseText>それで、この結果か……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>8</Id>
      <OldPtr>39516</OldPtr>
      <Status>To Do</Status>
    </Entry>
