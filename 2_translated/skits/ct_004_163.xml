    <Entry>
      <PointerOffset>44596</PointerOffset>
      <VoiceId>&lt;audio:VCT_004_163_001&gt;</VoiceId>
      <JapaneseText>なぁ、その注射器って敵に刺すんだよな？
その中、何入ってんだ？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>1</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>44664</PointerOffset>
      <VoiceId>&lt;audio:VCT_004_163_002&gt;</VoiceId>
      <JapaneseText>……聞きたい？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>2</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>44740</PointerOffset>
      <VoiceId>&lt;audio:VCT_004_163_003&gt;</VoiceId>
      <JapaneseText>……え？　あ、うん……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>3</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>44812</PointerOffset>
      <VoiceId>&lt;audio:VCT_004_163_004&gt;</VoiceId>
      <JapaneseText>……ボロンナボヌリン</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>4</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>44868</PointerOffset>
      <VoiceId>&lt;audio:VCT_004_163_005&gt;</VoiceId>
      <JapaneseText>え？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>5</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>44940</PointerOffset>
      <VoiceId>&lt;audio:VCT_004_163_006&gt;</VoiceId>
      <JapaneseText>ボロンナボヌリンよ</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>6</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>45056</PointerOffset>
      <VoiceId>&lt;audio:VCT_004_163_007&gt;</VoiceId>
      <JapaneseText>……その、ぼろんこ……って、何だ？
なんかスゲー名前だけど……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>7</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>45188</PointerOffset>
      <VoiceId>&lt;audio:VCT_004_163_008&gt;</VoiceId>
      <JapaneseText>これを注入されたら、すべての音が
ガラスを引っかいたみたいに聞こえるようになるの</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>8</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>45264</PointerOffset>
      <VoiceId>&lt;audio:VCT_004_163_009&gt;</VoiceId>
      <JapaneseText>ま、待てっ！　落ち着け！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>9</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>45408</PointerOffset>
      <VoiceId>&lt;audio:VCT_004_163_010&gt;</VoiceId>
      <JapaneseText>特にトマトに含まれるボロンヌヌキキ酸が
不足がちの１０代男性に効果がよく現れるんだって……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>10</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>45524</PointerOffset>
      <VoiceId>&lt;audio:VCT_004_163_011&gt;</VoiceId>
      <JapaneseText>う、あ、あああああ！！
い、いやだああああああああああああ！！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>11</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>45604</PointerOffset>
      <VoiceId>&lt;audio:VCT_004_163_012&gt;</VoiceId>
      <JapaneseText>……これでトマト食べるかな？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>12</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>45680</PointerOffset>
      <VoiceId>&lt;audio:VCT_004_163_013&gt;</VoiceId>
      <JapaneseText>うふふっ　だといいケド</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>13</Id>
      <Status>To Do</Status>
    </Entry>
