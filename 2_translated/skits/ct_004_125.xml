    <Entry>
      <PointerOffset>44504</PointerOffset>
      <VoiceId>&lt;audio:VCT_004_125_002&gt;</VoiceId>
      <JapaneseText>光れ、魂（ソウル）！　唸れ、拳骨！
オレの怒りをくらいやがれっー！！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>2</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>44580</PointerOffset>
      <VoiceId>&lt;audio:VCT_004_125_003&gt;</VoiceId>
      <JapaneseText>クッ！！　……クルール！</JapaneseText>
