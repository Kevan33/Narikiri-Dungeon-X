      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>44672</PointerOffset>
      <VoiceId>&lt;audio:VCT_004_125_004&gt;</VoiceId>
      <JapaneseText>あ、コラまてっ、
おまえ敵役だろー！！</JapaneseText>
