    <Entry>
      <PointerOffset>44788</PointerOffset>
      <VoiceId>&lt;audio:VCT_004_125_005&gt;</VoiceId>
      <JapaneseText>&lt;Dio&gt;ったら、いつのまにか
一人でも戦えるようになっちゃって…</JapaneseText>
