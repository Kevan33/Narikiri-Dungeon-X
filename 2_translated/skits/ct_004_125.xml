    <Entry>
      <PointerOffset>44884</PointerOffset>
      <VoiceId>&lt;audio:VCT_004_125_006&gt;</VoiceId>
      <JapaneseText>もう、わたしの助けなんて
いらないのかな……</JapaneseText>
