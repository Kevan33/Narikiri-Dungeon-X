      <PointerOffset>44384</PointerOffset>
      <VoiceId>&lt;audio:VCT_004_125_001&gt;</VoiceId>
      <JapaneseText>ふっ……
おまえらなど、オレひとりで十分だ……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>1</Id>
      <Status>To Do</Status>
