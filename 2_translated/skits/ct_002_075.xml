    <Entry>
      <PointerOffset>43824</PointerOffset>
      <VoiceId>&lt;audio:VCT_002_075_001&gt;</VoiceId>
      <JapaneseText>そう言えば、君たちがいなくなった後、
バジルのところで少し研究を手伝っていたんだが</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>1</Id>
      <OldPtr>37208</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>43896</PointerOffset>
      <VoiceId>&lt;audio:VCT_002_075_002&gt;</VoiceId>
      <JapaneseText>バジルさんの……！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>2</Id>
      <OldPtr>37576</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>43964</PointerOffset>
      <VoiceId>&lt;audio:VCT_002_075_003&gt;</VoiceId>
      <JapaneseText>ん？　どうした？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>3</Id>
      <OldPtr>37756</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>44036</PointerOffset>
      <VoiceId>&lt;audio:VCT_002_075_004&gt;</VoiceId>
      <JapaneseText>えっと……その……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>4</Id>
      <OldPtr>37992</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>44108</PointerOffset>
      <VoiceId>&lt;audio:VCT_002_075_005&gt;</VoiceId>
      <JapaneseText>なんでもありません</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>5</Id>
      <OldPtr>38304</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>44176</PointerOffset>
      <VoiceId>&lt;audio:VCT_002_075_006&gt;</VoiceId>
      <JapaneseText>……そうか……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>6</Id>
      <OldPtr>38616</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>44260</PointerOffset>
      <VoiceId>&lt;audio:VCT_002_075_007&gt;</VoiceId>
      <JapaneseText>ヘンなこと言わない方がいいよ……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>7</Id>
      <OldPtr>39520</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>44360</PointerOffset>
      <VoiceId>&lt;audio:VCT_002_075_008&gt;</VoiceId>
      <JapaneseText>でもさ、&lt;Claus&gt;さんに言って
止めてもらえれば……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>8</Id>
      <OldPtr>39700</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>44432</PointerOffset>
      <VoiceId>&lt;audio:VCT_002_075_009&gt;</VoiceId>
      <JapaneseText>でもわたしたち……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>9</Id>
      <OldPtr>40144</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>44512</PointerOffset>
      <VoiceId>&lt;audio:VCT_002_075_010&gt;</VoiceId>
      <JapaneseText>バジルの身に何かあったんだな</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>10</Id>
      <OldPtr>40312</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>44588</PointerOffset>
      <VoiceId>&lt;audio:VCT_002_075_011&gt;</VoiceId>
      <JapaneseText>え！　い、いや、その……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>11</Id>
      <OldPtr>40948</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>44720</PointerOffset>
      <VoiceId>&lt;audio:VCT_002_075_012&gt;</VoiceId>
      <JapaneseText>……何があったのかはわからないが、
それが運命ならば、ヤツも潔く受け止めるだろう</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>12</Id>
      <OldPtr>41364</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>44828</PointerOffset>
      <VoiceId>&lt;audio:VCT_002_075_013&gt;</VoiceId>
      <JapaneseText>だから、私もこれ以上、深くは聞かない。
それでいいだろ？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>13</Id>
      <OldPtr>41636</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>44900</PointerOffset>
      <VoiceId>&lt;audio:VCT_002_075_014&gt;</VoiceId>
      <JapaneseText>え……あ、はい……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>14</Id>
      <OldPtr>42320</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>44980</PointerOffset>
      <VoiceId>&lt;audio:VCT_002_075_015&gt;</VoiceId>
      <JapaneseText>……大人だな、&lt;Claus&gt;さん……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>15</Id>
      <OldPtr>42908</OldPtr>
      <Status>To Do</Status>
    </Entry>
