    <Entry>
      <PointerOffset>46508</PointerOffset>
      <VoiceId>&lt;audio:VCT_004_127_001&gt;</VoiceId>
      <JapaneseText>さ、さっきの&lt;Rody&gt;さん、
ちょっと怖かったかも……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>1</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>46616</PointerOffset>
      <VoiceId>&lt;audio:VCT_004_127_002&gt;</VoiceId>
      <JapaneseText>だよな。とっくに倒れてる敵に
あんだけの追い討ちだろ？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>2</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>46736</PointerOffset>
      <VoiceId>&lt;audio:VCT_004_127_003&gt;</VoiceId>
      <JapaneseText>思わず『もういい、もういいだろう！！』
……とか叫びそうになったよ</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>3</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>46832</PointerOffset>
      <VoiceId>&lt;audio:VCT_004_127_004&gt;</VoiceId>
      <JapaneseText>ずっと&lt;Rody&gt;のターンって
感じだったもんね</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>4</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>46904</PointerOffset>
      <VoiceId>&lt;audio:VCT_004_127_005&gt;</VoiceId>
      <JapaneseText>怒らせたらやべーよな</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>5</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>46976</PointerOffset>
      <VoiceId>&lt;audio:VCT_004_127_006&gt;</VoiceId>
      <JapaneseText>ん？　私を呼んだ？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>6</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>47072</PointerOffset>
      <VoiceId>&lt;audio:VCT_004_127_007&gt;</VoiceId>
      <JapaneseText>わっ！　い、いえ、なんでもアリマセンッ！！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>7</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>47212</PointerOffset>
      <VoiceId>&lt;audio:VCT_004_127_008&gt;</VoiceId>
      <JapaneseText>そ？　ん～。思いっきり戦ったから、いいストレス
発散になった♪　でも喉が渇いちゃったな</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>8</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>47308</PointerOffset>
      <VoiceId>&lt;audio:VCT_004_127_009&gt;</VoiceId>
      <JapaneseText>ハ、ハイ！
じゃあスグニ何か用意シマスッ！！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>9</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>47396</PointerOffset>
      <VoiceId>&lt;audio:VCT_004_127_010&gt;</VoiceId>
      <JapaneseText>なにアレ？　なんか拾い食いでもした？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>10</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>47464</PointerOffset>
      <VoiceId>&lt;audio:VCT_004_127_011&gt;</VoiceId>
      <JapaneseText>あ、あはは……

</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>11</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>47548</PointerOffset>
      <VoiceId>&lt;audio:VCT_004_127_012&gt;</VoiceId>
      <JapaneseText>……そこまで怖がらなくても……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>12</Id>
      <Status>To Do</Status>
    </Entry>
