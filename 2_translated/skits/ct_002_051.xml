  <Strings>
    <Section>Main</Section>
    <Entry>
      <PointerOffset>45764</PointerOffset>
      <VoiceId>&lt;audio:VCT_002_051_001&gt;</VoiceId>
      <JapaneseText>&lt;Dio&gt;！　足元気をつけて！　つまずくよ！</JapaneseText>
      <EnglishText>&lt;Dio&gt;! Watch your step! You're going to trip!</EnglishText>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>1</Id>
      <Status>Editing</Status>
    </Entry>
    <Entry>
      <PointerOffset>45840</PointerOffset>
      <VoiceId>&lt;audio:VCT_002_051_002&gt;</VoiceId>
      <JapaneseText>え……！　あ、ああ……</JapaneseText>
      <EnglishText>Wha...? Oh, huh...</EnglishText>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>2</Id>
      <Status>Editing</Status>
    </Entry>
    <Entry>
      <PointerOffset>45924</PointerOffset>
      <VoiceId>&lt;audio:VCT_002_051_003&gt;</VoiceId>
      <JapaneseText>そ、そっち行ったら、落ちる……！</JapaneseText>
      <EnglishText>W-wait don't go that way! You'll fall...!</EnglishText>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>3</Id>
      <Status>Editing</Status>
    </Entry>
    <Entry>
      <PointerOffset>45984</PointerOffset>
      <VoiceId>&lt;audio:VCT_002_051_004&gt;</VoiceId>
      <JapaneseText>うわっ！</JapaneseText>
      <EnglishText>Ow!</EnglishText>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>4</Id>
      <Status>Editing</Status>
    </Entry>
    <Entry>
      <PointerOffset>46088</PointerOffset>
      <VoiceId>&lt;audio:VCT_002_051_005&gt;</VoiceId>
      <JapaneseText>もう、危ないなぁ。
ほら、歩く時はちゃんと前見ないと</JapaneseText>
      <EnglishText>Ah, what a dangerous place. You should look where you are walking.</EnglishText>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>5</Id>
      <Status>Editing</Status>
    </Entry>
    <Entry>
      <PointerOffset>46168</PointerOffset>
      <VoiceId>&lt;audio:VCT_002_051_006&gt;</VoiceId>
      <JapaneseText>ちゃ、ちゃんと見てるっての</JapaneseText>
      <EnglishText>I'm looking where I'm going, dammit!</EnglishText>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>6</Id>
      <Status>Editing</Status>
    </Entry>
    <Entry>
      <PointerOffset>46232</PointerOffset>
      <VoiceId>&lt;audio:VCT_002_051_007&gt;</VoiceId>
      <JapaneseText>ほら、前！</JapaneseText>
      <EnglishText>Wait a second!</EnglishText>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>7</Id>
      <Status>Editing</Status>
    </Entry>
    <Entry>
      <PointerOffset>46300</PointerOffset>
      <VoiceId>&lt;audio:VCT_002_051_008&gt;</VoiceId>
      <JapaneseText>いーつつつつ……</JapaneseText>
      <EnglishText>O-ouch!</EnglishText>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>8</Id>
      <Status>Editing</Status>
    </Entry>
    <Entry>
      <PointerOffset>46372</PointerOffset>
      <VoiceId>&lt;audio:VCT_002_051_009&gt;</VoiceId>
      <JapaneseText>言ったそばから……</JapaneseText>
      <EnglishText>If you'd only listen just once...</EnglishText>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>9</Id>
      <Status>Editing</Status>
    </Entry>
    <Entry>
      <PointerOffset>46464</PointerOffset>
      <VoiceId>&lt;audio:VCT_002_051_010&gt;</VoiceId>
      <JapaneseText>……なんだか&lt;Dio&gt;、
ぼーっとしているね</JapaneseText>
      <EnglishText>...Have you noticed &lt;Dio&gt; is acting a little too thoughtful all of a sudden?</EnglishText>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>10</Id>
      <Status>Editing</Status>
    </Entry>
    <Entry>
      <PointerOffset>46584</PointerOffset>
      <VoiceId>&lt;audio:VCT_002_051_011&gt;</VoiceId>
      <JapaneseText>確かにぼーっとはしてますけど……
&lt;Dio&gt;の不注意はいつものことです</JapaneseText>
      <EnglishText>His head is definitely in the clouds... But I think it's just his head made of rock at work again.</EnglishText>
      <Notes/>
      <SpeakerId>4</SpeakerId>
      <Id>11</Id>
      <Status>Editing</Status>
    </Entry>
    <Entry>
      <PointerOffset>46644</PointerOffset>
      <VoiceId>&lt;audio:VCT_002_051_012&gt;</VoiceId>
      <JapaneseText>…………</JapaneseText>
      <EnglishText>...</EnglishText>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>12</Id>
      <Status>Editing</Status>
    </Entry>
