    <Entry>
      <PointerOffset>45840</PointerOffset>
      <VoiceId>&lt;audio:VCT_002_051_002&gt;</VoiceId>
      <JapaneseText>え……！　あ、ああ……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>2</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>45924</PointerOffset>
      <VoiceId>&lt;audio:VCT_002_051_003&gt;</VoiceId>
      <JapaneseText>そ、そっち行ったら、落ちる……！</JapaneseText>
