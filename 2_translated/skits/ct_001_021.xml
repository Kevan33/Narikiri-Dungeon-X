  </Speakers>
  <Strings>
    <Section>Main</Section>
    <Entry>
      <PointerOffset>45660</PointerOffset>
      <VoiceId>&lt;audio:VCT_001_021_001&gt;</VoiceId>
      <JapaneseText>&lt;Dio&gt;ね、……ダオス戦役のことが
書いてある本ってある？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>1</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>45736</PointerOffset>
      <VoiceId>&lt;audio:VCT_001_021_002&gt;</VoiceId>
      <JapaneseText>あるけど……全部、家だよ</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>2</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>45876</PointerOffset>
      <VoiceId>&lt;audio:VCT_001_021_003&gt;</VoiceId>
      <JapaneseText>&lt;Mel&gt;&lt;Mel&gt;～、おらの中に『ダオス戦役のひみつ』、
『こども歴史大百科』があっただよ</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>3</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>45980</PointerOffset>
      <VoiceId>&lt;audio:VCT_001_021_004&gt;</VoiceId>
      <JapaneseText>あ……それ、オレの本！
何、勝手に持ってきてんだ！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>4</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>46056</PointerOffset>
      <VoiceId>&lt;audio:VCT_001_021_005&gt;</VoiceId>
      <JapaneseText>ありがと、アルベルトさん</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>5</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>46124</PointerOffset>
      <VoiceId>&lt;audio:VCT_001_021_006&gt;</VoiceId>
      <JapaneseText>……ふんふん……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>6</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>46224</PointerOffset>
      <VoiceId>&lt;audio:VCT_001_021_007&gt;</VoiceId>
      <JapaneseText>でも、どーしたんだよ、
今まで興味なかったくせに</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>7</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>46352</PointerOffset>
      <VoiceId>&lt;audio:VCT_001_021_008&gt;</VoiceId>
      <JapaneseText>みんなのしてる話が全然、わかんないから、
このままじゃいけないと思ったんだ</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>8</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>46468</PointerOffset>
      <VoiceId>&lt;audio:VCT_001_021_009&gt;</VoiceId>
      <JapaneseText>こういうことは、ちゃんと知っておかないと
ダメなんだよ、きっと</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>9</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>46556</PointerOffset>
      <VoiceId>&lt;audio:VCT_001_021_010&gt;</VoiceId>
      <JapaneseText>&lt;Mel&gt;相変わらずって真面目だよな……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>10</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>46648</PointerOffset>
      <VoiceId>&lt;audio:VCT_001_021_011&gt;</VoiceId>
      <JapaneseText>あ～、どこぞのチビ助と違って、な！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>11</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>46736</PointerOffset>
      <VoiceId>&lt;audio:VCT_001_021_012&gt;</VoiceId>
      <JapaneseText>うるせー！　本棚に作り変えちまうぞ！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>12</Id>
      <Status>To Do</Status>
    </Entry>
  </Strings>
