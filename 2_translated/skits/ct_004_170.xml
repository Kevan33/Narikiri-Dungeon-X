  <Strings>
    <Section>Main</Section>
    <Entry>
      <PointerOffset>43392</PointerOffset>
      <VoiceId>&lt;audio:VCT_004_170_001&gt;</VoiceId>
      <JapaneseText>よし！　次はこっちのコスチュームを着て……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>1</Id>
      <OldPtr>37144</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>43504</PointerOffset>
      <VoiceId>&lt;audio:VCT_004_170_002&gt;</VoiceId>
      <JapaneseText>&lt;Mel&gt;&lt;Mel&gt;、頑張ってるだなぁ。いっぱい着替えまくっで</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>2</Id>
      <OldPtr>38092</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>43604</PointerOffset>
      <VoiceId>&lt;audio:VCT_004_170_003&gt;</VoiceId>
      <JapaneseText>わたしの力が役立つなら、
精いっぱいやらないと！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>3</Id>
      <OldPtr>38816</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>43708</PointerOffset>
      <VoiceId>&lt;audio:VCT_004_170_004&gt;</VoiceId>
      <JapaneseText>すんばらしーだ。おら感動で、目から汗が出てきたど</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>4</Id>
      <OldPtr>39240</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>43808</PointerOffset>
      <VoiceId>&lt;audio:VCT_004_170_005&gt;</VoiceId>
      <JapaneseText>アルベルトさんだって、頑張って、くれてるじゃない</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>5</Id>
      <OldPtr>40028</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>43916</PointerOffset>
      <VoiceId>&lt;audio:VCT_004_170_006&gt;</VoiceId>
      <JapaneseText>……と、よし！　着替え終わった。
じゃ、行ってきまーす！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>6</Id>
      <OldPtr>40544</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>44052</PointerOffset>
      <VoiceId>&lt;audio:VCT_004_170_007&gt;</VoiceId>
      <JapaneseText>&lt;Mel&gt;&lt;Mel&gt;の着替えを毎回手伝えるなら、
おらは何百着だって持つだーよ。うふ∀</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>7</Id>
      <OldPtr>42088</OldPtr>
      <Status>To Do</Status>
    </Entry>
