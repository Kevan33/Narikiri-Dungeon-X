  <Strings>
    <Section>Main</Section>
    <Entry>
      <PointerOffset>269372</PointerOffset>
      <JapaneseText>はーい
いらはい、いらはい。</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>1</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>269440</PointerOffset>
      <JapaneseText>なぁなぁ、
ここは何売ってるんだ？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>2</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>269548</PointerOffset>
      <JapaneseText>ここは、子どもたちに
夢を売る場所、
なんちて、なんちて、ぷぷぷ</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>3</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>269644</PointerOffset>
      <JapaneseText>そんな、怖い顔しないのー。
もう、大人気ないんだから</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>4</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>269700</PointerOffset>
      <JapaneseText>それで、何があるの？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>5</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>269836</PointerOffset>
      <JapaneseText>残念ながら物は売ってないんだけど
その代わりに、君たちの思い出を
見せてあげられる場所なんだよ</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>6</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>269880</PointerOffset>
      <JapaneseText>思い出？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>4</SpeakerId>
      <Id>7</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>270032</PointerOffset>
      <JapaneseText>そそそ、百聞は一見にしかず！
いいかい、行くよ～</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>8</Id>
      <BubbleId>0</BubbleId>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>270032</PointerOffset>
      <JapaneseText>だべよ？　だべか？
そうだべか？？？
ごって、わくわく～～～</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>8</Id>
      <BubbleId>1</BubbleId>
      <Status>To Do</Status>
    </Entry>
