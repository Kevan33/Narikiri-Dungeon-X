  <Strings>
    <Section>Main</Section>
    <Entry>
      <PointerOffset>275296</PointerOffset>
      <JapaneseText>全ての勲章を集められたのですね。
よく、この困難な道、
乗り越える事ができました</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>1</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>275384</PointerOffset>
      <JapaneseText>へん！　俺の力があれば、
こんなんチョロイチョロイ！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>2</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>275484</PointerOffset>
      <JapaneseText>またすぐ調子に乗る。
途中で、うぜー、だりぃー、
とか言ってたの誰よ</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>3</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>275548</PointerOffset>
      <JapaneseText>クッルール！
クッルール！！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>4</SpeakerId>
      <Id>4</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>275632</PointerOffset>
      <JapaneseText>んだよー。
終わったんだから、
別にいいじゃんかよ</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>5</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>275744</PointerOffset>
      <JapaneseText>ハゲぼうずは、ちーっと黙っとれ。
ノルン様から、
ありがてぇお話があるだよ</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>5</SpeakerId>
      <Id>6</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>275848</PointerOffset>
      <JapaneseText>&lt;Dio&gt;、&lt;Mel&gt;、あなた方の
前へ進む勇気、
本当に素晴らしいものでした</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>7</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>275972</PointerOffset>
      <JapaneseText>おらが、力貸してやったからだど。
こいつらの力は、微々たるもんだ。
おらだ、おらだーよ</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>5</SpeakerId>
      <Id>8</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>276092</PointerOffset>
      <JapaneseText>わかっていますよ、アルベルト。
あなたのおかげで、ふたりも
頑張ってこられたのでしょう</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>9</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>276184</PointerOffset>
      <JapaneseText>へっへっへぇ～～～。
わかりゃーいいだ、
わかりゃーよ</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>5</SpeakerId>
      <Id>10</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>276276</PointerOffset>
      <JapaneseText>そのあなた方の頑張りを
私から称えさせて頂きます</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>11</Id>
      <BubbleId>0</BubbleId>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>276276</PointerOffset>
      <JapaneseText>こちらへ</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>11</Id>
      <BubbleId>1</BubbleId>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>276336</PointerOffset>
      <JapaneseText>アルベルトは、下がりなさい</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>13</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>276436</PointerOffset>
      <JapaneseText>けっ、けっ！
おらの扱いはこんなもんだー。
ぶつぶつぶつ……。</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>5</SpeakerId>
      <Id>14</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>276504</PointerOffset>
      <JapaneseText>あなた方に、
これを授けましょう</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>15</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>276912</PointerOffset>
      <JapaneseText>あなたたちの旅に、
更なるご加護を……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>16</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>277004</PointerOffset>
      <JapaneseText>あっ…………！
行っちゃった。
いいのかな、これもらって……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>17</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>277096</PointerOffset>
      <JapaneseText>いいじゃんかよ、
せっかくだから、
ありがたく頂いておこうぜ</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>18</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>277152</PointerOffset>
      <JapaneseText>クルール！　クルール！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>4</SpeakerId>
      <Id>19</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>277260</PointerOffset>
      <JapaneseText>ちーとばかし、顔が良くて
乳デカイと思っとって、
あの女神様は、よ……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>5</SpeakerId>
      <Id>20</Id>
      <Status>To Do</Status>
    </Entry>
