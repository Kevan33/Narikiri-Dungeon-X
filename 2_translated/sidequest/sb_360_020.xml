    <Entry>
      <PointerOffset>278439</PointerOffset>
      <JapaneseText>みそを渡しますか？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <Id>13</Id>
      <Status>To Do</Status>
    </Entry>
  </Speakers>
  <Strings>
    <Section>Main</Section>
    <Entry>
      <PointerOffset>276440</PointerOffset>
      <JapaneseText>来ただす来ただす。
魅惑のありじごくこーなーに
また呼ばれて来ただす！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>1</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>276492</PointerOffset>
      <JapaneseText>魅惑って言うか……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>2</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>276588</PointerOffset>
      <JapaneseText>だーいじょぶ
だーいじょぶ。
ぜーんぶわかってるから</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>3</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>276644</PointerOffset>
      <JapaneseText>人の話聞いてないシ……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>4</SpeakerId>
      <Id>4</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>276828</PointerOffset>
      <JapaneseText>今回、こちらにぶち込んで……、
じゃなくて、ありじごく様に、
交換をお願いする品物は……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>5</Id>
      <BubbleId>0</BubbleId>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>276828</PointerOffset>
      <JapaneseText>ざざーん！
みそですね、みそ
食材の『みそ』ざんす～</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>5</Id>
      <BubbleId>1</BubbleId>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>276912</PointerOffset>
      <JapaneseText>みそくれよ、みそ！
の、みそだすね</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>7</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>277116</PointerOffset>
      <JapaneseText>それじゃ、やっとくか</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>8</Id>
      <BubbleId>0</BubbleId>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>277116</PointerOffset>
      <JapaneseText>だべよ？　だべか？
そうだべか？？？
ごって、わくわく～～～</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>8</Id>
      <BubbleId>1</BubbleId>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>277216</PointerOffset>
      <JapaneseText>みそを
ありじごくの中に捨てるって
随分シュールな絵だーよ……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>5</SpeakerId>
      <Id>10</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>277316</PointerOffset>
      <JapaneseText>捨ててるんじゃなくて
ありじごく様に
渡してるんだってばよ</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>11</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>277452</PointerOffset>
      <JapaneseText>ほなら、いくだすよ！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>12</Id>
      <BubbleId>0</BubbleId>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>277452</PointerOffset>
      <JapaneseText>マジで？　ジーマー？
本気の本気で？？？
ガス、ガスガス、ガス！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>12</Id>
      <BubbleId>1</BubbleId>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>277516</PointerOffset>
      <JapaneseText>はいよー、来たよー</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>14</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>277636</PointerOffset>
      <JapaneseText>さーさー、
今回のお宝はなんだすか～？？
なんだろうだすか～～～？？？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>15</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>277720</PointerOffset>
      <JapaneseText>だかだかだかだかだか～
ざざ～～～～ん！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>16</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>277788</PointerOffset>
      <JapaneseText>今回はじゃがいもでした！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>17</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>277868</PointerOffset>
      <JapaneseText>なんで、みそが
じゃがいもに変わるんだよ……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>6</SpeakerId>
      <Id>18</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>277972</PointerOffset>
      <JapaneseText>なんでだすかなぁ？
ありじごく様の
お考えだすからなぁ</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>19</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>278084</PointerOffset>
      <JapaneseText>あれじゃない？
みそを砂の上に落とすと、
じゃがいもっぽく見えるとか？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>20</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>278152</PointerOffset>
      <JapaneseText>それ、本気で
言ってるのかしら？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>7</SpeakerId>
      <Id>21</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>278236</PointerOffset>
      <JapaneseText>そんなもん、
うちらだって
知るもんかよ</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>22</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>278284</PointerOffset>
      <JapaneseText>クリュウ……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>8</SpeakerId>
      <Id>23</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>278364</PointerOffset>
      <JapaneseText>なんだよー。
期待させんじゃねぇよ</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>24</Id>
      <Status>To Do</Status>
    </Entry>
