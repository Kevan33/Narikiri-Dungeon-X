    <Entry>
      <PointerOffset>280544</PointerOffset>
      <JapaneseText>手伝いますか？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <Id>11</Id>
      <Status>To Do</Status>
    </Entry>
