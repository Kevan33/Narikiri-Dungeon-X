  <Strings>
    <Section>Main</Section>
    <Entry>
      <PointerOffset>293760</PointerOffset>
      <JapaneseText>ファァァ～～～！
な、何ここ？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>1</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>293824</PointerOffset>
      <JapaneseText>すっごいね。
遊園地かなぁ？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>2</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>293928</PointerOffset>
      <JapaneseText>やっほー。
はじめまして、かな？　かな？
ここの事教えてあげようか？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>3</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>294000</PointerOffset>
      <JapaneseText>う、うん。
ボクたち初めてきたかラ……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>4</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>294180</PointerOffset>
      <JapaneseText>ここはね、嗜好の楽天地、
その名も『&lt;Red&gt;ナム孤島&lt;White&gt;』って、
言うんだお∀</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>5</Id>
      <BubbleId>0</BubbleId>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>294180</PointerOffset>
      <JapaneseText>大人も、子どもも、男も女も、
人じゃない方々も、
だ～れでも、楽しめる場所さ</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>5</Id>
      <BubbleId>1</BubbleId>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>294248</PointerOffset>
      <JapaneseText>だれでも、って事は、
タダなのか!?</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>4</SpeakerId>
      <Id>7</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>294436</PointerOffset>
      <JapaneseText>あ、うん、入るのは、
誰でもタダだにょ～。
遊ぶにはちょとお金が必要だすが</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>8</Id>
      <BubbleId>0</BubbleId>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>294436</PointerOffset>
      <JapaneseText>だから、そこの、動く木箱とか、
ゴムマリみたいな獣とかでも
入るのは自由だよ～ん</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>8</Id>
      <BubbleId>1</BubbleId>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>294552</PointerOffset>
      <JapaneseText>だーれが、木箱だ、え？
おめぇのその変な着ぐるみ、
燃やして火だるまにすっぞ！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>5</SpeakerId>
      <Id>10</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>294660</PointerOffset>
      <JapaneseText>はいはい、すごいすごい。
怖い怖いってね。
だから、適当に楽しんできな～</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>11</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>294736</PointerOffset>
      <JapaneseText>よーし、
さっそく入ってみっか。
行くぜ！！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>4</SpeakerId>
      <Id>12</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>294828</PointerOffset>
      <JapaneseText>ハゲぼうず、待つだ！
抜け駆けは許さないだーよ！！！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>5</SpeakerId>
      <Id>13</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>294880</PointerOffset>
      <JapaneseText>クッルール！！！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>6</SpeakerId>
      <Id>14</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>294964</PointerOffset>
      <JapaneseText>ね、エト、
とりあえず、
わたしたちも行ってみようよ</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>15</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>295032</PointerOffset>
      <JapaneseText>そうだね。
せっかく来たんだもんね</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>16</Id>
      <Status>To Do</Status>
    </Entry>
