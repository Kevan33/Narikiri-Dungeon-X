    <Entry>
      <PointerOffset>278491</PointerOffset>
      <JapaneseText>シャクナゲを渡しますか？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <Id>10</Id>
      <Status>To Do</Status>
    </Entry>
  </Speakers>
  <Strings>
    <Section>Main</Section>
    <Entry>
      <PointerOffset>276444</PointerOffset>
      <JapaneseText>おーおー、来た来た、
あくなき挑戦者たちが</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>1</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>276544</PointerOffset>
      <JapaneseText>ふひひ、
いいだすよー、
欲望丸出し感じがするだすー</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>2</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>276620</PointerOffset>
      <JapaneseText>なんか、言葉遣いが、
悪くなってきてない？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>3</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>276716</PointerOffset>
      <JapaneseText>まーまー、
ちっちゃいことは、
気にすんじゃないって</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>4</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>276804</PointerOffset>
      <JapaneseText>んで、もちろん
やっていくだすよね？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>5</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>276992</PointerOffset>
      <JapaneseText>今回、こちらに奪われる……、
じゃなくて、ありじごく様に、
交換をお願いする品物は……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>6</Id>
      <BubbleId>0</BubbleId>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>276992</PointerOffset>
      <JapaneseText>ざざーん！
シャクナゲですね、
武器の『シャクナゲ』でっす～</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>6</Id>
      <BubbleId>1</BubbleId>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>277072</PointerOffset>
      <JapaneseText>ほれ、サッサと
出すだすよ！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>8</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>277284</PointerOffset>
      <JapaneseText>面倒っちいけど、やるか</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>9</Id>
      <BubbleId>0</BubbleId>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>277284</PointerOffset>
      <JapaneseText>だべよ？　だべか？
そうだべか？？？
ごって、わくわく～～～</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>9</Id>
      <BubbleId>1</BubbleId>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>277392</PointerOffset>
      <JapaneseText>シャクナゲって刀だよな？
そんなもん入れたら
刺さっちまうんじゃねーの？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>4</SpeakerId>
      <Id>11</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>277488</PointerOffset>
      <JapaneseText>刺さるわけねぇだろ。
ちょっと考えればわかんじゃん</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>12</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>277628</PointerOffset>
      <JapaneseText>ほら、御託はいいだすよ！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>13</Id>
      <BubbleId>0</BubbleId>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>277628</PointerOffset>
      <JapaneseText>マジで？　ジーマー？
本気の本気で？？？
ガス、ガスガス、ガス！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>13</Id>
      <BubbleId>1</BubbleId>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>277688</PointerOffset>
      <JapaneseText>あー、来た来たー</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>15</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>277808</PointerOffset>
      <JapaneseText>さーさー、
今回のお宝はなんだすか～？？
なんだろうだすか～～～？？？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>16</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>277892</PointerOffset>
      <JapaneseText>だかだかだかだかだか～
ざざ～～～～ん！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>17</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>277964</PointerOffset>
      <JapaneseText>今回はスティレットでした！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>18</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>278056</PointerOffset>
      <JapaneseText>ま、間違いなく、
渡したものから、
劣化してるだーよ……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>4</SpeakerId>
      <Id>19</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>278184</PointerOffset>
      <JapaneseText>ありじごく様のご加護がある
由緒正しき短剣だすよ～。
他では手に入らないだすよ～</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>20</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>278252</PointerOffset>
      <JapaneseText>え？　じゃあ、
何か特殊な効果が？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>5</SpeakerId>
      <Id>21</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>278336</PointerOffset>
      <JapaneseText>あるわけねぇじゃん！
ぷー、ぷぷぷぷぷ</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>22</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>278416</PointerOffset>
      <JapaneseText>使えねぇなぁ。
サッサと持って来いよ</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>23</Id>
      <Status>To Do</Status>
    </Entry>
