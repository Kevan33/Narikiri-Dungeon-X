  <Strings>
    <Section>Main</Section>
    <Entry>
      <PointerOffset>271184</PointerOffset>
      <JapaneseText>ふふふ、私たちの注文を
とりに来たのですか？面白いです。</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>1</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>271280</PointerOffset>
      <JapaneseText>わたしたちの中で
本当のことを言っているのは一人だけ</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>2</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>271356</PointerOffset>
      <JapaneseText>正しい注文を取れるのか、勝負です！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>3</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>271456</PointerOffset>
      <JapaneseText>いや、普通に注文しろよ……
お前ら含めて、全員損するだけだぞ……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>4</SpeakerId>
      <Id>4</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>271520</PointerOffset>
      <JapaneseText>人生遊びが必要なのです！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>5</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>271596</PointerOffset>
      <JapaneseText>こんな世知辛い世の中だからこそ！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>6</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>271692</PointerOffset>
      <JapaneseText>だから、こちらもガマンして
楽しい空間を演出するのです！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>7</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>271768</PointerOffset>
      <JapaneseText>……なあ、
こいつらひっぱたいてもいいか？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>4</SpeakerId>
      <Id>8</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>271824</PointerOffset>
      <JapaneseText>ちょ、ちょっと&lt;Dio&gt;！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>5</SpeakerId>
      <Id>9</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>271888</PointerOffset>
      <JapaneseText>……わかった。わたしに任せて</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>6</SpeakerId>
      <Id>10</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>271956</PointerOffset>
      <JapaneseText>かかってきなさいなのです！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>11</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>272012</PointerOffset>
      <JapaneseText>負けません！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>12</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>272092</PointerOffset>
      <JapaneseText>お腹が空きました……
早くしてください</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>13</Id>
      <Status>To Do</Status>
    </Entry>
