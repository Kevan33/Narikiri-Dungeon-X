  <Strings>
    <Section>Main</Section>
    <Entry>
      <PointerOffset>272212</PointerOffset>
      <JapaneseText>ん？
なんか気配が……
いや、気のせいだな</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>1</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>272300</PointerOffset>
      <JapaneseText>おおーい、そこの君ー
君だよ君、待ってくれたまえ！！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>2</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>272348</PointerOffset>
      <JapaneseText>え？　え？？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>3</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>272420</PointerOffset>
      <JapaneseText>……ひょっとして、
井戸の中からかな？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>4</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>272484</PointerOffset>
      <JapaneseText>おおーい！
誰かいるのかー？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>5</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>272648</PointerOffset>
      <JapaneseText>おおっ！　そうだよそうだよ
やっと気づいてもらえたか</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>6</Id>
      <BubbleId>0</BubbleId>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>272648</PointerOffset>
      <JapaneseText>……ほう、いい面構えだ。
久しぶりにピーンときた！
君ならばやってくれそうだ</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>6</Id>
      <BubbleId>1</BubbleId>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>272712</PointerOffset>
      <JapaneseText>……中が真っ暗で何も見えねー</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>8</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>272816</PointerOffset>
      <JapaneseText>でも、人がいるみたい
……何も見えないけど。
黒い服とか着てるのかな？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>9</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>272932</PointerOffset>
      <JapaneseText>おーい！　なんだアンタ！？
はまってんのかー？　待ってろ
すぐ引き上げてやるからなー</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>10</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>273052</PointerOffset>
      <JapaneseText>いや、ちょっと違うんだ。
なんだかここは違う世界のようで
帰る手段を探しているんだよ</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>11</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>273096</PointerOffset>
      <JapaneseText>違う世界？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>12</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>273324</PointerOffset>
      <JapaneseText>んだ。次元やら空間やらを超えた、
別の世界が無数にあるらしいだ。
そのどっか１箇所だよ。たぶんな</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>4</SpeakerId>
      <Id>13</Id>
      <BubbleId>0</BubbleId>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>273324</PointerOffset>
      <JapaneseText>おめぇらが使ってる時空転移と
腹違いの弟の親戚みたいなもんだ。
あ～、やっぱり、おらは博識だよ</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>4</SpeakerId>
      <Id>13</Id>
      <BubbleId>1</BubbleId>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>273540</PointerOffset>
      <JapaneseText>そうそう、それだよ君。
なんか変なオーロラに入ったら
ここに飛ばされてしまったんだ</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>15</Id>
      <BubbleId>0</BubbleId>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>273540</PointerOffset>
      <JapaneseText>どうだろう？
なんとかならないかね？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>15</Id>
      <BubbleId>1</BubbleId>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>273540</PointerOffset>
      <JapaneseText>もしくは、そういう何とか転移に
詳しい人を呼んでもらえないかね？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>15</Id>
      <BubbleId>2</BubbleId>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>273588</PointerOffset>
      <JapaneseText>……と、くれば</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>18</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>273632</PointerOffset>
      <JapaneseText>うん、だね</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>19</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>273844</PointerOffset>
      <JapaneseText>そんな&lt;Mel&gt;&lt;Mel&gt;に見つめられると
照れてしかたないだ～よ∀
おら、頼られてるだなや～∀∀∀</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>4</SpeakerId>
      <Id>20</Id>
      <BubbleId>0</BubbleId>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>273844</PointerOffset>
      <JapaneseText>だども、裏切るようだが、
おらはあんな黒いおっさんと
らんでぶーなどまっぴらだっぺ</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>4</SpeakerId>
      <Id>20</Id>
      <BubbleId>1</BubbleId>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>273888</PointerOffset>
      <JapaneseText>ちげーよ！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>22</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>273960</PointerOffset>
      <JapaneseText>あの、ちょっとだけ
待っててください</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>23</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>274056</PointerOffset>
      <JapaneseText>おお！ありがとう。待ってるから
あわてずに行ってくれたまえ</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>24</Id>
      <Status>To Do</Status>
    </Entry>
