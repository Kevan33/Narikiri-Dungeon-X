    <Entry>
      <PointerOffset>269184</PointerOffset>
      <JapaneseText>すげぇ、すげぇ！
何、これ、超すげぇじゃん！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>1</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>269372</PointerOffset>
      <JapaneseText>だしょ～。当店自慢の
『ムービープレイヤー・クロス』は
世界で1つしかないからね</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>2</Id>
      <BubbleId>0</BubbleId>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>269372</PointerOffset>
      <JapaneseText>今まで見たものだったら、
いつでも見られるから、
遊びに来てね～∀</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>2</Id>
      <BubbleId>1</BubbleId>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>269440</PointerOffset>
      <JapaneseText>俺、来る！
また、絶対来るから！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>4</Id>
      <Status>To Do</Status>
    </Entry>
