      <PointerOffset>302092</PointerOffset>
      <JapaneseText>&lt;Dio&gt;さん、&lt;Mel&gt;さん、
どうもお久しぶりです</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>1</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>302136</PointerOffset>
      <JapaneseText>久しぶり！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>2</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>302184</PointerOffset>
      <JapaneseText>元気だった？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>3</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>302236</PointerOffset>
      <JapaneseText>はい、おかげさまで</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>4</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>302336</PointerOffset>
      <JapaneseText>ご報告します</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>4</SpeakerId>
      <Id>5</Id>
      <BubbleId>0</BubbleId>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>302336</PointerOffset>
      <JapaneseText>&lt;Red&gt;ユークリッド&lt;White&gt;方面は、
我が部隊で固めました</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>4</SpeakerId>
      <Id>5</Id>
      <BubbleId>1</BubbleId>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>302412</PointerOffset>
      <JapaneseText>ご苦労様です。
もう少し様子を
見ましょう</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>7</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>302504</PointerOffset>
      <JapaneseText>……相変わらず、
&lt;Suzu&gt;ちゃんは頭領の仕事で
忙しいんだな</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>8</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>302584</PointerOffset>
      <JapaneseText>……だね。わたしたち、
お邪魔みたい、行こ……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>9</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>302676</PointerOffset>
      <JapaneseText>&lt;Dio&gt;さん？　&lt;Mel&gt;さん？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>10</Id>
      <BubbleId>0</BubbleId>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>302676</PointerOffset>
      <JapaneseText>……行ってしまわれたのですね</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>10</Id>
      <BubbleId>1</BubbleId>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>302916</PointerOffset>
      <JapaneseText>あなたの本当の心は
まだ闇の中にある……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>5</SpeakerId>
      <Id>12</Id>
      <BubbleId>0</BubbleId>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>302916</PointerOffset>
      <JapaneseText>正気を失っていたとは言え、
実の両親に手をかけた</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>5</SpeakerId>
      <Id>12</Id>
      <BubbleId>1</BubbleId>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>302916</PointerOffset>
      <JapaneseText>それには正当な理由が
あったのかもしれない</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>5</SpeakerId>
      <Id>12</Id>
      <BubbleId>2</BubbleId>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>302916</PointerOffset>
      <JapaneseText>でも、あの時の刃の重みは。
両親を斬った時に手に感じた
鈍い重みは消えない</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>5</SpeakerId>
      <Id>12</Id>
      <BubbleId>3</BubbleId>
      <Status>To Do</Status>
    </Entry>
