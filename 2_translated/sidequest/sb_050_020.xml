    <Entry>
      <PointerOffset>272856</PointerOffset>
      <JapaneseText>ほっほっほ……
キッキョーヤ、
おぬしもワルやのぅ</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>1</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>272956</PointerOffset>
      <JapaneseText>なんのなんの、
ジョーグン様ほどでは
ございません……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>2</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>273048</PointerOffset>
      <JapaneseText>……後は向こうの棚に
入ってる書類を処分すれば……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>3</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>273128</PointerOffset>
      <JapaneseText>国庫横領の証拠は
消える、と……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>4</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>273184</PointerOffset>
      <JapaneseText>ほっほっほ……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>5</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>273248</PointerOffset>
      <JapaneseText>なんのなんの……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>6</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>273308</PointerOffset>
      <JapaneseText>むむ……何ヤツ……！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>7</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>273380</PointerOffset>
      <JapaneseText>出あえ出あえ、曲者じゃ！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>8</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>273520</PointerOffset>
      <JapaneseText>&lt;Suzu&gt;ちゃんにもらった
