    <Entry>
      <PointerOffset>288298</PointerOffset>
      <JapaneseText>４万ガルド払いますか？</JapaneseText>
      <EnglishText>Pay 40,000 Gald?</EnglishText>
      <Notes/>
      <Id>12</Id>
      <Status>Editing</Status>
