  <Strings>
    <Section>Main</Section>
    <Entry>
      <PointerOffset>267572</PointerOffset>
      <JapaneseText>おおっ！
さらにやってくれたのか！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>1</Id>
      <BubbleId>0</BubbleId>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>267572</PointerOffset>
      <JapaneseText>……じゃがすまんのう。
もうわしには渡せるものが
無いんじゃ……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>1</Id>
      <BubbleId>1</BubbleId>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>267956</PointerOffset>
      <JapaneseText>ん？　待てよ？　お前さんたち、
ここまでやるからには
相当強いんじゃよな？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>3</Id>
      <BubbleId>0</BubbleId>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>267956</PointerOffset>
      <JapaneseText>ならば、&lt;Red&gt;ヴァルハラ町&lt;White&gt;にいる
ヒリップという若者を訪ねるといい</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>3</Id>
      <BubbleId>1</BubbleId>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>267956</PointerOffset>
      <JapaneseText>やつは今、強き人間を求めておる。
お前さんたちなら
願ったり適ったりじゃ</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>3</Id>
      <BubbleId>2</BubbleId>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>267956</PointerOffset>
      <JapaneseText>たぶん報酬もスンごいのを
くれるじゃろう</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>3</Id>
      <BubbleId>3</BubbleId>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>267956</PointerOffset>
      <JapaneseText>……こんなことしか
できんですまんのう</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>3</Id>
      <BubbleId>4</BubbleId>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>267956</PointerOffset>
      <JapaneseText>じゃがありがとうよ。
お前さんたちには感謝しとるよ</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>3</Id>
      <BubbleId>5</BubbleId>
      <Status>To Do</Status>
    </Entry>
  </Strings>
