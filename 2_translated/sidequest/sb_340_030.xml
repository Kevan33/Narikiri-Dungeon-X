      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>60</Id>
      <BubbleId>0</BubbleId>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>288384</PointerOffset>
      <JapaneseText>破滅の４回戦……
ゴーーーーー、ファイトッ！！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>60</Id>
      <BubbleId>1</BubbleId>
      <Status>To Do</Status>
    </Entry>
    <Entry>
