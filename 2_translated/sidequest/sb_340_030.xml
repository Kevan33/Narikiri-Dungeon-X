      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>58</Id>
      <BubbleId>1</BubbleId>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>288384</PointerOffset>
      <JapaneseText>おまえの最期の刻は
