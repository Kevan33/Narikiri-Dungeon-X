      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>66</Id>
      <BubbleId>1</BubbleId>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>288860</PointerOffset>
