      <VoiceId>&lt;audio:VSM_250_040_042&gt;</VoiceId>
      <JapaneseText>&lt;Dio&gt;&lt;Mel&gt;</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>22</Id>
      <BubbleId>0</BubbleId>
