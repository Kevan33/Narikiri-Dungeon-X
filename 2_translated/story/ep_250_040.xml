    <Section>Main</Section>
    <Entry>
      <PointerOffset>296176</PointerOffset>
      <VoiceId>&lt;audio:VSM_250_040_001&gt;</VoiceId>
      <JapaneseText>待て！</JapaneseText>
      <EnglishText>Wait! </EnglishText>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>1</Id>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset>296256</PointerOffset>
      <VoiceId>&lt;audio:VSM_250_040_002&gt;</VoiceId>
      <JapaneseText>あ、あたしの
あげた絵……！</JapaneseText>
      <EnglishText>Th-The painting I gave them...</EnglishText>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>2</Id>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset>296336</PointerOffset>
      <VoiceId>&lt;audio:VSM_250_040_003&gt;</VoiceId>
      <JapaneseText>……まさか、
時間転移……？</JapaneseText>
      <EnglishText>...Could it be they are
about to time travel?</EnglishText>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>3</Id>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset>296404</PointerOffset>
      <VoiceId>&lt;audio:VSM_250_040_004&gt;</VoiceId>
      <JapaneseText>行こう、&lt;Dio&gt;！</JapaneseText>
      <EnglishText>Let's go after them, &lt;Dio&gt;!</EnglishText>
      <Notes/>
      <SpeakerId>4</SpeakerId>
      <Id>4</Id>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset>296484</PointerOffset>
      <VoiceId>&lt;audio:VSM_250_040_005&gt;</VoiceId>
      <JapaneseText>今度こそ捕まえて
ぶん殴る！</JapaneseText>
      <EnglishText>I'm going to catch them and
beat the daylights out of them!</EnglishText>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>5</Id>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset>296580</PointerOffset>
      <VoiceId>&lt;audio:VSM_250_040_006&gt;</VoiceId>
      <JapaneseText>待って！</JapaneseText>
      <EnglishText>Wait!</EnglishText>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>6</Id>
      <BubbleId>0</BubbleId>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset>296580</PointerOffset>
      <VoiceId>&lt;audio:VSM_250_040_007&gt;</VoiceId>
      <JapaneseText>……もうほっとこ</JapaneseText>
      <EnglishText>...Just drop it.</EnglishText>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>6</Id>
      <BubbleId>1</BubbleId>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset>296644</PointerOffset>
      <VoiceId>&lt;audio:VSM_250_040_008&gt;</VoiceId>
      <JapaneseText>なんでだよ！</JapaneseText>
      <EnglishText>What did you say!?</EnglishText>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>8</Id>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset>296828</PointerOffset>
      <VoiceId>&lt;audio:VSM_250_040_009&gt;</VoiceId>
      <JapaneseText>ぼくに、けがさせて、
きみたちを怒らせて、
追いかけてこさせて……</JapaneseText>
      <EnglishText>They barge into our house, attack me,
try to anger you and then escape...</EnglishText>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>9</Id>
      <BubbleId>0</BubbleId>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset>296828</PointerOffset>
      <VoiceId>&lt;audio:VSM_250_040_010&gt;</VoiceId>
      <JapaneseText>それがあいつらの
ねらいでしょ？
罠だよ、これは</JapaneseText>
      <EnglishText>Isn't this what they want?
This is obviously a trap.</EnglishText>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>9</Id>
      <BubbleId>1</BubbleId>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset>296888</PointerOffset>
      <VoiceId>&lt;audio:VSM_250_040_011&gt;</VoiceId>
      <JapaneseText>でも……</JapaneseText>
      <EnglishText>B-But...</EnglishText>
      <Notes/>
      <SpeakerId>4</SpeakerId>
      <Id>11</Id>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset>297012</PointerOffset>
      <VoiceId>&lt;audio:VSM_250_040_012&gt;</VoiceId>
      <JapaneseText>それに。
きみたちには
お仕事があるでしょ</JapaneseText>
      <EnglishText>Moreover, you guys have a job to do.</EnglishText>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>12</Id>
      <BubbleId>0</BubbleId>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset>297012</PointerOffset>
      <VoiceId>&lt;audio:VSM_250_040_013&gt;</VoiceId>
      <JapaneseText>ね？　ほラ</JapaneseText>
      <EnglishText>Right? Let's go.</EnglishText>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>12</Id>
      <BubbleId>1</BubbleId>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset>298536</PointerOffset>
      <VoiceId>&lt;audio:VSM_250_040_031&gt;</VoiceId>
      <JapaneseText>……どうしたの？　エト。
どうしてそんなに……</JapaneseText>
      <EnglishText>...What's going on, Eto? Why are
you persuading us to stay?</EnglishText>
      <Notes/>
      <SpeakerId>4</SpeakerId>
      <Id>14</Id>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset>298636</PointerOffset>
      <VoiceId>&lt;audio:VSM_250_040_032&gt;</VoiceId>
      <JapaneseText>わかるんだ……
なんかあるって……
嫌な感じがする</JapaneseText>
      <EnglishText>I feel...something is going on...
Something is definitely wrong.</EnglishText>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>15</Id>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset>298780</PointerOffset>
      <VoiceId>&lt;audio:VSM_250_040_033&gt;</VoiceId>
      <JapaneseText>そうかな……
うん……そうかも</JapaneseText>
      <EnglishText>Really...so that's what you feel...</EnglishText>
      <Notes/>
      <SpeakerId>4</SpeakerId>
      <Id>16</Id>
      <BubbleId>0</BubbleId>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset>298780</PointerOffset>
      <VoiceId>&lt;audio:VSM_250_040_034&gt;</VoiceId>
      <JapaneseText>よくはわかんないけど、
よくない予感がする</JapaneseText>
      <EnglishText>I'm not sure, but I have a
bad feeling about this too.</EnglishText>
      <Notes/>
      <SpeakerId>4</SpeakerId>
      <Id>16</Id>
      <BubbleId>1</BubbleId>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset>298940</PointerOffset>
      <VoiceId>&lt;audio:VSM_250_040_035&gt;</VoiceId>
      <JapaneseText>オレにはそんなんわかんねー。
けど、もしそうだとしても</JapaneseText>
      <EnglishText>No idea about this either...</EnglishText>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>18</Id>
      <BubbleId>0</BubbleId>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset>298940</PointerOffset>
      <VoiceId>&lt;audio:VSM_250_040_036&gt;</VoiceId>
      <JapaneseText>オレは行かなきゃ
なんない気がする</JapaneseText>
      <EnglishText>But, I feel like we have
to go no matter what.</EnglishText>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>18</Id>
      <BubbleId>1</BubbleId>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset>299008</PointerOffset>
      <VoiceId>&lt;audio:VSM_250_040_037&gt;</VoiceId>
      <JapaneseText>うん、そうだね</JapaneseText>
      <EnglishText>Yeah. I know.</EnglishText>
      <Notes/>
      <SpeakerId>4</SpeakerId>
      <Id>20</Id>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset>299284</PointerOffset>
      <VoiceId>&lt;audio:VSM_250_040_041&gt;</VoiceId>
      <JapaneseText>……わかった</JapaneseText>
      <EnglishText>...Ok.</EnglishText>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>21</Id>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset>299480</PointerOffset>
      <VoiceId>&lt;audio:VSM_250_040_042&gt;</VoiceId>
      <JapaneseText>&lt;Dio&gt;、&lt;Mel&gt;。
助けがほしかったら、
いつでも呼んで</JapaneseText>
      <EnglishText>&lt;Dio&gt;, &lt;Mel&gt;. If you ever need
help, just say the word, ok?</EnglishText>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>22</Id>
      <BubbleId>0</BubbleId>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset>299480</PointerOffset>
      <VoiceId>&lt;audio:VSM_250_040_043&gt;</VoiceId>
      <JapaneseText>“絶世の美女魔女&lt;Arche&gt;と
その仲間たち”はいつでも
君たちの味方だからね</JapaneseText>
      <EnglishText>You can always ask for help from
"Pretty Magical Witch &lt;Arche&gt;
Starring Uninteresting Extras."</EnglishText>
      <Notes>Uninteresting Extras</Notes>
      <SpeakerId>2</SpeakerId>
      <Id>22</Id>
      <BubbleId>1</BubbleId>
      <Status>Problematic</Status>
    </Entry>
