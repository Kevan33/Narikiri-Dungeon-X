    <Entry>
      <PointerOffset>298200</PointerOffset>
      <VoiceId>&lt;audio:VSM_090_030_007&gt;</VoiceId>
      <JapaneseText>待たぬ！わらわは命令されるのと
眠りを妨げられるのが
一番嫌いなのじゃ！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>6</Id>
      <BubbleId>1</BubbleId>
      <Status>To Do</Status>
