    <Entry>
      <PointerOffset>297736</PointerOffset>
      <VoiceId>&lt;audio:VSM_090_030_001&gt;</VoiceId>
      <JapaneseText>誰じゃ！
わらわの眠りを妨げる者は</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>1</Id>
      <OldPtr>280852</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>297844</PointerOffset>
      <VoiceId>&lt;audio:VSM_090_030_002&gt;</VoiceId>
      <JapaneseText>ウンディーネ！
私だ！　先年、おまえと
契約を結んだ……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>2</Id>
      <OldPtr>285924</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>297968</PointerOffset>
      <VoiceId>&lt;audio:VSM_090_030_003&gt;</VoiceId>
      <JapaneseText>また貴様か！
一度ならず二度までも！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>3</Id>
      <BubbleId>0</BubbleId>
      <OldPtr>286064</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>297968</PointerOffset>
      <VoiceId>&lt;audio:VSM_090_030_004&gt;</VoiceId>
      <JapaneseText>もう許さぬ！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>3</Id>
      <BubbleId>1</BubbleId>
      <OldPtr>286064</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>298052</PointerOffset>
      <VoiceId>&lt;audio:VSM_090_030_005&gt;</VoiceId>
      <JapaneseText>待ってください、
わたしたち……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>5</Id>
      <OldPtr>286316</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>298200</PointerOffset>
      <VoiceId>&lt;audio:VSM_090_030_006&gt;</VoiceId>
      <JapaneseText>待たぬ！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>6</Id>
      <BubbleId>0</BubbleId>
      <OldPtr>287280</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>298200</PointerOffset>
      <VoiceId>&lt;audio:VSM_090_030_007&gt;</VoiceId>
      <JapaneseText>わらわは命令されるのと
眠りを妨げられるのが
一番嫌いなのじゃ！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>6</Id>
      <BubbleId>1</BubbleId>
      <OldPtr>287280</OldPtr>
      <Status>To Do</Status>
    </Entry>
