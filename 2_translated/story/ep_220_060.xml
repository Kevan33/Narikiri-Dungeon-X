    <Entry>
      <PointerOffset>277976</PointerOffset>
      <VoiceId>&lt;audio:VSM_220_060_001&gt;</VoiceId>
      <JapaneseText>ちこっとここらで、
休憩する？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>1</Id>
      <OldPtr>259420</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>278268</PointerOffset>
      <VoiceId>&lt;audio:VSM_220_060_004&gt;</VoiceId>
      <JapaneseText>世界が瘴気に沈もうとしてるのに、
ここの空気がキレイなのは、
オリジンがいるからですか？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>2</Id>
      <OldPtr>262188</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>278336</PointerOffset>
      <VoiceId>&lt;audio:VSM_220_060_005&gt;</VoiceId>
      <JapaneseText>そうだと思います</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>3</Id>
      <OldPtr>262788</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>278736</PointerOffset>
      <VoiceId>&lt;audio:VSM_220_060_010&gt;</VoiceId>
      <JapaneseText>なになに？
ラブラブのプレゼント？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>4</SpeakerId>
      <Id>4</Id>
      <OldPtr>264004</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>278808</PointerOffset>
      <VoiceId>&lt;audio:VSM_220_060_011&gt;</VoiceId>
      <JapaneseText>あはは、どうかなぁ</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>5</Id>
      <OldPtr>265420</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>278884</PointerOffset>
      <VoiceId>&lt;audio:VSM_220_060_012&gt;</VoiceId>
      <JapaneseText>うわー、うらやましー∀</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>4</SpeakerId>
      <Id>6</Id>
      <OldPtr>266788</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>279244</PointerOffset>
      <VoiceId>&lt;audio:VSM_220_060_016&gt;</VoiceId>
      <JapaneseText>……でも、
この時代にもう、
あの人はいないんだよね</JapaneseText>
