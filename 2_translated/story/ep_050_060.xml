    <Entry>
      <PointerOffset>278152</PointerOffset>
      <VoiceId>&lt;audio:VSM_050_060_000&gt;</VoiceId>
      <JapaneseText>うわぁああん！！
おなか、おなかが</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>1</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>278236</PointerOffset>
      <VoiceId>&lt;audio:VSM_050_060_001&gt;</VoiceId>
      <JapaneseText>な、なんだ！？
腹痛いのか！？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>2</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>278336</PointerOffset>
      <VoiceId>&lt;audio:VSM_050_060_002&gt;</VoiceId>
      <JapaneseText>おなかすいたぁ！！
うわぁああん！！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>3</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>279072</PointerOffset>
      <VoiceId>&lt;audio:VSM_050_060_012&gt;</VoiceId>
      <JapaneseText>ああ……どうしよう……
ねぇ、エト……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>4</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>279500</PointerOffset>
      <VoiceId>&lt;audio:VSM_050_060_016&gt;</VoiceId>
      <JapaneseText>うわああああああん！！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>5</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>279572</PointerOffset>
      <VoiceId>&lt;audio:VSM_050_060_017&gt;</VoiceId>
      <JapaneseText>ああっ！　もうっ！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>6</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>279656</PointerOffset>
      <VoiceId>&lt;audio:VSM_050_060_018Z&gt;</VoiceId>
      <JapaneseText>ほら、僕の手を見てごらん</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>4</SpeakerId>
      <Id>7</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>279728</PointerOffset>
      <VoiceId>&lt;audio:VSM_050_060_019&gt;</VoiceId>
      <JapaneseText>おおっ、すげーっ……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>8</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>279804</PointerOffset>
      <VoiceId>&lt;audio:VSM_050_060_020Z&gt;</VoiceId>
      <JapaneseText>はい、おしまい</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>4</SpeakerId>
      <Id>9</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>279904</PointerOffset>
      <VoiceId>&lt;audio:VSM_050_060_021&gt;</VoiceId>
      <JapaneseText>おもろい、おもろい！
もっとやって！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>10</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>280036</PointerOffset>
      <VoiceId>&lt;audio:VSM_050_060_022Z&gt;</VoiceId>
      <JapaneseText></JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>4</SpeakerId>
      <Id>11</Id>
      <BubbleId>0</BubbleId>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>280036</PointerOffset>
      <VoiceId>&lt;audio:VSM_050_060_023Z&gt;</VoiceId>
      <JapaneseText>また今度今日はこれを食べて、
元気出してお家に帰りな</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>4</SpeakerId>
      <Id>11</Id>
      <BubbleId>1</BubbleId>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>280140</PointerOffset>
      <VoiceId>&lt;audio:VSM_050_060_024&gt;</VoiceId>
      <JapaneseText>アメちゃんだ！
あんがとー、おじさん！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>13</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>280208</PointerOffset>
      <VoiceId>&lt;audio:VSM_050_060_025&gt;</VoiceId>
      <JapaneseText>あっ。あんた……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>14</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>280296</PointerOffset>
      <VoiceId>&lt;audio:VSM_050_060_026Z&gt;</VoiceId>
      <JapaneseText>ん？　どこかで会ったかな？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>4</SpeakerId>
      <Id>15</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>280412</PointerOffset>
      <VoiceId>&lt;audio:VSM_050_060_027&gt;</VoiceId>
      <JapaneseText>&lt;Red&gt;&lt;White&gt;&lt;Claus&gt;ユークリッド村でお会いした、
さんのお友達、
ですよね？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>16</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>280492</PointerOffset>
      <VoiceId>&lt;audio:VSM_050_060_028Z&gt;</VoiceId>
      <JapaneseText>ああ、あの時の……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>4</SpeakerId>
      <Id>17</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>280560</PointerOffset>
      <VoiceId>&lt;audio:VSM_050_060_029&gt;</VoiceId>
      <JapaneseText>なぁ、今の魔術？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>18</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>280660</PointerOffset>
      <VoiceId>&lt;audio:VSM_050_060_030Z&gt;</VoiceId>
      <JapaneseText>いや、ただの手品だよ。
どうやったかは秘密</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>4</SpeakerId>
      <Id>19</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>280752</PointerOffset>
      <VoiceId>&lt;audio:VSM_050_060_031Z&gt;</VoiceId>
      <JapaneseText>ところで君たち、
どうしてここに？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>4</SpeakerId>
      <Id>20</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>280852</PointerOffset>
      <VoiceId>&lt;audio:VSM_050_060_032&gt;</VoiceId>
      <JapaneseText>えっと……バジルさんって
ヤツに会いに来て……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>21</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>280932</PointerOffset>
      <VoiceId>&lt;audio:VSM_050_060_033Z&gt;</VoiceId>
      <JapaneseText>バジルは、僕だけど</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>4</SpeakerId>
      <Id>22</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>281008</PointerOffset>
      <VoiceId>&lt;audio:VSM_050_060_034&gt;</VoiceId>
      <JapaneseText>あなたがバジルさん……？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>23</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>281092</PointerOffset>
      <VoiceId>&lt;audio:VSM_050_060_035&gt;</VoiceId>
      <JapaneseText>&lt;Claus&gt;さんに
会わなかったか？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>24</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>281176</PointerOffset>
      <VoiceId>&lt;audio:VSM_050_060_036Z&gt;</VoiceId>
      <JapaneseText>&lt;Claus&gt;え？　が
来てるのかい？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>5</SpeakerId>
      <Id>25</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>281240</PointerOffset>
      <VoiceId>&lt;audio:VSM_050_060_037Z&gt;</VoiceId>
      <JapaneseText>どこに？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>5</SpeakerId>
      <Id>26</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>281340</PointerOffset>
      <VoiceId>&lt;audio:VSM_050_060_038&gt;</VoiceId>
      <JapaneseText>ええっと……
バジルさんを探して、
どこかに……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>27</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>281404</PointerOffset>
      <VoiceId>&lt;audio:VSM_050_060_039Z&gt;</VoiceId>
      <JapaneseText>&lt;Claus&gt;！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>5</SpeakerId>
      <Id>28</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>281480</PointerOffset>
      <VoiceId>&lt;audio:VSM_050_060_040&gt;</VoiceId>
      <JapaneseText>あっ……ちょっと……！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>29</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>281548</PointerOffset>
      <VoiceId>&lt;audio:VSM_050_060_041&gt;</VoiceId>
      <JapaneseText>追いかけよーぜ</JapaneseText>
      <EnglishText/>
      <Notes/>
