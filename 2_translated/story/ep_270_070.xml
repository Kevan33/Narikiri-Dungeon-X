    <Entry>
      <PointerOffset>278016</PointerOffset>
      <VoiceId>&lt;audio:VSM_270_070_001&gt;</VoiceId>
      <JapaneseText>&lt;Dio&gt;……！？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>1</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>278092</PointerOffset>
      <VoiceId>&lt;audio:VSM_270_070_002&gt;</VoiceId>
      <JapaneseText>え……？
あ……ああ……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>2</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>278172</PointerOffset>
      <VoiceId>&lt;audio:VSM_270_070_003&gt;</VoiceId>
      <JapaneseText>&lt;Dio&gt;も、
見たんだね……？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>3</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>278304</PointerOffset>
      <VoiceId>&lt;audio:VSM_270_070_005&gt;</VoiceId>
      <JapaneseText>クルール～？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>4</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>278368</PointerOffset>
      <VoiceId>&lt;audio:VSM_270_070_006&gt;</VoiceId>
      <JapaneseText>何を見たの？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>4</SpeakerId>
      <Id>5</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>278468</PointerOffset>
      <VoiceId>&lt;audio:VSM_270_070_007&gt;</VoiceId>
      <JapaneseText>ひとりの男の子が
デリス・カーラーンにいて……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>6</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>278564</PointerOffset>
      <VoiceId>&lt;audio:VSM_270_070_008&gt;</VoiceId>
      <JapaneseText>デリス・カーラーン……
ダオスの故郷の……？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>5</SpeakerId>
      <Id>7</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>278668</PointerOffset>
      <VoiceId>&lt;audio:VSM_270_070_009&gt;</VoiceId>
      <JapaneseText>うん……パレスセダムって
国の兵隊に親を殺されてんだ</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>8</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>279036</PointerOffset>
      <VoiceId>&lt;audio:VSM_270_070_012&gt;</VoiceId>
      <JapaneseText></JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>4</SpeakerId>
      <Id>9</Id>
      <BubbleId>0</BubbleId>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>279036</PointerOffset>
      <VoiceId>&lt;audio:VSM_270_070_013&gt;</VoiceId>
      <JapaneseText></JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>4</SpeakerId>
      <Id>9</Id>
      <BubbleId>1</BubbleId>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>279036</PointerOffset>
      <VoiceId>&lt;audio:VSM_270_070_014&gt;</VoiceId>
      <JapaneseText>ダオスに聞いたことあるパレスセダムとパレスグドラ、
ふたつの国が戦争してたってその時使われた魔科学兵器が
デリス・カーラーンを
滅ぼしたってことも</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>4</SpeakerId>
      <Id>9</Id>
      <BubbleId>2</BubbleId>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>279152</PointerOffset>
      <VoiceId>&lt;audio:VSM_270_070_015&gt;</VoiceId>
      <JapaneseText>その男の子は、
パレスグドラの軍人になってた。
復讐するために……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>12</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>279260</PointerOffset>
      <VoiceId>&lt;audio:VSM_270_070_016&gt;</VoiceId>
      <JapaneseText>&lt;Dio&gt;そんなもの見せて、を
どうするつもりなんだろ……？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>5</SpeakerId>
      <Id>13</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>279360</PointerOffset>
      <VoiceId>&lt;audio:VSM_270_070_017&gt;</VoiceId>
      <JapaneseText>さぁ……
わかんねけど……
オレらは行かなきゃ……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>14</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>279420</PointerOffset>
      <VoiceId>&lt;audio:VSM_270_070_018&gt;</VoiceId>
      <JapaneseText>どこに？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>5</SpeakerId>
      <Id>15</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>279496</PointerOffset>
      <VoiceId>&lt;audio:VSM_270_070_019&gt;</VoiceId>
      <JapaneseText>『怒れる大地』ってとこ</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>16</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>279608</PointerOffset>
      <VoiceId>&lt;audio:VSM_270_070_020&gt;</VoiceId>
      <JapaneseText>あの仮面の人たちが
封印を解いたことは
何か関係ある気がする</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>17</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>279720</PointerOffset>
      <VoiceId>&lt;audio:VSM_270_070_021&gt;</VoiceId>
      <JapaneseText>でも、きみたちがもうこれ以上、
それに関わる意味があるの？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>5</SpeakerId>
      <Id>18</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>279792</PointerOffset>
      <VoiceId>&lt;audio:VSM_270_070_022&gt;</VoiceId>
      <JapaneseText>ある、気がする……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>19</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>279892</PointerOffset>
      <VoiceId>&lt;audio:VSM_270_070_023&gt;</VoiceId>
      <JapaneseText></JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>20</Id>
      <BubbleId>0</BubbleId>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>279892</PointerOffset>
      <VoiceId>&lt;audio:VSM_270_070_024&gt;</VoiceId>
      <JapaneseText>……わたしもゴメンね、エト</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>20</Id>
      <BubbleId>1</BubbleId>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>280044</PointerOffset>
      <VoiceId>&lt;audio:VSM_270_070_025&gt;</VoiceId>
      <JapaneseText></JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>4</SpeakerId>
      <Id>22</Id>
      <BubbleId>0</BubbleId>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>280044</PointerOffset>
      <VoiceId>&lt;audio:VSM_270_070_026&gt;</VoiceId>
      <JapaneseText>……いいんじゃないの。
ふたりが自分の意思で
決めたことでしょ？行かせてあげればさ</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>4</SpeakerId>
      <Id>22</Id>
      <BubbleId>1</BubbleId>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>280160</PointerOffset>
      <VoiceId>&lt;audio:VSM_270_070_027&gt;</VoiceId>
      <JapaneseText></JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>5</SpeakerId>
      <Id>24</Id>
      <BubbleId>0</BubbleId>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>280160</PointerOffset>
      <VoiceId>&lt;audio:VSM_270_070_028&gt;</VoiceId>
      <JapaneseText>……だよねうん、行こう。
『怒れる大地』にさ</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>5</SpeakerId>
      <Id>24</Id>
      <BubbleId>1</BubbleId>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>280292</PointerOffset>
      <VoiceId>&lt;audio:VSM_270_070_029&gt;</VoiceId>
      <JapaneseText></JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>4</SpeakerId>
      <Id>26</Id>
      <BubbleId>0</BubbleId>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>280292</PointerOffset>
      <VoiceId>&lt;audio:VSM_270_070_030&gt;</VoiceId>
      <JapaneseText>よし……でも、なんかふたつ
出てきたけど、
どっち先行くの？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>4</SpeakerId>
      <Id>26</Id>
      <BubbleId>1</BubbleId>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>280384</PointerOffset>
      <VoiceId>&lt;audio:VSM_270_070_031&gt;</VoiceId>
      <JapaneseText>とりあえず、近い方から
行ってみようぜ</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>28</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>280468</PointerOffset>
      <VoiceId>&lt;audio:VSM_270_070_032&gt;</VoiceId>
      <JapaneseText>子離れの時、だね、
エトちゃん</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>4</SpeakerId>
      <Id>29</Id>
      <Status>To Do</Status>
    </Entry>
