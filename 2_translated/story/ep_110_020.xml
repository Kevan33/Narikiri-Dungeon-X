      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>272916</PointerOffset>
      <VoiceId>&lt;audio:VSM_110_020_015&gt;</VoiceId>
      <JapaneseText>&lt;Cless&gt;まぁ、それはいいとしてさんを探すんでしょ</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>10</Id>
      <BubbleId>1</BubbleId>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>273008</PointerOffset>
      <VoiceId>&lt;audio:VSM_110_020_016&gt;</VoiceId>
      <JapaneseText>マクスウェルの手がかりも
見つけないと</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>12</Id>
