  <Strings>
    <Section>Main</Section>
    <Entry>
      <PointerOffset>275572</PointerOffset>
      <VoiceId>&lt;audio:VSM_010_020_001&gt;</VoiceId>
      <JapaneseText>もう……&lt;Dio&gt;……
どこに行ったんだろ……</JapaneseText>
      <EnglishText>Oh...&lt;Dio&gt;... Where are you? </EnglishText>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>1</Id>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset>275640</PointerOffset>
      <VoiceId>&lt;audio:VSM_010_020_002&gt;</VoiceId>
      <JapaneseText>平気だって、エト</JapaneseText>
      <EnglishText>It'll be okay, Eto. </EnglishText>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>2</Id>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset>275960</PointerOffset>
      <VoiceId>&lt;audio:VSM_010_020_005&gt;</VoiceId>
      <JapaneseText>きっと、いつもみたいに
けろっとした顔して
帰ってくるって</JapaneseText>
      <EnglishText>I'm sure he'll be back safe 
and sound, just like always. </EnglishText>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>3</Id>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset>276196</PointerOffset>
      <VoiceId>&lt;audio:VSM_010_020_008&gt;</VoiceId>
      <JapaneseText>ただいま～</JapaneseText>
      <EnglishText>I'm back! </EnglishText>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>4</Id>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset>276256</PointerOffset>
      <VoiceId>&lt;audio:VSM_010_020_009&gt;</VoiceId>
      <JapaneseText>ほら……</JapaneseText>
      <EnglishText>See...</EnglishText>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>5</Id>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset>276508</PointerOffset>
      <VoiceId>&lt;audio:VSM_010_020_012&gt;</VoiceId>
      <JapaneseText>いっ……てっ……！
何すんだよ！</JapaneseText>
      <EnglishText>O-Ow! What's your problem!? </EnglishText>
      <Notes/>
      <SpeakerId>4</SpeakerId>
      <Id>6</Id>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset>276612</PointerOffset>
      <VoiceId>&lt;audio:VSM_010_020_013&gt;</VoiceId>
      <JapaneseText>危ないから家を離れるなって、
いつも言ってるでしょ</JapaneseText>
      <EnglishText>How many times do we have to tell you before 
you'll listen, it's dangerous to leave the house!</EnglishText>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>7</Id>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset>276716</PointerOffset>
      <VoiceId>&lt;audio:VSM_010_020_014&gt;</VoiceId>
      <JapaneseText>分かってるって。
だから、危ないことなんて
してねーし</JapaneseText>
      <EnglishText>Geez, I know! It's not dangerous
outside at all, though. </EnglishText>
      <Notes>Review
Maybe "Geez, I know! It's really not all that dangerous outside, though."
~Gator</Notes>
      <SpeakerId>4</SpeakerId>
      <Id>8</Id>
      <Status>Problematic</Status>
    </Entry>
    <Entry>
      <PointerOffset>276796</PointerOffset>
      <VoiceId>&lt;audio:VSM_010_020_015&gt;</VoiceId>
      <JapaneseText>そういうことじゃなくて……</JapaneseText>
      <EnglishText>That's kinda not the point... </EnglishText>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>9</Id>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset>276960</PointerOffset>
      <VoiceId>&lt;audio:VSM_010_020_016&gt;</VoiceId>
      <JapaneseText>オレ、狭い家にずっと
閉じこもってんのなんて
ヤだよ</JapaneseText>
      <EnglishText>I'm always shut inside this lame house. </EnglishText>
      <Notes/>
      <SpeakerId>4</SpeakerId>
      <Id>10</Id>
      <BubbleId>0</BubbleId>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset>276960</PointerOffset>
      <VoiceId>&lt;audio:VSM_010_020_017&gt;</VoiceId>
      <JapaneseText>もっと外見たい……
いろんな街に行きたい！</JapaneseText>
      <EnglishText>I want to see more of the outside!
I want to visit other places! </EnglishText>
      <Notes/>
      <SpeakerId>4</SpeakerId>
      <Id>10</Id>
      <BubbleId>1</BubbleId>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset>277296</PointerOffset>
      <VoiceId>&lt;audio:VSM_010_020_021&gt;</VoiceId>
      <JapaneseText>ここで三人で
楽しく暮らせれば、
それでいいじゃない？</JapaneseText>
      <EnglishText>All three of us live happily here.
Isn't that good enough for you? </EnglishText>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>12</Id>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset>277412</PointerOffset>
      <VoiceId>&lt;audio:VSM_010_020_022&gt;</VoiceId>
      <JapaneseText>そりゃ、オレだって
そうできたらって思うよ！
でも、だからって……</JapaneseText>
      <EnglishText>I know what you're saying and all but still… </EnglishText>
      <Notes/>
      <SpeakerId>4</SpeakerId>
      <Id>13</Id>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset>277476</PointerOffset>
      <VoiceId>&lt;audio:VSM_010_020_023&gt;</VoiceId>
      <JapaneseText>なに……？</JapaneseText>
      <EnglishText>What was that? </EnglishText>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>14</Id>
      <Status>Proofreading</Status>
    </Entry>
