  <Strings>
    <Section>Main</Section>
    <Entry>
      <PointerOffset>268812</PointerOffset>
      <VoiceId>&lt;audio:VSM_320_010_001&gt;</VoiceId>
      <JapaneseText>あれが『&lt;Red&gt;審理の晶谷&lt;White&gt;』なんだね</JapaneseText>
      <EnglishText>So that's the &lt;Red&gt;Crystal Valley of Judgment&lt;White&gt;...</EnglishText>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>1</Id>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset>268896</PointerOffset>
      <VoiceId>&lt;audio:VSM_320_010_002&gt;</VoiceId>
      <JapaneseText>うん、
ノルンが作った審理の場所</JapaneseText>
      <EnglishText>Yes. It's a place Norn made just for our trial.</EnglishText>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>2</Id>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset>268984</PointerOffset>
      <VoiceId>&lt;audio:VSM_320_010_003&gt;</VoiceId>
      <JapaneseText>ノルンが……
きみたちの罪を裁くの？</JapaneseText>
      <EnglishText>Norn... Will she be passing
judgment on your sins?</EnglishText>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>3</Id>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset>269080</PointerOffset>
      <VoiceId>&lt;audio:VSM_320_010_004&gt;</VoiceId>
      <JapaneseText>わたしたちに
試練を与えたのは
ノルンだから</JapaneseText>
      <EnglishText>Norn was the one who gave us this trial.</EnglishText>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>4</Id>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset>269172</PointerOffset>
      <VoiceId>&lt;audio:VSM_320_010_005&gt;</VoiceId>
      <JapaneseText>もうひとりのオレらも
あそこで待ってんだ</JapaneseText>
      <EnglishText>This is our last stop.</EnglishText>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>5</Id>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset>269240</PointerOffset>
      <VoiceId>&lt;audio:VSM_320_010_006&gt;</VoiceId>
      <JapaneseText>うん……行こう</JapaneseText>
      <EnglishText>Ok...let's go...</EnglishText>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>6</Id>
      <Status>Proofreading</Status>
    </Entry>
  </Strings>
