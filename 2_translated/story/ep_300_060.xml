      <PointerOffset>298252</PointerOffset>
      <VoiceId>&lt;audio:VSM_300_060_001&gt;</VoiceId>
      <JapaneseText>マナが……
世界中のマナが
消えていく……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>1</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>298368</PointerOffset>
      <VoiceId>&lt;audio:VSM_300_060_002&gt;</VoiceId>
      <JapaneseText></JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>2</Id>
      <BubbleId>0</BubbleId>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>298368</PointerOffset>
      <VoiceId>&lt;audio:VSM_300_060_003&gt;</VoiceId>
      <JapaneseText>どうして！？どうして、発射させたの！？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>2</Id>
      <BubbleId>1</BubbleId>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>298468</PointerOffset>
      <VoiceId>&lt;audio:VSM_300_060_004&gt;</VoiceId>
      <JapaneseText>あのまま、放っておけば、
わが国は滅びていた</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>4</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>298540</PointerOffset>
      <VoiceId>&lt;audio:VSM_300_060_005&gt;</VoiceId>
      <JapaneseText>その代償が……！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>5</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>298616</PointerOffset>
      <VoiceId>&lt;audio:VSM_300_060_006&gt;</VoiceId>
      <JapaneseText>……私だって同罪よね</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>6</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>298784</PointerOffset>
      <VoiceId>&lt;audio:VSM_300_060_007&gt;</VoiceId>
      <JapaneseText></JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>7</Id>
      <BubbleId>0</BubbleId>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>298784</PointerOffset>
      <VoiceId>&lt;audio:VSM_300_060_008&gt;</VoiceId>
      <JapaneseText>……メルティアが
悪いわけじゃない戦争がすべて悪い。
オレたちをこんなふうにした
この戦争が……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>7</Id>
      <BubbleId>1</BubbleId>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>298884</PointerOffset>
      <VoiceId>&lt;audio:VSM_300_060_009&gt;</VoiceId>
      <JapaneseText>もし、あなたが
奴らに両親を
殺されてなければ</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>9</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>298988</PointerOffset>
      <VoiceId>&lt;audio:VSM_300_060_010&gt;</VoiceId>
      <JapaneseText>もし、おまえがもっと
両親に愛情を
もらっていれば</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>10</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>299052</PointerOffset>
      <VoiceId>&lt;audio:VSM_300_060_011&gt;</VoiceId>
      <JapaneseText>くっ……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>11</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>299160</PointerOffset>
      <VoiceId>&lt;audio:VSM_300_060_012&gt;</VoiceId>
