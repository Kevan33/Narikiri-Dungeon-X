    <Entry>
      <PointerOffset>299160</PointerOffset>
      <VoiceId>&lt;audio:VSM_300_060_013&gt;</VoiceId>
      <JapaneseText>メルティア……！？うっ……くっ……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>12</Id>
      <BubbleId>1</BubbleId>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>299252</PointerOffset>
      <VoiceId>&lt;audio:VSM_300_060_014&gt;</VoiceId>
      <JapaneseText>マナが……
薄くなってきてるのよ……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>14</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
