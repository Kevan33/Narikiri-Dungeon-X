    <Entry>
      <PointerOffset>299432</PointerOffset>
      <VoiceId>&lt;audio:VSM_300_060_016&gt;</VoiceId>
      <JapaneseText>……おしまいよ、この星は、
デリス・カーラーンは……お父様が願われていた
デリス・カーラーンの
平和は……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>15</Id>
      <BubbleId>1</BubbleId>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>299528</PointerOffset>
      <VoiceId>&lt;audio:VSM_300_060_017&gt;</VoiceId>
      <JapaneseText>ふっ……
デリス・カーラーンの
平和、か……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>17</Id>
      <Status>To Do</Status>
    </Entry>
