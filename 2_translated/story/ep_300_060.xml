    <Section>Main</Section>
    <Entry>
      <PointerOffset>298252</PointerOffset>
      <VoiceId>&lt;audio:VSM_300_060_001&gt;</VoiceId>
      <JapaneseText>マナが……
世界中のマナが
消えていく……</JapaneseText>
      <EnglishText>Th-The Mana....all of the Mana
in the world...it's disappearing...</EnglishText>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>1</Id>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset>298368</PointerOffset>
      <VoiceId>&lt;audio:VSM_300_060_002&gt;</VoiceId>
      <JapaneseText>どうして！？</JapaneseText>
      <EnglishText>WHY!?</EnglishText>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>2</Id>
      <BubbleId>0</BubbleId>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset>298368</PointerOffset>
      <VoiceId>&lt;audio:VSM_300_060_003&gt;</VoiceId>
      <JapaneseText>どうして、発射させたの！？</JapaneseText>
      <EnglishText>WHY DID YOU HAVE TO FIRE IT!?</EnglishText>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>2</Id>
      <BubbleId>1</BubbleId>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset>298468</PointerOffset>
      <VoiceId>&lt;audio:VSM_300_060_004&gt;</VoiceId>
      <JapaneseText>あのまま、放っておけば、
わが国は滅びていた</JapaneseText>
      <EnglishText>If I didn't, our country would have been ruined.</EnglishText>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>4</Id>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset>298540</PointerOffset>
      <VoiceId>&lt;audio:VSM_300_060_005&gt;</VoiceId>
      <JapaneseText>その代償が……！</JapaneseText>
      <EnglishText>That's just an excuse...!</EnglishText>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>5</Id>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset>298616</PointerOffset>
      <VoiceId>&lt;audio:VSM_300_060_006&gt;</VoiceId>
      <JapaneseText>……私だって同罪よね</JapaneseText>
      <EnglishText>...And...I'm just as guilty as you are...
for building this monstrosity...</EnglishText>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>6</Id>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset>298784</PointerOffset>
      <VoiceId>&lt;audio:VSM_300_060_007&gt;</VoiceId>
      <JapaneseText>……メルティアが
悪いわけじゃない</JapaneseText>
      <EnglishText>Meltia, you aren't evil.</EnglishText>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>7</Id>
      <BubbleId>0</BubbleId>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset>298784</PointerOffset>
      <VoiceId>&lt;audio:VSM_300_060_008&gt;</VoiceId>
      <JapaneseText>戦争がすべて悪い。
オレたちをこんなふうにした
この戦争が……</JapaneseText>
      <EnglishText>War is so full of hatred. Thanks
to this stupid war, my parents...</EnglishText>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>7</Id>
      <BubbleId>1</BubbleId>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset>298884</PointerOffset>
      <VoiceId>&lt;audio:VSM_300_060_009&gt;</VoiceId>
      <JapaneseText>もし、あなたが
奴らに両親を
殺されてなければ</JapaneseText>
      <EnglishText>I see. Yeah, they killed your
parents, didn't they...?</EnglishText>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>9</Id>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset>298988</PointerOffset>
      <VoiceId>&lt;audio:VSM_300_060_010&gt;</VoiceId>
      <JapaneseText>もし、おまえがもっと
両親に愛情を
もらっていれば</JapaneseText>
      <EnglishText>And thanks to the war, you were
abandoned by your parents...</EnglishText>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>10</Id>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset>299052</PointerOffset>
      <VoiceId>&lt;audio:VSM_300_060_011&gt;</VoiceId>
      <JapaneseText>くっ……</JapaneseText>
      <EnglishText>Guh...</EnglishText>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>11</Id>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset>299160</PointerOffset>
      <VoiceId>&lt;audio:VSM_300_060_012&gt;</VoiceId>
      <JapaneseText>メルティア……！？</JapaneseText>
      <EnglishText>Meltia...!?</EnglishText>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>12</Id>
      <BubbleId>0</BubbleId>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset>299160</PointerOffset>
      <VoiceId>&lt;audio:VSM_300_060_013&gt;</VoiceId>
      <JapaneseText>うっ……くっ……</JapaneseText>
      <EnglishText>Ugh...guh...</EnglishText>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>12</Id>
      <BubbleId>1</BubbleId>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset>299252</PointerOffset>
      <VoiceId>&lt;audio:VSM_300_060_014&gt;</VoiceId>
      <JapaneseText>マナが……
薄くなってきてるのよ……</JapaneseText>
      <EnglishText>The Mana...it's disappearing...</EnglishText>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>14</Id>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset>299432</PointerOffset>
      <VoiceId>&lt;audio:VSM_300_060_015&gt;</VoiceId>
      <JapaneseText>……おしまいよ、この星は、
デリス・カーラーンは……</JapaneseText>
      <EnglishText>...This is the end of our world.
This is how Derris Kharlan dies...</EnglishText>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>15</Id>
      <BubbleId>0</BubbleId>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset>299432</PointerOffset>
      <VoiceId>&lt;audio:VSM_300_060_016&gt;</VoiceId>
      <JapaneseText>お父様が願われていた
デリス・カーラーンの
平和は……</JapaneseText>
      <EnglishText>We couldn't fulfill father's wish...
for a peaceful Derris Kharlan...</EnglishText>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>15</Id>
      <BubbleId>1</BubbleId>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset>299528</PointerOffset>
      <VoiceId>&lt;audio:VSM_300_060_017&gt;</VoiceId>
      <JapaneseText>ふっ……
デリス・カーラーンの
平和、か……</JapaneseText>
      <EnglishText>Heh...peace for...Derris Kharlan...?</EnglishText>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>17</Id>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset>299680</PointerOffset>
      <VoiceId>&lt;audio:VSM_300_060_018&gt;</VoiceId>
      <JapaneseText>あなたがたは……
罰を受けなければなりません</JapaneseText>
      <EnglishText>You two...There is no fitting punishment
for the transgressions you committed...</EnglishText>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>18</Id>
      <BubbleId>0</BubbleId>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset>299680</PointerOffset>
      <VoiceId>&lt;audio:VSM_300_060_019&gt;</VoiceId>
      <JapaneseText>星を滅ぼした大罪に
報いるための罰を</JapaneseText>
      <EnglishText>You have extinguished the life of an entire
planet. Snatched away the future of millions.
For such a sin, your punishment...</EnglishText>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>18</Id>
      <BubbleId>1</BubbleId>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset>299756</PointerOffset>
      <VoiceId>&lt;audio:VSM_300_060_020&gt;</VoiceId>
      <JapaneseText>オレたちは……悪くない</JapaneseText>
      <EnglishText>No...we didn't mean to...</EnglishText>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>20</Id>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset>299832</PointerOffset>
      <VoiceId>&lt;audio:VSM_300_060_021&gt;</VoiceId>
      <JapaneseText>全部、戦争のせい……</JapaneseText>
      <EnglishText>It's all...the war's fault...</EnglishText>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>21</Id>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset>299912</PointerOffset>
      <VoiceId>&lt;audio:VSM_300_060_022&gt;</VoiceId>
      <JapaneseText>本当に……
そうでしょうか</JapaneseText>
      <EnglishText>So...you truly believe that?</EnglishText>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>22</Id>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset>300240</PointerOffset>
      <VoiceId>&lt;audio:VSM_300_060_023&gt;</VoiceId>
      <JapaneseText>……わかりました</JapaneseText>
      <EnglishText>...Understood.</EnglishText>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>23</Id>
      <BubbleId>0</BubbleId>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset>300240</PointerOffset>
      <VoiceId>&lt;audio:VSM_300_060_024&gt;</VoiceId>
      <JapaneseText>あなたがたに
機会を与えましょう</JapaneseText>
      <EnglishText>I shall grant you one last chance.</EnglishText>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>23</Id>
      <BubbleId>1</BubbleId>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset>300240</PointerOffset>
      <VoiceId>&lt;audio:VSM_300_060_025&gt;</VoiceId>
      <JapaneseText>私はあなたがたを子どもに戻し、
異なる時、異なる場所へ
飛ばします</JapaneseText>
      <EnglishText>You will live again. In a different place.
In a different time. Where no conflict
will taint your judgment.</EnglishText>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>23</Id>
      <BubbleId>2</BubbleId>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset>300240</PointerOffset>
      <VoiceId>&lt;audio:VSM_300_060_026&gt;</VoiceId>
      <JapaneseText>……そして試練を受けなさい。
そこで私は見定めましょう</JapaneseText>
      <EnglishText>...And then you will be tested. I shall
make sure proper judgment is passed.</EnglishText>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>23</Id>
      <BubbleId>3</BubbleId>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset>300240</PointerOffset>
      <VoiceId>&lt;audio:VSM_300_060_027&gt;</VoiceId>
      <JapaneseText>あなたがたの本質が
善なのか悪なのか</JapaneseText>
      <EnglishText>I shall judge whether your essence is evil or good.</EnglishText>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>23</Id>
      <BubbleId>4</BubbleId>
      <Status>Proofreading</Status>
    </Entry>
