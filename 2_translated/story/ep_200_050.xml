    <Entry>
      <PointerOffset>275476</PointerOffset>
      <VoiceId>&lt;audio:VSM_200_050_001&gt;</VoiceId>
      <JapaneseText>ヴォルトがいるのって
まだ先か？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>1</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>275608</PointerOffset>
      <VoiceId>&lt;audio:VSM_200_050_002&gt;</VoiceId>
      <JapaneseText>私もヴォルトには会ったこと
がないので正確ではありませんが、
あと少しだと思います</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>2</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>275728</PointerOffset>
      <VoiceId>&lt;audio:VSM_200_050_003&gt;</VoiceId>
      <JapaneseText>指輪にマナが少しずつ
溜まってきてる……
精霊さんが近くにいる証拠だね</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>3</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>275812</PointerOffset>
      <VoiceId>&lt;audio:VSM_200_050_004&gt;</VoiceId>
      <JapaneseText>その指輪、便利だよな、
いろいろ</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>4</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>275932</PointerOffset>
      <VoiceId>&lt;audio:VSM_200_050_005&gt;</VoiceId>
      <JapaneseText>&lt;Rody&gt;もしかして、それくれた人、
さんのこと、
好きだったんですか？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>4</SpeakerId>
      <Id>5</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>276076</PointerOffset>
      <VoiceId>&lt;audio:VSM_200_050_006&gt;</VoiceId>
      <JapaneseText></JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>6</Id>
      <BubbleId>0</BubbleId>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>276076</PointerOffset>
      <VoiceId>&lt;audio:VSM_200_050_007&gt;</VoiceId>
      <JapaneseText>まさか。
んなわけないって相手は大人だし、
私はまだお子ちゃまだったしさ</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>6</Id>
      <BubbleId>1</BubbleId>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>276152</PointerOffset>
      <VoiceId>&lt;audio:VSM_200_050_008&gt;</VoiceId>
      <JapaneseText>どんな人だったんですか？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>4</SpeakerId>
      <Id>8</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>276352</PointerOffset>
      <VoiceId>&lt;audio:VSM_200_050_010&gt;</VoiceId>
      <JapaneseText></JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>9</Id>
      <BubbleId>0</BubbleId>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>276352</PointerOffset>
      <VoiceId>&lt;audio:VSM_200_050_011&gt;</VoiceId>
      <JapaneseText>……うーん……
冷たい人？でも、温かい人</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>9</Id>
      <BubbleId>1</BubbleId>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>276420</PointerOffset>
      <VoiceId>&lt;audio:VSM_200_050_012&gt;</VoiceId>
      <JapaneseText>なんだ、そりゃ</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>11</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>276576</PointerOffset>
      <VoiceId>&lt;audio:VSM_200_050_013&gt;</VoiceId>
      <JapaneseText></JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>12</Id>
      <BubbleId>0</BubbleId>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>276576</PointerOffset>
      <VoiceId>&lt;audio:VSM_200_050_014&gt;</VoiceId>
      <JapaneseText>必死に探してても、
出てこないくせに寂しくて空見上げてたら
そっと出てくる気まぐれさん</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>12</Id>
      <BubbleId>1</BubbleId>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>276648</PointerOffset>
      <VoiceId>&lt;audio:VSM_200_050_015&gt;</VoiceId>
      <JapaneseText>なんかヤなヤツだな</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>14</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>276724</PointerOffset>
      <VoiceId>&lt;audio:VSM_200_050_016&gt;</VoiceId>
      <JapaneseText>きっと照れ屋さんなんだよ</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>4</SpeakerId>
      <Id>15</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>276884</PointerOffset>
      <VoiceId>&lt;audio:VSM_200_050_017&gt;</VoiceId>
      <JapaneseText></JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>16</Id>
      <BubbleId>0</BubbleId>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>276884</PointerOffset>
      <VoiceId>&lt;audio:VSM_200_050_018&gt;</VoiceId>
      <JapaneseText>私もヤなヤツって思ったで、ボソボソ話すんだよ、
空には絶対、動かない星が
あるってことを</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>16</Id>
      <BubbleId>1</BubbleId>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>276980</PointerOffset>
      <VoiceId>&lt;audio:VSM_200_050_019&gt;</VoiceId>
      <JapaneseText>あ、それって
“北の真ん中星”のことだろ？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>18</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>277176</PointerOffset>
      <VoiceId>&lt;audio:VSM_200_050_020&gt;</VoiceId>
      <JapaneseText></JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>19</Id>
      <BubbleId>0</BubbleId>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>277176</PointerOffset>
      <VoiceId>&lt;audio:VSM_200_050_021&gt;</VoiceId>
      <JapaneseText>そう。そん時は私、
何それって思ったのでも、ある時ね、森の奥で迷子に
なって泣きそうになってたら、
ふとあいつの話を思い出して</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>19</Id>
      <BubbleId>1</BubbleId>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>277268</PointerOffset>
      <VoiceId>&lt;audio:VSM_200_050_022&gt;</VoiceId>
      <JapaneseText>その星を目印に
家に戻ったわけですね？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>21</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>277732</PointerOffset>
      <VoiceId>&lt;audio:VSM_200_050_027&gt;</VoiceId>
      <JapaneseText></JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>22</Id>
      <BubbleId>0</BubbleId>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>277732</PointerOffset>
      <VoiceId>&lt;audio:VSM_200_050_028&gt;</VoiceId>
      <JapaneseText>うん。まぁ、そんな話さぁ、行こ行こ、
“北の真ん中星”目印にさ</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>22</Id>
      <BubbleId>1</BubbleId>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>277828</PointerOffset>
      <VoiceId>&lt;audio:VSM_200_050_029&gt;</VoiceId>
      <JapaneseText>目印にと言っても、
ここは洞窟ですから……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>24</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>277904</PointerOffset>
      <VoiceId>&lt;audio:VSM_200_050_030&gt;</VoiceId>
      <JapaneseText>たとえ話だよ。ほらほら</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>25</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>278020</PointerOffset>
      <VoiceId>&lt;audio:VSM_200_050_031&gt;</VoiceId>
      <JapaneseText>どんな心細い時にも
いつもあなたの記憶が
私とともにあるんだ……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>26</Id>
      <Status>To Do</Status>
    </Entry>
  </Strings>
