    <Entry>
      <PointerOffset>267780</PointerOffset>
      <JapaneseText>下ばかり見てると
いろいろ落ちてるよ</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>1</Id>
      <BubbleId>0</BubbleId>
      <OldPtr>258452</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>267780</PointerOffset>
      <JapaneseText>あ、今日はこのバッグを
この店で見つけてね</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>1</Id>
      <BubbleId>1</BubbleId>
      <OldPtr>258452</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>267872</PointerOffset>
      <JapaneseText>あ……これキミたちの？
