    <Entry>
      <PointerOffset>281200</PointerOffset>
      <JapaneseText>&lt;Cless&gt;様、
おかえりなさい</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>1</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>281276</PointerOffset>
      <JapaneseText>……ただいま。
村の人たちは
いかがですか？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>2</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>281408</PointerOffset>
      <JapaneseText>ええ、みんな元気に
やっています</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>3</Id>
      <BubbleId>0</BubbleId>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>281408</PointerOffset>
      <JapaneseText>それよりも、
他の町からたくさんの人が
押しかけて大変ですよ</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>3</Id>
      <BubbleId>1</BubbleId>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>281464</PointerOffset>
      <JapaneseText>どういうことですか？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>5</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>281548</PointerOffset>
      <JapaneseText>いえ、&lt;Cless&gt;様の評判を
みんな聞きつけて</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>6</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>281592</PointerOffset>
      <JapaneseText>僕の……？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>7</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>281712</PointerOffset>
      <JapaneseText>このあいだの&lt;Red&gt;ヴァルハラ&lt;White&gt;での
戦いでいっきに&lt;Cless&gt;様の
名前が広まったんです</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>8</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>281800</PointerOffset>
      <JapaneseText>あれ……？　&lt;Cless&gt;さんって
時空戦士で有名なんだよね？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>9</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>281876</PointerOffset>
      <JapaneseText>この時代にはダオスは
現れてないからだろ？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>4</SpeakerId>
      <Id>10</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>281920</PointerOffset>
      <JapaneseText>そうなの？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>11</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>282040</PointerOffset>
      <JapaneseText>歴史の本には、&lt;Claus&gt;さんの
いた時代と、&lt;Suzu&gt;ちゃんの時代の
ことしか書いてなかったぜ</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>4</SpeakerId>
      <Id>12</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>282144</PointerOffset>
      <JapaneseText>それなのに、この時代の
&lt;Cless&gt;さんがダオスを倒した
時空戦士になったの？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>13</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>282252</PointerOffset>
      <JapaneseText>君たちも知らないんだな</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>14</Id>
      <BubbleId>0</BubbleId>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>282252</PointerOffset>
      <JapaneseText>２年前、ダオスが
復活しそうになった事件を</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>14</Id>
      <BubbleId>1</BubbleId>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>282304</PointerOffset>
      <JapaneseText>そんなことが……？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>4</SpeakerId>
      <Id>16</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>282396</PointerOffset>
      <JapaneseText>その時に、その復活を
阻止したのが、
この&lt;Cless&gt;様だ</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>17</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>282440</PointerOffset>
      <JapaneseText>へぇ……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>4</SpeakerId>
      <Id>18</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>282568</PointerOffset>
      <JapaneseText>&lt;Cless&gt;様は英雄として、
ユークリッド大陸では
有名だけど</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>19</Id>
      <BubbleId>0</BubbleId>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>282568</PointerOffset>
      <JapaneseText>他の地域では、
まだいまいちだね</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>19</Id>
      <BubbleId>1</BubbleId>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>282648</PointerOffset>
      <JapaneseText>え、えっと……
その話はもう
いいんじゃないかな</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>21</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>282736</PointerOffset>
      <JapaneseText>で、そのこの村に
住みたいといって
来た人たちはどこに？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>22</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>282856</PointerOffset>
      <JapaneseText>それがですね、泊まる場所も
ないので、その辺りの原っぱ
で野宿してもらってます</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>23</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>282932</PointerOffset>
      <JapaneseText>村の外って……
魔物がいるんじゃねのか？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>4</SpeakerId>
      <Id>24</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>283152</PointerOffset>
      <JapaneseText>その辺りは抜かりない。
ちゃんと&lt;Red&gt;トーティス&lt;White&gt;遊撃隊が
護衛に出ているよ</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>25</Id>
      <BubbleId>0</BubbleId>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>283152</PointerOffset>
      <JapaneseText>……それで……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>25</Id>
      <BubbleId>1</BubbleId>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>283152</PointerOffset>
      <JapaneseText>住みたいという人たちが
住めるように村を広げようと
辺りの調査をしていたら</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>25</Id>
      <BubbleId>2</BubbleId>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>283152</PointerOffset>
      <JapaneseText>こんなものが……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>25</Id>
      <BubbleId>3</BubbleId>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>283252</PointerOffset>
      <JapaneseText>こ、これは……！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>29</Id>
      <BubbleId>0</BubbleId>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>283252</PointerOffset>
      <JapaneseText>エターナルソード……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>29</Id>
      <BubbleId>1</BubbleId>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>283252</PointerOffset>
      <JapaneseText>どうしてこんなところに……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>29</Id>
      <BubbleId>2</BubbleId>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>283316</PointerOffset>
      <JapaneseText>ああ……
私が埋めておいたんだ</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>5</SpeakerId>
      <Id>32</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>283424</PointerOffset>
      <JapaneseText>&lt;Claus&gt;さんが……！？
だってエターナルソードは
責任持って封印するって……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>33</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>283696</PointerOffset>
      <JapaneseText>確かにそう約束した。
だが、この剣は君こそが
持つにふさわしいと思ってね</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>5</SpeakerId>
      <Id>34</Id>
      <BubbleId>0</BubbleId>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>283696</PointerOffset>
      <JapaneseText>いつか、この村で活躍する
だろう君の手に渡るよう
この村の近くに埋めたのだ</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>5</SpeakerId>
      <Id>34</Id>
      <BubbleId>1</BubbleId>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>283696</PointerOffset>
      <JapaneseText>時間転移の能力だけは
若干弱めてあるがな</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>5</SpeakerId>
      <Id>34</Id>
      <BubbleId>2</BubbleId>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>283696</PointerOffset>
      <JapaneseText>まさか、私がいる時に、
こんな形で
掘り返されるとは……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>5</SpeakerId>
      <Id>34</Id>
      <BubbleId>3</BubbleId>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>283768</PointerOffset>
      <JapaneseText>こうして握ると……
色々思い出すな……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>38</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>283836</PointerOffset>
      <JapaneseText>ああ、その剣は
君にこそふさわしい</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>5</SpeakerId>
      <Id>39</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>283896</PointerOffset>
      <JapaneseText>そ、そんな&lt;Claus&gt;さん……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>40</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>284044</PointerOffset>
      <JapaneseText>こんな手紙が
一緒に……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>41</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>284312</PointerOffset>
      <JapaneseText>『&lt;Cless&gt;へ……』
……僕宛て？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>42</Id>
      <BubbleId>0</BubbleId>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>284312</PointerOffset>
      <JapaneseText>『この剣が、
いつか、この村で活躍する
君の手に渡ればいいと思う』</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>42</Id>
      <BubbleId>1</BubbleId>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>284312</PointerOffset>
      <JapaneseText>『時間転移の能力だけは
若干弱めてはあるが、
君の助けになるだろう』</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>42</Id>
      <BubbleId>2</BubbleId>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>284312</PointerOffset>
      <JapaneseText>『……これは君こそが
手にするにふさわしい剣だ』</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>42</Id>
      <BubbleId>3</BubbleId>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>284312</PointerOffset>
      <JapaneseText>『&lt;Claus&gt;・Ｆ・レスター』</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>42</Id>
      <BubbleId>4</BubbleId>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>284360</PointerOffset>
      <JapaneseText>&lt;Claus&gt;さん……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>47</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>284440</PointerOffset>
      <JapaneseText>それは……&lt;Cless&gt;さんが
ダオスを倒した時の剣？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>4</SpeakerId>
      <Id>48</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>284528</PointerOffset>
      <JapaneseText>ああ……うん……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>49</Id>
      <BubbleId>0</BubbleId>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>284528</PointerOffset>
      <JapaneseText>こうして握ると……
色々思い出すな……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>49</Id>
      <BubbleId>1</BubbleId>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>284576</PointerOffset>
      <JapaneseText>そうですね……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>6</SpeakerId>
      <Id>51</Id>
      <Status>To Do</Status>
    </Entry>
