    <Entry>
      <PointerOffset>293416</PointerOffset>
      <VoiceId>&lt;audio:VSM_050_030_002&gt;</VoiceId>
      <JapaneseText>左様。儂に何か用か？
小さき者よ</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>2</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
