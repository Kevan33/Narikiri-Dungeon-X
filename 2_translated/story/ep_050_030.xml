      <PointerOffset>293328</PointerOffset>
      <VoiceId>&lt;audio:VSM_050_030_001&gt;</VoiceId>
      <JapaneseText>あなたがイフリートさんですか？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>1</Id>
      <Status>To Do</Status>
