    <Entry>
      <PointerOffset>293548</PointerOffset>
      <VoiceId>&lt;audio:VSM_050_030_004&gt;</VoiceId>
      <JapaneseText>わたしたちに
力を貸してほしいんです今、とても困っていて……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>3</Id>
      <BubbleId>1</BubbleId>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>293632</PointerOffset>
      <VoiceId>&lt;audio:VSM_050_030_005&gt;</VoiceId>
      <JapaneseText>儂が人間の手助けを？　断る</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>5</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>294068</PointerOffset>
      <VoiceId>&lt;audio:VSM_050_030_009&gt;</VoiceId>
      <JapaneseText></JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>6</Id>
      <BubbleId>0</BubbleId>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>294068</PointerOffset>
      <VoiceId>&lt;audio:VSM_050_030_010&gt;</VoiceId>
      <JapaneseText>どうしてもと言う覚悟があるなら、
力づくで従わせるがよい骨の髄まで溶かし尽くす
儂の炎を恐れぬのならばな！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>6</Id>
      <BubbleId>1</BubbleId>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>294128</PointerOffset>
      <VoiceId>&lt;audio:VSM_050_030_011&gt;</VoiceId>
      <JapaneseText>くっ……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>8</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>294464</PointerOffset>
      <VoiceId>&lt;audio:VSM_050_030_015&gt;</VoiceId>
      <JapaneseText>ここまで来て、
引き返せないもの、ね？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>9</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>294532</PointerOffset>
      <VoiceId>&lt;audio:VSM_050_030_016&gt;</VoiceId>
      <JapaneseText>だよな……うん</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>10</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>294596</PointerOffset>
      <VoiceId>&lt;audio:VSM_050_030_017&gt;</VoiceId>
      <JapaneseText>クルール！！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>4</SpeakerId>
      <Id>11</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>294764</PointerOffset>
      <VoiceId>&lt;audio:VSM_050_030_019&gt;</VoiceId>
      <JapaneseText>やはり来るのか、
小さき者！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>12</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>294836</PointerOffset>
      <VoiceId>&lt;audio:VSM_050_030_020&gt;</VoiceId>
      <JapaneseText>ああ、覚悟、しろ！</JapaneseText>
      <EnglishText/>
      <Notes/>
