    <Entry>
      <PointerOffset>307648</PointerOffset>
      <VoiceId>&lt;audio:VSM_130_020_001&gt;</VoiceId>
      <JapaneseText>あら？
ちょっと待っていてくださいね</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>1</Id>
      <OldPtr>278648</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>307720</PointerOffset>
      <VoiceId>&lt;audio:VSM_130_020_002&gt;</VoiceId>
      <JapaneseText>あれが、&lt;Mint&gt;さん？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>2</Id>
      <OldPtr>278788</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>307784</PointerOffset>
      <VoiceId>&lt;audio:VSM_130_020_003&gt;</VoiceId>
      <JapaneseText>みたいだね</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>3</Id>
      <OldPtr>278928</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>308428</PointerOffset>
      <VoiceId>&lt;audio:VSM_130_020_010&gt;</VoiceId>
      <JapaneseText>それでね、
聞いてくださいよ、
&lt;Mint&gt;様</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>4</SpeakerId>
      <Id>4</Id>
      <BubbleId>0</BubbleId>
      <OldPtr>279068</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>308428</PointerOffset>
      <VoiceId>&lt;audio:VSM_130_020_011&gt;</VoiceId>
      <JapaneseText>&lt;Red&gt;オリーブヴィレッジ&lt;White&gt;に住む
うちの嫁が私のことを
名前で呼ぶんですよ</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>4</SpeakerId>
      <Id>4</Id>
      <BubbleId>1</BubbleId>
      <OldPtr>279068</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>308632</PointerOffset>
      <VoiceId>&lt;audio:VSM_130_020_013&gt;</VoiceId>
      <JapaneseText>グチグチグチグチ……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>4</SpeakerId>
      <Id>6</Id>
      <OldPtr>279572</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>308764</PointerOffset>
      <VoiceId>&lt;audio:VSM_130_020_014&gt;</VoiceId>
      <JapaneseText>……そうなんですよ、
また、それで息子も
自分の部屋に引きこもって……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>4</SpeakerId>
      <Id>7</Id>
      <OldPtr>280120</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>308832</PointerOffset>
      <VoiceId>&lt;audio:VSM_130_020_015&gt;</VoiceId>
      <JapaneseText>ええ、それで？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>5</SpeakerId>
      <Id>8</Id>
      <OldPtr>280260</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>308908</PointerOffset>
      <VoiceId>&lt;audio:VSM_130_020_016&gt;</VoiceId>
      <JapaneseText>それでね……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>4</SpeakerId>
      <Id>9</Id>
      <OldPtr>280400</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>309072</PointerOffset>
      <VoiceId>&lt;audio:VSM_130_020_017&gt;</VoiceId>
      <JapaneseText>はぁ……すっきりした</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>4</SpeakerId>
      <Id>10</Id>
      <BubbleId>0</BubbleId>
      <OldPtr>281004</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>309072</PointerOffset>
      <VoiceId>&lt;audio:VSM_130_020_018&gt;</VoiceId>
      <JapaneseText>いつも私の悩み聞いてくれて、
ありがとうございます、&lt;Mint&gt;様</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>4</SpeakerId>
      <Id>10</Id>
      <BubbleId>1</BubbleId>
      <OldPtr>281004</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>309132</PointerOffset>
      <VoiceId>&lt;audio:VSM_130_020_019&gt;</VoiceId>
      <JapaneseText>いえ……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>5</SpeakerId>
      <Id>12</Id>
      <OldPtr>281200</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>309232</PointerOffset>
      <VoiceId>&lt;audio:VSM_130_020_020&gt;</VoiceId>
      <JapaneseText>あ、そう言えば、
最近、肩が凝るのよ</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>4</SpeakerId>
      <Id>13</Id>
      <OldPtr>281464</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>309360</PointerOffset>
      <VoiceId>&lt;audio:VSM_130_020_021&gt;</VoiceId>
      <JapaneseText>それでは、法術を
かけておきましょう</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>5</SpeakerId>
      <Id>14</Id>
      <BubbleId>0</BubbleId>
      <OldPtr>281604</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>309360</PointerOffset>
      <VoiceId>&lt;audio:VSM_130_020_022&gt;</VoiceId>
      <JapaneseText>ファーストエイド……！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>5</SpeakerId>
      <Id>14</Id>
      <BubbleId>1</BubbleId>
      <OldPtr>281604</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>309460</PointerOffset>
      <VoiceId>&lt;audio:VSM_130_020_023&gt;</VoiceId>
      <JapaneseText>さすが&lt;Mint&gt;様だわ。
すっきりした</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>4</SpeakerId>
      <Id>16</Id>
      <OldPtr>282384</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>309556</PointerOffset>
      <VoiceId>&lt;audio:VSM_130_020_024&gt;</VoiceId>
      <JapaneseText>なんか一方的に
喋って帰ってったような……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>6</SpeakerId>
      <Id>17</Id>
      <OldPtr>283484</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>309704</PointerOffset>
      <VoiceId>&lt;audio:VSM_130_020_025&gt;</VoiceId>
      <JapaneseText>はい、お待たせしました</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>5</SpeakerId>
      <Id>18</Id>
      <BubbleId>0</BubbleId>
      <OldPtr>283856</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>309704</PointerOffset>
      <VoiceId>&lt;audio:VSM_130_020_026&gt;</VoiceId>
      <JapaneseText>今日は、どうなさいましたか？
どこか、悪いところが……？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>5</SpeakerId>
      <Id>18</Id>
      <BubbleId>1</BubbleId>
      <OldPtr>283856</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>309804</PointerOffset>
      <VoiceId>&lt;audio:VSM_130_020_027&gt;</VoiceId>
      <JapaneseText>いや、オレらは
悪いのと違くて……
ええっと……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>6</SpeakerId>
      <Id>20</Id>
      <OldPtr>284692</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>309904</PointerOffset>
      <VoiceId>&lt;audio:VSM_130_020_028&gt;</VoiceId>
      <JapaneseText>&lt;Cless&gt;さんが
帰ってきたので
お知らせにきたんです</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>21</Id>
      <OldPtr>285216</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>309976</PointerOffset>
      <VoiceId>&lt;audio:VSM_130_020_029&gt;</VoiceId>
      <JapaneseText>&lt;Cless&gt;さんが……！？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>5</SpeakerId>
      <Id>22</Id>
      <OldPtr>285532</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>310084</PointerOffset>
      <VoiceId>&lt;audio:VSM_130_020_030&gt;</VoiceId>
      <JapaneseText>ダメですよね。
私はここを離れるわけには
いきませんから</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>5</SpeakerId>
      <Id>23</Id>
      <OldPtr>287336</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>310152</PointerOffset>
      <VoiceId>&lt;audio:VSM_130_020_031&gt;</VoiceId>
      <JapaneseText>どうしてですか？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>24</Id>
      <OldPtr>287692</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>310276</PointerOffset>
      <VoiceId>&lt;audio:VSM_130_020_032&gt;</VoiceId>
      <JapaneseText>いつ、私を頼りにして
来てくださる方がいらっしゃるか、
わからないですから</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>5</SpeakerId>
      <Id>25</Id>
      <OldPtr>287900</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>310472</PointerOffset>
      <VoiceId>&lt;audio:VSM_130_020_034&gt;</VoiceId>
      <JapaneseText>でも、&lt;Mint&gt;さんは
&lt;Cless&gt;さんに
会いたいんですよね</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>26</Id>
      <OldPtr>288040</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>310696</PointerOffset>
      <VoiceId>&lt;audio:VSM_130_020_036&gt;</VoiceId>
      <JapaneseText>いいんです、
&lt;Cless&gt;さんはわかって
くださってますし……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>5</SpeakerId>
      <Id>27</Id>
      <OldPtr>288180</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>310828</PointerOffset>
      <VoiceId>&lt;audio:VSM_130_020_037&gt;</VoiceId>
      <JapaneseText>あ～！　じれってー！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>6</SpeakerId>
      <Id>28</Id>
      <BubbleId>0</BubbleId>
      <OldPtr>288552</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>310828</PointerOffset>
      <VoiceId>&lt;audio:VSM_130_020_038&gt;</VoiceId>
      <JapaneseText>他のやつなんてどーでも
いいじゃんかよ！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>6</SpeakerId>
      <Id>28</Id>
      <BubbleId>1</BubbleId>
      <OldPtr>288552</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>311100</PointerOffset>
      <VoiceId>&lt;audio:VSM_130_020_041&gt;</VoiceId>
      <JapaneseText>じゃなくて、
あんたはどうしたいんだよ！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>6</SpeakerId>
      <Id>30</Id>
      <OldPtr>289368</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>311236</PointerOffset>
      <VoiceId>&lt;audio:VSM_130_020_042&gt;</VoiceId>
      <JapaneseText>私……？　それは……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>5</SpeakerId>
      <Id>31</Id>
      <BubbleId>0</BubbleId>
      <OldPtr>289772</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>311236</PointerOffset>
      <VoiceId>&lt;audio:VSM_130_020_043&gt;</VoiceId>
      <JapaneseText>私だって&lt;Cless&gt;さんには
会いたいです。でも……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>5</SpeakerId>
      <Id>31</Id>
      <BubbleId>1</BubbleId>
      <OldPtr>289772</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>311348</PointerOffset>
      <VoiceId>&lt;audio:VSM_130_020_044&gt;</VoiceId>
      <JapaneseText>でも、じゃねーよ！
だったら、会いに
行きゃいいじゃねーか！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>6</SpeakerId>
      <Id>33</Id>
      <OldPtr>290088</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>311416</PointerOffset>
      <VoiceId>&lt;audio:VSM_130_020_045&gt;</VoiceId>
      <JapaneseText>アルベルトさん</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>34</Id>
      <OldPtr>290856</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>311528</PointerOffset>
      <VoiceId>&lt;audio:VSM_130_020_046&gt;</VoiceId>
      <JapaneseText>あ～～～い、&lt;Mel&gt;&lt;Mel&gt;～～、
おらのこと呼んだべか∀</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>7</SpeakerId>
      <Id>35</Id>
      <OldPtr>291796</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>311596</PointerOffset>
      <VoiceId>&lt;audio:VSM_130_020_047&gt;</VoiceId>
      <JapaneseText>服、お願いします</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>36</Id>
      <OldPtr>291936</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>311716</PointerOffset>
      <VoiceId>&lt;audio:VSM_130_020_048&gt;</VoiceId>
      <JapaneseText>かわいい&lt;Mel&gt;&lt;Mel&gt;が
今度はどんなかわえぇ～
服着るんだべや？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>7</SpeakerId>
      <Id>37</Id>
      <OldPtr>292232</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>311808</PointerOffset>
      <VoiceId>&lt;audio:VSM_130_020_049&gt;</VoiceId>
      <JapaneseText>いてぇっ！！
いきなり、何しやがんだ！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>6</SpeakerId>
      <Id>38</Id>
      <OldPtr>294832</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>311884</PointerOffset>
      <VoiceId>&lt;audio:VSM_130_020_050&gt;</VoiceId>
      <JapaneseText>ファーストエイド……！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>39</Id>
      <OldPtr>295488</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>311952</PointerOffset>
      <VoiceId>&lt;audio:VSM_130_020_051&gt;</VoiceId>
      <JapaneseText>あなたも法術を？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>5</SpeakerId>
      <Id>40</Id>
      <OldPtr>296572</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>312084</PointerOffset>
      <VoiceId>&lt;audio:VSM_130_020_052&gt;</VoiceId>
      <JapaneseText>ええ、少しだけですけど</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>41</Id>
      <BubbleId>0</BubbleId>
      <OldPtr>296992</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>312084</PointerOffset>
      <VoiceId>&lt;audio:VSM_130_020_053&gt;</VoiceId>
      <JapaneseText>わたしでよければ、
お留守番、しますよ？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>41</Id>
      <BubbleId>1</BubbleId>
      <OldPtr>296992</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>312180</PointerOffset>
      <VoiceId>&lt;audio:VSM_130_020_054&gt;</VoiceId>
      <JapaneseText>でも、&lt;Cless&gt;さんも
お忙しいでしょうし……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>5</SpeakerId>
      <Id>43</Id>
      <OldPtr>297376</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>312264</PointerOffset>
      <VoiceId>&lt;audio:VSM_130_020_055&gt;</VoiceId>
      <JapaneseText>そっちは、
オレがなんとかする！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>6</SpeakerId>
      <Id>44</Id>
      <OldPtr>297572</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>312352</PointerOffset>
      <VoiceId>&lt;audio:VSM_130_020_056&gt;</VoiceId>
      <JapaneseText>あっ！　ちょっと&lt;Dio&gt;！
待って！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>45</Id>
      <OldPtr>298376</OldPtr>
      <Status>To Do</Status>
