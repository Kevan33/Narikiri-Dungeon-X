    <Entry>
      <PointerOffset>271472</PointerOffset>
      <VoiceId>&lt;audio:VSM_280_015_001&gt;</VoiceId>
      <JapaneseText>ダオス、言ったよな、
インネンがなんとかって……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>1</Id>
      <OldPtr>258452</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>271544</PointerOffset>
      <VoiceId>&lt;audio:VSM_280_015_002&gt;</VoiceId>
      <JapaneseText>因縁を追え、だよね</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>2</Id>
      <OldPtr>258592</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>271700</PointerOffset>
      <VoiceId>&lt;audio:VSM_280_015_003&gt;</VoiceId>
      <JapaneseText>ダオスと
あの仮面のヤツって
関係あんのかな……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>3</Id>
      <BubbleId>0</BubbleId>
      <OldPtr>258732</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>271700</PointerOffset>
      <VoiceId>&lt;audio:VSM_280_015_004&gt;</VoiceId>
      <JapaneseText>&lt;Rody&gt;は、
なんか心当たりないのか？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>3</Id>
      <BubbleId>1</BubbleId>
      <OldPtr>258732</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>271944</PointerOffset>
      <VoiceId>&lt;audio:VSM_280_015_006&gt;</VoiceId>
      <JapaneseText>あんな仮面してたら
あいつらが誰かわかんないし</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>5</Id>
      <BubbleId>0</BubbleId>
      <OldPtr>258872</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>271944</PointerOffset>
      <VoiceId>&lt;audio:VSM_280_015_007&gt;</VoiceId>
      <JapaneseText>それに……あいつ、
肝心なこと、あんま
話さなかったしな</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>5</Id>
      <BubbleId>1</BubbleId>
      <OldPtr>258872</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>272012</PointerOffset>
      <VoiceId>&lt;audio:VSM_280_015_008&gt;</VoiceId>
      <JapaneseText>そうなんですか？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>7</Id>
      <OldPtr>259012</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>272116</PointerOffset>
      <VoiceId>&lt;audio:VSM_280_015_009&gt;</VoiceId>
      <JapaneseText>それどころか、私が
ほとんど一方的に
話してた気がする</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>8</Id>
      <OldPtr>259152</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>272204</PointerOffset>
      <VoiceId>&lt;audio:VSM_280_015_010&gt;</VoiceId>
      <JapaneseText>でも……あれ？
何話したんだっけ？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>9</Id>
      <OldPtr>259292</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>272276</PointerOffset>
      <VoiceId>&lt;audio:VSM_280_015_011&gt;</VoiceId>
      <JapaneseText>覚えてないんですか？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>10</Id>
      <OldPtr>259432</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>272436</PointerOffset>
      <VoiceId>&lt;audio:VSM_280_015_012&gt;</VoiceId>
      <JapaneseText>夢中になっていろいろ
話した覚えはあるんだけど</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>11</Id>
      <BubbleId>0</BubbleId>
      <OldPtr>259572</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>272436</PointerOffset>
      <VoiceId>&lt;audio:VSM_280_015_013&gt;</VoiceId>
      <JapaneseText>あはは、肝心の話の中身が
全然思い出せないや</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>11</Id>
      <BubbleId>1</BubbleId>
      <OldPtr>259572</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>272500</PointerOffset>
      <VoiceId>&lt;audio:VSM_280_015_014&gt;</VoiceId>
      <JapaneseText>なんだ、それ</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>13</Id>
      <OldPtr>259712</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>272712</PointerOffset>
      <VoiceId>&lt;audio:VSM_280_015_015&gt;</VoiceId>
      <JapaneseText>あ、空の星には
たくさんの種類があって……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>14</Id>
      <BubbleId>0</BubbleId>
      <OldPtr>259852</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>272712</PointerOffset>
      <VoiceId>&lt;audio:VSM_280_015_016&gt;</VoiceId>
      <JapaneseText>……ってこれ、
ダオスがしてた話だし</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>14</Id>
      <BubbleId>1</BubbleId>
      <OldPtr>259852</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>272712</PointerOffset>
      <VoiceId>&lt;audio:VSM_280_015_017&gt;</VoiceId>
      <JapaneseText>なんか、あいつのしてた話は
よく覚えてんだよね</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>14</Id>
      <BubbleId>2</BubbleId>
      <OldPtr>259852</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>272824</PointerOffset>
      <VoiceId>&lt;audio:VSM_280_015_018&gt;</VoiceId>
      <JapaneseText>太陽の周りを回るアセリアは遊星、
その周りを回るのが衛星だ</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>4</SpeakerId>
      <Id>17</Id>
      <OldPtr>259992</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>272904</PointerOffset>
      <VoiceId>&lt;audio:VSM_280_015_019&gt;</VoiceId>
      <JapaneseText>デリス・カーラーンは衛星？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>18</Id>
      <OldPtr>260132</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>272984</PointerOffset>
      <VoiceId>&lt;audio:VSM_280_015_020&gt;</VoiceId>
      <JapaneseText>デリス・カーラーンは彗星だ</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>4</SpeakerId>
      <Id>19</Id>
      <OldPtr>260272</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>273044</PointerOffset>
      <VoiceId>&lt;audio:VSM_280_015_021&gt;</VoiceId>
      <JapaneseText>彗星？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>20</Id>
      <OldPtr>260412</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>273216</PointerOffset>
      <VoiceId>&lt;audio:VSM_280_015_022&gt;</VoiceId>
      <JapaneseText>純然たるマナの塊星（かたまりぼし）</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>4</SpeakerId>
      <Id>21</Id>
      <BubbleId>0</BubbleId>
      <OldPtr>260552</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>273216</PointerOffset>
      <VoiceId>&lt;audio:VSM_280_015_023&gt;</VoiceId>
      <JapaneseText>ガス化したマナは
太陽から吹く風を受けて
尾を引き、彗星になる……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>4</SpeakerId>
      <Id>21</Id>
      <BubbleId>1</BubbleId>
      <OldPtr>260552</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>273292</PointerOffset>
      <VoiceId>&lt;audio:VSM_280_015_024&gt;</VoiceId>
      <JapaneseText>へぇ……綺麗なんだろうね</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>23</Id>
      <OldPtr>260692</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>273456</PointerOffset>
      <VoiceId>&lt;audio:VSM_280_015_025&gt;</VoiceId>
      <JapaneseText>１００年に１度、我が母星は
このアセリアに近づく</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>4</SpeakerId>
      <Id>24</Id>
      <BubbleId>0</BubbleId>
      <OldPtr>260832</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>273456</PointerOffset>
      <VoiceId>&lt;audio:VSM_280_015_026&gt;</VoiceId>
      <JapaneseText>この星から見えるのは
５０年以上も先のことだ</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>4</SpeakerId>
      <Id>24</Id>
      <BubbleId>1</BubbleId>
      <OldPtr>260832</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>273544</PointerOffset>
      <VoiceId>&lt;audio:VSM_280_015_027&gt;</VoiceId>
      <JapaneseText>その頃、私、
もうおばあちゃんだね</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>26</Id>
      <OldPtr>260972</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>273824</PointerOffset>
      <VoiceId>&lt;audio:VSM_280_015_028&gt;</VoiceId>
      <JapaneseText>ダオスは初め全然、
話してくれなくて、
ずっと私だけが喋ってたけど</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>27</Id>
      <BubbleId>0</BubbleId>
      <OldPtr>261112</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>273824</PointerOffset>
      <VoiceId>&lt;audio:VSM_280_015_029&gt;</VoiceId>
      <JapaneseText>少しずつ、本当に少しずつ
自分のことを話すようになった</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>27</Id>
      <BubbleId>1</BubbleId>
      <OldPtr>261112</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>273824</PointerOffset>
      <VoiceId>&lt;audio:VSM_280_015_030&gt;</VoiceId>
      <JapaneseText>デリス・カーラーンとか、
『大いなる実り』とか、
旅の苦難とかのことを……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>27</Id>
      <BubbleId>2</BubbleId>
      <OldPtr>261112</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>274008</PointerOffset>
      <VoiceId>&lt;audio:VSM_280_015_031&gt;</VoiceId>
      <JapaneseText>その話を聞いて、
私はダオスのために何か
してあげたいって思った</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>30</Id>
      <BubbleId>0</BubbleId>
      <OldPtr>261252</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>274008</PointerOffset>
      <VoiceId>&lt;audio:VSM_280_015_032&gt;</VoiceId>
      <JapaneseText>『大いなる実り』を、
なんとかしてあげたかったんだ</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>30</Id>
      <BubbleId>1</BubbleId>
      <OldPtr>261252</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>274096</PointerOffset>
      <VoiceId>&lt;audio:VSM_280_015_033&gt;</VoiceId>
      <JapaneseText>手に入れる方法
なんかあったのか？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>32</Id>
      <OldPtr>261392</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>274360</PointerOffset>
      <VoiceId>&lt;audio:VSM_280_015_034&gt;</VoiceId>
      <JapaneseText>なかったよ。私は
まだほんの子どもだったんだから</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>33</Id>
      <BubbleId>0</BubbleId>
      <OldPtr>261532</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>274360</PointerOffset>
      <VoiceId>&lt;audio:VSM_280_015_035&gt;</VoiceId>
      <JapaneseText>ま、大人になったからって
何もできてないんだけどさ</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>33</Id>
      <BubbleId>1</BubbleId>
      <OldPtr>261532</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>274360</PointerOffset>
      <VoiceId>&lt;audio:VSM_280_015_036&gt;</VoiceId>
      <JapaneseText>ダオスを止めることも……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>33</Id>
      <BubbleId>2</BubbleId>
      <OldPtr>261532</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>274360</PointerOffset>
      <VoiceId>&lt;audio:VSM_280_015_037&gt;</VoiceId>
      <JapaneseText>……真実を知ることさえも
怖くて……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>33</Id>
      <BubbleId>3</BubbleId>
      <OldPtr>261532</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>274476</PointerOffset>
      <VoiceId>&lt;audio:VSM_280_015_038&gt;</VoiceId>
      <JapaneseText>ダオスと仮面の連中の話だったのに、
つまんない話になっちゃったね</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>37</Id>
      <OldPtr>261672</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>274592</PointerOffset>
      <VoiceId>&lt;audio:VSM_280_015_039&gt;</VoiceId>
      <JapaneseText>いえ……いつかちゃんと
ダオスに会って話が聞ければ
……いいですね</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>38</Id>
      <OldPtr>261812</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>274712</PointerOffset>
      <VoiceId>&lt;audio:VSM_280_015_040&gt;</VoiceId>
      <JapaneseText>次、会って何も言わねーで
逃げやがったら、オレらで
とっ捕まえてやるよ</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>39</Id>
      <OldPtr>261952</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>274800</PointerOffset>
      <VoiceId>&lt;audio:VSM_280_015_041&gt;</VoiceId>
      <JapaneseText>ありがと、
双子ちゃんはいい子だね</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>40</Id>
      <OldPtr>262092</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>274860</PointerOffset>
      <VoiceId>&lt;audio:VSM_280_015_042&gt;</VoiceId>
      <JapaneseText>……♪</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>5</SpeakerId>
      <Id>41</Id>
      <OldPtr>262232</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>274932</PointerOffset>
      <VoiceId>&lt;audio:VSM_280_015_043&gt;</VoiceId>
      <JapaneseText>さっ、先に進もうぜ</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>42</Id>
      <OldPtr>262372</OldPtr>
      <Status>To Do</Status>
    </Entry>
