      <VoiceId>&lt;audio:VSM_260_040_005&gt;</VoiceId>
      <JapaneseText>それはわたしたちじゃありません！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>5</Id>
