  <Strings>
    <Section>Main</Section>
    <Entry>
      <PointerOffset>276696</PointerOffset>
      <VoiceId>&lt;audio:VSM_220_040_000&gt;</VoiceId>
      <JapaneseText>……今のって……
何なんだ……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>1</Id>
      <OldPtr>259808</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>276788</PointerOffset>
      <VoiceId>&lt;audio:VSM_220_040_001&gt;</VoiceId>
      <JapaneseText>瘴気……魔界のことわりで
できたガスです</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>2</Id>
      <OldPtr>260208</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>276980</PointerOffset>
      <VoiceId>&lt;audio:VSM_220_040_003&gt;</VoiceId>
      <JapaneseText>魔界の住民たちが
生命活動を行ううえで
ある程度必要なものだそうです</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>3</Id>
      <OldPtr>261416</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>277068</PointerOffset>
      <VoiceId>&lt;audio:VSM_220_040_004&gt;</VoiceId>
      <JapaneseText>でも、人間には
すごく毒なんだよね</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>4</Id>
      <OldPtr>261612</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>277240</PointerOffset>
      <VoiceId>&lt;audio:VSM_220_040_005&gt;</VoiceId>
      <JapaneseText>私の仲間たちはみんな、
あれにやられたのでしょう</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>4</SpeakerId>
      <Id>5</Id>
      <BubbleId>0</BubbleId>
      <OldPtr>261808</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>277240</PointerOffset>
      <VoiceId>&lt;audio:VSM_220_040_006&gt;</VoiceId>
      <JapaneseText>でも、間違いありません、
あの洞窟にプルートがいます</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>4</SpeakerId>
      <Id>5</Id>
      <BubbleId>1</BubbleId>
      <OldPtr>261808</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>277348</PointerOffset>
      <VoiceId>&lt;audio:VSM_220_040_007&gt;</VoiceId>
      <JapaneseText>だとすると、
なんとかして入る方法が
あればいいんだけど</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>5</SpeakerId>
      <Id>7</Id>
      <OldPtr>262360</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>277428</PointerOffset>
      <VoiceId>&lt;audio:VSM_220_040_008&gt;</VoiceId>
      <JapaneseText>瘴気をなくす方法、
ですか？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>6</SpeakerId>
      <Id>8</Id>
      <OldPtr>262828</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>277520</PointerOffset>
      <VoiceId>&lt;audio:VSM_220_040_009&gt;</VoiceId>
      <JapaneseText>……オリジンに
頼むというのはどうだろう</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>7</SpeakerId>
      <Id>9</Id>
      <OldPtr>263456</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>277684</PointerOffset>
      <VoiceId>&lt;audio:VSM_220_040_010&gt;</VoiceId>
      <JapaneseText>オリジンって……
精霊の王様だろ？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>10</Id>
      <BubbleId>0</BubbleId>
      <OldPtr>264308</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>277684</PointerOffset>
      <VoiceId>&lt;audio:VSM_220_040_011&gt;</VoiceId>
      <JapaneseText>昔話によく出てくんぜ？
今のアセリアの基礎を
作ったヤツだって</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>10</Id>
      <BubbleId>1</BubbleId>
      <OldPtr>264308</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>277876</PointerOffset>
      <VoiceId>&lt;audio:VSM_220_040_013&gt;</VoiceId>
      <JapaneseText>あの瘴気を浄化するには、
万物を司るくらいの力でないと
難しいかもしれない</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>7</SpeakerId>
      <Id>12</Id>
      <OldPtr>264588</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>277988</PointerOffset>
      <VoiceId>&lt;audio:VSM_220_040_014&gt;</VoiceId>
      <JapaneseText>オリジンだったら、
世界中の瘴気も
浄化できるんじゃないかな？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>8</SpeakerId>
      <Id>13</Id>
      <OldPtr>264956</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>278056</PointerOffset>
      <VoiceId>&lt;audio:VSM_220_040_015&gt;</VoiceId>
      <JapaneseText>かもしれないな</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>7</SpeakerId>
      <Id>14</Id>
      <OldPtr>265256</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>278152</PointerOffset>
      <VoiceId>&lt;audio:VSM_220_040_016&gt;</VoiceId>
      <JapaneseText>でもさ、オリジン、
また出てきてくれるかな？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>15</Id>
      <OldPtr>265452</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>278284</PointerOffset>
      <VoiceId>&lt;audio:VSM_220_040_017&gt;</VoiceId>
      <JapaneseText>オリジンが姿を見せたのは
ラグナロクの時とダオス戦役の
時だけだと言いますから……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>16</Id>
      <OldPtr>266188</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>278384</PointerOffset>
      <VoiceId>&lt;audio:VSM_220_040_018&gt;</VoiceId>
      <JapaneseText>ダメかどうかは、
やってみないと
わかんねーだろ</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>17</Id>
      <OldPtr>266624</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>278468</PointerOffset>
      <VoiceId>&lt;audio:VSM_220_040_019&gt;</VoiceId>
      <JapaneseText>そう、だね。
行ってみましょう</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>6</SpeakerId>
      <Id>18</Id>
      <OldPtr>267488</OldPtr>
      <Status>To Do</Status>
    </Entry>
  </Strings>
