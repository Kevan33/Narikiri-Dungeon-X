    <Entry>
      <PointerOffset>300180</PointerOffset>
      <VoiceId>&lt;audio:VSM_300_070_001&gt;</VoiceId>
      <JapaneseText>これって……</JapaneseText>
      <EnglishText>This is...</EnglishText>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>1</Id>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset>300256</PointerOffset>
      <VoiceId>&lt;audio:VSM_300_070_002&gt;</VoiceId>
      <JapaneseText>夢……？
ううん、幻……</JapaneseText>
      <EnglishText>A dream...? No, an illusion perhaps?</EnglishText>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>2</Id>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset>300340</PointerOffset>
      <VoiceId>&lt;audio:VSM_300_070_003&gt;</VoiceId>
      <JapaneseText>今のは、ふたりにも
見えたんだね</JapaneseText>
      <EnglishText>So you two saw it this time.</EnglishText>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>3</Id>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset>300456</PointerOffset>
      <VoiceId>&lt;audio:VSM_300_070_004&gt;</VoiceId>
      <JapaneseText>ディオス、メルティアって
&lt;Dio&gt;くんと、
&lt;Mel&gt;ちゃんのこと……</JapaneseText>
      <EnglishText>Dios and Meltia... They
are &lt;Dio&gt; and &lt;Mel&gt;'s...</EnglishText>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>4</Id>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset>300516</PointerOffset>
      <VoiceId>&lt;audio:VSM_300_070_005&gt;</VoiceId>
      <JapaneseText>ああ……</JapaneseText>
      <EnglishText>Yeah...</EnglishText>
      <Notes/>
      <SpeakerId>4</SpeakerId>
      <Id>5</Id>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset>300608</PointerOffset>
      <VoiceId>&lt;audio:VSM_300_070_006&gt;</VoiceId>
      <JapaneseText>デリス・カーラーンを
滅ぼしたのは君たち</JapaneseText>
      <EnglishText>You...you were the ones that
destroyed Derris Kharlan...</EnglishText>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>6</Id>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset>300668</PointerOffset>
      <VoiceId>&lt;audio:VSM_300_070_007&gt;</VoiceId>
      <JapaneseText>そうだ</JapaneseText>
      <EnglishText>Indeed.</EnglishText>
      <Notes/>
      <SpeakerId>5</SpeakerId>
      <Id>7</Id>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset>300884</PointerOffset>
      <VoiceId>&lt;audio:VSM_300_070_008&gt;</VoiceId>
      <JapaneseText>違う！　違うよ！</JapaneseText>
      <EnglishText>No! That's wrong!</EnglishText>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>8</Id>
      <BubbleId>0</BubbleId>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset>300884</PointerOffset>
      <VoiceId>&lt;audio:VSM_300_070_009&gt;</VoiceId>
      <JapaneseText>あんなのはぼくの
カワイイ双子じゃない！</JapaneseText>
      <EnglishText>Those can't be my fair pair of twins!</EnglishText>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>8</Id>
      <BubbleId>1</BubbleId>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset>300884</PointerOffset>
      <VoiceId>&lt;audio:VSM_300_070_010&gt;</VoiceId>
      <JapaneseText>だって、ぼくは、ふたりが
うーーんとちっちゃい頃から
知ってるんだかラ！</JapaneseText>
      <EnglishText>I know them very, very, VERY well!
I know they wouldn't do that!</EnglishText>
      <Notes>Tl check</Notes>
      <SpeakerId>2</SpeakerId>
      <Id>8</Id>
      <BubbleId>2</BubbleId>
      <Status>Problematic</Status>
    </Entry>
    <Entry>
      <PointerOffset>300964</PointerOffset>
      <VoiceId>&lt;audio:VSM_300_070_011&gt;</VoiceId>
      <JapaneseText>ううん……
あれはわたしたち</JapaneseText>
      <EnglishText>It's ok...I know that was us...</EnglishText>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>11</Id>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset>301060</PointerOffset>
      <VoiceId>&lt;audio:VSM_300_070_012&gt;</VoiceId>
      <JapaneseText>だよ。オレらは
決着つけなきゃ
いけないんだ</JapaneseText>
      <EnglishText>Yeah. It's time for us
to make things right.</EnglishText>
      <Notes/>
      <SpeakerId>4</SpeakerId>
      <Id>12</Id>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset>301144</PointerOffset>
      <VoiceId>&lt;audio:VSM_300_070_013&gt;</VoiceId>
      <JapaneseText>どうやって
決着をつけるのだ</JapaneseText>
      <EnglishText>And how do you plan to do that?</EnglishText>
      <Notes/>
      <SpeakerId>6</SpeakerId>
      <Id>13</Id>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset>301240</PointerOffset>
      <VoiceId>&lt;audio:VSM_300_070_014&gt;</VoiceId>
      <JapaneseText>その、うっとうしいの取れよ、
わかってんだ</JapaneseText>
      <EnglishText>You can drop that irritating act!</EnglishText>
      <Notes/>
      <SpeakerId>4</SpeakerId>
      <Id>14</Id>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset>301308</PointerOffset>
      <VoiceId>&lt;audio:VSM_300_070_015&gt;</VoiceId>
      <JapaneseText>きみたちは……！</JapaneseText>
      <EnglishText>You are...!</EnglishText>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>15</Id>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset>301408</PointerOffset>
      <VoiceId>&lt;audio:VSM_300_070_016&gt;</VoiceId>
      <JapaneseText>よくも簡単に
決着をつけるなどと
言えたものだ</JapaneseText>
      <EnglishText>How dare you say all that
like it's no big deal?</EnglishText>
      <Notes>Tl check</Notes>
      <SpeakerId>7</SpeakerId>
      <Id>16</Id>
      <Status>Problematic</Status>
    </Entry>
    <Entry>
      <PointerOffset>301496</PointerOffset>
      <VoiceId>&lt;audio:VSM_300_070_017&gt;</VoiceId>
      <JapaneseText>星を一個まるまる
滅ぼしたくせに</JapaneseText>
      <EnglishText>You're trying to make up for
destroying an entire planet?</EnglishText>
      <Notes/>
      <SpeakerId>8</SpeakerId>
      <Id>17</Id>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset>301592</PointerOffset>
      <VoiceId>&lt;audio:VSM_300_070_018&gt;</VoiceId>
      <JapaneseText>きみたちがやったんでしょ！
他人事みたいに！</JapaneseText>
      <EnglishText>But you were the ones who destroyed
Derris Kharlan! Stop acting like it's
someone else's fault!</EnglishText>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>18</Id>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset>301688</PointerOffset>
      <VoiceId>&lt;audio:VSM_300_070_019&gt;</VoiceId>
      <JapaneseText>悪いのは戦争よ！
わたしたちじゃない！</JapaneseText>
      <EnglishText>It was the war's fault, not ours!</EnglishText>
      <Notes/>
      <SpeakerId>8</SpeakerId>
      <Id>19</Id>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset>301840</PointerOffset>
      <VoiceId>&lt;audio:VSM_300_070_020&gt;</VoiceId>
      <JapaneseText>そうだ……
ノルンがおれたちを……
おまえたちを裁いてくれる</JapaneseText>
      <EnglishText>That's right... We...you
will be judged by Norn.</EnglishText>
      <Notes/>
      <SpeakerId>7</SpeakerId>
      <Id>20</Id>
      <BubbleId>0</BubbleId>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset>301840</PointerOffset>
      <VoiceId>&lt;audio:VSM_300_070_021&gt;</VoiceId>
      <JapaneseText>来いよ、審理の場へ</JapaneseText>
      <EnglishText>Now come. To the place of the trial.</EnglishText>
      <Notes/>
      <SpeakerId>7</SpeakerId>
      <Id>20</Id>
      <BubbleId>1</BubbleId>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset>301944</PointerOffset>
      <VoiceId>&lt;audio:VSM_300_070_022&gt;</VoiceId>
      <JapaneseText>あ……逃げた……！
&lt;Dio&gt;、&lt;Mel&gt;、
追わないと……</JapaneseText>
      <EnglishText>They ran away...! And...you
two aren't going after them...</EnglishText>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>22</Id>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset>302008</PointerOffset>
      <VoiceId>&lt;audio:VSM_300_070_023&gt;</VoiceId>
      <JapaneseText>大丈夫だって</JapaneseText>
      <EnglishText>It's just fine.</EnglishText>
      <Notes/>
      <SpeakerId>4</SpeakerId>
      <Id>23</Id>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset>302112</PointerOffset>
      <VoiceId>&lt;audio:VSM_300_070_024&gt;</VoiceId>
      <JapaneseText>あれはわたしたちだもん。
どこ行ったかはすぐにわかる</JapaneseText>
      <EnglishText>They're us. We will know where they went.</EnglishText>
      <Notes>Tl check</Notes>
      <SpeakerId>3</SpeakerId>
      <Id>24</Id>
      <Status>Problematic</Status>
    </Entry>
    <Entry>
      <PointerOffset>302204</PointerOffset>
      <VoiceId>&lt;audio:VSM_300_070_025&gt;</VoiceId>
      <JapaneseText>あなたはそこで
ただ黙って見てるだけ？</JapaneseText>
      <EnglishText>...Are you going to just
silently wait there?</EnglishText>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>25</Id>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset>302312</PointerOffset>
      <VoiceId>&lt;audio:VSM_300_070_026&gt;</VoiceId>
      <JapaneseText>今のこの身は&lt;Red&gt;ダオス城&lt;White&gt;で眠る
我が残存思念の夢に過ぎぬ</JapaneseText>
      <EnglishText>The real Dhaos in this time period sleeps
in Dhaos's Castle. I am but a lingering
recollection of dreams long gone.</EnglishText>
      <Notes/>
      <SpeakerId>5</SpeakerId>
      <Id>26</Id>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset>302396</PointerOffset>
      <VoiceId>&lt;audio:VSM_300_070_027&gt;</VoiceId>
      <JapaneseText>あいつは……
&lt;Red&gt;ダオス城&lt;White&gt;に……</JapaneseText>
      <EnglishText>He is in...&lt;Red&gt;Dhaos's Castle&lt;White&gt;...</EnglishText>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>27</Id>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset>302472</PointerOffset>
      <VoiceId>&lt;audio:VSM_300_070_028&gt;</VoiceId>
      <JapaneseText>ダオスに
会いに行こうぜ</JapaneseText>
      <EnglishText>Let's go meet with Dhaos!</EnglishText>
      <Notes/>
      <SpeakerId>4</SpeakerId>
      <Id>28</Id>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset>302548</PointerOffset>
      <VoiceId>&lt;audio:VSM_300_070_029&gt;</VoiceId>
      <JapaneseText>ダオスに？
どうして！？</JapaneseText>
      <EnglishText>With Dhaos? Why!?</EnglishText>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>29</Id>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset>302704</PointerOffset>
      <VoiceId>&lt;audio:VSM_300_070_030&gt;</VoiceId>
      <JapaneseText>決着つける前に、
確かめたいことが
あるから、わたしたち</JapaneseText>
      <EnglishText>Before we bring an end to this,
we need to understand everything.</EnglishText>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>30</Id>
      <BubbleId>0</BubbleId>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset>302704</PointerOffset>
      <VoiceId>&lt;audio:VSM_300_070_031&gt;</VoiceId>
      <JapaneseText>ね？　いいでしょ？
&lt;Rody&gt;さん</JapaneseText>
      <EnglishText>Don't you think, Miss &lt;Rody&gt;?</EnglishText>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>30</Id>
      <BubbleId>1</BubbleId>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset>302808</PointerOffset>
      <VoiceId>&lt;audio:VSM_300_070_032&gt;</VoiceId>
      <JapaneseText>え？　私？
……いいっていうか、
確かめたいのは……</JapaneseText>
      <EnglishText>Eh? Me? ...Even if you're asking me,
you've already made up your mind.</EnglishText>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>32</Id>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset>302868</PointerOffset>
      <VoiceId>&lt;audio:VSM_300_070_033&gt;</VoiceId>
      <JapaneseText>いいだろ</JapaneseText>
      <EnglishText>Yeah.</EnglishText>
      <Notes/>
      <SpeakerId>4</SpeakerId>
      <Id>33</Id>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset>302992</PointerOffset>
      <VoiceId>&lt;audio:VSM_300_070_034&gt;</VoiceId>
      <JapaneseText>……ダオスはたぶん、
この世界の南西のはじにある、
&lt;Red&gt;ダオス城&lt;White&gt;にいるよ</JapaneseText>
      <EnglishText>...&lt;Red&gt;Dhaos's Castle&lt;White&gt; is southwest of here.</EnglishText>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>34</Id>
      <Status>Proofreading</Status>
    </Entry>
