    <Entry>
      <PointerOffset>270176</PointerOffset>
      <VoiceId>&lt;audio:VSM_260_020_001&gt;</VoiceId>
      <JapaneseText>ここが、&lt;Red&gt;焔王の楔&lt;White&gt;……？</JapaneseText>
      <EnglishText>So this is the &lt;Red&gt;Linchpin of the Lord of Fire&lt;White&gt;, 
right?</EnglishText>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>1</Id>
      <Status>Editing</Status>
    </Entry>
    <Entry>
      <PointerOffset>270236</PointerOffset>
      <VoiceId>&lt;audio:VSM_260_020_002&gt;</VoiceId>
      <JapaneseText>さぁ……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>2</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>270320</PointerOffset>
      <VoiceId>&lt;audio:VSM_260_020_003&gt;</VoiceId>
      <JapaneseText>入り口が凍ってて
入れないよ？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>3</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>270384</PointerOffset>
      <VoiceId>&lt;audio:VSM_260_020_004&gt;</VoiceId>
      <JapaneseText>クルールー！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>4</SpeakerId>
      <Id>4</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>270504</PointerOffset>
      <VoiceId>&lt;audio:VSM_260_020_005&gt;</VoiceId>
      <JapaneseText>別の方向にも
違うもんが見えたぞ</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>5</Id>
      <BubbleId>0</BubbleId>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>270504</PointerOffset>
      <VoiceId>&lt;audio:VSM_260_020_006&gt;</VoiceId>
      <JapaneseText>あれじゃねーかな</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>5</Id>
      <BubbleId>1</BubbleId>
      <Status>To Do</Status>
    </Entry>
    <Entry>
