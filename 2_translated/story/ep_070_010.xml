    <Entry>
      <PointerOffset>279636</PointerOffset>
      <VoiceId>&lt;audio:VSM_070_010_001&gt;</VoiceId>
      <JapaneseText>勝手に入ってきたな～</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>1</Id>
      <OldPtr>259952</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>279700</PointerOffset>
      <VoiceId>&lt;audio:VSM_070_010_002&gt;</VoiceId>
      <JapaneseText>な、なに！？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>2</Id>
      <OldPtr>261688</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>279816</PointerOffset>
      <VoiceId>&lt;audio:VSM_070_010_003&gt;</VoiceId>
      <JapaneseText>ノームか？
私だ、召喚師の&lt;Claus&gt;だ！
かつておまえと契約した……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>3</Id>
      <OldPtr>261968</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>279916</PointerOffset>
      <VoiceId>&lt;audio:VSM_070_010_004&gt;</VoiceId>
      <JapaneseText>うるさ～い～！
気持ち悪いのら～！
許さないのら～</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>4</Id>
      <OldPtr>262108</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>279984</PointerOffset>
      <VoiceId>&lt;audio:VSM_070_010_005&gt;</VoiceId>
      <JapaneseText>ファぁあっ！！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>4</SpeakerId>
      <Id>5</Id>
      <OldPtr>262564</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>280052</PointerOffset>
      <VoiceId>&lt;audio:VSM_070_010_006&gt;</VoiceId>
      <JapaneseText>エト！！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>5</SpeakerId>
      <Id>6</Id>
      <OldPtr>263676</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>280212</PointerOffset>
      <VoiceId>&lt;audio:VSM_070_010_008&gt;</VoiceId>
      <JapaneseText>どういうことだ。
精霊が突然、
人を襲うなんて……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>7</Id>
      <OldPtr>264744</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>280308</PointerOffset>
      <VoiceId>&lt;audio:VSM_070_010_009&gt;</VoiceId>
      <JapaneseText>人じゃなくて、正確には
『妖精』さんだっけ？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>6</SpeakerId>
      <Id>8</Id>
      <OldPtr>265148</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>280376</PointerOffset>
      <VoiceId>&lt;audio:VSM_070_010_010&gt;</VoiceId>
      <JapaneseText>エト！　エト！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>9</Id>
      <OldPtr>265344</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>280476</PointerOffset>
      <VoiceId>&lt;audio:VSM_070_010_011&gt;</VoiceId>
      <JapaneseText>どうしよう……エト……
どこ行っちゃったの……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>7</SpeakerId>
      <Id>10</Id>
      <OldPtr>265808</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>280628</PointerOffset>
      <VoiceId>&lt;audio:VSM_070_010_013&gt;</VoiceId>
      <JapaneseText>だ、だいじょーぶか、&lt;Mel&gt;！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>11</Id>
      <OldPtr>266216</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>280700</PointerOffset>
      <VoiceId>&lt;audio:VSM_070_010_014&gt;</VoiceId>
      <JapaneseText>え……あ、うん……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>7</SpeakerId>
      <Id>12</Id>
      <OldPtr>266572</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>280760</PointerOffset>
      <VoiceId>&lt;audio:VSM_070_010_015&gt;</VoiceId>
      <JapaneseText>よし……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>13</Id>
      <OldPtr>266820</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>280860</PointerOffset>
      <VoiceId>&lt;audio:VSM_070_010_016&gt;</VoiceId>
      <JapaneseText>ク、&lt;Claus&gt;さん、
あの野郎、この洞窟の奥だよな？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>14</Id>
      <OldPtr>267172</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>280944</PointerOffset>
      <VoiceId>&lt;audio:VSM_070_010_017&gt;</VoiceId>
      <JapaneseText>ノームか？
ああ、たぶんな……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>15</Id>
      <OldPtr>267416</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>281036</PointerOffset>
      <VoiceId>&lt;audio:VSM_070_010_018&gt;</VoiceId>
      <JapaneseText>し、しっかりしろ、&lt;Mel&gt;！
行くぞ……！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>16</Id>
      <OldPtr>268036</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>281108</PointerOffset>
      <VoiceId>&lt;audio:VSM_070_010_019&gt;</VoiceId>
      <JapaneseText>平気……平気だから</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>7</SpeakerId>
      <Id>17</Id>
      <OldPtr>268388</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>281332</PointerOffset>
      <VoiceId>&lt;audio:VSM_070_010_022&gt;</VoiceId>
      <JapaneseText>あのエトスって子、
あのふたりと
どんな関係なの？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>6</SpeakerId>
      <Id>18</Id>
      <OldPtr>268688</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>281404</PointerOffset>
      <VoiceId>&lt;audio:VSM_070_010_023&gt;</VoiceId>
      <JapaneseText>親代わりなんだとさ</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>19</Id>
      <OldPtr>268932</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>281508</PointerOffset>
      <VoiceId>&lt;audio:VSM_070_010_024&gt;</VoiceId>
      <JapaneseText>そっか……ずいぶん、
心の支えになってるみたい……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>6</SpeakerId>
      <Id>20</Id>
      <OldPtr>269176</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>281696</PointerOffset>
      <VoiceId>&lt;audio:VSM_070_010_026&gt;</VoiceId>
      <JapaneseText>ま、ノームには精霊晶核も
もらわなきゃだし、ね？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>6</SpeakerId>
      <Id>21</Id>
      <OldPtr>269900</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>281772</PointerOffset>
      <VoiceId>&lt;audio:VSM_070_010_027&gt;</VoiceId>
      <JapaneseText>エトを取り返すのが先です</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>7</SpeakerId>
      <Id>22</Id>
      <OldPtr>270464</OldPtr>
      <Status>To Do</Status>
    </Entry>
