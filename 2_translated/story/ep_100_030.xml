  <Strings>
    <Section>Main</Section>
    <Entry>
      <PointerOffset>291284</PointerOffset>
      <VoiceId>&lt;audio:VSM_100_030_001&gt;</VoiceId>
      <JapaneseText>気のせいか、虹輪が
大きくなってるような
気がするんだけド……</JapaneseText>
      <EnglishText>It must be my imagination, but the
Prism Ring looks bigger than before...</EnglishText>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>1</Id>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset>291360</PointerOffset>
      <VoiceId>&lt;audio:VSM_100_030_002&gt;</VoiceId>
      <JapaneseText>気のせいじゃない……！</JapaneseText>
      <EnglishText>It's not your imagination...!</EnglishText>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>2</Id>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset>291448</PointerOffset>
      <VoiceId>&lt;audio:VSM_100_030_003&gt;</VoiceId>
      <JapaneseText>&lt;Dio&gt;、
エレメンツポットを……！</JapaneseText>
      <EnglishText>&lt;Dio&gt;, use the Elements' Pot!</EnglishText>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>3</Id>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset>291528</PointerOffset>
      <VoiceId>&lt;audio:VSM_100_030_004&gt;</VoiceId>
      <JapaneseText>どうすりゃいいんだ……！？</JapaneseText>
      <EnglishText>How exactly?!</EnglishText>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>4</Id>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset>291624</PointerOffset>
      <VoiceId>&lt;audio:VSM_100_030_005&gt;</VoiceId>
      <JapaneseText>フタを開けなさい。
私たちの力で抑えこみます</JapaneseText>
      <EnglishText>Simply open the lid. Our powers shall be released then.</EnglishText>
      <Notes/>
      <SpeakerId>4</SpeakerId>
      <Id>5</Id>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset>291836</PointerOffset>
      <VoiceId>&lt;audio:VSM_100_030_008&gt;</VoiceId>
      <JapaneseText>開きゃいいんだな</JapaneseText>
      <EnglishText>I'll just open it, then!</EnglishText>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>6</Id>
      <Status>Proofreading</Status>
    </Entry>
  </Strings>
