      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>46</Id>
      <BubbleId>0</BubbleId>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>286880</PointerOffset>
      <JapaneseText>ありがとう……それじゃあ</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>46</Id>
      <BubbleId>1</BubbleId>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>286992</PointerOffset>
      <JapaneseText>……思わず払っちゃったけど、
本当にそんな危険な術、
使ってもいいのかな……？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
