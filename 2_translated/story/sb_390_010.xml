    <Entry>
      <PointerOffset>287116</PointerOffset>
      <JapaneseText>全然だいじょーぶだって強いヤツ呼び出して、
ばばばっと敵やっつけたほうが、
かっこいいぜ！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>63</Id>
      <BubbleId>1</BubbleId>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>287168</PointerOffset>
      <JapaneseText>かっこ、いい……？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>65</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>287264</PointerOffset>
      <JapaneseText>い、いや……
そのほうが魔物やっつけるのも
さくさくって進むだろ</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>66</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>287320</PointerOffset>
      <JapaneseText>……確かにそうだけど</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>67</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>287392</PointerOffset>
      <JapaneseText>魔術のほうは
おまえが使えよ。
……ほら</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>68</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>287436</PointerOffset>
      <JapaneseText>えぇっ……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>69</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>287508</PointerOffset>
      <JapaneseText>……えっと……
……ふんふんふん……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>70</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>287576</PointerOffset>
      <JapaneseText>……ほんと、
大丈夫なのかな……？</JapaneseText>
