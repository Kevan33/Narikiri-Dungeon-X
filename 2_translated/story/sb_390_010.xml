      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>52</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>287320</PointerOffset>
      <JapaneseText>……確かにそうだけど</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>53</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>287392</PointerOffset>
      <JapaneseText>魔術のほうは
おまえが使えよ。
……ほら</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>54</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
