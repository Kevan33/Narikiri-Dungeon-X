    <Entry>
      <PointerOffset>273688</PointerOffset>
      <VoiceId>&lt;audio:VSM_110_040_001&gt;</VoiceId>
      <JapaneseText>ん？　君たちは
道場の入門者……
にしては、ちんまいね</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>1</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>273796</PointerOffset>
      <VoiceId>&lt;audio:VSM_110_040_002&gt;</VoiceId>
      <JapaneseText>&lt;Cless&gt;いえ、あの、
わたしたち、さんに
会いに来たんです</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>2</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>273892</PointerOffset>
      <VoiceId>&lt;audio:VSM_110_040_003&gt;</VoiceId>
      <JapaneseText>うちの主に？
うーん、それは困った</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>3</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>273956</PointerOffset>
      <VoiceId>&lt;audio:VSM_110_040_004&gt;</VoiceId>
      <JapaneseText>いねーのか？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>4</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>274140</PointerOffset>
      <VoiceId>&lt;audio:VSM_110_040_005&gt;</VoiceId>
      <JapaneseText>&lt;Red&gt;&lt;White&gt;</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>5</Id>
      <BubbleId>0</BubbleId>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>274140</PointerOffset>
      <VoiceId>&lt;audio:VSM_110_040_006&gt;</VoiceId>
      <JapaneseText>&lt;Red&gt;&lt;White&gt;まぁね。今、うちの主は、
ユークリッド騎士団の
特別顧問をしていてねヴァルハラで
軍事行動中なんだよ</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>5</Id>
      <BubbleId>1</BubbleId>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>274228</PointerOffset>
      <VoiceId>&lt;audio:VSM_110_040_007&gt;</VoiceId>
      <JapaneseText>&lt;Red&gt;&lt;White&gt;ヴァルハラで
何かあったのか？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>7</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>274500</PointerOffset>
      <VoiceId>&lt;audio:VSM_110_040_009&gt;</VoiceId>
      <JapaneseText></JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>8</Id>
      <BubbleId>0</BubbleId>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>274500</PointerOffset>
      <VoiceId>&lt;audio:VSM_110_040_010&gt;</VoiceId>
      <JapaneseText>『シグルド』って暴力集団が、
街に立てこもってるんだブレイナーってのが
リーダーになって以来、
厄介でね……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>8</Id>
      <BubbleId>1</BubbleId>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>274580</PointerOffset>
      <VoiceId>&lt;audio:VSM_110_040_011&gt;</VoiceId>
      <JapaneseText>&lt;Red&gt;&lt;White&gt;ヴァルハラっていや……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>10</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>274696</PointerOffset>
      <VoiceId>&lt;audio:VSM_110_040_012&gt;</VoiceId>
      <JapaneseText>あぁ、あそこも
色々あったからね、
住民が追い出されたり</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>11</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>274756</PointerOffset>
      <VoiceId>&lt;audio:VSM_110_040_013&gt;</VoiceId>
      <JapaneseText>住民が？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>12</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>274944</PointerOffset>
      <VoiceId>&lt;audio:VSM_110_040_014&gt;</VoiceId>
      <JapaneseText></JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>13</Id>
      <BubbleId>0</BubbleId>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>274944</PointerOffset>
      <VoiceId>&lt;audio:VSM_110_040_015&gt;</VoiceId>
      <JapaneseText>&lt;Red&gt;&lt;White&gt;ああ、『紅の月』の
採掘者と住民が
ぶつかってなともかく、危険だから、
ヴァルハラには
近づかない方がいいね</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>13</Id>
      <BubbleId>1</BubbleId>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>275016</PointerOffset>
      <VoiceId>&lt;audio:VSM_110_040_016&gt;</VoiceId>
      <JapaneseText>どうしよう、エト……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>15</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>275144</PointerOffset>
      <VoiceId>&lt;audio:VSM_110_040_017&gt;</VoiceId>
      <JapaneseText>その間にマクスウェルのこと、
知ってる人いないか、
探せばいいんじゃないかな</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>4</SpeakerId>
      <Id>16</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>275236</PointerOffset>
      <VoiceId>&lt;audio:VSM_110_040_018&gt;</VoiceId>
      <JapaneseText>でも、ダオスの話も
聞かなくちゃだし……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>17</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>275396</PointerOffset>
      <VoiceId>&lt;audio:VSM_110_040_019&gt;</VoiceId>
      <JapaneseText></JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>18</Id>
      <BubbleId>0</BubbleId>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>275396</PointerOffset>
      <VoiceId>&lt;audio:VSM_110_040_020&gt;</VoiceId>
      <JapaneseText>&lt;Mint&gt;なんだ、
ダオスの話を
聞きたいのかい？だったら、様に
会ってみちゃどうかね</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>18</Id>
      <BubbleId>1</BubbleId>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>275476</PointerOffset>
      <VoiceId>&lt;audio:VSM_110_040_021&gt;</VoiceId>
      <JapaneseText>&lt;Mint&gt;って……
時空戦士の？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>20</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>275572</PointerOffset>
      <VoiceId>&lt;audio:VSM_110_040_022&gt;</VoiceId>
      <JapaneseText>そのぅ……その人は、
どこにいるんですか？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>21</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>275680</PointerOffset>
      <VoiceId>&lt;audio:VSM_110_040_023&gt;</VoiceId>
      <JapaneseText>&lt;Mint&gt;もちろん。様は、
村の教会にいると思うけど</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>22</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>275748</PointerOffset>
      <VoiceId>&lt;audio:VSM_110_040_024&gt;</VoiceId>
      <JapaneseText>この村すげー……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>23</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>275820</PointerOffset>
      <VoiceId>&lt;audio:VSM_110_040_025&gt;</VoiceId>
      <JapaneseText>すごいってなにが？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>24</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>275912</PointerOffset>
      <VoiceId>&lt;audio:VSM_110_040_026&gt;</VoiceId>
      <JapaneseText>だってさ、
時空戦士がふたりも
いんだぜ？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>25</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>276356</PointerOffset>
      <VoiceId>&lt;audio:VSM_110_040_031&gt;</VoiceId>
      <JapaneseText>&lt;Mint&gt;は時空戦士の法術師で、
結社を作って、
世界に法術を広めた人なんだ</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>26</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>276420</PointerOffset>
      <VoiceId>&lt;audio:VSM_110_040_032&gt;</VoiceId>
      <JapaneseText>詳しいんだね</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>27</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>276568</PointerOffset>
      <VoiceId>&lt;audio:VSM_110_040_033&gt;</VoiceId>
      <JapaneseText>&lt;Mint&gt;</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>4</SpeakerId>
      <Id>28</Id>
      <BubbleId>0</BubbleId>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>276568</PointerOffset>
      <VoiceId>&lt;audio:VSM_110_040_034&gt;</VoiceId>
      <JapaneseText>それじゃあ、
そのさんに
会いに行ってみようか村の教会にいるんだっけ？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>4</SpeakerId>
      <Id>28</Id>
      <BubbleId>1</BubbleId>
      <Status>To Do</Status>
    </Entry>
