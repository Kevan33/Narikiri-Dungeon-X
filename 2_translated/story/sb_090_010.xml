  <Strings>
    <Section>Main</Section>
    <Entry>
      <PointerOffset>269928</PointerOffset>
      <JapaneseText>ん？　なんだい君たち？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>1</Id>
      <OldPtr>258164</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>270000</PointerOffset>
      <JapaneseText>んー、えと……
あんた、ヒリップさん？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>2</Id>
      <OldPtr>258304</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>270072</PointerOffset>
      <JapaneseText>わたしたち、ギスキーさんの
紹介で……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>3</Id>
      <OldPtr>258444</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>270168</PointerOffset>
      <JapaneseText>ほほう、ギスキー氏の。
じゃあ君らが
協力してくれるのかい？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>4</SpeakerId>
      <Id>4</Id>
      <OldPtr>258584</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>270208</PointerOffset>
      <JapaneseText>協力？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>5</Id>
      <OldPtr>258724</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>270528</PointerOffset>
      <JapaneseText>そう。実はね、一度
闘技場のチャンピオンを
見てみたいんだ</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>4</SpeakerId>
      <Id>6</Id>
      <BubbleId>0</BubbleId>
      <OldPtr>258864</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>270528</PointerOffset>
      <JapaneseText>この前友達と口論になってね。
パワー重視のムキムキマッチョが
一番強いのか……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>4</SpeakerId>
      <Id>6</Id>
      <BubbleId>1</BubbleId>
      <OldPtr>258864</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>270528</PointerOffset>
      <JapaneseText>それともスピード重視の
スマートタイプが強いのか？
さらにそれとも……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>4</SpeakerId>
      <Id>6</Id>
      <BubbleId>2</BubbleId>
      <OldPtr>258864</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>270528</PointerOffset>
      <JapaneseText>バランスタイプが強いのか？
でもこれは器用貧乏そうだしなぁ。
その答えを見たいのさ</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>4</SpeakerId>
      <Id>6</Id>
      <BubbleId>3</BubbleId>
      <OldPtr>258864</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>270612</PointerOffset>
      <JapaneseText>ようするに
闘技場で優勝して来い、
ってことなのか？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>10</Id>
      <OldPtr>259004</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>270740</PointerOffset>
      <JapaneseText>どうかな？
チャンピオン、
なってくれるかな？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>4</SpeakerId>
      <Id>11</Id>
      <BubbleId>0</BubbleId>
      <OldPtr>259144</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>270740</PointerOffset>
      <JapaneseText>ギスキーさんの紹介なら、
君たち、強いんだよね？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>4</SpeakerId>
      <Id>11</Id>
      <BubbleId>1</BubbleId>
      <OldPtr>259144</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>270824</PointerOffset>
      <JapaneseText>なんかウサギとはまったく
関係ないみたいだけど……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>13</Id>
      <OldPtr>259408</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>270900</PointerOffset>
      <JapaneseText>これもなりきり士の仕事、
ということなら</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>14</Id>
      <OldPtr>259548</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>270988</PointerOffset>
      <JapaneseText>わかった！　じゃあ
チャンピオンになったら
また来るよ！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>15</Id>
      <OldPtr>260080</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>271088</PointerOffset>
      <JapaneseText>助かるよ。
フフフ……これで
ヒリップ強まり計画が始動できる……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>4</SpeakerId>
      <Id>16</Id>
      <OldPtr>260324</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>271132</PointerOffset>
      <JapaneseText>…………？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>17</Id>
      <OldPtr>260464</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>271208</PointerOffset>
      <JapaneseText>ま、まぁ、あまり気にせずに
行きましょう</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>18</Id>
      <OldPtr>260868</OldPtr>
      <Status>To Do</Status>
    </Entry>
