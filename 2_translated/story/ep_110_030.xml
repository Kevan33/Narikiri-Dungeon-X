      <PointerOffset>277012</PointerOffset>
      <VoiceId>&lt;audio:VSM_110_030_001&gt;</VoiceId>
      <JapaneseText>……何並んでんだ、これ？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>1</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>277116</PointerOffset>
      <VoiceId>&lt;audio:VSM_110_030_002&gt;</VoiceId>
      <JapaneseText>あら？　ボクちゃんたち、
横入りはダメよ？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>2</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>277192</PointerOffset>
      <VoiceId>&lt;audio:VSM_110_030_003&gt;</VoiceId>
      <JapaneseText>これ、何の列なんですか？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>3</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>277296</PointerOffset>
      <VoiceId>&lt;audio:VSM_110_030_004&gt;</VoiceId>
      <JapaneseText>&lt;Mint&gt;様に診察してもらう
