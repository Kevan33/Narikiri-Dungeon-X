      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>4</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>277376</PointerOffset>
      <VoiceId>&lt;audio:VSM_110_030_005&gt;</VoiceId>
      <JapaneseText>&lt;Mint&gt;って……
時空戦士の？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>5</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>277472</PointerOffset>
      <VoiceId>&lt;audio:VSM_110_030_006&gt;</VoiceId>
      <JapaneseText>そうよ。
ここが最後尾。
９時間待ち</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>6</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>277540</PointerOffset>
      <VoiceId>&lt;audio:VSM_110_030_007&gt;</VoiceId>
      <JapaneseText>く、９時間！？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>7</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>278392</PointerOffset>
      <VoiceId>&lt;audio:VSM_110_030_017&gt;</VoiceId>
      <JapaneseText>&lt;Mint&gt;は時空戦士の法術師で、
結社を作って、
世界に法術を広めた人なんだ</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>8</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>278456</PointerOffset>
      <VoiceId>&lt;audio:VSM_110_030_018&gt;</VoiceId>
      <JapaneseText>詳しいんだね</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>9</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>278540</PointerOffset>
      <VoiceId>&lt;audio:VSM_110_030_019&gt;</VoiceId>
      <JapaneseText>今は&lt;Cless&gt;さんに
会うんでしょ？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>4</SpeakerId>
      <Id>10</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>278612</PointerOffset>
      <VoiceId>&lt;audio:VSM_110_030_020&gt;</VoiceId>
      <JapaneseText>あ、そうだった……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>11</Id>
      <Status>To Do</Status>
