    <Section>Main</Section>
    <Entry>
      <PointerOffset>269588</PointerOffset>
      <VoiceId>&lt;audio:VSM_270_060_001&gt;</VoiceId>
      <JapaneseText>……父ちゃん、母ちゃん、
行ってくるよ……</JapaneseText>
      <EnglishText>...Mom...Dad...I'll do it...</EnglishText>
      <Notes>tl check</Notes>
      <SpeakerId>1</SpeakerId>
      <Id>1</Id>
      <BubbleId>0</BubbleId>
      <Status>Problematic</Status>
    </Entry>
    <Entry>
      <PointerOffset>269588</PointerOffset>
      <VoiceId>&lt;audio:VSM_270_060_002&gt;</VoiceId>
      <JapaneseText>行って、絶対、仇を……</JapaneseText>
      <EnglishText>I'll do it, I'll get my revenge...</EnglishText>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>1</Id>
      <BubbleId>1</BubbleId>
      <Status>Problematic</Status>
    </Entry>
    <Entry>
      <PointerOffset>269696</PointerOffset>
      <VoiceId>&lt;audio:VSM_270_060_003&gt;</VoiceId>
      <JapaneseText>何をやっている、ディオス！
すぐに持ち場へつけ！</JapaneseText>
      <EnglishText>What are you doing loitering about, Dios!
Go back to your position at once!</EnglishText>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>3</Id>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset>269768</PointerOffset>
      <VoiceId>&lt;audio:VSM_270_060_004&gt;</VoiceId>
      <JapaneseText>はい！　父上……！</JapaneseText>
      <EnglishText>Yes, father...!</EnglishText>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>4</Id>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset>269836</PointerOffset>
      <VoiceId>&lt;audio:VSM_270_060_005&gt;</VoiceId>
      <JapaneseText>ディオス！</JapaneseText>
      <EnglishText>Dios!</EnglishText>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>5</Id>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset>269924</PointerOffset>
      <VoiceId>&lt;audio:VSM_270_060_006&gt;</VoiceId>
      <JapaneseText>ようやく
両親の仇を取れるな</JapaneseText>
      <EnglishText>You're finally going to avenge your parents.</EnglishText>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>6</Id>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset>270044</PointerOffset>
      <VoiceId>&lt;audio:VSM_270_060_007&gt;</VoiceId>
      <JapaneseText>いえ……父上の望まれる
デリス・カーラーンの平和を
手に入れるために</JapaneseText>
      <EnglishText>No...I'm doing this for father's desire
for a peaceful Derris Kharlan...</EnglishText>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>7</Id>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset>270148</PointerOffset>
      <VoiceId>&lt;audio:VSM_270_060_008&gt;</VoiceId>
      <JapaneseText>平和……そうだな</JapaneseText>
      <EnglishText>Peace... Yes, that's our goal.</EnglishText>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>8</Id>
      <BubbleId>0</BubbleId>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset>270148</PointerOffset>
      <VoiceId>&lt;audio:VSM_270_060_009&gt;</VoiceId>
      <JapaneseText>……行け！</JapaneseText>
      <EnglishText>Now, go!</EnglishText>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>8</Id>
      <BubbleId>1</BubbleId>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset>270212</PointerOffset>
      <VoiceId>&lt;audio:VSM_270_060_010&gt;</VoiceId>
      <JapaneseText>はっ……</JapaneseText>
      <EnglishText>Yes sir...!</EnglishText>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>10</Id>
      <Status>Proofreading</Status>
    </Entry>
