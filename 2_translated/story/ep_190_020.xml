    <Section>Main</Section>
    <Entry>
      <PointerOffset>272724</PointerOffset>
      <VoiceId>&lt;audio:VSM_190_020_000&gt;</VoiceId>
      <JapaneseText>女の子……！？</JapaneseText>
      <EnglishText>A little girl...!?</EnglishText>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>1</Id>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset>272816</PointerOffset>
      <VoiceId>&lt;audio:VSM_190_020_001&gt;</VoiceId>
      <JapaneseText>でも、あの服……
敵と同じ感じだよ！？</JapaneseText>
      <EnglishText>But, those clothes... She's
one of our enemies!?</EnglishText>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>2</Id>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset>272924</PointerOffset>
      <VoiceId>&lt;audio:VSM_190_020_002&gt;</VoiceId>
      <JapaneseText>へん、こんな女の子くらい、
オレひとりで
じゅーぶんだぜ！</JapaneseText>
      <EnglishText>Hah! I can handle this
little kiddo all by myself!</EnglishText>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>3</Id>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset>272984</PointerOffset>
      <VoiceId>&lt;audio:VSM_190_020_003&gt;</VoiceId>
      <JapaneseText>お見事！</JapaneseText>
      <EnglishText>He's got her! Not!</EnglishText>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>4</Id>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset>273072</PointerOffset>
      <VoiceId>&lt;audio:VSM_190_020_004&gt;</VoiceId>
      <JapaneseText>う、動かねー……
は、はなせよ……！</JapaneseText>
      <EnglishText>I-I can't move! Hey! Let go of
my sword, that's cheating...!</EnglishText>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>5</Id>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset>273180</PointerOffset>
      <VoiceId>&lt;audio:VSM_190_020_005&gt;</VoiceId>
      <JapaneseText>わたしの手違いで拘束して
申し訳ありませんでした</JapaneseText>
      <EnglishText>I must apologize for the blunder
of taking you into custody.</EnglishText>
      <Notes/>
      <SpeakerId>4</SpeakerId>
      <Id>6</Id>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset>273260</PointerOffset>
      <VoiceId>&lt;audio:VSM_190_020_006&gt;</VoiceId>
      <JapaneseText>ど……どういうことですか？</JapaneseText>
      <EnglishText>Wh-What do you mean?</EnglishText>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>7</Id>
      <Status>Proofreading</Status>
    </Entry>
