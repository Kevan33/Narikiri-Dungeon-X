    <Section>Main</Section>
    <Entry>
      <PointerOffset>269076</PointerOffset>
      <VoiceId>&lt;audio:VSM_250_010_001&gt;</VoiceId>
      <JapaneseText>起きてー起きてー
起きないと
チクチクしちゃうよ</JapaneseText>
      <EnglishText>Wake up! Hey, wake up!
If you don't wake up,
I'll tickle you!</EnglishText>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>1</Id>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset>269256</PointerOffset>
      <VoiceId>&lt;audio:VSM_250_010_003&gt;</VoiceId>
      <JapaneseText>ダオスを倒してから、
もう数ヶ月が経とうとしています</JapaneseText>
      <EnglishText>It's been a few months since
we fought against Dhaos.</EnglishText>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>2</Id>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset>269332</PointerOffset>
      <VoiceId>&lt;audio:VSM_250_010_004&gt;</VoiceId>
      <JapaneseText>あっ！　おはよ、&lt;Mel&gt;</JapaneseText>
      <EnglishText>Ah, I see you're up, &lt;Mel&gt;!</EnglishText>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>3</Id>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset>269404</PointerOffset>
      <VoiceId>&lt;audio:VSM_250_010_005&gt;</VoiceId>
      <JapaneseText>……おはよ、エト……</JapaneseText>
      <EnglishText>...Good morning, Eto...</EnglishText>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>4</Id>
      <Status>Proofreading</Status>
    </Entry>
