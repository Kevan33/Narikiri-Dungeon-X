    <Entry>
      <PointerOffset>292712</PointerOffset>
      <VoiceId>&lt;audio:VSM_310_080_001&gt;</VoiceId>
      <JapaneseText>わざわざ
消されに来たか</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>1</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>292808</PointerOffset>
      <VoiceId>&lt;audio:VSM_310_080_002&gt;</VoiceId>
      <JapaneseText>あんたに会って、
聞きたいことがあったんだ</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>2</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>292932</PointerOffset>
      <VoiceId>&lt;audio:VSM_310_080_003&gt;</VoiceId>
      <JapaneseText>あなたは悔いや恨みのため、
残存思念になって
今もここにいるって言いました</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>3</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>293028</PointerOffset>
      <VoiceId>&lt;audio:VSM_310_080_004&gt;</VoiceId>
      <JapaneseText>でも、それって本当は
違うんじゃないのか？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>4</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>293220</PointerOffset>
      <VoiceId>&lt;audio:VSM_310_080_006&gt;</VoiceId>
      <JapaneseText>そのようなことを
貴様らに語る必要はない</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>5</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>293352</PointerOffset>
      <VoiceId>&lt;audio:VSM_310_080_007&gt;</VoiceId>
      <JapaneseText>あんたは、本当はこの星でも
いっぱい人を殺したことが
ひっかかってんじゃないのか？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>6</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>293464</PointerOffset>
      <VoiceId>&lt;audio:VSM_310_080_008&gt;</VoiceId>
      <JapaneseText>&lt;Rody&gt;が言ってました、
本当はあなたは
優しい人だって……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>7</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>293648</PointerOffset>
      <VoiceId>&lt;audio:VSM_310_080_010&gt;</VoiceId>
      <JapaneseText>……失せるがいい</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>8</Id>
      <Status>To Do</Status>
    </Entry>
  </Strings>
