      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>297880</PointerOffset>
      <VoiceId>&lt;audio:VSM_090_030_009&gt;</VoiceId>
      <JapaneseText>ゆ、許してたもれ……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>2</Id>
      <BubbleId>0</BubbleId>
