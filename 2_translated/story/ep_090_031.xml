    <Entry>
      <PointerOffset>297880</PointerOffset>
      <VoiceId>&lt;audio:VSM_090_030_010&gt;</VoiceId>
      <JapaneseText>貴様らの願いを
なんでも叶えてしんぜようぞ</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>2</Id>
      <BubbleId>1</BubbleId>
      <OldPtr>280600</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>297980</PointerOffset>
      <VoiceId>&lt;audio:VSM_090_030_011&gt;</VoiceId>
      <JapaneseText>んじゃあ、オレらに
精霊晶核っての分けてくれ！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>4</Id>
      <OldPtr>280964</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>298100</PointerOffset>
      <VoiceId>&lt;audio:VSM_090_030_012&gt;</VoiceId>
      <JapaneseText>精霊晶核とな？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>5</Id>
      <BubbleId>0</BubbleId>
      <OldPtr>281104</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>298100</PointerOffset>
      <VoiceId>&lt;audio:VSM_090_030_013&gt;</VoiceId>
      <JapaneseText>よかろう……
受け取るがよい</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>5</Id>
      <BubbleId>1</BubbleId>
      <OldPtr>281104</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>298172</PointerOffset>
      <VoiceId>&lt;audio:VSM_090_030_014&gt;</VoiceId>
      <JapaneseText>さらばじゃ……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>7</Id>
      <OldPtr>283120</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>298252</PointerOffset>
      <VoiceId>&lt;audio:VSM_090_030_015&gt;</VoiceId>
      <JapaneseText>四大精霊の力が集まった……！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>8</Id>
      <OldPtr>283740</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>298316</PointerOffset>
      <VoiceId>&lt;audio:VSM_090_030_016&gt;</VoiceId>
      <JapaneseText>クルール！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>4</SpeakerId>
      <Id>9</Id>
      <OldPtr>284728</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>298400</PointerOffset>
      <VoiceId>&lt;audio:VSM_090_030_017&gt;</VoiceId>
      <JapaneseText>これで魔術の暴走が
抑えられるぜ</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>10</Id>
      <OldPtr>284980</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>298492</PointerOffset>
      <VoiceId>&lt;audio:VSM_090_030_018&gt;</VoiceId>
      <JapaneseText>&lt;Claus&gt;さん、本当に
ありがとうございます</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>11</Id>
      <OldPtr>285580</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>298560</PointerOffset>
      <VoiceId>&lt;audio:VSM_090_030_019&gt;</VoiceId>
      <JapaneseText>いや、なに……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>5</SpeakerId>
      <Id>12</Id>
      <OldPtr>285776</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>298628</PointerOffset>
      <VoiceId>&lt;audio:VSM_090_030_020&gt;</VoiceId>
      <JapaneseText>&lt;Rody&gt;さんも</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>13</Id>
      <OldPtr>285916</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>298736</PointerOffset>
      <VoiceId>&lt;audio:VSM_090_030_021&gt;</VoiceId>
      <JapaneseText>え……？　あ、うん、
これまたご丁寧に。
どういたしまして</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>6</SpeakerId>
      <Id>14</Id>
      <OldPtr>286056</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>298812</PointerOffset>
      <VoiceId>&lt;audio:VSM_090_030_022&gt;</VoiceId>
      <JapaneseText>君はこれからどうするんだ</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>5</SpeakerId>
      <Id>15</Id>
      <OldPtr>286476</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>298876</PointerOffset>
      <VoiceId>&lt;audio:VSM_090_030_023&gt;</VoiceId>
      <JapaneseText>そうだね……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>6</SpeakerId>
      <Id>16</Id>
      <OldPtr>286840</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>298968</PointerOffset>
      <VoiceId>&lt;audio:VSM_090_030_024&gt;</VoiceId>
      <JapaneseText>ま、とりあえず、
ここを出ましょうか！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>6</SpeakerId>
      <Id>17</Id>
