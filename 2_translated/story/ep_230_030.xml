    <Entry>
      <PointerOffset>298648</PointerOffset>
      <VoiceId>&lt;audio:VSM_230_030_001&gt;</VoiceId>
      <JapaneseText>オリジンの力を
使ったのは貴様たちか</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>1</Id>
      <OldPtr>280924</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>298720</PointerOffset>
      <VoiceId>&lt;audio:VSM_230_030_002&gt;</VoiceId>
      <JapaneseText>ダオス戦役以来だな</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>2</Id>
      <OldPtr>282588</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>298824</PointerOffset>
      <VoiceId>&lt;audio:VSM_230_030_003&gt;</VoiceId>
      <JapaneseText>その節はずいぶんと
世話になったな。
こたびは何用だ</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>3</Id>
      <OldPtr>282828</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>298908</PointerOffset>
      <VoiceId>&lt;audio:VSM_230_030_004&gt;</VoiceId>
      <JapaneseText>魔界へ帰りなさい、
プルート！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>4</Id>
      <OldPtr>283524</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>299004</PointerOffset>
      <VoiceId>&lt;audio:VSM_230_030_005&gt;</VoiceId>
      <JapaneseText>かつて、ともに戦った者を
不当に排除するか</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>5</Id>
      <OldPtr>283664</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>299176</PointerOffset>
      <VoiceId>&lt;audio:VSM_230_030_006&gt;</VoiceId>
      <JapaneseText>不当に
地上を侵略しているのは
そちらです！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>6</Id>
      <BubbleId>0</BubbleId>
      <OldPtr>283804</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>299176</PointerOffset>
      <VoiceId>&lt;audio:VSM_230_030_007&gt;</VoiceId>
      <JapaneseText>精霊王との契約で
閉じられた扉を開き、
地上を瘴気に沈めた！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>6</Id>
      <BubbleId>1</BubbleId>
      <OldPtr>283804</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>299340</PointerOffset>
      <VoiceId>&lt;audio:VSM_230_030_008&gt;</VoiceId>
      <JapaneseText>精霊王との契約か……
確かにそんなものもあったな</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>8</Id>
      <BubbleId>0</BubbleId>
      <OldPtr>284008</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>299340</PointerOffset>
      <VoiceId>&lt;audio:VSM_230_030_009&gt;</VoiceId>
      <JapaneseText>しかし、
もはや数千年も前の
朽ち果てた約束</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>8</Id>
      <BubbleId>1</BubbleId>
      <OldPtr>284008</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>299440</PointerOffset>
      <VoiceId>&lt;audio:VSM_230_030_010&gt;</VoiceId>
      <JapaneseText>精霊の王との崇高な契約を
『朽ち果てた』とは……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>10</Id>
      <OldPtr>284532</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>299588</PointerOffset>
      <VoiceId>&lt;audio:VSM_230_030_011&gt;</VoiceId>
      <JapaneseText>知らぬようだから、
教えてやる</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>11</Id>
      <BubbleId>0</BubbleId>
      <OldPtr>284672</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>299588</PointerOffset>
      <VoiceId>&lt;audio:VSM_230_030_012&gt;</VoiceId>
      <JapaneseText>もともと、
この地上は我々のもの
だったのだぞ</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>11</Id>
      <BubbleId>1</BubbleId>
      <OldPtr>284672</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>299652</PointerOffset>
      <VoiceId>&lt;audio:VSM_230_030_013&gt;</VoiceId>
      <JapaneseText>なんだって？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>4</SpeakerId>
      <Id>13</Id>
      <OldPtr>286108</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>299896</PointerOffset>
      <VoiceId>&lt;audio:VSM_230_030_014&gt;</VoiceId>
      <JapaneseText>ラグナロク後、
この地上はその影響で
瘴気の海に満たされていた</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>14</Id>
      <BubbleId>0</BubbleId>
      <OldPtr>286476</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>299896</PointerOffset>
      <VoiceId>&lt;audio:VSM_230_030_015&gt;</VoiceId>
      <JapaneseText>我々、魔界の民は
その瘴気の海から
生まれたのだ</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>14</Id>
      <BubbleId>1</BubbleId>
      <OldPtr>286476</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>299896</PointerOffset>
      <VoiceId>&lt;audio:VSM_230_030_016&gt;</VoiceId>
      <JapaneseText>百数十年に渡って我々は、
この地上を支配した</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>14</Id>
      <BubbleId>2</BubbleId>
      <OldPtr>286476</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>299968</PointerOffset>
      <VoiceId>&lt;audio:VSM_230_030_017&gt;</VoiceId>
      <JapaneseText>そんな……嘘だ……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>17</Id>
      <OldPtr>286800</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>300176</PointerOffset>
      <VoiceId>&lt;audio:VSM_230_030_018&gt;</VoiceId>
      <JapaneseText>嘘ではない</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>18</Id>
      <BubbleId>0</BubbleId>
      <OldPtr>287120</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>300176</PointerOffset>
      <VoiceId>&lt;audio:VSM_230_030_019&gt;</VoiceId>
      <JapaneseText>その世界の支配者たる我々を
精霊王オリジンは魔界へと
放逐したのだ</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>18</Id>
      <BubbleId>1</BubbleId>
      <OldPtr>287120</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>300176</PointerOffset>
      <VoiceId>&lt;audio:VSM_230_030_020&gt;</VoiceId>
      <JapaneseText>世界をラグナロク以前の
人の世界に戻すため</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>18</Id>
      <BubbleId>2</BubbleId>
      <OldPtr>287120</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>300296</PointerOffset>
      <VoiceId>&lt;audio:VSM_230_030_021&gt;</VoiceId>
      <JapaneseText>だから今度はおまえたちが
それを自分たちの手に
取り戻そうというのか</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>21</Id>
      <OldPtr>287316</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>300528</PointerOffset>
      <VoiceId>&lt;audio:VSM_230_030_022&gt;</VoiceId>
      <JapaneseText>その通り、
それが我ら魔界の民の悲願</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>22</Id>
      <BubbleId>0</BubbleId>
      <OldPtr>287456</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>300528</PointerOffset>
      <VoiceId>&lt;audio:VSM_230_030_023&gt;</VoiceId>
      <JapaneseText>やがて、すべての街が
瘴気の底に沈む</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>22</Id>
      <BubbleId>1</BubbleId>
      <OldPtr>287456</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>300528</PointerOffset>
      <VoiceId>&lt;audio:VSM_230_030_024&gt;</VoiceId>
      <JapaneseText>我が幾億の同胞たちが、
魔界より姿を現し、
世界をその掌中にするだろう</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>22</Id>
      <BubbleId>2</BubbleId>
      <OldPtr>287456</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>300616</PointerOffset>
      <VoiceId>&lt;audio:VSM_230_030_025&gt;</VoiceId>
      <JapaneseText>そんなんさせねー！
な、&lt;Suzu&gt;ちゃん</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>5</SpeakerId>
      <Id>25</Id>
      <OldPtr>287724</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>300716</PointerOffset>
      <VoiceId>&lt;audio:VSM_230_030_026&gt;</VoiceId>
      <JapaneseText>はい。あなたを倒して、
私はこの世界を守ります</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>26</Id>
      <OldPtr>287920</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>300884</PointerOffset>
      <VoiceId>&lt;audio:VSM_230_030_027&gt;</VoiceId>
      <JapaneseText>我らが悲願を阻む者、
許すわけにはいかぬ</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>27</Id>
      <BubbleId>0</BubbleId>
      <OldPtr>288308</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>300884</PointerOffset>
      <VoiceId>&lt;audio:VSM_230_030_028&gt;</VoiceId>
      <JapaneseText>来い！　叩きのめして、
その魂、魔界の底へ
封じ込めん！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>27</Id>
      <BubbleId>1</BubbleId>
      <OldPtr>288308</OldPtr>
      <Status>To Do</Status>
    </Entry>
