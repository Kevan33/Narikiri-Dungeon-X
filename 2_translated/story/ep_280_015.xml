    <Entry>
      <PointerOffset>275676</PointerOffset>
      <VoiceId>&lt;audio:VSM_280_015_001&gt;</VoiceId>
      <JapaneseText>ダオス、言ったよな、
インネンがなんとかって……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>1</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>275748</PointerOffset>
      <VoiceId>&lt;audio:VSM_280_015_002&gt;</VoiceId>
      <JapaneseText>因縁を追え、だよね</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>2</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>275904</PointerOffset>
      <VoiceId>&lt;audio:VSM_280_015_003&gt;</VoiceId>
