    <Entry>
      <PointerOffset>280548</PointerOffset>
      <VoiceId>&lt;audio:VSM_000_020_026&gt;</VoiceId>
      <JapaneseText>ふふふっ……
こんにちは。はじめまして。
可愛い双子ちゃん</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>24</Id>
      <BubbleId>1</BubbleId>
      <OldPtr>269272</OldPtr>
