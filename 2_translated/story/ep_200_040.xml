    <Entry>
      <PointerOffset>271160</PointerOffset>
      <VoiceId>&lt;audio:VSM_200_040_002&gt;</VoiceId>
      <JapaneseText>おふたりは
私をかっこいいと
おっしゃいましたでも私は
あなた方の方が
うらやましいです</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>1</Id>
      <BubbleId>1</BubbleId>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>271228</PointerOffset>
      <VoiceId>&lt;audio:VSM_200_040_003&gt;</VoiceId>
      <JapaneseText>え？　オレらが？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>3</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>271320</PointerOffset>
      <VoiceId>&lt;audio:VSM_200_040_004&gt;</VoiceId>
      <JapaneseText>あなた方は
何にだって
なれるんですから</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>4</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>271424</PointerOffset>
      <VoiceId>&lt;audio:VSM_200_040_005&gt;</VoiceId>
      <JapaneseText>&lt;Suzu&gt;ちゃんは、
一族の頭領やってるのが
いやなの？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>5</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>271608</PointerOffset>
      <VoiceId>&lt;audio:VSM_200_040_006&gt;</VoiceId>
      <JapaneseText></JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>6</Id>
      <BubbleId>0</BubbleId>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>271608</PointerOffset>
      <VoiceId>&lt;audio:VSM_200_040_007&gt;</VoiceId>
      <JapaneseText>そ、そういうことでは
ありません。ただ……私にも他の可能性を
模索する機会があれば
どうだったのかと考えただけです</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>6</Id>
      <BubbleId>1</BubbleId>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>271688</PointerOffset>
      <VoiceId>&lt;audio:VSM_200_040_008&gt;</VoiceId>
      <JapaneseText>それがイヤってことじゃ……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>8</Id>
      <Status>To Do</Status>
    </Entry>
