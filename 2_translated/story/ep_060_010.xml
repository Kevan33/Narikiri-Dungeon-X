    <Entry>
      <PointerOffset>310236</PointerOffset>
      <VoiceId>&lt;audio:VSM_060_010_040&gt;</VoiceId>
      <JapaneseText>どんな魂胆だ？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>5</SpeakerId>
      <Id>33</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>310308</PointerOffset>
      <VoiceId>&lt;audio:VSM_060_010_041&gt;</VoiceId>
      <JapaneseText>どんな魂胆もないよ</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>7</SpeakerId>
      <Id>34</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>310384</PointerOffset>
      <VoiceId>&lt;audio:VSM_060_010_042&gt;</VoiceId>
      <JapaneseText>まあ……かまわんがな……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>5</SpeakerId>
      <Id>35</Id>
      <Status>To Do</Status>
