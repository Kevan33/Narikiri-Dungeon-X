    <Entry>
      <PointerOffset>309124</PointerOffset>
      <VoiceId>&lt;audio:VSM_060_010_027&gt;</VoiceId>
      <JapaneseText>こちらのお子さんたちは？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>7</SpeakerId>
      <Id>22</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>309216</PointerOffset>
      <VoiceId>&lt;audio:VSM_060_010_028&gt;</VoiceId>
      <JapaneseText>わけあって、一緒に
精霊を探してるんだ</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>5</SpeakerId>
      <Id>23</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>309308</PointerOffset>
      <VoiceId>&lt;audio:VSM_060_010_029&gt;</VoiceId>
      <JapaneseText>ふぅん、そうなんだ、
精霊さんにね……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>7</SpeakerId>
      <Id>24</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>309396</PointerOffset>
      <VoiceId>&lt;audio:VSM_060_010_030&gt;</VoiceId>
      <JapaneseText>どう？
私もよければ、
力貸すけど？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>7</SpeakerId>
      <Id>25</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>309480</PointerOffset>
      <VoiceId>&lt;audio:VSM_060_010_031&gt;</VoiceId>
      <JapaneseText>お姉さんが？
んなひょろい腕で？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>26</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>309584</PointerOffset>
      <VoiceId>&lt;audio:VSM_060_010_032&gt;</VoiceId>
      <JapaneseText>そそそ。色々なことが
できちゃうのよ、この腕。
ね？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>7</SpeakerId>
      <Id>27</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>309648</PointerOffset>
      <VoiceId>&lt;audio:VSM_060_010_033&gt;</VoiceId>
      <JapaneseText>だったかね</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>5</SpeakerId>
      <Id>28</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>309808</PointerOffset>
      <VoiceId>&lt;audio:VSM_060_010_035&gt;</VoiceId>
      <JapaneseText>ふーん……
じゃあ、よろしく
“ろんでるーの”さん</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>29</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>310004</PointerOffset>
      <VoiceId>&lt;audio:VSM_060_010_037&gt;</VoiceId>
      <JapaneseText>&lt;Mel&gt;です。
よろしくお願いします。
ロンデ、ロンデロ……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>30</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>310092</PointerOffset>
      <VoiceId>&lt;audio:VSM_060_010_038&gt;</VoiceId>
      <JapaneseText>&lt;Rody&gt;フフッ、でいいよ。
よろしく</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>7</SpeakerId>
      <Id>31</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>310168</PointerOffset>
      <VoiceId>&lt;audio:VSM_060_010_039&gt;</VoiceId>
      <JapaneseText>じゃ、じゃあ、行こうぜ</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>32</Id>
      <Status>To Do</Status>
