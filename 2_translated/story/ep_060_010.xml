      <PointerOffset>309048</PointerOffset>
      <VoiceId>&lt;audio:VSM_060_010_026&gt;</VoiceId>
      <JapaneseText>私の大切なもの</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>7</SpeakerId>
      <Id>21</Id>
      <Status>To Do</Status>
