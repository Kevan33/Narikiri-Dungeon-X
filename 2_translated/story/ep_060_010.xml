    <Entry>
      <PointerOffset>307080</PointerOffset>
      <VoiceId>&lt;audio:VSM_060_010_001&gt;</VoiceId>
      <JapaneseText>うわぁ、すごい風……</JapaneseText>
      <EnglishText>Wow...the wind here is really strong...</EnglishText>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>1</Id>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset>307156</PointerOffset>
      <VoiceId>&lt;audio:VSM_060_010_002&gt;</VoiceId>
      <JapaneseText>シルフがいそうな感じだな</JapaneseText>
      <EnglishText>I'm sure Sylph is ahead! </EnglishText>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>2</Id>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset>307228</PointerOffset>
      <VoiceId>&lt;audio:VSM_060_010_003&gt;</VoiceId>
      <JapaneseText>きゃはぁっ！！</JapaneseText>
      <EnglishText>Wow!</EnglishText>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>3</Id>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset>307292</PointerOffset>
      <VoiceId>&lt;audio:VSM_060_010_004&gt;</VoiceId>
      <JapaneseText>うわっ！！</JapaneseText>
      <EnglishText>Woah!</EnglishText>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>4</Id>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset>307484</PointerOffset>
      <VoiceId>&lt;audio:VSM_060_010_007&gt;</VoiceId>
      <JapaneseText>な、なに……！？</JapaneseText>
      <EnglishText>W-What the..!?</EnglishText>
      <Notes/>
      <SpeakerId>4</SpeakerId>
      <Id>5</Id>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset>307552</PointerOffset>
      <VoiceId>&lt;audio:VSM_060_010_008&gt;</VoiceId>
      <JapaneseText>……&lt;Rody&gt;！？</JapaneseText>
      <EnglishText>...Rody?</EnglishText>
      <Notes/>
      <SpeakerId>5</SpeakerId>
      <Id>6</Id>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset>307620</PointerOffset>
      <VoiceId>&lt;audio:VSM_060_010_009&gt;</VoiceId>
      <JapaneseText>&lt;Klarth&gt;！？</JapaneseText>
      <EnglishText>&lt;Klarth&gt;!?</EnglishText>
      <Notes/>
      <SpeakerId>6</SpeakerId>
      <Id>7</Id>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset>307720</PointerOffset>
      <VoiceId>&lt;audio:VSM_060_010_010&gt;</VoiceId>
      <JapaneseText>ここは……
&lt;Red&gt;ローンヴァレイ&lt;White&gt;？
なんで……</JapaneseText>
      <EnglishText>This is...Lone Valley? Where am I...?</EnglishText>
      <Notes/>
      <SpeakerId>6</SpeakerId>
      <Id>8</Id>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset>307796</PointerOffset>
      <VoiceId>&lt;audio:VSM_060_010_011&gt;</VoiceId>
      <JapaneseText>あっ……そっか……</JapaneseText>
      <EnglishText>Ah...that's right...</EnglishText>
      <Notes/>
      <SpeakerId>6</SpeakerId>
      <Id>9</Id>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset>307880</PointerOffset>
      <VoiceId>&lt;audio:VSM_060_010_012&gt;</VoiceId>
      <JapaneseText>何？
&lt;Klarth&gt;さんの知ってるヤツ？</JapaneseText>
      <EnglishText>What? Somebody you know?</EnglishText>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>10</Id>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset>307988</PointerOffset>
      <VoiceId>&lt;audio:VSM_060_010_013&gt;</VoiceId>
      <JapaneseText>ああ。ダオスと戦った時、
途中まで一緒だった。
だが……</JapaneseText>
      <EnglishText>Yeah. We met her while we were fighting Dhaos, but...</EnglishText>
      <Notes/>
      <SpeakerId>5</SpeakerId>
      <Id>11</Id>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset>308096</PointerOffset>
      <VoiceId>&lt;audio:VSM_060_010_014&gt;</VoiceId>
      <JapaneseText>戦う寸前に、ダオスに
どこかへと
飛ばされた大間抜け</JapaneseText>
      <EnglishText>Just when I was about to fight, I was sent
off somewhere else before the big finale.</EnglishText>
      <Notes/>
      <SpeakerId>6</SpeakerId>
      <Id>12</Id>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset>308188</PointerOffset>
      <VoiceId>&lt;audio:VSM_060_010_015&gt;</VoiceId>
      <JapaneseText>&lt;Rondoline&gt;・Ｅ・
エッフェンベルグだよ</JapaneseText>
      <EnglishText>Name's &lt;Rondoline&gt; E. Effenberg.</EnglishText>
      <Notes/>
      <SpeakerId>6</SpeakerId>
      <Id>13</Id>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset>308268</PointerOffset>
      <VoiceId>&lt;audio:VSM_060_010_016&gt;</VoiceId>
      <JapaneseText>今までどこへ
行ってたんだ？</JapaneseText>
      <EnglishText>How did you end up here?</EnglishText>
      <Notes/>
      <SpeakerId>5</SpeakerId>
      <Id>14</Id>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset>308404</PointerOffset>
      <VoiceId>&lt;audio:VSM_060_010_017&gt;</VoiceId>
      <JapaneseText>どこって……</JapaneseText>
      <EnglishText>That's what I'm asking...</EnglishText>
      <Notes/>
      <SpeakerId>7</SpeakerId>
      <Id>15</Id>
      <BubbleId>0</BubbleId>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset>308404</PointerOffset>
      <VoiceId>&lt;audio:VSM_060_010_018&gt;</VoiceId>
      <JapaneseText>たった今、&lt;Red&gt;ダオス城&lt;White&gt;から
飛ばされてきたばかりだよ？</JapaneseText>
      <EnglishText>Just a moment ago I said I was ejected
from Dhaos' Castle, didn't I?</EnglishText>
      <Notes/>
      <SpeakerId>7</SpeakerId>
      <Id>15</Id>
      <BubbleId>1</BubbleId>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset>308576</PointerOffset>
      <VoiceId>&lt;audio:VSM_060_010_020&gt;</VoiceId>
      <JapaneseText>そうか……</JapaneseText>
      <EnglishText>Oh...Right...</EnglishText>
      <Notes/>
      <SpeakerId>5</SpeakerId>
      <Id>17</Id>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset>308644</PointerOffset>
      <VoiceId>&lt;audio:VSM_060_010_021&gt;</VoiceId>
      <JapaneseText>時間転移、だね</JapaneseText>
      <EnglishText>Definitely time travelling's doing.</EnglishText>
      <Notes/>
      <SpeakerId>7</SpeakerId>
      <Id>18</Id>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset>308804</PointerOffset>
      <VoiceId>&lt;audio:VSM_060_010_023&gt;</VoiceId>
      <JapaneseText>時間、転移？
この人も……？</JapaneseText>
      <EnglishText>Time...travelling? This person too...? </EnglishText>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>19</Id>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset>308892</PointerOffset>
      <VoiceId>&lt;audio:VSM_060_010_024&gt;</VoiceId>
      <JapaneseText>そのネックレスの先……
指輪……？</JapaneseText>
      <EnglishText>Is that a ring on your necklace's tip?</EnglishText>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>20</Id>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset>309048</PointerOffset>
      <VoiceId>&lt;audio:VSM_060_010_026&gt;</VoiceId>
      <JapaneseText>私の大切なもの</JapaneseText>
      <EnglishText>It's my precious momento.</EnglishText>
      <Notes/>
      <SpeakerId>7</SpeakerId>
      <Id>21</Id>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset>309124</PointerOffset>
      <VoiceId>&lt;audio:VSM_060_010_027&gt;</VoiceId>
      <JapaneseText>こちらのお子さんたちは？</JapaneseText>
      <EnglishText>At any rate, what're you planning to do here?</EnglishText>
      <Notes/>
      <SpeakerId>7</SpeakerId>
      <Id>22</Id>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset>309216</PointerOffset>
      <VoiceId>&lt;audio:VSM_060_010_028&gt;</VoiceId>
      <JapaneseText>わけあって、一緒に
精霊を探してるんだ</JapaneseText>
      <EnglishText>We're here to find the local Summon Spirit.</EnglishText>
      <Notes/>
      <SpeakerId>5</SpeakerId>
      <Id>23</Id>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset>309308</PointerOffset>
      <VoiceId>&lt;audio:VSM_060_010_029&gt;</VoiceId>
      <JapaneseText>ふぅん、そうなんだ、
精霊さんにね……</JapaneseText>
      <EnglishText>Heh, I see. Business with Spirit gentlemen again, uh? </EnglishText>
      <Notes/>
      <SpeakerId>7</SpeakerId>
      <Id>24</Id>
      <Status>Problematic</Status>
    </Entry>
    <Entry>
      <PointerOffset>309396</PointerOffset>
      <VoiceId>&lt;audio:VSM_060_010_030&gt;</VoiceId>
      <JapaneseText>どう？
私もよければ、
力貸すけど？</JapaneseText>
      <EnglishText>How about this? I'll lend you my
power, if that's alright with you.</EnglishText>
      <Notes/>
      <SpeakerId>7</SpeakerId>
      <Id>25</Id>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset>309480</PointerOffset>
      <VoiceId>&lt;audio:VSM_060_010_031&gt;</VoiceId>
      <JapaneseText>お姉さんが？
んなひょろい腕で？</JapaneseText>
      <EnglishText>You? With such scrawny-looking arms?</EnglishText>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>26</Id>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset>309584</PointerOffset>
      <VoiceId>&lt;audio:VSM_060_010_032&gt;</VoiceId>
      <JapaneseText>そそそ。色々なことが
できちゃうのよ、この腕。
ね？</JapaneseText>
      <EnglishText>Right-o! You wouldn't believe the many things
I can do with these arms! Or would you? </EnglishText>
      <Notes/>
      <SpeakerId>7</SpeakerId>
      <Id>27</Id>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset>309648</PointerOffset>
      <VoiceId>&lt;audio:VSM_060_010_033&gt;</VoiceId>
      <JapaneseText>だったかね</JapaneseText>
      <EnglishText>So it is.</EnglishText>
      <Notes/>
      <SpeakerId>5</SpeakerId>
      <Id>28</Id>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset>309808</PointerOffset>
      <VoiceId>&lt;audio:VSM_060_010_035&gt;</VoiceId>
      <JapaneseText>ふーん……
じゃあ、よろしく
“ろんでるーの”さん</JapaneseText>
      <EnglishText>Mmm... Alright, nice to meet you Londruno. </EnglishText>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>29</Id>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset>310004</PointerOffset>
      <VoiceId>&lt;audio:VSM_060_010_037&gt;</VoiceId>
      <JapaneseText>&lt;Mel&gt;です。
よろしくお願いします。
ロンデ、ロンデロ……</JapaneseText>
      <EnglishText>I'm &lt;Mel&gt;. Pleased to meet you Lond...Londero... </EnglishText>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>30</Id>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset>310092</PointerOffset>
      <VoiceId>&lt;audio:VSM_060_010_038&gt;</VoiceId>
      <JapaneseText>フフッ、&lt;Rody&gt;でいいよ。
よろしく</JapaneseText>
      <EnglishText>Hahaha, Rody is fine. Nice to meet ya!</EnglishText>
      <Notes/>
      <SpeakerId>7</SpeakerId>
      <Id>31</Id>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset>310168</PointerOffset>
      <VoiceId>&lt;audio:VSM_060_010_039&gt;</VoiceId>
      <JapaneseText>じゃ、じゃあ、行こうぜ</JapaneseText>
      <EnglishText>O-Okay! Let's go! </EnglishText>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>32</Id>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset>310236</PointerOffset>
      <VoiceId>&lt;audio:VSM_060_010_040&gt;</VoiceId>
      <JapaneseText>どんな魂胆だ？</JapaneseText>
      <EnglishText>Why are you really here?</EnglishText>
      <Notes/>
      <SpeakerId>5</SpeakerId>
      <Id>33</Id>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset>310308</PointerOffset>
      <VoiceId>&lt;audio:VSM_060_010_041&gt;</VoiceId>
      <JapaneseText>どんな魂胆もないよ</JapaneseText>
      <EnglishText>I'm not hiding anything.</EnglishText>
      <Notes/>
      <SpeakerId>7</SpeakerId>
      <Id>34</Id>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset>310384</PointerOffset>
      <VoiceId>&lt;audio:VSM_060_010_042&gt;</VoiceId>
      <JapaneseText>まあ……かまわんがな……</JapaneseText>
      <EnglishText>Ah, I'll let this slide for once...</EnglishText>
      <Notes/>
      <SpeakerId>5</SpeakerId>
      <Id>35</Id>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset>310464</PointerOffset>
      <VoiceId>&lt;audio:VSM_060_010_043&gt;</VoiceId>
      <JapaneseText>まだ……
間に合うよね……？</JapaneseText>
      <EnglishText>I still...can't meet you...?</EnglishText>
      <Notes/>
      <SpeakerId>7</SpeakerId>
      <Id>36</Id>
      <Status>Proofreading</Status>
    </Entry>
