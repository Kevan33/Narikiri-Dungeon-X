    <Entry>
      <PointerOffset>307988</PointerOffset>
      <VoiceId>&lt;audio:VSM_060_010_013&gt;</VoiceId>
      <JapaneseText>ああ。ダオスと戦った時、
途中まで一緒だった。
だが……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>5</SpeakerId>
      <Id>11</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>308096</PointerOffset>
      <VoiceId>&lt;audio:VSM_060_010_014&gt;</VoiceId>
      <JapaneseText>戦う寸前に、ダオスに
どこかへと
