    <Entry>
      <PointerOffset>280071</PointerOffset>
      <JapaneseText>プロテクトリングを渡しますか？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <Id>12</Id>
      <Status>To Do</Status>
    </Entry>
  </Speakers>
  <Strings>
    <Section>Main</Section>
    <Entry>
      <PointerOffset>278004</PointerOffset>
      <JapaneseText>うっわー、
また来たよ、
こいつら</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>1</Id>
      <OldPtr>259192</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>278104</PointerOffset>
      <JapaneseText>よっぽど、
物が欲しいだすね、物が。
物欲の塊だす～</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>2</Id>
      <OldPtr>259388</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>278176</PointerOffset>
      <JapaneseText>どんどん、
本心が出てきてるね、
こりゃ</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>3</Id>
      <OldPtr>259584</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>278276</PointerOffset>
      <JapaneseText>ちっちぇーことは、
気にすんなってよ。
丸出しねぇちゃん</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>4</Id>
      <OldPtr>259724</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>278384</PointerOffset>
      <JapaneseText>んだんだ、
ありじごく様は、
どんなヤツらにも平等だすよ～</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>5</Id>
      <OldPtr>259864</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>278576</PointerOffset>
      <JapaneseText>さてさて、今回、我々が頂く……、
じゃなくて、ありじごく様に、
交換をお願いする品物は……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>6</Id>
      <BubbleId>0</BubbleId>
      <OldPtr>260004</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>278576</PointerOffset>
      <JapaneseText>ざざーん！
プロテクトリングですね。
アクセサリーどぇ～す</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>6</Id>
      <BubbleId>1</BubbleId>
      <OldPtr>260004</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>278700</PointerOffset>
      <JapaneseText>ほれ、ジャンプしてみろだす。
チャラチャラいってるの
サッサと出すだすよ！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>8</Id>
      <OldPtr>260144</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>278948</PointerOffset>
      <JapaneseText>いい加減、
これも飽きてきたなぁ……。
ふー、やるか</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>9</Id>
      <BubbleId>0</BubbleId>
      <OldPtr>261120</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>278948</PointerOffset>
      <JapaneseText>だべよ？　だべか？
そうだべか？？？
ごって、わくわく～～～</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>9</Id>
      <BubbleId>1</BubbleId>
      <OldPtr>261120</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>279028</PointerOffset>
      <JapaneseText>こいつらの、悪態、
どんどんひどくなってるな…</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>4</SpeakerId>
      <Id>11</Id>
      <OldPtr>262496</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>279084</PointerOffset>
      <JapaneseText>だぁーってろ</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>12</Id>
      <OldPtr>262796</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>279232</PointerOffset>
      <JapaneseText>うるさいだすよ。
ほら、いくだすよ！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>13</Id>
      <BubbleId>0</BubbleId>
      <OldPtr>262936</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>279232</PointerOffset>
      <JapaneseText>マジで？　ジーマー？
本気の本気で？？？
ガス、ガスガス、ガス！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>13</Id>
      <BubbleId>1</BubbleId>
      <OldPtr>262936</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>279324</PointerOffset>
      <JapaneseText>ねぇ、ひょっとして、
ボクたちが渡した物、
そのまま……？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>5</SpeakerId>
      <Id>15</Id>
      <OldPtr>265556</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>279452</PointerOffset>
      <JapaneseText>ん！　んな、バカなこと、
あるわけねぇだすよ！
バカ言っちゃいけねぇだすよ！！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>16</Id>
      <OldPtr>265976</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>279572</PointerOffset>
      <JapaneseText>あー、もーもー、モー！
ちゃんと、来てますよ。
こちらの方に</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>17</Id>
      <BubbleId>0</BubbleId>
      <OldPtr>266892</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>279572</PointerOffset>
      <JapaneseText>はい、どんぞ～</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>17</Id>
      <BubbleId>1</BubbleId>
      <OldPtr>266892</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>279740</PointerOffset>
      <JapaneseText>おめぇ、こりゃー、
さっき後ろ向いてる時に
こそこそなんかして……？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>6</SpeakerId>
      <Id>19</Id>
      <OldPtr>267628</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>279848</PointerOffset>
      <JapaneseText>そそそ、ボクちんの
搾りたて、ギューピュピュって。
ぐふふふ～～～</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>20</Id>
      <OldPtr>267768</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>279908</PointerOffset>
      <JapaneseText>なんか、もう
疲れるね……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>7</SpeakerId>
      <Id>21</Id>
      <OldPtr>268244</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>279996</PointerOffset>
      <JapaneseText>んだよ。
ダメ人間どもが。
早く用意しろよな</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>22</Id>
      <OldPtr>268716</OldPtr>
      <Status>To Do</Status>
    </Entry>
