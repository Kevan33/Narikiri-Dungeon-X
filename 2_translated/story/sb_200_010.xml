    <Section>Main</Section>
    <Entry>
      <PointerOffset>281604</PointerOffset>
      <JapaneseText>ちょっと待っていてくれ</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>1</Id>
      <OldPtr>262736</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>281696</PointerOffset>
      <JapaneseText>……&lt;Claus&gt;さん、
きっとこっそり、
父ちゃんの手紙見たんだぜ</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>2</Id>
      <OldPtr>263220</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>281776</PointerOffset>
      <JapaneseText>手紙ってミラルドさんに
渡されたあれのこと？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>3</Id>
      <OldPtr>263632</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>281876</PointerOffset>
      <JapaneseText>ここの井戸に&lt;Claus&gt;さんの
父ちゃんが何か隠したって
書いてあったもん</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>4</Id>
      <OldPtr>263940</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>281936</PointerOffset>
      <JapaneseText>&lt;Dio&gt;、中身見たの……？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>4</SpeakerId>
      <Id>5</Id>
      <OldPtr>264136</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>282016</PointerOffset>
      <JapaneseText>え、あ、うん……
あれ？　まずかったか……？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>6</Id>
      <OldPtr>264500</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>282068</PointerOffset>
      <JapaneseText>……きみ、ねぇ……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>7</Id>
      <OldPtr>264912</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>282148</PointerOffset>
      <JapaneseText>でも、結局、&lt;Claus&gt;さん、
手紙読んだんだね……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>4</SpeakerId>
      <Id>8</Id>
      <OldPtr>265336</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>282196</PointerOffset>
      <JapaneseText>……あった……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>9</Id>
      <OldPtr>265696</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>282244</PointerOffset>
      <JapaneseText>よし、いいぞ</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>10</Id>
      <OldPtr>266972</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>282292</PointerOffset>
      <JapaneseText>何だったんだ？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>11</Id>
      <OldPtr>267804</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>282376</PointerOffset>
      <JapaneseText>何ってこともない。
武器がひとつ見つかっただけだ</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>12</Id>
      <OldPtr>268072</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>282452</PointerOffset>
      <JapaneseText>父ちゃんのプレゼントって
武器だったんだな</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>13</Id>
      <OldPtr>268212</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>282536</PointerOffset>
      <JapaneseText>しょうがないな。
きみも父からの手紙を読んだのか</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>14</Id>
      <OldPtr>268652</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>282588</PointerOffset>
      <JapaneseText>ご、ごめんなさい</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>15</Id>
      <OldPtr>268848</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>282708</PointerOffset>
      <JapaneseText>いや、いいんだ……
ふっ……まったく驚きだな</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>16</Id>
      <BubbleId>0</BubbleId>
      <OldPtr>269044</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>282708</PointerOffset>
      <JapaneseText>謝罪の言葉で埋めつくされてる
手紙なんて</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>16</Id>
      <BubbleId>1</BubbleId>
      <OldPtr>269044</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>282768</PointerOffset>
      <JapaneseText>そう……
だったんですか？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>4</SpeakerId>
      <Id>18</Id>
      <OldPtr>269304</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>283088</PointerOffset>
      <JapaneseText>ああ……うちの父は
家庭を顧みず、研究に没頭した</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>19</Id>
      <BubbleId>0</BubbleId>
      <OldPtr>269668</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>283088</PointerOffset>
      <JapaneseText>そうであったことを
ずっと後悔してたんだと</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>19</Id>
      <BubbleId>1</BubbleId>
      <OldPtr>269668</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>283088</PointerOffset>
      <JapaneseText>もっと私と話をしとけばよかった、
母との時間も作っておけばよかった</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>19</Id>
      <BubbleId>2</BubbleId>
      <OldPtr>269668</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>283088</PointerOffset>
      <JapaneseText>後悔することはたくさんあるが、
それでも研究をすることも
自分には大切だったんだとな</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>19</Id>
      <BubbleId>3</BubbleId>
      <OldPtr>269668</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>283088</PointerOffset>
      <JapaneseText>私にも……今なら、ほんの少し
その気持ちがわかる</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>19</Id>
      <BubbleId>4</BubbleId>
      <OldPtr>269668</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>283136</PointerOffset>
      <JapaneseText>そうなのか？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>24</Id>
      <OldPtr>271372</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>283292</PointerOffset>
      <JapaneseText>時々、研究に没頭して、
周囲が見えなくなることも
少なくないからな</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>25</Id>
      <BubbleId>0</BubbleId>
      <OldPtr>271804</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>283292</PointerOffset>
      <JapaneseText>私もいつか……
父のように後悔する時が
来るのだろうか……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>25</Id>
      <BubbleId>1</BubbleId>
      <OldPtr>271804</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>283396</PointerOffset>
      <JapaneseText>でもさ、最後にそうならねー
ように毎日、大切に過ごせ
って書いてあったろ</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>27</Id>
      <OldPtr>272064</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>283536</PointerOffset>
      <JapaneseText>ふっ、自分に
できなかったことを
簡単に言ってくれるな</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>28</Id>
      <BubbleId>0</BubbleId>
      <OldPtr>272428</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>283536</PointerOffset>
      <JapaneseText>でも……肝に銘じるとするよ、
反面教師として……親父</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>28</Id>
      <BubbleId>1</BubbleId>
      <OldPtr>272428</OldPtr>
      <Status>To Do</Status>
    </Entry>
