    <Entry>
      <PointerOffset>299784</PointerOffset>
      <VoiceId>&lt;audio:VSM_240_010_016&gt;</VoiceId>
      <JapaneseText>地よ、水よ、火よ、風よ、
天理なす配合を乱し
壊劫（えこう）を招来せよ地よ、水よ、火よ、風よ、
天理なす……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>1</Id>
      <BubbleId>1</BubbleId>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>299956</PointerOffset>
      <VoiceId>&lt;audio:VSM_240_010_017&gt;</VoiceId>
      <JapaneseText></JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>3</Id>
      <BubbleId>0</BubbleId>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>299956</PointerOffset>
      <VoiceId>&lt;audio:VSM_240_010_018&gt;</VoiceId>
      <JapaneseText></JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>3</Id>
      <BubbleId>1</BubbleId>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>299956</PointerOffset>
      <VoiceId>&lt;audio:VSM_240_010_019&gt;</VoiceId>
      <JapaneseText>何、呪文がこだまして……
これが暴走の正体……この声が消えない限りは……声……？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>3</Id>
      <BubbleId>2</BubbleId>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>300052</PointerOffset>
      <VoiceId>&lt;audio:VSM_240_010_020&gt;</VoiceId>
      <JapaneseText>音を司り、それを操る精霊、
グラムロックだ</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>6</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>300136</PointerOffset>
      <VoiceId>&lt;audio:VSM_240_010_021&gt;</VoiceId>
      <JapaneseText>もしかしたら……
ぼくの力で……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>7</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>300240</PointerOffset>
      <VoiceId>&lt;audio:VSM_240_010_022&gt;</VoiceId>
      <JapaneseText>多くの過ちがゆえ……
我がおまえから記憶を奪った</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>8</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>300364</PointerOffset>
      <VoiceId>&lt;audio:VSM_240_010_023&gt;</VoiceId>
      <JapaneseText>……でも、記憶も戻ってきて
もしぼくが今と違うぼくに
なっちゃったラ……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>9</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>300644</PointerOffset>
      <VoiceId>&lt;audio:VSM_240_010_025&gt;</VoiceId>
      <JapaneseText></JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>10</Id>
      <BubbleId>0</BubbleId>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>300644</PointerOffset>
      <VoiceId>&lt;audio:VSM_240_010_026&gt;</VoiceId>
      <JapaneseText></JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>10</Id>
      <BubbleId>1</BubbleId>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>300644</PointerOffset>
      <VoiceId>&lt;audio:VSM_240_010_027&gt;</VoiceId>
      <JapaneseText>……ううん……あのふたりには……
もうお母さんはいらない……だから……旅の最後くらい、
ぼくの可愛い双子のために
なれば……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>10</Id>
      <BubbleId>2</BubbleId>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>300732</PointerOffset>
      <VoiceId>&lt;audio:VSM_240_010_028&gt;</VoiceId>
      <JapaneseText>ぼく……
ふたりの力になりたい……！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>13</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>300820</PointerOffset>
      <VoiceId>&lt;audio:VSM_240_010_029&gt;</VoiceId>
      <JapaneseText>……そうだ、ぼくは……
音の精霊……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>14</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>300936</PointerOffset>
      <VoiceId>&lt;audio:VSM_240_010_030&gt;</VoiceId>
      <JapaneseText>鎮めよ、言霊（ことだま）、
我が眷属となり、
我が元に集い来ん……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>15</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>301000</PointerOffset>
      <VoiceId>&lt;audio:VSM_240_010_031&gt;</VoiceId>
      <JapaneseText>えぇいっ！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>16</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>301108</PointerOffset>
      <VoiceId>&lt;audio:VSM_240_010_032&gt;</VoiceId>
      <JapaneseText>地よ、水よ、火よ、風よ、
天理なす配合を乱し
壊劫を……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>17</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>301204</PointerOffset>
      <VoiceId>&lt;audio:VSM_240_010_033&gt;</VoiceId>
      <JapaneseText>&lt;Dio&gt;&lt;Mel&gt;！　！
聞こえる！？　今だよ！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>18</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>301288</PointerOffset>
      <VoiceId>&lt;audio:VSM_240_010_034&gt;</VoiceId>
      <JapaneseText>え……な、何が
あったんだよ！？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>4</SpeakerId>
      <Id>19</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>301372</PointerOffset>
      <VoiceId>&lt;audio:VSM_240_010_035&gt;</VoiceId>
      <JapaneseText>……わかんない……
でも……！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>5</SpeakerId>
      <Id>20</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>301444</PointerOffset>
      <VoiceId>&lt;audio:VSM_240_010_036&gt;</VoiceId>
      <JapaneseText>精霊よ！　もう一度！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>4</SpeakerId>
      <Id>21</Id>
      <Status>To Do</Status>
    </Entry>
