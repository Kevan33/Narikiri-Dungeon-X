    <Entry>
      <PointerOffset>299452</PointerOffset>
      <VoiceId>&lt;audio:VSM_020_040_037&gt;</VoiceId>
      <JapaneseText>ああ、空が……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>1</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>299376</PointerOffset>
      <VoiceId>&lt;audio:VSM_020_040_036&gt;</VoiceId>
      <JapaneseText>な、何が起きたんだ</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>2</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>299536</PointerOffset>
      <VoiceId>&lt;audio:VSM_020_040_038&gt;</VoiceId>
      <JapaneseText>おかーさーん、こわいよ－</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>3</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>296448</PointerOffset>
      <VoiceId>&lt;audio:VSM_020_040_001&gt;</VoiceId>
      <JapaneseText></JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>4</SpeakerId>
      <Id>4</Id>
      <BubbleId>0</BubbleId>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>296448</PointerOffset>
      <VoiceId>&lt;audio:VSM_020_040_002&gt;</VoiceId>
      <JapaneseText>わたしの……魔術が……わたしのせい……？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>4</SpeakerId>
      <Id>4</Id>
      <BubbleId>1</BubbleId>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>296516</PointerOffset>
      <VoiceId>&lt;audio:VSM_020_040_003&gt;</VoiceId>
      <JapaneseText>え、えっと……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>5</SpeakerId>
      <Id>6</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>296608</PointerOffset>
      <VoiceId>&lt;audio:VSM_020_040_004&gt;</VoiceId>
      <JapaneseText>でも、まだそうと
決まったわけじゃないよ</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>6</SpeakerId>
      <Id>7</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>296764</PointerOffset>
      <VoiceId>&lt;audio:VSM_020_040_005Z&gt;</VoiceId>
      <JapaneseText></JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>7</SpeakerId>
      <Id>8</Id>
      <BubbleId>0</BubbleId>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>296764</PointerOffset>
      <VoiceId>&lt;audio:VSM_020_040_006Z&gt;</VoiceId>
      <JapaneseText>『虹輪（プリズムリング）』が
発生するなんて！！これは大きい！
大変だぞ</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>7</SpeakerId>
      <Id>8</Id>
      <BubbleId>1</BubbleId>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>296832</PointerOffset>
      <VoiceId>&lt;audio:VSM_020_040_007&gt;</VoiceId>
      <JapaneseText>あんた、誰……？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>5</SpeakerId>
      <Id>10</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>296964</PointerOffset>
      <VoiceId>&lt;audio:VSM_020_040_008Z&gt;</VoiceId>
      <JapaneseText>&lt;Red&gt;&lt;White&gt;私はオリーブヴィレッジに
住む魔術師だ。
魔法力の研究をしている</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>7</SpeakerId>
      <Id>11</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>297044</PointerOffset>
      <VoiceId>&lt;audio:VSM_020_040_009&gt;</VoiceId>
      <JapaneseText>……『虹輪』って何ですか？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>4</SpeakerId>
      <Id>12</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>297236</PointerOffset>
      <VoiceId>&lt;audio:VSM_020_040_010Z&gt;</VoiceId>
      <JapaneseText></JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>7</SpeakerId>
      <Id>13</Id>
      <BubbleId>0</BubbleId>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>297236</PointerOffset>
      <VoiceId>&lt;audio:VSM_020_040_011Z&gt;</VoiceId>
      <JapaneseText>凝縮したマナの塊が、
魔法力を得て
虹色の輪になるんだ近くのマナを吸収して、
どんどん大きくなっていくのさ。</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>7</SpeakerId>
      <Id>13</Id>
      <BubbleId>1</BubbleId>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>297300</PointerOffset>
      <VoiceId>&lt;audio:VSM_020_040_012&gt;</VoiceId>
      <JapaneseText>ふーん……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>5</SpeakerId>
      <Id>15</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>297444</PointerOffset>
      <VoiceId>&lt;audio:VSM_020_040_013Z&gt;</VoiceId>
      <JapaneseText>ほうっておいたら世界中の
マナを吸い尽くしてしまう……
魔術が暴走するなんて……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>7</SpeakerId>
      <Id>16</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>297508</PointerOffset>
      <VoiceId>&lt;audio:VSM_020_040_014&gt;</VoiceId>
      <JapaneseText>そんな……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>4</SpeakerId>
      <Id>17</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>297596</PointerOffset>
      <VoiceId>&lt;audio:VSM_020_040_015&gt;</VoiceId>
      <JapaneseText>どうすれば、
止められるんですか？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>4</SpeakerId>
      <Id>18</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>297772</PointerOffset>
      <VoiceId>&lt;audio:VSM_020_040_016Z&gt;</VoiceId>
      <JapaneseText></JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>7</SpeakerId>
      <Id>19</Id>
      <BubbleId>0</BubbleId>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>297772</PointerOffset>
      <VoiceId>&lt;audio:VSM_020_040_017Z&gt;</VoiceId>
      <JapaneseText>虹輪は
地水火風の４つの力が
混ざり合ったものだ……四大精霊の力を
借りられたらいいんだが……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>7</SpeakerId>
      <Id>19</Id>
      <BubbleId>1</BubbleId>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>297860</PointerOffset>
      <VoiceId>&lt;audio:VSM_020_040_018&gt;</VoiceId>
      <JapaneseText>四大精霊……
あの、それはどこに！？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>4</SpeakerId>
      <Id>21</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>297976</PointerOffset>
      <VoiceId>&lt;audio:VSM_020_040_019Z&gt;</VoiceId>
      <JapaneseText>伝承として伝えられているが、
実際に会った者はいない</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>7</SpeakerId>
      <Id>22</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>298040</PointerOffset>
      <VoiceId>&lt;audio:VSM_020_040_020&gt;</VoiceId>
      <JapaneseText>んだよ……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>5</SpeakerId>
      <Id>23</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>298176</PointerOffset>
      <VoiceId>&lt;audio:VSM_020_040_021Z&gt;</VoiceId>
      <JapaneseText>魔女の塔にブライトローズという
魔女が住んでいると
聞いたことがある。</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>7</SpeakerId>
      <Id>24</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>298248</PointerOffset>
      <VoiceId>&lt;audio:VSM_020_040_022&gt;</VoiceId>
      <JapaneseText>ブライト……ローズ？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>4</SpeakerId>
      <Id>25</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>298368</PointerOffset>
      <VoiceId>&lt;audio:VSM_020_040_023Z&gt;</VoiceId>
      <JapaneseText>これはもしかすると
あの魔女の仕業かも
しれないな……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>7</SpeakerId>
      <Id>26</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>298468</PointerOffset>
      <VoiceId>&lt;audio:VSM_020_040_024&gt;</VoiceId>
      <JapaneseText>なぁ、おっさん。
魔女の塔ってドコに
あるんだ？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>5</SpeakerId>
      <Id>27</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>298676</PointerOffset>
      <VoiceId>&lt;audio:VSM_020_040_025Z&gt;</VoiceId>
      <JapaneseText>&lt;Red&gt;&lt;White&gt;</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>7</SpeakerId>
      <Id>28</Id>
      <BubbleId>0</BubbleId>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>298676</PointerOffset>
      <VoiceId>&lt;audio:VSM_020_040_026Z&gt;</VoiceId>
      <JapaneseText>ここから東の方向で、
別名きらめきの塔と呼ばれているきみたち行くつもりなのかい。
危険かもしれないから
気をつけるんだぞ</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>7</SpeakerId>
      <Id>28</Id>
      <BubbleId>1</BubbleId>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>298772</PointerOffset>
      <VoiceId>&lt;audio:VSM_020_040_027&gt;</VoiceId>
      <JapaneseText>オレ、ちょっと、
その魔女んとこ、
行ってくる</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>5</SpeakerId>
      <Id>30</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>298844</PointerOffset>
      <VoiceId>&lt;audio:VSM_020_040_028&gt;</VoiceId>
      <JapaneseText>行ってくるって……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>4</SpeakerId>
      <Id>31</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>299000</PointerOffset>
      <VoiceId>&lt;audio:VSM_020_040_029&gt;</VoiceId>
      <JapaneseText></JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>5</SpeakerId>
      <Id>32</Id>
      <BubbleId>0</BubbleId>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>299000</PointerOffset>
      <VoiceId>&lt;audio:VSM_020_040_030&gt;</VoiceId>
      <JapaneseText>そいつに聞きゃ、
あれ消せるかもだしそれと、
困ってる人助けんのが
オレらの仕事なんだろ</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>5</SpeakerId>
      <Id>32</Id>
      <BubbleId>1</BubbleId>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>299072</PointerOffset>
      <VoiceId>&lt;audio:VSM_020_040_031&gt;</VoiceId>
      <JapaneseText>……わたしも行くよ</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>4</SpeakerId>
      <Id>34</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>299296</PointerOffset>
      <VoiceId>&lt;audio:VSM_020_040_034&gt;</VoiceId>
      <JapaneseText></JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>5</SpeakerId>
      <Id>35</Id>
      <BubbleId>0</BubbleId>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>299296</PointerOffset>
      <VoiceId>&lt;audio:VSM_020_040_035C&gt;</VoiceId>
      <JapaneseText>そっか……んじゃ、行こうぜ</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>5</SpeakerId>
      <Id>35</Id>
      <BubbleId>1</BubbleId>
      <Status>To Do</Status>
    </Entry>
