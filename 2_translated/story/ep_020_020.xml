  <Strings>
    <Section>Main</Section>
    <Entry>
      <PointerOffset>277260</PointerOffset>
      <VoiceId>&lt;audio:VSM_020_020_001&gt;</VoiceId>
      <JapaneseText>ここは？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>1</Id>
      <OldPtr>258628</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>277404</PointerOffset>
      <VoiceId>&lt;audio:VSM_020_020_002&gt;</VoiceId>
      <JapaneseText>はっ、そったらことも知らねーだが？
ここはお店で旅に役立つもんが
いろいろ揃ってるだーよ</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>2</Id>
      <OldPtr>258896</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>277484</PointerOffset>
      <VoiceId>&lt;audio:VSM_020_020_003&gt;</VoiceId>
      <JapaneseText>へん！
タンス野郎が偉そうに</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>3</Id>
      <OldPtr>259260</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>277608</PointerOffset>
      <VoiceId>&lt;audio:VSM_020_020_004&gt;</VoiceId>
      <JapaneseText>たたたた、た、たんすぅ～～!?
ざけっでねーよ！
おらをバカにすっかもう</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>4</Id>
      <OldPtr>259512</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>277692</PointerOffset>
      <VoiceId>&lt;audio:VSM_020_020_005&gt;</VoiceId>
      <JapaneseText>&lt;Dio&gt;。
アルベルトさんでしょ</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>5</Id>
      <OldPtr>259752</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>277840</PointerOffset>
      <VoiceId>&lt;audio:VSM_020_020_006&gt;</VoiceId>
      <JapaneseText>おーおーほほ、さすがは&lt;Mel&gt;&lt;Mel&gt;だ。
おらのことをよーぐわがっでる。
優しい娘っ子だなや～</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>6</Id>
      <OldPtr>260172</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>277912</PointerOffset>
      <VoiceId>&lt;audio:VSM_020_020_007&gt;</VoiceId>
      <JapaneseText>&lt;Mel&gt;&lt;Mel&gt;って……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>4</SpeakerId>
      <Id>7</Id>
      <OldPtr>260748</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>278052</PointerOffset>
      <VoiceId>&lt;audio:VSM_020_020_008&gt;</VoiceId>
      <JapaneseText>そんな&lt;Mel&gt;&lt;Mel&gt;のために、
ここはおらが買い物の仕方、
手取り足取り教えてやるだーよ</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>8</Id>
      <OldPtr>260944</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>278324</PointerOffset>
      <VoiceId>&lt;audio:VSM_020_020_010&gt;</VoiceId>
      <JapaneseText>えーまんず、店の人間に
ちゃんと挨拶するだ</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>9</Id>
      <BubbleId>0</BubbleId>
      <OldPtr>262516</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>278324</PointerOffset>
      <VoiceId>&lt;audio:VSM_020_020_011&gt;</VoiceId>
      <JapaneseText>おい、おめんとこ商品
買いに来てやったど</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>9</Id>
      <BubbleId>1</BubbleId>
      <OldPtr>262516</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>278588</PointerOffset>
      <VoiceId>&lt;audio:VSM_020_020_012&gt;</VoiceId>
      <JapaneseText>わ、
クローゼットが
しゃべった！？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>5</SpeakerId>
      <Id>11</Id>
      <BubbleId>0</BubbleId>
      <OldPtr>262876</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>278588</PointerOffset>
      <VoiceId>&lt;audio:VSM_020_020_013&gt;</VoiceId>
      <JapaneseText>いや……クローゼットでも
お客様……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>5</SpeakerId>
      <Id>11</Id>
      <BubbleId>1</BubbleId>
      <OldPtr>262876</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>278588</PointerOffset>
      <VoiceId>&lt;audio:VSM_020_020_014&gt;</VoiceId>
      <JapaneseText>いらっしゃいませ～♪
道具屋『天地無用』へ
ようこそ！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>5</SpeakerId>
      <Id>11</Id>
      <BubbleId>2</BubbleId>
      <OldPtr>262876</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>278588</PointerOffset>
      <VoiceId>&lt;audio:VSM_020_020_015&gt;</VoiceId>
      <JapaneseText>お探しの品は何でしょうか</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>5</SpeakerId>
      <Id>11</Id>
      <BubbleId>3</BubbleId>
      <OldPtr>262876</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>278704</PointerOffset>
      <VoiceId>&lt;audio:VSM_020_020_016&gt;</VoiceId>
      <JapaneseText>ええが？
このショップ画面に入ったら、
買いたい商品を選んで</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>15</Id>
      <OldPtr>263380</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>278916</PointerOffset>
      <VoiceId>&lt;audio:VSM_020_020_017&gt;</VoiceId>
      <JapaneseText>方向キーの左右で欲しい個数を
決めるだよ。んで、&lt;CIRCLE&gt;で
買ってやればいいだ</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>16</Id>
      <BubbleId>0</BubbleId>
      <OldPtr>263672</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>278916</PointerOffset>
      <VoiceId>&lt;audio:VSM_020_020_018&gt;</VoiceId>
      <JapaneseText>複数の商品が欲しい場合は
まとめて買うことも
できるっちゅー話だど</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>16</Id>
      <BubbleId>1</BubbleId>
      <OldPtr>263672</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>279044</PointerOffset>
      <VoiceId>&lt;audio:VSM_020_020_019&gt;</VoiceId>
      <JapaneseText>あー、商品買う前には、
ガルドが足りてるかどうか
きーっちり確認しとくだよ</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>18</Id>
      <OldPtr>263964</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>279108</PointerOffset>
      <VoiceId>&lt;audio:VSM_020_020_020&gt;</VoiceId>
      <JapaneseText>何してんだ？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>19</Id>
      <OldPtr>266492</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>279188</PointerOffset>
      <VoiceId>&lt;audio:VSM_020_020_021&gt;</VoiceId>
      <JapaneseText>今、買ったモノを
書いてるの</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>20</Id>
      <OldPtr>266848</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>279276</PointerOffset>
      <VoiceId>&lt;audio:VSM_020_020_022&gt;</VoiceId>
      <JapaneseText>買ったもの全部
そこに書くつもりか？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>21</Id>
      <OldPtr>266988</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>279400</PointerOffset>
      <VoiceId>&lt;audio:VSM_020_020_023&gt;</VoiceId>
      <JapaneseText>そ。いつ、どこで、誰と、
何したか、こうして
書いとけば思いだせるでしょ</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>22</Id>
      <OldPtr>267184</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>279492</PointerOffset>
      <VoiceId>&lt;audio:VSM_020_020_024&gt;</VoiceId>
      <JapaneseText>ふーん……
めんどくせーこと
してんのな</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>23</Id>
      <OldPtr>267436</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>279816</PointerOffset>
      <VoiceId>&lt;audio:VSM_020_020_026&gt;</VoiceId>
      <JapaneseText>メニューのライブラリを開けば、
&lt;Mel&gt;&lt;Mel&gt;が書いたメモが
いつでも見られるだ</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>24</Id>
      <BubbleId>0</BubbleId>
      <OldPtr>267960</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>279816</PointerOffset>
      <VoiceId>&lt;audio:VSM_020_020_027&gt;</VoiceId>
      <JapaneseText>これからの旅に
色々と役立つ情報ばかりだで、
こまめに確認するといいべよ</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>24</Id>
      <BubbleId>1</BubbleId>
      <OldPtr>267960</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>280044</PointerOffset>
      <VoiceId>&lt;audio:VSM_020_020_030&gt;</VoiceId>
      <JapaneseText>さ、行こうぜ。
困った人探しの続き</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>26</Id>
      <OldPtr>268200</OldPtr>
      <Status>To Do</Status>
    </Entry>
