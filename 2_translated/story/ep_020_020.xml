    <Entry>
      <PointerOffset>280097</PointerOffset>
      <JapaneseText>買い物の仕方を聞きますか？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <Id>10</Id>
      <Status>To Do</Status>
    </Entry>
