      <JapaneseText></JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>27</Id>
      <BubbleId>0</BubbleId>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>281664</PointerOffset>
      <JapaneseText>ふん……
幸せなお嬢ちゃんだ……ウッ……クッ……ゲホッ！
ゲホッ　ゲホッ　ゲホッ！
ゲホッ　ゲホッ　ゲホッ！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>27</Id>
      <BubbleId>1</BubbleId>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>281716</PointerOffset>
      <JapaneseText>大丈夫ですか！？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>4</SpeakerId>
      <Id>29</Id>
      <Status>To Do</Status>
    </Entry>
