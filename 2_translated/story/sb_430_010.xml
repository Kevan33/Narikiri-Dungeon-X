  <Strings>
    <Section>Main</Section>
    <Entry>
      <PointerOffset>273664</PointerOffset>
      <JapaneseText>いつ来ても
ここは暑いねぇ～</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>1</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>273708</PointerOffset>
      <JapaneseText>クルール～</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>2</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>273788</PointerOffset>
      <JapaneseText>おい、タンス野郎！
お前、何勝手に休んでんだよ</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>3</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>273836</PointerOffset>
      <JapaneseText>聞いてんのか!?</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>4</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>273964</PointerOffset>
      <JapaneseText>まーったく、アホウ鳥のように
ギャーギャーうるせぇガキだーよ。
そんなんだから毛が生えねぇだ</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>4</SpeakerId>
      <Id>5</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>274024</PointerOffset>
      <JapaneseText>んだと！
こんのー！！！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>6</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>274160</PointerOffset>
      <JapaneseText>ぷぷぷー。おらは省エネ作戦で、
ここで涼んでるだーよ</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>4</SpeakerId>
      <Id>7</Id>
      <BubbleId>0</BubbleId>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>274160</PointerOffset>
      <JapaneseText>おめぇは、熱くなって、
暑くなるがいいだーよ</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>4</SpeakerId>
      <Id>7</Id>
      <BubbleId>1</BubbleId>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>274280</PointerOffset>
      <JapaneseText>アルベルトさんの言う通り
少しでも直射日光避けないと、
私たちも体力奪われちゃうもんね</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>5</SpeakerId>
      <Id>9</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>274420</PointerOffset>
      <JapaneseText>んだんだ、さすが&lt;Mel&gt;&lt;Mel&gt;だーよ。
おらの意図が、よくわかってるだ</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>4</SpeakerId>
      <Id>10</Id>
      <BubbleId>0</BubbleId>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>274420</PointerOffset>
      <JapaneseText>んだば、
ふたりで木陰で休むだよ～</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>4</SpeakerId>
      <Id>10</Id>
      <BubbleId>1</BubbleId>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>274512</PointerOffset>
      <JapaneseText>い、いや……、
ふたりでというより
みんなで休みましょ、ね？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>5</SpeakerId>
      <Id>12</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>274556</PointerOffset>
      <JapaneseText>クルール！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>13</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>274636</PointerOffset>
      <JapaneseText>どうしたの&lt;Dio&gt;？
一緒に木陰で涼まないの？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>14</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>274720</PointerOffset>
      <JapaneseText>だって……、
どう見ても、
そっちの方が暑そうだし</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>15</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>274920</PointerOffset>
      <JapaneseText>んだ、風呂に入らねぇクソぼうずが
こっち来たら、エライ事になるだ。
おめぇには、炎天下がお似合いだ</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>4</SpeakerId>
      <Id>16</Id>
      <BubbleId>0</BubbleId>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>274920</PointerOffset>
      <JapaneseText>おらは、&lt;Mel&gt;&lt;Mel&gt;と密着できて、
汗かけるなら、本望だでよ～∀</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>4</SpeakerId>
      <Id>16</Id>
      <BubbleId>1</BubbleId>
      <Status>To Do</Status>
    </Entry>
