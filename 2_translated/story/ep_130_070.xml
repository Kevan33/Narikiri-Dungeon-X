    <Entry>
      <PointerOffset>277944</PointerOffset>
      <VoiceId>&lt;audio:VSM_130_070_000&gt;</VoiceId>
      <JapaneseText>これ、どこへ
持っていけばいい？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>1</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>278036</PointerOffset>
      <VoiceId>&lt;audio:VSM_130_070_001&gt;</VoiceId>
      <JapaneseText>えっと……それは
前から三番目の馬車へ</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>2</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>278116</PointerOffset>
      <VoiceId>&lt;audio:VSM_130_070_002&gt;</VoiceId>
      <JapaneseText>俺、何すればいい？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>3</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>278236</PointerOffset>
      <VoiceId>&lt;audio:VSM_130_070_003&gt;</VoiceId>
      <JapaneseText>あ、んじゃあ、
今夜、みんなが寝れるよう、
道場の方の準備してくれよ</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>4</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>278304</PointerOffset>
      <VoiceId>&lt;audio:VSM_130_070_004&gt;</VoiceId>
      <JapaneseText>了解～</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>5</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>278400</PointerOffset>
      <VoiceId>&lt;audio:VSM_130_070_005&gt;</VoiceId>
      <JapaneseText>……みんな、なんで、
自分で考えないんだろ？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>6</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>278524</PointerOffset>
      <VoiceId>&lt;audio:VSM_130_070_006&gt;</VoiceId>
      <JapaneseText>&lt;Cless&gt;もしかして、さんが
なんでも指示するから、
自分で何も考えないのか？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>7</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>278588</PointerOffset>
      <VoiceId>&lt;audio:VSM_130_070_007&gt;</VoiceId>
      <JapaneseText>うーん……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>8</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>278664</PointerOffset>
      <VoiceId>&lt;audio:VSM_130_070_008&gt;</VoiceId>
      <JapaneseText>&lt;Cless&gt;様々だな</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>4</SpeakerId>
      <Id>9</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>278744</PointerOffset>
      <VoiceId>&lt;audio:VSM_130_070_009&gt;</VoiceId>
      <JapaneseText>いや、まったくです</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>5</SpeakerId>
      <Id>10</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>278916</PointerOffset>
      <VoiceId>&lt;audio:VSM_130_070_010&gt;</VoiceId>
      <JapaneseText></JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>4</SpeakerId>
      <Id>11</Id>
      <BubbleId>0</BubbleId>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>278916</PointerOffset>
      <VoiceId>&lt;audio:VSM_130_070_011&gt;</VoiceId>
      <JapaneseText>奴のおかげで、
多くの騎士志願者も
取り込めるあいつら、
英雄の言うことなら
なんでも聞くしな</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>4</SpeakerId>
      <Id>11</Id>
      <BubbleId>1</BubbleId>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>279032</PointerOffset>
      <VoiceId>&lt;audio:VSM_130_070_012&gt;</VoiceId>
      <JapaneseText>この調子で、うちの騎士団
もっと大きくなればいいですな</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>5</SpeakerId>
      <Id>13</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>279136</PointerOffset>
      <VoiceId>&lt;audio:VSM_130_070_013&gt;</VoiceId>
      <JapaneseText>ああ……そうなったら、
他の国々も圧倒できる</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>4</SpeakerId>
      <Id>14</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>279276</PointerOffset>
      <VoiceId>&lt;audio:VSM_130_070_014&gt;</VoiceId>
      <JapaneseText>&lt;Red&gt;&lt;White&gt;ヴァルハラのちんけな犯罪組織の
鎮圧仕事など、バカバカしくて
やってられません</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>5</SpeakerId>
      <Id>15</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>279440</PointerOffset>
      <VoiceId>&lt;audio:VSM_130_070_015&gt;</VoiceId>
      <JapaneseText>&lt;Cless&gt;</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>4</SpeakerId>
      <Id>16</Id>
      <BubbleId>0</BubbleId>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>279440</PointerOffset>
      <VoiceId>&lt;audio:VSM_130_070_016&gt;</VoiceId>
      <JapaneseText>そう言うな。
様の持ってきた仕事だきっちりこなして、
信頼を得なければ
台無しだぞ</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>4</SpeakerId>
      <Id>16</Id>
      <BubbleId>1</BubbleId>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>279528</PointerOffset>
      <VoiceId>&lt;audio:VSM_130_070_017&gt;</VoiceId>
      <JapaneseText>そうですな、
わっはっはっは</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>5</SpeakerId>
      <Id>18</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>279612</PointerOffset>
      <VoiceId>&lt;audio:VSM_130_070_018&gt;</VoiceId>
      <JapaneseText>……どーゆーことだよ、
これ……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>19</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>279732</PointerOffset>
      <VoiceId>&lt;audio:VSM_130_070_019&gt;</VoiceId>
      <JapaneseText>&lt;Cless&gt;さてと、そろそろ、
様にはちゃんと
働いてもらわないとな</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>4</SpeakerId>
      <Id>20</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>279832</PointerOffset>
      <VoiceId>&lt;audio:VSM_130_070_020&gt;</VoiceId>
      <JapaneseText>な、なんだ、
今の話聞いていたのか！？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>4</SpeakerId>
      <Id>21</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>279932</PointerOffset>
      <VoiceId>&lt;audio:VSM_130_070_021&gt;</VoiceId>
      <JapaneseText>&lt;Cless&gt;こいつ……！
様の代理やってた……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>5</SpeakerId>
      <Id>22</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>280012</PointerOffset>
      <VoiceId>&lt;audio:VSM_130_070_022&gt;</VoiceId>
      <JapaneseText>こいつら……
許せない……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>23</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>280072</PointerOffset>
      <VoiceId>&lt;audio:VSM_130_070_023&gt;</VoiceId>
      <JapaneseText>&lt;Dio&gt;！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>6</SpeakerId>
      <Id>24</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>280164</PointerOffset>
      <VoiceId>&lt;audio:VSM_130_070_024&gt;</VoiceId>
      <JapaneseText>&lt;Cless&gt;さん！
こいつら……ひどいんだ！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>25</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>280224</PointerOffset>
      <VoiceId>&lt;audio:VSM_130_070_025&gt;</VoiceId>
      <JapaneseText>いいんだ</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>6</SpeakerId>
      <Id>26</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>280288</PointerOffset>
      <VoiceId>&lt;audio:VSM_130_070_026&gt;</VoiceId>
      <JapaneseText>だって……！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>27</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>280352</PointerOffset>
      <VoiceId>&lt;audio:VSM_130_070_027&gt;</VoiceId>
      <JapaneseText>いいんだよ</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>6</SpeakerId>
      <Id>28</Id>
      <Status>To Do</Status>
    </Entry>
