    <Entry>
      <PointerOffset>278952</PointerOffset>
      <VoiceId>&lt;audio:VSM_200_010_010&gt;</VoiceId>
      <JapaneseText>見たか！
これが『なりきり士』の力だ！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>1</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>279120</PointerOffset>
      <VoiceId>&lt;audio:VSM_200_010_011&gt;</VoiceId>
      <JapaneseText></JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>2</Id>
      <BubbleId>0</BubbleId>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>279120</PointerOffset>
      <VoiceId>&lt;audio:VSM_200_010_012&gt;</VoiceId>
      <JapaneseText>私が息絶えたとしても
我が一族は、あなたたちへの
追撃の手を緩めません！プルートにそう伝えなさい！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>2</Id>
      <BubbleId>1</BubbleId>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>279188</PointerOffset>
      <VoiceId>&lt;audio:VSM_200_010_013&gt;</VoiceId>
      <JapaneseText>ぐっ……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>4</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>279268</PointerOffset>
      <VoiceId>&lt;audio:VSM_200_010_014&gt;</VoiceId>
      <JapaneseText>あ……追わなくてもいいの？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>4</SpeakerId>
      <Id>5</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>279384</PointerOffset>
      <VoiceId>&lt;audio:VSM_200_010_015&gt;</VoiceId>
      <JapaneseText>構いません。
私たちの今の目的は
彼を倒すことではないのですから</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>6</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>279492</PointerOffset>
      <VoiceId>&lt;audio:VSM_200_010_016&gt;</VoiceId>
      <JapaneseText>&lt;Suzu&gt;ちゃん、
かっこおもしろいよ！
さすが時空戦士だな</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>7</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>279560</PointerOffset>
      <VoiceId>&lt;audio:VSM_200_010_017&gt;</VoiceId>
      <JapaneseText>クゥールール！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>5</SpeakerId>
      <Id>8</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>279640</PointerOffset>
      <VoiceId>&lt;audio:VSM_200_010_018&gt;</VoiceId>
      <JapaneseText>かっこ……
何ですか、それ？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>9</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>279772</PointerOffset>
      <VoiceId>&lt;audio:VSM_200_010_019&gt;</VoiceId>
      <JapaneseText></JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>4</SpeakerId>
      <Id>10</Id>
      <BubbleId>0</BubbleId>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>279772</PointerOffset>
      <VoiceId>&lt;audio:VSM_200_010_020&gt;</VoiceId>
      <JapaneseText>かっこいいってこと、
だよね？堂々としてて、
凛としてて……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>4</SpeakerId>
      <Id>10</Id>
      <BubbleId>1</BubbleId>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>279936</PointerOffset>
      <VoiceId>&lt;audio:VSM_200_010_021&gt;</VoiceId>
      <JapaneseText></JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>12</Id>
      <BubbleId>0</BubbleId>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>279936</PointerOffset>
      <VoiceId>&lt;audio:VSM_200_010_022&gt;</VoiceId>
      <JapaneseText>わたしが侮られるというのは
一族が侮られるということそれは、一族全体の士気にも
関わってきます</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>12</Id>
      <BubbleId>1</BubbleId>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>280036</PointerOffset>
      <VoiceId>&lt;audio:VSM_200_010_023&gt;</VoiceId>
      <JapaneseText>すごいな。オレらなんて
自分のことで精一杯なのに</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>14</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>280684</PointerOffset>
      <VoiceId>&lt;audio:VSM_200_010_031&gt;</VoiceId>
      <JapaneseText>&lt;Rody&gt;どうしたんですか、
さん</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>4</SpeakerId>
      <Id>15</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>280772</PointerOffset>
      <VoiceId>&lt;audio:VSM_200_010_032&gt;</VoiceId>
      <JapaneseText>え？　あ、ううん、
なんでもないよ</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>6</SpeakerId>
      <Id>16</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>280868</PointerOffset>
      <VoiceId>&lt;audio:VSM_200_010_033&gt;</VoiceId>
      <JapaneseText>……それ、
誰かからのプレゼント、
ですか？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>4</SpeakerId>
      <Id>17</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>280932</PointerOffset>
      <VoiceId>&lt;audio:VSM_200_010_034&gt;</VoiceId>
      <JapaneseText>まぁね……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>6</SpeakerId>
      <Id>18</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>281268</PointerOffset>
      <VoiceId>&lt;audio:VSM_200_010_038&gt;</VoiceId>
      <JapaneseText>さ、行こう</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>6</SpeakerId>
      <Id>19</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>281332</PointerOffset>
      <VoiceId>&lt;audio:VSM_200_010_039&gt;</VoiceId>
      <JapaneseText>あの指輪……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>4</SpeakerId>
      <Id>20</Id>
      <Status>To Do</Status>
    </Entry>
