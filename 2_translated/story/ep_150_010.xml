    <Entry>
      <PointerOffset>316232</PointerOffset>
      <VoiceId>&lt;audio:VSM_150_010_001&gt;</VoiceId>
      <JapaneseText>&lt;Cless&gt;さん！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>1</Id>
      <OldPtr>279224</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>316296</PointerOffset>
      <VoiceId>&lt;audio:VSM_150_010_002&gt;</VoiceId>
      <JapaneseText>君たち……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>2</Id>
      <OldPtr>280288</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>316380</PointerOffset>
      <VoiceId>&lt;audio:VSM_150_010_003&gt;</VoiceId>
      <JapaneseText>わたしたちも
一緒に行きます！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>3</Id>
      <OldPtr>280612</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>316460</PointerOffset>
      <VoiceId>&lt;audio:VSM_150_010_004&gt;</VoiceId>
      <JapaneseText>なんだよ、騒がしいぞ！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>4</SpeakerId>
      <Id>4</Id>
      <OldPtr>280752</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>316540</PointerOffset>
      <VoiceId>&lt;audio:VSM_150_010_005&gt;</VoiceId>
      <JapaneseText>きみは……！
また会えたね！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>5</SpeakerId>
      <Id>5</Id>
      <OldPtr>282012</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>316692</PointerOffset>
      <VoiceId>&lt;audio:VSM_150_010_006&gt;</VoiceId>
      <JapaneseText>なんだ、この前会った
変なヤツじゃないか</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>4</SpeakerId>
      <Id>6</Id>
      <BubbleId>0</BubbleId>
      <OldPtr>282248</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>316692</PointerOffset>
      <VoiceId>&lt;audio:VSM_150_010_007&gt;</VoiceId>
      <JapaneseText>こんなとこまで
追いかけてきたのか？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>4</SpeakerId>
      <Id>6</Id>
      <BubbleId>1</BubbleId>
      <OldPtr>282248</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>316812</PointerOffset>
      <VoiceId>&lt;audio:VSM_150_010_008&gt;</VoiceId>
      <JapaneseText>あ……えっと……ぼくも
まさかこんなとこで
会えると思ってなくて……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>5</SpeakerId>
      <Id>8</Id>
      <OldPtr>282388</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>316900</PointerOffset>
      <VoiceId>&lt;audio:VSM_150_010_009&gt;</VoiceId>
      <JapaneseText>僕たちは、
ルナの力を借りに来たんだ</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>9</Id>
      <OldPtr>283320</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>316980</PointerOffset>
      <VoiceId>&lt;audio:VSM_150_010_010&gt;</VoiceId>
      <JapaneseText>ルナお姉ちゃんの力を？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>4</SpeakerId>
      <Id>10</Id>
      <OldPtr>283460</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>317096</PointerOffset>
      <VoiceId>&lt;audio:VSM_150_010_011&gt;</VoiceId>
      <JapaneseText>魔界の扉を閉じるために、
どうしてもルナの光の力が
必要なんです</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>6</SpeakerId>
      <Id>11</Id>
      <OldPtr>283880</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>317264</PointerOffset>
      <VoiceId>&lt;audio:VSM_150_010_012&gt;</VoiceId>
      <JapaneseText>あーっ！　思い出したぞ</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>4</SpeakerId>
      <Id>12</Id>
      <BubbleId>0</BubbleId>
      <OldPtr>284204</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>317264</PointerOffset>
      <VoiceId>&lt;audio:VSM_150_010_013&gt;</VoiceId>
      <JapaneseText>おまえら１００年くらい前に
ルナお姉ちゃんを勝手に
連れ出したヤツらだろ</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>4</SpeakerId>
      <Id>12</Id>
      <BubbleId>1</BubbleId>
      <OldPtr>284204</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>317344</PointerOffset>
      <VoiceId>&lt;audio:VSM_150_010_014&gt;</VoiceId>
      <JapaneseText>その節は
お世話になりました</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>6</SpeakerId>
      <Id>14</Id>
      <OldPtr>284560</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>317452</PointerOffset>
      <VoiceId>&lt;audio:VSM_150_010_015&gt;</VoiceId>
      <JapaneseText>帰った帰った。
今度はルナお姉ちゃんを
渡さないからな</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>4</SpeakerId>
      <Id>15</Id>
      <OldPtr>284792</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>317540</PointerOffset>
      <VoiceId>&lt;audio:VSM_150_010_016&gt;</VoiceId>
      <JapaneseText>待って！　教えて！
ぼくのことを！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>5</SpeakerId>
      <Id>16</Id>
      <OldPtr>288080</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>317628</PointerOffset>
      <VoiceId>&lt;audio:VSM_150_010_017&gt;</VoiceId>
      <JapaneseText>知るかよ、
おまえのことなんて！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>4</SpeakerId>
      <Id>17</Id>
      <OldPtr>288748</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>317728</PointerOffset>
      <VoiceId>&lt;audio:VSM_150_010_018&gt;</VoiceId>
      <JapaneseText>でも、あそこから出したら
教えてくれるって……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>5</SpeakerId>
      <Id>18</Id>
      <OldPtr>289228</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>317800</PointerOffset>
      <VoiceId>&lt;audio:VSM_150_010_019&gt;</VoiceId>
      <JapaneseText>ウソだったんだろ？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>19</Id>
      <OldPtr>289424</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>317916</PointerOffset>
      <VoiceId>&lt;audio:VSM_150_010_020&gt;</VoiceId>
      <JapaneseText>そーだよーだ。あそこから
出たかっただけだっての。
悪いかよ！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>4</SpeakerId>
      <Id>20</Id>
      <OldPtr>289564</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>317980</PointerOffset>
      <VoiceId>&lt;audio:VSM_150_010_021&gt;</VoiceId>
      <JapaneseText>こいつ……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>21</Id>
      <OldPtr>289884</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>318100</PointerOffset>
      <VoiceId>&lt;audio:VSM_150_010_022&gt;</VoiceId>
      <JapaneseText>ねぇ、本当に知らないの？
ぼく、ずっと妖精の仲間を
探してたのに……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>5</SpeakerId>
      <Id>22</Id>
      <OldPtr>291988</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>318200</PointerOffset>
      <VoiceId>&lt;audio:VSM_150_010_023&gt;</VoiceId>
      <JapaneseText>うるさいなぁ！
知らないって
言ってんだろ！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>4</SpeakerId>
      <Id>23</Id>
      <OldPtr>292184</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>318264</PointerOffset>
      <VoiceId>&lt;audio:VSM_150_010_024&gt;</VoiceId>
      <JapaneseText>うわっ……！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>24</Id>
      <OldPtr>293664</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>318348</PointerOffset>
      <VoiceId>&lt;audio:VSM_150_010_025&gt;</VoiceId>
      <JapaneseText>あ……
エレメンツポットが……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>25</Id>
      <OldPtr>297156</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>318444</PointerOffset>
      <VoiceId>&lt;audio:VSM_150_010_026&gt;</VoiceId>
      <JapaneseText>うっ……
そ、そっちが
悪いんだからな！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>4</SpeakerId>
      <Id>26</Id>
      <OldPtr>297364</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>318540</PointerOffset>
      <VoiceId>&lt;audio:VSM_150_010_027&gt;</VoiceId>
      <JapaneseText>せっかく……
集めたのに……
精霊と戦って……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>27</Id>
      <OldPtr>300124</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>318640</PointerOffset>
      <VoiceId>&lt;audio:VSM_150_010_028&gt;</VoiceId>
      <JapaneseText>ゴメン……
オレがちゃんと持って
なかったから……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>28</Id>
      <OldPtr>300264</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>318740</PointerOffset>
      <VoiceId>&lt;audio:VSM_150_010_029&gt;</VoiceId>
      <JapaneseText>違うよ、&lt;Dio&gt;……！
ぼくがぶつかったかラ……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>5</SpeakerId>
      <Id>29</Id>
      <OldPtr>300508</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>318808</PointerOffset>
      <VoiceId>&lt;audio:VSM_150_010_030&gt;</VoiceId>
      <JapaneseText>クルールゥ……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>7</SpeakerId>
      <Id>30</Id>
      <OldPtr>300648</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>318892</PointerOffset>
      <VoiceId>&lt;audio:VSM_150_010_031&gt;</VoiceId>
      <JapaneseText>み、皆さん、
元気出してください</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>6</SpeakerId>
      <Id>31</Id>
      <OldPtr>300880</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>319016</PointerOffset>
      <VoiceId>&lt;audio:VSM_150_010_032&gt;</VoiceId>
      <JapaneseText>ルナに会おう</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>32</Id>
      <BubbleId>0</BubbleId>
      <OldPtr>301020</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>319016</PointerOffset>
      <VoiceId>&lt;audio:VSM_150_010_033&gt;</VoiceId>
      <JapaneseText>精霊のことは、精霊に
聞けばなんとかなるよ</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>32</Id>
      <BubbleId>1</BubbleId>
      <OldPtr>301020</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>319080</PointerOffset>
      <VoiceId>&lt;audio:VSM_150_010_034&gt;</VoiceId>
      <JapaneseText>マジに……？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>34</Id>
      <OldPtr>301356</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>319200</PointerOffset>
      <VoiceId>&lt;audio:VSM_150_010_035&gt;</VoiceId>
      <JapaneseText>ええ、可能性はあります。
ここで希望を捨てるのは
よくないと思いますよ</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>6</SpeakerId>
      <Id>35</Id>
      <OldPtr>301700</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>319288</PointerOffset>
      <VoiceId>&lt;audio:VSM_150_010_036&gt;</VoiceId>
      <JapaneseText>そ、そうだよな……
行こう、&lt;Mel&gt;</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>36</Id>
      <OldPtr>303608</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>319348</PointerOffset>
      <VoiceId>&lt;audio:VSM_150_010_037&gt;</VoiceId>
      <JapaneseText>…………</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>37</Id>
      <OldPtr>303804</OldPtr>
      <Status>To Do</Status>
    </Entry>
