    <Entry>
      <PointerOffset>271548</PointerOffset>
      <VoiceId>&lt;audio:VSM_320_020_003&gt;</VoiceId>
      <JapaneseText>静かだね……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>3</Id>
      <OldPtr>259456</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>271644</PointerOffset>
      <VoiceId>&lt;audio:VSM_320_020_004&gt;</VoiceId>
      <JapaneseText>静かすぎて、
耳の中がつん
ってするぐらい……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>4</SpeakerId>
      <Id>4</Id>
      <OldPtr>259596</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>271728</PointerOffset>
      <VoiceId>&lt;audio:VSM_320_020_005&gt;</VoiceId>
      <JapaneseText>感じるよ……
もうひとりの自分を</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>5</Id>
      <OldPtr>259860</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>271820</PointerOffset>
      <VoiceId>&lt;audio:VSM_320_020_006&gt;</VoiceId>
      <JapaneseText>うん……オレも。
あいつら、ここにいる</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>6</Id>
      <OldPtr>260092</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>271920</PointerOffset>
      <VoiceId>&lt;audio:VSM_320_020_007&gt;</VoiceId>
      <JapaneseText>……決着をつけるって
あのふたりを倒すってこと？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>4</SpeakerId>
      <Id>7</Id>
      <OldPtr>260232</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>272020</PointerOffset>
      <VoiceId>&lt;audio:VSM_320_020_008&gt;</VoiceId>
      <JapaneseText>そーゆーこと。
悪いことしたヤツは、
倒さねーとな</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>8</Id>
      <OldPtr>260744</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>272140</PointerOffset>
      <VoiceId>&lt;audio:VSM_320_020_009&gt;</VoiceId>
      <JapaneseText>自分の悪い心に勝つ、
それがノルンがわたしたちに
与えた試練だからね</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>9</Id>
      <OldPtr>261008</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>272208</PointerOffset>
      <VoiceId>&lt;audio:VSM_320_020_010&gt;</VoiceId>
      <JapaneseText>そう、なんだ……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>4</SpeakerId>
      <Id>10</Id>
      <OldPtr>261204</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>272272</PointerOffset>
      <VoiceId>&lt;audio:VSM_320_020_011&gt;</VoiceId>
      <JapaneseText>行こーぜ！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>11</Id>
      <OldPtr>261720</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>272332</PointerOffset>
      <VoiceId>&lt;audio:VSM_320_020_012&gt;</VoiceId>
      <JapaneseText>……うん</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>12</Id>
      <OldPtr>262132</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>272520</PointerOffset>
      <VoiceId>&lt;audio:VSM_320_020_013&gt;</VoiceId>
      <JapaneseText>……&lt;Cless&gt;さんや&lt;Mint&gt;さん……
それにダオスさえも……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>4</SpeakerId>
      <Id>13</Id>
      <BubbleId>0</BubbleId>
      <OldPtr>262272</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>272520</PointerOffset>
      <VoiceId>&lt;audio:VSM_320_020_014&gt;</VoiceId>
      <JapaneseText>今まで会ってきた人たちが
きみたちの決断を
支えてくれたんだね……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>4</SpeakerId>
      <Id>13</Id>
      <BubbleId>1</BubbleId>
      <OldPtr>262272</OldPtr>
      <Status>To Do</Status>
    </Entry>
