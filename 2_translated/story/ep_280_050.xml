    <Entry>
      <PointerOffset>275360</PointerOffset>
      <VoiceId>&lt;audio:VSM_280_050_012&gt;</VoiceId>
      <JapaneseText>あれは……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>12</Id>
      <OldPtr>263568</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>275452</PointerOffset>
      <VoiceId>&lt;audio:VSM_280_050_013&gt;</VoiceId>
      <JapaneseText>わたしたちの因縁が
眠ってるの、あそこに</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>5</SpeakerId>
      <Id>13</Id>
      <OldPtr>263708</OldPtr>
      <Status>To Do</Status>
