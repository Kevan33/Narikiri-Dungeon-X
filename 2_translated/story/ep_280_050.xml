      <SpeakerId>3</SpeakerId>
      <Id>8</Id>
      <OldPtr>261824</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>275176</PointerOffset>
      <VoiceId>&lt;audio:VSM_280_050_009&gt;</VoiceId>
      <JapaneseText>しっかりして！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>5</SpeakerId>
      <Id>9</Id>
      <OldPtr>262332</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>275296</PointerOffset>
      <VoiceId>&lt;audio:VSM_280_050_010&gt;</VoiceId>
      <JapaneseText>はぁはぁ……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>10</Id>
      <BubbleId>0</BubbleId>
      <OldPtr>262804</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>275296</PointerOffset>
      <VoiceId>&lt;audio:VSM_280_050_011&gt;</VoiceId>
      <JapaneseText>全然……
だいじょーぶだっての……！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>10</Id>
      <BubbleId>1</BubbleId>
      <OldPtr>262804</OldPtr>
      <Status>To Do</Status>
