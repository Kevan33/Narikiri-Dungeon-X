    <Entry>
      <PointerOffset>275848</PointerOffset>
      <VoiceId>&lt;audio:VSM_280_050_019&gt;</VoiceId>
      <JapaneseText>そこに何が……あるの？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>19</Id>
      <OldPtr>264772</OldPtr>
      <Status>To Do</Status>
