      <PointerOffset>274680</PointerOffset>
      <VoiceId>&lt;audio:VSM_280_050_001&gt;</VoiceId>
      <JapaneseText>ここは、貴様に殺された
多くの魂が眠っている……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>1</Id>
      <BubbleId>0</BubbleId>
      <OldPtr>258732</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>274680</PointerOffset>
      <VoiceId>&lt;audio:VSM_280_050_002&gt;</VoiceId>
      <JapaneseText>我はその怨念の化身、残存思念</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>1</Id>
      <BubbleId>1</BubbleId>
      <OldPtr>258732</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>274756</PointerOffset>
      <VoiceId>&lt;audio:VSM_280_050_003&gt;</VoiceId>
      <JapaneseText>オレが……殺した……？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>3</Id>
      <OldPtr>260400</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>274824</PointerOffset>
      <VoiceId>&lt;audio:VSM_280_050_004&gt;</VoiceId>
      <JapaneseText>&lt;Dio&gt;、大丈夫？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>4</Id>
      <OldPtr>260660</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>274900</PointerOffset>
      <VoiceId>&lt;audio:VSM_280_050_005&gt;</VoiceId>
      <JapaneseText>また、何か見えたんだね？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>4</SpeakerId>
      <Id>5</Id>
      <OldPtr>260800</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>275048</PointerOffset>
      <VoiceId>&lt;audio:VSM_280_050_006&gt;</VoiceId>
      <JapaneseText>あれは……オレ自身……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>6</Id>
      <BubbleId>0</BubbleId>
      <OldPtr>261064</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>275048</PointerOffset>
      <VoiceId>&lt;audio:VSM_280_050_007&gt;</VoiceId>
      <JapaneseText>……オレが……大人？
それってどーゆー……
うっ……！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>6</Id>
      <BubbleId>1</BubbleId>
      <OldPtr>261064</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
