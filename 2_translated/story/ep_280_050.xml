    <Entry>
      <PointerOffset>275772</PointerOffset>
      <VoiceId>&lt;audio:VSM_280_050_017&gt;</VoiceId>
      <JapaneseText>&lt;Red&gt;ロキ魔科学研究窟&lt;White&gt;
