    <Entry>
      <PointerOffset>275524</PointerOffset>
      <VoiceId>&lt;audio:VSM_280_050_014&gt;</VoiceId>
      <JapaneseText>そうだな、
行こうぜ</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>14</Id>
      <OldPtr>263904</OldPtr>
