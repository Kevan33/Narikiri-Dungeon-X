    <Entry>
      <PointerOffset>275952</PointerOffset>
      <VoiceId>&lt;audio:VSM_280_050_020&gt;</VoiceId>
      <JapaneseText>わかんね……でも、
何かがそこにいる、
そう言ってた</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>20</Id>
      <OldPtr>265036</OldPtr>
