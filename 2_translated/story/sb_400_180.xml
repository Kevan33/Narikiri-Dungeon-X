  <Strings>
    <Section>Main</Section>
    <Entry>
      <PointerOffset>266848</PointerOffset>
      <JapaneseText>スルト森林のグレムリンレアー
ですが、魔界に帰りそこない
捕らえられました</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>1</Id>
      <BubbleId>0</BubbleId>
      <OldPtr>257556</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>266848</PointerOffset>
      <JapaneseText>現在、こちらの教会で、
確保しております</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>1</Id>
      <BubbleId>1</BubbleId>
      <OldPtr>257556</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>267044</PointerOffset>
      <JapaneseText>こちらの世界に取り残され、
ここで確保していた
グレムリンレアーですが</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>3</Id>
      <BubbleId>0</BubbleId>
      <OldPtr>257696</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>267044</PointerOffset>
      <JapaneseText>見張りの隙を突いて、
逃げ出してしまいました</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>3</Id>
      <BubbleId>1</BubbleId>
      <OldPtr>257696</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>267044</PointerOffset>
      <JapaneseText>これも私の不徳……
一体、ヤツはどこへ……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>3</Id>
      <BubbleId>2</BubbleId>
      <OldPtr>257696</OldPtr>
      <Status>To Do</Status>
    </Entry>
