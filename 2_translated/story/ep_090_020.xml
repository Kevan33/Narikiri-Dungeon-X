    <Entry>
      <PointerOffset>298600</PointerOffset>
      <VoiceId>&lt;audio:VSM_090_020_001&gt;</VoiceId>
      <JapaneseText>これが終わったら、
君たちの精霊さん集めは終わり？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>1</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>298668</PointerOffset>
      <VoiceId>&lt;audio:VSM_090_020_002&gt;</VoiceId>
      <JapaneseText>え？　あ、うん</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>2</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>298728</PointerOffset>
      <VoiceId>&lt;audio:VSM_090_020_003&gt;</VoiceId>
      <JapaneseText>そう……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>3</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>298824</PointerOffset>
      <VoiceId>&lt;audio:VSM_090_020_004&gt;</VoiceId>
      <JapaneseText>クラースさんと
バジルさんがいて
助かったよ</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>4</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>298932</PointerOffset>
      <VoiceId>&lt;audio:VSM_090_020_005&gt;</VoiceId>
      <JapaneseText>&lt;Red&gt;&lt;White&gt;エレメンツポットも
もらえたし、
浸食洞にも入れたし</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>5</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>299196</PointerOffset>
      <VoiceId>&lt;audio:VSM_090_020_008&gt;</VoiceId>
      <JapaneseText>バジルさんにも
お礼言っといてくれよ</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>6</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>299260</PointerOffset>
      <VoiceId>&lt;audio:VSM_090_020_009&gt;</VoiceId>
      <JapaneseText>クルール！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>7</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>299344</PointerOffset>
      <VoiceId>&lt;audio:VSM_090_020_010&gt;</VoiceId>
      <JapaneseText>ああ、わかった。
伝えておくよ</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>4</SpeakerId>
      <Id>8</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>299468</PointerOffset>
      <VoiceId>&lt;audio:VSM_090_020_011&gt;</VoiceId>
      <JapaneseText>そう言えばあのバジルって人、
ずいぶん熱心だね。
魔科学の研究もしてるの？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>9</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>299560</PointerOffset>
      <VoiceId>&lt;audio:VSM_090_020_012&gt;</VoiceId>
      <JapaneseText>いや。前はしていたが、
今はやっていない</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>4</SpeakerId>
      <Id>10</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>299632</PointerOffset>
      <VoiceId>&lt;audio:VSM_090_020_013&gt;</VoiceId>
      <JapaneseText>ふーん、そっか……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>11</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>299700</PointerOffset>
      <VoiceId>&lt;audio:VSM_090_020_014&gt;</VoiceId>
      <JapaneseText>魔科学って何だ？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>12</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>299808</PointerOffset>
      <VoiceId>&lt;audio:VSM_090_020_015&gt;</VoiceId>
      <JapaneseText>人間が科学を使って
魔術を使えるようにする
方法のことだ</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>4</SpeakerId>
      <Id>13</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>299904</PointerOffset>
      <VoiceId>&lt;audio:VSM_090_020_016&gt;</VoiceId>
      <JapaneseText>え……？
そんな便利なものが
あるんですか？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>5</SpeakerId>
      <Id>14</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>299992</PointerOffset>
      <VoiceId>&lt;audio:VSM_090_020_017&gt;</VoiceId>
      <JapaneseText>まあな。
でも、今は禁止されている</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>4</SpeakerId>
      <Id>15</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>300080</PointerOffset>
      <VoiceId>&lt;audio:VSM_090_020_018&gt;</VoiceId>
      <JapaneseText>え？　なんで？
そんな便利なのに……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>16</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>300196</PointerOffset>
      <VoiceId>&lt;audio:VSM_090_020_019&gt;</VoiceId>
      <JapaneseText>魔科学はマナを大量に消費し、
世界のことわりを破壊するから、
だよ</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>17</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>300276</PointerOffset>
      <VoiceId>&lt;audio:VSM_090_020_020&gt;</VoiceId>
      <JapaneseText>どうして、君、
それを……？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>4</SpeakerId>
      <Id>18</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>300348</PointerOffset>
      <VoiceId>&lt;audio:VSM_090_020_021&gt;</VoiceId>
      <JapaneseText>昔、友達に聞いたんだ</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>19</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>300412</PointerOffset>
      <VoiceId>&lt;audio:VSM_090_020_022&gt;</VoiceId>
      <JapaneseText>友達だって？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>4</SpeakerId>
      <Id>20</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>300492</PointerOffset>
      <VoiceId>&lt;audio:VSM_090_020_023&gt;</VoiceId>
      <JapaneseText>そう。森のものしり博士さーん</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>21</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>300596</PointerOffset>
      <VoiceId>&lt;audio:VSM_090_020_024&gt;</VoiceId>
      <JapaneseText>オレらの時代に魔科学なんて、
んなもん、ねーよな？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>22</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>300692</PointerOffset>
      <VoiceId>&lt;audio:VSM_090_020_025&gt;</VoiceId>
      <JapaneseText>使っちゃ悪いものだから、
すたれたんでしょ</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>5</SpeakerId>
      <Id>23</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>300948</PointerOffset>
      <VoiceId>&lt;audio:VSM_090_020_028&gt;</VoiceId>
      <JapaneseText>さてさて、先
進んじゃいましょう</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>24</Id>
      <Status>To Do</Status>
    </Entry>
