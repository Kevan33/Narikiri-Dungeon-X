      <VoiceId>&lt;audio:VSM_020_050_006&gt;</VoiceId>
      <JapaneseText>クルール！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>6</Id>
      <OldPtr>261896</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>278368</PointerOffset>
      <VoiceId>&lt;audio:VSM_020_050_007&gt;</VoiceId>
      <JapaneseText>なんか……
ついてきたがってる
みたいだけド……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>4</SpeakerId>
      <Id>7</Id>
      <OldPtr>262148</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>278472</PointerOffset>
      <VoiceId>&lt;audio:VSM_020_050_008&gt;</VoiceId>
      <JapaneseText>ダメダメ。
おまえみたいなチビっ子、
連れてけねって</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>8</Id>
      <OldPtr>263664</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>278544</PointerOffset>
      <VoiceId>&lt;audio:VSM_020_050_009&gt;</VoiceId>
      <JapaneseText>クルール！！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>9</Id>
      <OldPtr>264140</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>278656</PointerOffset>
      <VoiceId>&lt;audio:VSM_020_050_010&gt;</VoiceId>
      <JapaneseText>ゴメンね、わたしたち、
これから危険なところへ
行くから……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>10</Id>
      <OldPtr>264280</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>278728</PointerOffset>
      <VoiceId>&lt;audio:VSM_020_050_011&gt;</VoiceId>
      <JapaneseText>……危険なのかな？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>11</Id>
      <OldPtr>264940</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>278824</PointerOffset>
      <VoiceId>&lt;audio:VSM_020_050_012&gt;</VoiceId>
      <JapaneseText>全然だいじょーぶだって。
なんとかなるって</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>12</Id>
      <OldPtr>265564</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>278944</PointerOffset>
      <VoiceId>&lt;audio:VSM_020_050_013&gt;</VoiceId>
      <JapaneseText>&lt;Mel&gt;は先に家に帰って。
心配ないよ、
&lt;Dio&gt;にはぼくがついてくかラ</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>4</SpeakerId>
      <Id>13</Id>
      <OldPtr>266560</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>279076</PointerOffset>
      <VoiceId>&lt;audio:VSM_020_050_014&gt;</VoiceId>
      <JapaneseText>……ううん、行くよ。
だって、あの魔術はわたしが
したことなのかもしれないし……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>14</Id>
      <OldPtr>266976</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>279320</PointerOffset>
      <VoiceId>&lt;audio:VSM_020_050_017&gt;</VoiceId>
      <JapaneseText>そうしないとダメだと
思うから</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>15</Id>
      <OldPtr>267116</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>279384</PointerOffset>
      <VoiceId>&lt;audio:VSM_020_050_018&gt;</VoiceId>
      <JapaneseText>そう……？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>4</SpeakerId>
      <Id>16</Id>
      <OldPtr>267256</OldPtr>
      <Status>To Do</Status>
