    <Entry>
      <PointerOffset>278200</PointerOffset>
      <VoiceId>&lt;audio:VSM_020_050_005&gt;</VoiceId>
      <JapaneseText>どうしたの？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>5</Id>
      <OldPtr>261544</OldPtr>
      <Status>To Do</Status>
