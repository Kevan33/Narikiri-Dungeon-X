    <Section>Main</Section>
    <Entry>
      <PointerOffset>306444</PointerOffset>
      <VoiceId>&lt;audio:VSM_230_020_001&gt;</VoiceId>
      <JapaneseText>うぉっ……</JapaneseText>
      <EnglishText>Whoa...</EnglishText>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>1</Id>
      <BubbleId>0</BubbleId>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset>306444</PointerOffset>
      <VoiceId>&lt;audio:VSM_230_020_002&gt;</VoiceId>
      <JapaneseText>なんだ、あれ……</JapaneseText>
      <EnglishText>What are those guys doing?</EnglishText>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>1</Id>
      <BubbleId>1</BubbleId>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset>306536</PointerOffset>
      <VoiceId>&lt;audio:VSM_230_020_003&gt;</VoiceId>
      <JapaneseText>プルートの手下の
魔界の者たちのようです</JapaneseText>
      <EnglishText>They are Servants of Pluto from
the Demon realm, no less.</EnglishText>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>3</Id>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset>306632</PointerOffset>
      <VoiceId>&lt;audio:VSM_230_020_004&gt;</VoiceId>
      <JapaneseText>あの大群を
いっぺんに相手するのは
少し骨だね</JapaneseText>
      <EnglishText>Facing so many at once
could prove tricky.</EnglishText>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>4</Id>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset>306708</PointerOffset>
      <VoiceId>&lt;audio:VSM_230_020_005&gt;</VoiceId>
      <JapaneseText>うーん、どうしよう……</JapaneseText>
      <EnglishText>Hmm, this is trouble...</EnglishText>
      <Notes/>
      <SpeakerId>4</SpeakerId>
      <Id>5</Id>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset>306888</PointerOffset>
      <VoiceId>&lt;audio:VSM_230_020_007&gt;</VoiceId>
      <JapaneseText>ね、この岩場、
登って上の方から回って
あそこやり過ごせないかな</JapaneseText>
      <EnglishText>Hey! If we climb that rocky mountain
we could get past them without
drawing attention!</EnglishText>
      <Notes/>
      <SpeakerId>4</SpeakerId>
      <Id>6</Id>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset>307028</PointerOffset>
      <VoiceId>&lt;audio:VSM_230_020_008&gt;</VoiceId>
      <JapaneseText>ぼくは飛べるけド……</JapaneseText>
      <EnglishText>I can fly, but...</EnglishText>
      <Notes/>
      <SpeakerId>5</SpeakerId>
      <Id>7</Id>
      <BubbleId>0</BubbleId>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset>307028</PointerOffset>
      <VoiceId>&lt;audio:VSM_230_020_009&gt;</VoiceId>
      <JapaneseText>&lt;Dio&gt;や&lt;Mel&gt;に
この岩場登るなんて、
無茶だよ</JapaneseText>
      <EnglishText>&lt;Dio&gt; and &lt;Mel&gt; are too small
to climb this...</EnglishText>
      <Notes/>
      <SpeakerId>5</SpeakerId>
      <Id>7</Id>
      <BubbleId>1</BubbleId>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset>307108</PointerOffset>
      <VoiceId>&lt;audio:VSM_230_020_010&gt;</VoiceId>
      <JapaneseText>無茶かどうか
試してみようよ</JapaneseText>
      <EnglishText>We won't know if it
works until we try!</EnglishText>
      <Notes/>
      <SpeakerId>4</SpeakerId>
      <Id>9</Id>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset>307432</PointerOffset>
      <VoiceId>&lt;audio:VSM_230_020_014&gt;</VoiceId>
      <JapaneseText>あの目ん玉野郎は目んとこ、
なんかヤバそうだよな</JapaneseText>
      <EnglishText>Those eye guys seem to be trouble.</EnglishText>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>10</Id>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset>307532</PointerOffset>
      <VoiceId>&lt;audio:VSM_230_020_015&gt;</VoiceId>
      <JapaneseText>あいつ、
目から石化光線出して、
厄介なんだよな</JapaneseText>
      <EnglishText>Their gaze can petrify
people. So yeah, trouble.</EnglishText>
      <Notes/>
      <SpeakerId>6</SpeakerId>
      <Id>11</Id>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset>307628</PointerOffset>
      <VoiceId>&lt;audio:VSM_230_020_016&gt;</VoiceId>
      <JapaneseText>あ！　だったらさ、
リキュールボトルを……</JapaneseText>
      <EnglishText>Ah! If it comes to that, we
could just use a Liqueur Bottle!</EnglishText>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>12</Id>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset>307712</PointerOffset>
      <VoiceId>&lt;audio:VSM_230_020_017&gt;</VoiceId>
      <JapaneseText>双子ちゃん、
ちょっと成長したね</JapaneseText>
      <EnglishText>The twins sure have grown up a lot.</EnglishText>
      <Notes/>
      <SpeakerId>7</SpeakerId>
      <Id>13</Id>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset>307772</PointerOffset>
      <VoiceId>&lt;audio:VSM_230_020_018&gt;</VoiceId>
      <JapaneseText>……かも</JapaneseText>
      <EnglishText>...Probably.</EnglishText>
      <Notes/>
      <SpeakerId>5</SpeakerId>
      <Id>14</Id>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset>308016</PointerOffset>
      <VoiceId>&lt;audio:VSM_230_020_021&gt;</VoiceId>
      <JapaneseText>さ～てと。
そろそろかな</JapaneseText>
      <EnglishText>Let's see... Anytime now...!</EnglishText>
      <Notes/>
      <SpeakerId>7</SpeakerId>
      <Id>15</Id>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset>308144</PointerOffset>
      <VoiceId>&lt;audio:VSM_230_020_022&gt;</VoiceId>
      <JapaneseText>……だね……
そろそろかも……</JapaneseText>
      <EnglishText>...Right...anytime...now...</EnglishText>
      <Notes/>
      <SpeakerId>5</SpeakerId>
      <Id>16</Id>
      <BubbleId>0</BubbleId>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset>308144</PointerOffset>
      <VoiceId>&lt;audio:VSM_230_020_023&gt;</VoiceId>
      <JapaneseText>え……？
そろそろって……？</JapaneseText>
      <EnglishText>Wha? What do you mean anytime now?</EnglishText>
      <Notes/>
      <SpeakerId>5</SpeakerId>
      <Id>16</Id>
      <BubbleId>1</BubbleId>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset>308208</PointerOffset>
      <VoiceId>&lt;audio:VSM_230_020_024&gt;</VoiceId>
      <JapaneseText>伏せて……！</JapaneseText>
      <EnglishText>Take cover!</EnglishText>
      <Notes/>
      <SpeakerId>7</SpeakerId>
      <Id>18</Id>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset>308276</PointerOffset>
      <VoiceId>&lt;audio:VSM_230_020_025&gt;</VoiceId>
      <JapaneseText>な、何だ……？</JapaneseText>
      <EnglishText>What was that...!?</EnglishText>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>19</Id>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset>308340</PointerOffset>
      <VoiceId>&lt;audio:VSM_230_020_026&gt;</VoiceId>
      <JapaneseText>爆発……？</JapaneseText>
      <EnglishText>An explosion!?</EnglishText>
      <Notes/>
      <SpeakerId>4</SpeakerId>
      <Id>20</Id>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset>308428</PointerOffset>
      <VoiceId>&lt;audio:VSM_230_020_027&gt;</VoiceId>
      <JapaneseText>だーいじょうぶ。
小さい爆発だから</JapaneseText>
      <EnglishText>It's ok! Just some controlled demolition!</EnglishText>
      <Notes/>
      <SpeakerId>7</SpeakerId>
      <Id>21</Id>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset>308500</PointerOffset>
      <VoiceId>&lt;audio:VSM_230_020_028&gt;</VoiceId>
      <JapaneseText>ちょっと何したのよ</JapaneseText>
      <EnglishText>Wait a minute, what're you up to?</EnglishText>
      <Notes/>
      <SpeakerId>8</SpeakerId>
      <Id>22</Id>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset>308588</PointerOffset>
      <VoiceId>&lt;audio:VSM_230_020_029&gt;</VoiceId>
      <JapaneseText>入り口んとこに
火薬をしかけといた</JapaneseText>
      <EnglishText>Oh, nothing. Just left some small
presents near the entrance.</EnglishText>
      <Notes/>
      <SpeakerId>7</SpeakerId>
      <Id>23</Id>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset>308852</PointerOffset>
      <VoiceId>&lt;audio:VSM_230_020_032&gt;</VoiceId>
      <JapaneseText>あれ……？　それじゃあ、
さっきいなかったのは……</JapaneseText>
      <EnglishText>You mean...that's what you
were doing back there?</EnglishText>
      <Notes/>
      <SpeakerId>4</SpeakerId>
      <Id>24</Id>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset>308932</PointerOffset>
      <VoiceId>&lt;audio:VSM_230_020_033&gt;</VoiceId>
      <JapaneseText>そそそ、
これ仕掛けるためね</JapaneseText>
      <EnglishText>Yup! A small trap to thank
them for their hospitality!</EnglishText>
      <Notes/>
      <SpeakerId>7</SpeakerId>
      <Id>25</Id>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset>309232</PointerOffset>
      <VoiceId>&lt;audio:VSM_230_020_037&gt;</VoiceId>
      <JapaneseText>ほら、敵さんが
少なくなったよ、
行くなら今のうち</JapaneseText>
      <EnglishText>All right, the enemies should be
dispersed. It's now or never!</EnglishText>
      <Notes/>
      <SpeakerId>7</SpeakerId>
      <Id>26</Id>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset>309300</PointerOffset>
      <VoiceId>&lt;audio:VSM_230_020_038&gt;</VoiceId>
      <JapaneseText>行きましょう！</JapaneseText>
      <EnglishText>It is time to move!</EnglishText>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>27</Id>
      <Status>Proofreading</Status>
    </Entry>
