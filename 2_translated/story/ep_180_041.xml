    <Entry>
      <PointerOffset>312900</PointerOffset>
      <VoiceId>&lt;audio:VSM_180_040_045&gt;</VoiceId>
      <JapaneseText>&lt;Rody&gt;！！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>6</SpeakerId>
      <Id>26</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>312976</PointerOffset>
      <VoiceId>&lt;audio:VSM_180_040_046&gt;</VoiceId>
      <JapaneseText>プロセス終了を確認しました</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>4</SpeakerId>
      <Id>27</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>313048</PointerOffset>
      <VoiceId>&lt;audio:VSM_180_040_047&gt;</VoiceId>
      <JapaneseText>戻って……きたのか？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>28</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>313156</PointerOffset>
      <VoiceId>&lt;audio:VSM_180_040_048&gt;</VoiceId>
      <JapaneseText>外に出てみたら？
そしたらたぶん
わかるんじゃないかな？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>9</SpeakerId>
      <Id>29</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>313240</PointerOffset>
      <VoiceId>&lt;audio:VSM_180_040_049&gt;</VoiceId>
      <JapaneseText>&lt;Rody&gt;さん、
