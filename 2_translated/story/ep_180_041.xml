    <Entry>
      <PointerOffset>312836</PointerOffset>
      <VoiceId>&lt;audio:VSM_180_040_044&gt;</VoiceId>
      <JapaneseText>んじゃあね♪</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>9</SpeakerId>
      <Id>25</Id>
      <Status>To Do</Status>
