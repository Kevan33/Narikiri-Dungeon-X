      <PointerOffset>280644</PointerOffset>
      <JapaneseText></JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>4</SpeakerId>
      <Id>47</Id>
      <BubbleId>0</BubbleId>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>280644</PointerOffset>
      <JapaneseText>ああ、そうかそうだね、先生が戻ってきて
から持ってきてくれたほうが
いいかもね</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>4</SpeakerId>
      <Id>47</Id>
      <BubbleId>1</BubbleId>
      <Status>To Do</Status>
    </Entry>
