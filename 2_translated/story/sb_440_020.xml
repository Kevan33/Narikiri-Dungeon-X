      <EnglishText/>
      <Notes/>
      <SpeakerId>4</SpeakerId>
      <Id>43</Id>
      <BubbleId>0</BubbleId>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>280848</PointerOffset>
      <JapaneseText>そっか。それじゃあ、
もし、集まったら、
持ってきてくれるかなあ、無理に、とは言わないから。
できれば、でいいからね</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>4</SpeakerId>
      <Id>43</Id>
      <BubbleId>1</BubbleId>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>280460</PointerOffset>
      <JapaneseText></JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>4</SpeakerId>
      <Id>45</Id>
      <BubbleId>0</BubbleId>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>280460</PointerOffset>
      <JapaneseText>ああ、ありがと。
いただくよ先生も喜ぶよ、きっと</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>4</SpeakerId>
      <Id>45</Id>
      <BubbleId>1</BubbleId>
      <Status>To Do</Status>
    </Entry>
