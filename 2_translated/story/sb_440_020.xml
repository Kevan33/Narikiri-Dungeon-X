      <SpeakerId>4</SpeakerId>
      <Id>49</Id>
      <BubbleId>0</BubbleId>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>280960</PointerOffset>
      <JapaneseText>また先生が戻ってきたら、
来てね先生も君たちに
とても会いたがってたから</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>4</SpeakerId>
      <Id>49</Id>
      <BubbleId>1</BubbleId>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>281008</PointerOffset>
      <JapaneseText>え、ええ……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>51</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>281064</PointerOffset>
      <JapaneseText>それじゃあ……また</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>4</SpeakerId>
      <Id>52</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>281240</PointerOffset>
      <JapaneseText>やっぱり……あの人に……！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>53</Id>
      <Status>To Do</Status>
    </Entry>
