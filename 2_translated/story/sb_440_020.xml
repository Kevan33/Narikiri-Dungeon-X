      <PointerOffset>277492</PointerOffset>
      <JapaneseText>……そう言えばさ……
前にバジルさんに
頼まれ事してたよな……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>1</Id>
