  <Strings>
    <Section>Main</Section>
    <Entry>
      <PointerOffset>272040</PointerOffset>
      <JapaneseText>事情は聞いてる系？
だからあたしに任せれば
ダイジョブ系？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>1</Id>
      <OldPtr>258376</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>272104</PointerOffset>
      <JapaneseText>よろしくお願いするズラ！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>2</Id>
      <OldPtr>258572</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>272168</PointerOffset>
      <JapaneseText>お、さっそくやってるみたいだな</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>3</Id>
      <OldPtr>258768</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>272228</PointerOffset>
      <JapaneseText>タルロウさん、がんばって！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>4</SpeakerId>
      <Id>4</Id>
      <OldPtr>258964</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>272320</PointerOffset>
      <JapaneseText>とても激しい特訓だったが
お見せ出来ないのが残念だぜ……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>5</Id>
      <OldPtr>259620</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>272368</PointerOffset>
      <JapaneseText>見せる？誰に？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>4</SpeakerId>
      <Id>6</Id>
      <OldPtr>259920</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>272416</PointerOffset>
      <JapaneseText>いや、別に……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>7</Id>
      <OldPtr>260276</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>272504</PointerOffset>
      <JapaneseText>ハァ、ハァ……
き、きっそー……
全然ダメズラ……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>8</Id>
      <OldPtr>260800</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>272616</PointerOffset>
      <JapaneseText>そうでもない系？　なんか
後ひとつポイントさえつかめば
一気に花開く系？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>9</Id>
      <OldPtr>260940</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>272708</PointerOffset>
      <JapaneseText>本当ズラか！？
そのひとつのポイントって
何ズラか！？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>10</Id>
      <OldPtr>261136</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>272820</PointerOffset>
      <JapaneseText>それは……タイミング系？
間というか、タイミングを
つかめば、いける系？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>11</Id>
      <OldPtr>261276</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>272900</PointerOffset>
      <JapaneseText>そ、それはどうやって
学べばいいズラか！？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>12</Id>
      <OldPtr>261416</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>273008</PointerOffset>
      <JapaneseText>う～ん、悩む系？
これは一人で教えるより
二人で教えたほうがいい系？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>13</Id>
      <OldPtr>261612</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>273064</PointerOffset>
      <JapaneseText>ショックハート！！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>14</Id>
      <OldPtr>261752</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>273188</PointerOffset>
      <JapaneseText>どっかにこのあたし並とは
言わない系だけど、それなりに
踊れる系？がいればいいのに系？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>15</Id>
      <OldPtr>261892</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>273260</PointerOffset>
      <JapaneseText>う、うーん、
また探してこようか……？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>4</SpeakerId>
      <Id>16</Id>
      <OldPtr>262188</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>273336</PointerOffset>
      <JapaneseText>なんだ、それなら
&lt;Mel&gt;踊ればいいじゃん？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>17</Id>
      <OldPtr>262552</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>273384</PointerOffset>
      <JapaneseText>え？わたし！？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>4</SpeakerId>
      <Id>18</Id>
      <OldPtr>262748</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>273464</PointerOffset>
      <JapaneseText>そうそう。
そんなコスチュームなかったっけ？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>19</Id>
      <OldPtr>262944</OldPtr>
      <Status>To Do</Status>
    </Entry>
