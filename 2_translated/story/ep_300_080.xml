      <Id>16</Id>
      <BubbleId>0</BubbleId>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>276668</PointerOffset>
      <VoiceId>&lt;audio:VSM_300_080_017&gt;</VoiceId>
      <JapaneseText>私もそう思うでも、つらくても、私はダオスに
会えなかった自分を想像できない
し、したくもないんだ</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>16</Id>
      <BubbleId>1</BubbleId>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>276756</PointerOffset>
      <VoiceId>&lt;audio:VSM_300_080_018&gt;</VoiceId>
      <JapaneseText>&lt;Rody&gt;さん、
そんなにダオスを……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>18</Id>
      <Status>To Do</Status>
    </Entry>
