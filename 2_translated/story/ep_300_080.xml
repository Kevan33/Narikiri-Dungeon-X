    <Entry>
      <PointerOffset>275628</PointerOffset>
      <VoiceId>&lt;audio:VSM_300_080_004&gt;</VoiceId>
      <JapaneseText>さん、
やっぱりわたしたちのこと、
許せないですか？ダオスをあんなにした原因、
わたしたちだし……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>3</Id>
      <BubbleId>1</BubbleId>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>275688</PointerOffset>
      <VoiceId>&lt;audio:VSM_300_080_005&gt;</VoiceId>
      <JapaneseText>許せない</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>5</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>275752</PointerOffset>
      <VoiceId>&lt;audio:VSM_300_080_006&gt;</VoiceId>
      <JapaneseText>……ですよね</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>6</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>275852</PointerOffset>
      <VoiceId>&lt;audio:VSM_300_080_007&gt;</VoiceId>
      <JapaneseText>……って言ったら、一発、
殴らせてくれるのかな？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>7</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>275920</PointerOffset>
      <VoiceId>&lt;audio:VSM_300_080_008&gt;</VoiceId>
      <JapaneseText>ど、どうぞ……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>8</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>276020</PointerOffset>
      <VoiceId>&lt;audio:VSM_300_080_009&gt;</VoiceId>
      <JapaneseText>&lt;Mel&gt;ちゃん、カワイイ。
食べちゃっていい？∀</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>9</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>276108</PointerOffset>
      <VoiceId>&lt;audio:VSM_300_080_010&gt;</VoiceId>
      <JapaneseText>ちょ、ちょっと……
やめてください！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>10</Id>
      <Status>To Do</Status>
    </Entry>
