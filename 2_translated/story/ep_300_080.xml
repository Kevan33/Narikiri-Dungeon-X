    <Entry>
      <PointerOffset>275452</PointerOffset>
      <VoiceId>&lt;audio:VSM_300_080_002&gt;</VoiceId>
      <JapaneseText>どうしたの？　&lt;Mel&gt;ちゃん</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>2</Id>
      <OldPtr>259544</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>275628</PointerOffset>
      <VoiceId>&lt;audio:VSM_300_080_003&gt;</VoiceId>
      <JapaneseText>&lt;Rody&gt;さん、
やっぱりわたしたちのこと、
許せないですか？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>3</Id>
      <BubbleId>0</BubbleId>
      <OldPtr>259724</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>275628</PointerOffset>
      <VoiceId>&lt;audio:VSM_300_080_004&gt;</VoiceId>
      <JapaneseText>ダオスをあんなにした原因、
わたしたちだし……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>3</Id>
      <BubbleId>1</BubbleId>
      <OldPtr>259724</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>275688</PointerOffset>
      <VoiceId>&lt;audio:VSM_300_080_005&gt;</VoiceId>
      <JapaneseText>許せない</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>5</Id>
      <OldPtr>259988</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>275752</PointerOffset>
      <VoiceId>&lt;audio:VSM_300_080_006&gt;</VoiceId>
      <JapaneseText>……ですよね</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>6</Id>
      <OldPtr>260128</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>275852</PointerOffset>
      <VoiceId>&lt;audio:VSM_300_080_007&gt;</VoiceId>
      <JapaneseText>……って言ったら、一発、
殴らせてくれるのかな？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>7</Id>
      <OldPtr>260324</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>275920</PointerOffset>
      <VoiceId>&lt;audio:VSM_300_080_008&gt;</VoiceId>
      <JapaneseText>ど、どうぞ……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>8</Id>
      <OldPtr>260520</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>276020</PointerOffset>
      <VoiceId>&lt;audio:VSM_300_080_009&gt;</VoiceId>
      <JapaneseText>&lt;Mel&gt;ちゃん、カワイイ。
食べちゃっていい？∀</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>9</Id>
      <OldPtr>261172</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>276108</PointerOffset>
      <VoiceId>&lt;audio:VSM_300_080_010&gt;</VoiceId>
      <JapaneseText>ちょ、ちょっと……
やめてください！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>10</Id>
      <OldPtr>261368</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>276380</PointerOffset>
      <VoiceId>&lt;audio:VSM_300_080_011&gt;</VoiceId>
      <JapaneseText>フフっ……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>11</Id>
      <BubbleId>0</BubbleId>
      <OldPtr>261632</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>276380</PointerOffset>
      <VoiceId>&lt;audio:VSM_300_080_012&gt;</VoiceId>
      <JapaneseText>……そうだなぁ、
なんとも思ってない
わけないけど</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>11</Id>
      <BubbleId>1</BubbleId>
      <OldPtr>261632</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>276380</PointerOffset>
      <VoiceId>&lt;audio:VSM_300_080_013&gt;</VoiceId>
      <JapaneseText>そもそも、君たちのやったことが
なければ、ダオスは
アセリアに来なかったし</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>11</Id>
      <BubbleId>2</BubbleId>
      <OldPtr>261632</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>276380</PointerOffset>
      <VoiceId>&lt;audio:VSM_300_080_014&gt;</VoiceId>
      <JapaneseText>私がダオスに
会うこともなかった</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>11</Id>
      <BubbleId>3</BubbleId>
      <OldPtr>261632</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>276500</PointerOffset>
      <VoiceId>&lt;audio:VSM_300_080_015&gt;</VoiceId>
      <JapaneseText>でも、そっちの方が
ダオスにも、&lt;Rody&gt;さんにも
幸せだったと思います</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>15</Id>
      <OldPtr>262092</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>276668</PointerOffset>
      <VoiceId>&lt;audio:VSM_300_080_016&gt;</VoiceId>
      <JapaneseText>私もそう思う</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>16</Id>
      <BubbleId>0</BubbleId>
      <OldPtr>262232</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>276668</PointerOffset>
      <VoiceId>&lt;audio:VSM_300_080_017&gt;</VoiceId>
      <JapaneseText>でも、つらくても、私はダオスに
会えなかった自分を想像できない
し、したくもないんだ</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>16</Id>
      <BubbleId>1</BubbleId>
      <OldPtr>262232</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>276756</PointerOffset>
      <VoiceId>&lt;audio:VSM_300_080_018&gt;</VoiceId>
      <JapaneseText>&lt;Rody&gt;さん、
そんなにダオスを……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>18</Id>
      <OldPtr>262644</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>276936</PointerOffset>
      <VoiceId>&lt;audio:VSM_300_080_019&gt;</VoiceId>
      <JapaneseText>それに君たちがあんなこと
した張本人だって言われても
ちょっとピンと来なくて</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>19</Id>
      <BubbleId>0</BubbleId>
      <OldPtr>263332</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>276936</PointerOffset>
      <VoiceId>&lt;audio:VSM_300_080_020&gt;</VoiceId>
      <JapaneseText>見守らせて、
君たちの罪の行方、私に</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>19</Id>
      <BubbleId>1</BubbleId>
      <OldPtr>263332</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>277024</PointerOffset>
      <VoiceId>&lt;audio:VSM_300_080_021&gt;</VoiceId>
      <JapaneseText>よろしくお願いします、
&lt;Rody&gt;さん</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>21</Id>
      <OldPtr>263900</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>277100</PointerOffset>
      <VoiceId>&lt;audio:VSM_300_080_022&gt;</VoiceId>
      <JapaneseText>だーかーらー、固いってば</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>22</Id>
      <OldPtr>264324</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>277180</PointerOffset>
      <VoiceId>&lt;audio:VSM_300_080_023&gt;</VoiceId>
      <JapaneseText>……よろしくね……&lt;Rody&gt;</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>23</Id>
      <OldPtr>264792</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>277240</PointerOffset>
      <VoiceId>&lt;audio:VSM_300_080_024&gt;</VoiceId>
      <JapaneseText>…………</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>24</Id>
      <OldPtr>265332</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>277304</PointerOffset>
      <VoiceId>&lt;audio:VSM_300_080_025&gt;</VoiceId>
      <JapaneseText>クルール！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>25</Id>
      <OldPtr>265664</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>277384</PointerOffset>
      <VoiceId>&lt;audio:VSM_300_080_026&gt;</VoiceId>
      <JapaneseText>何やってんだ、
置いてくぞ！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>4</SpeakerId>
      <Id>26</Id>
      <OldPtr>266000</OldPtr>
      <Status>To Do</Status>
