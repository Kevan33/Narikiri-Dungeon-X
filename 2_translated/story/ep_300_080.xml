    <Entry>
      <PointerOffset>276380</PointerOffset>
      <VoiceId>&lt;audio:VSM_300_080_014&gt;</VoiceId>
      <JapaneseText>フフっ…………そうだなぁ、
なんとも思ってない
わけないけどそもそも、君たちのやったことが
なければ、ダオスは
アセリアに来なかったし私がダオスに
会うこともなかった</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>11</Id>
      <BubbleId>3</BubbleId>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>276500</PointerOffset>
      <VoiceId>&lt;audio:VSM_300_080_015&gt;</VoiceId>
      <JapaneseText>&lt;Rody&gt;でも、そっちの方が
ダオスにも、さんにも
幸せだったと思います</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>15</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>276668</PointerOffset>
