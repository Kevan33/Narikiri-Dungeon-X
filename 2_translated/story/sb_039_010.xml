    <Entry>
      <PointerOffset>294564</PointerOffset>
      <VoiceId>&lt;audio:VSS_039_010_001&gt;</VoiceId>
      <JapaneseText>クルール！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>1</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>294776</PointerOffset>
      <VoiceId>&lt;audio:VSS_039_010_002&gt;</VoiceId>
      <JapaneseText>見つけてくれて
サンキュー！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>2</Id>
      <BubbleId>0</BubbleId>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>294776</PointerOffset>
      <VoiceId>&lt;audio:VSS_039_010_003&gt;</VoiceId>
      <JapaneseText>ん……？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>2</Id>
      <BubbleId>1</BubbleId>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>294776</PointerOffset>
      <VoiceId>&lt;audio:VSS_039_010_004&gt;</VoiceId>
      <JapaneseText>……うふふふふふふふふ……、
これはいい面構え！
ひさしぶりにピーンと来た！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>2</Id>
      <BubbleId>2</BubbleId>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>294844</PointerOffset>
      <VoiceId>&lt;audio:VSS_039_010_005&gt;</VoiceId>
      <JapaneseText>だ、だれ……？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>5</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>295140</PointerOffset>
      <VoiceId>&lt;audio:VSS_039_010_006&gt;</VoiceId>
      <JapaneseText>聞かれて名乗らぬは女の恥！
いいかしら、聞いて驚け、
私の名は……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>6</Id>
      <BubbleId>0</BubbleId>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>295140</PointerOffset>
      <VoiceId>&lt;audio:VSS_039_010_007&gt;</VoiceId>
      <JapaneseText>味の結社
『すばらしき味の世界』の
主任料理長、ワンダーシェフ！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>6</Id>
      <BubbleId>1</BubbleId>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>295140</PointerOffset>
      <VoiceId>&lt;audio:VSS_039_010_008&gt;</VoiceId>
      <JapaneseText>人は、ドラムを叩くような
包丁さばきから私を
稲妻のリリアンと呼ぶわ！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>6</Id>
      <BubbleId>2</BubbleId>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>295212</PointerOffset>
      <VoiceId>&lt;audio:VSS_039_010_009&gt;</VoiceId>
      <JapaneseText>似合わねー名前……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>4</SpeakerId>
      <Id>9</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>295416</PointerOffset>
      <VoiceId>&lt;audio:VSS_039_010_010&gt;</VoiceId>
      <JapaneseText>人は親しみ込めて
リッちゃん∀って呼ぶわよ！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>5</SpeakerId>
      <Id>10</Id>
      <BubbleId>0</BubbleId>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>295416</PointerOffset>
      <VoiceId>&lt;audio:VSS_039_010_011&gt;</VoiceId>
      <JapaneseText>私を見つけられたご褒美に、
『すばらしき味の世界』直伝、
料理レシピを教えてあげる！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>5</SpeakerId>
      <Id>10</Id>
      <BubbleId>1</BubbleId>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>295480</PointerOffset>
      <VoiceId>&lt;audio:VSS_039_010_012&gt;</VoiceId>
      <JapaneseText>マジで！？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>4</SpeakerId>
      <Id>12</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>295588</PointerOffset>
      <VoiceId>&lt;audio:VSS_039_010_013&gt;</VoiceId>
      <JapaneseText>信じる者は救われる！
し・ん・じ・な・さいっ！！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>5</SpeakerId>
      <Id>13</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>295704</PointerOffset>
      <VoiceId>&lt;audio:VSS_039_010_014&gt;</VoiceId>
      <JapaneseText>&lt;Dio&gt;……
知らない人から変なもの、
もらっちゃいけないって……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>14</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>296000</PointerOffset>
      <VoiceId>&lt;audio:VSS_039_010_015&gt;</VoiceId>
      <JapaneseText>変なものとか、言うなぁあっ！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>5</SpeakerId>
      <Id>15</Id>
      <BubbleId>0</BubbleId>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>296000</PointerOffset>
      <VoiceId>&lt;audio:VSS_039_010_016&gt;</VoiceId>
      <JapaneseText>んんっ……食事は命の洗濯、
食卓は清らかな水湧く泉、
食器は洗濯板！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>5</SpeakerId>
      <Id>15</Id>
      <BubbleId>1</BubbleId>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>296000</PointerOffset>
      <VoiceId>&lt;audio:VSS_039_010_017&gt;</VoiceId>
      <JapaneseText>戦いに疲れた時、
いや人生に疲れた時、</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>5</SpeakerId>
      <Id>15</Id>
      <BubbleId>2</BubbleId>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>296000</PointerOffset>
      <VoiceId>&lt;audio:VSS_039_010_018&gt;</VoiceId>
      <JapaneseText>このレシピはあなたを洗う
泡立つしゃぼんとなる！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>5</SpeakerId>
      <Id>15</Id>
      <BubbleId>3</BubbleId>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>296192</PointerOffset>
      <VoiceId>&lt;audio:VSS_039_010_019&gt;</VoiceId>
      <JapaneseText>そして、食材は
洗剤のようなもの！！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>5</SpeakerId>
      <Id>19</Id>
      <BubbleId>0</BubbleId>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>296192</PointerOffset>
      <VoiceId>&lt;audio:VSS_039_010_020&gt;</VoiceId>
      <JapaneseText>これをあげるから、
たくさん練習を積み上げるのよ！
あの山の頂のケルンのように！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>5</SpeakerId>
      <Id>19</Id>
      <BubbleId>1</BubbleId>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>296276</PointerOffset>
      <VoiceId>&lt;audio:VSS_039_010_021&gt;</VoiceId>
      <JapaneseText>……では、サラバっ！！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>5</SpeakerId>
      <Id>21</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>296412</PointerOffset>
      <VoiceId>&lt;audio:VSS_039_010_022&gt;</VoiceId>
      <JapaneseText>……このレシピ、
ちゃんとしてる……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>22</Id>
      <BubbleId>0</BubbleId>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>296412</PointerOffset>
      <VoiceId>&lt;audio:VSS_039_010_023&gt;</VoiceId>
      <JapaneseText>もらった食材も
新鮮だし……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>22</Id>
      <BubbleId>1</BubbleId>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>296488</PointerOffset>
      <VoiceId>&lt;audio:VSS_039_010_024&gt;</VoiceId>
      <JapaneseText>んじゃ、
もらっとこーぜ</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>4</SpeakerId>
      <Id>24</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>296564</PointerOffset>
      <VoiceId>&lt;audio:VSS_039_010_025&gt;</VoiceId>
      <JapaneseText>うーん、いいのかな……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>25</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>296632</PointerOffset>
      <VoiceId>&lt;audio:VSS_039_010_026&gt;</VoiceId>
      <JapaneseText>気にすんなって</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>4</SpeakerId>
      <Id>26</Id>
      <Status>To Do</Status>
    </Entry>
