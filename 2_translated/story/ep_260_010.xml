    <Section>Main</Section>
    <Entry>
      <PointerOffset>293848</PointerOffset>
      <VoiceId>&lt;audio:VSM_260_010_000&gt;</VoiceId>
      <JapaneseText>あいつら……
どこ行ったんだ？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>1</Id>
      <OldPtr>278424</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>293972</PointerOffset>
      <VoiceId>&lt;audio:VSM_260_010_001&gt;</VoiceId>
      <JapaneseText>……わからない……
ここ、どこなんだろう……
なんかイヤな感じがする……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>2</Id>
      <OldPtr>278848</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>294036</PointerOffset>
      <VoiceId>&lt;audio:VSM_260_010_002&gt;</VoiceId>
      <JapaneseText>クルクルッ！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>3</Id>
      <OldPtr>279468</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>294120</PointerOffset>
      <VoiceId>&lt;audio:VSM_260_010_003&gt;</VoiceId>
      <JapaneseText>ダオス！
倒したはずなのに……！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>4</Id>
      <OldPtr>281088</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>294332</PointerOffset>
      <VoiceId>&lt;audio:VSM_260_010_005&gt;</VoiceId>
      <JapaneseText>今の私は
私であって、私でない</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>4</SpeakerId>
      <Id>5</Id>
      <BubbleId>0</BubbleId>
      <OldPtr>281228</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>294332</PointerOffset>
      <VoiceId>&lt;audio:VSM_260_010_006&gt;</VoiceId>
      <JapaneseText>おまえたちが戦った
私もまた</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>4</SpeakerId>
      <Id>5</Id>
      <BubbleId>1</BubbleId>
      <OldPtr>281228</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>294416</PointerOffset>
      <VoiceId>&lt;audio:VSM_260_010_007&gt;</VoiceId>
      <JapaneseText>…………？
どーゆーことだよっ！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>7</Id>
      <OldPtr>281600</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>294496</PointerOffset>
      <VoiceId>&lt;audio:VSM_260_010_008&gt;</VoiceId>
      <JapaneseText>残存思念、
それが今の私だ</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>4</SpeakerId>
      <Id>8</Id>
      <OldPtr>281740</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>294560</PointerOffset>
      <VoiceId>&lt;audio:VSM_260_010_009&gt;</VoiceId>
      <JapaneseText>残存思念？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>9</Id>
      <OldPtr>281992</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>294712</PointerOffset>
      <VoiceId>&lt;audio:VSM_260_010_010&gt;</VoiceId>
      <JapaneseText>執着、遺恨、悔い</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>4</SpeakerId>
      <Id>10</Id>
      <BubbleId>0</BubbleId>
      <OldPtr>282356</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>294712</PointerOffset>
      <VoiceId>&lt;audio:VSM_260_010_011&gt;</VoiceId>
      <JapaneseText>ここはそうした思念が
本来の時空からはぐれ
集った暗黒時空なのだ</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>4</SpeakerId>
      <Id>10</Id>
      <BubbleId>1</BubbleId>
      <OldPtr>282356</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>294864</PointerOffset>
      <VoiceId>&lt;audio:VSM_260_010_012&gt;</VoiceId>
      <JapaneseText>あんたのこととか
ここがどことか
どーだっていい！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>12</Id>
      <BubbleId>0</BubbleId>
      <OldPtr>282720</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>294864</PointerOffset>
      <VoiceId>&lt;audio:VSM_260_010_013&gt;</VoiceId>
      <JapaneseText>仮面つけたヤツら、
見なかったか？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>12</Id>
      <BubbleId>1</BubbleId>
      <OldPtr>282720</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>295008</PointerOffset>
      <VoiceId>&lt;audio:VSM_260_010_014&gt;</VoiceId>
      <JapaneseText>……『&lt;Red&gt;焔王（ほむらおう）の楔&lt;White&gt;』
へ行った</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>4</SpeakerId>
      <Id>14</Id>
      <BubbleId>0</BubbleId>
      <OldPtr>283036</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>295008</PointerOffset>
      <VoiceId>&lt;audio:VSM_260_010_015&gt;</VoiceId>
      <JapaneseText>追うがいい！
貴様らの因縁を</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>4</SpeakerId>
      <Id>14</Id>
      <BubbleId>1</BubbleId>
      <OldPtr>283036</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>295104</PointerOffset>
      <VoiceId>&lt;audio:VSM_260_010_016&gt;</VoiceId>
      <JapaneseText>消えた……
なんか親切すぎねーか？
あいつ……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>16</Id>
      <OldPtr>283660</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>295180</PointerOffset>
      <VoiceId>&lt;audio:VSM_260_010_017&gt;</VoiceId>
      <JapaneseText>それに襲ってこなかったシ</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>5</SpeakerId>
      <Id>17</Id>
      <OldPtr>283904</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>295296</PointerOffset>
      <VoiceId>&lt;audio:VSM_260_010_018&gt;</VoiceId>
      <JapaneseText>……今、見たの、
前会ったダオスとは
なんか違う雰囲気だったね？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>18</Id>
      <OldPtr>284340</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>295492</PointerOffset>
      <VoiceId>&lt;audio:VSM_260_010_020&gt;</VoiceId>
      <JapaneseText>とにかく、
『&lt;Red&gt;焔王の楔&lt;White&gt;』ってとこ
行ってみよーぜ</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>19</Id>
      <OldPtr>284604</OldPtr>
      <Status>To Do</Status>
    </Entry>
  </Strings>
