    <Entry>
      <PointerOffset>275648</PointerOffset>
      <VoiceId>&lt;audio:VSM_270_020_001&gt;</VoiceId>
      <JapaneseText>う～……寒い……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>1</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>275728</PointerOffset>
      <VoiceId>&lt;audio:VSM_270_020_002&gt;</VoiceId>
      <JapaneseText>子どもは風の子！
がんばれ！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>2</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>275808</PointerOffset>
      <VoiceId>&lt;audio:VSM_270_020_003&gt;</VoiceId>
      <JapaneseText>クルクルクル、クルール～！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>3</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>275992</PointerOffset>
      <VoiceId>&lt;audio:VSM_270_020_005&gt;</VoiceId>
      <JapaneseText>&lt;Rody&gt;あの……
さん……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>4</SpeakerId>
      <Id>4</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>276308</PointerOffset>
      <VoiceId>&lt;audio:VSM_270_020_009&gt;</VoiceId>
      <JapaneseText>前にデリス・カーラーン
って言ってましたよね</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>4</SpeakerId>
      <Id>5</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>276380</PointerOffset>
      <VoiceId>&lt;audio:VSM_270_020_010&gt;</VoiceId>
      <JapaneseText>……言ってたっけ？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>6</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>276468</PointerOffset>
      <VoiceId>&lt;audio:VSM_270_020_011&gt;</VoiceId>
      <JapaneseText>ダオスが何か
持ち帰ろうとしてたって</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>4</SpeakerId>
      <Id>7</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>276544</PointerOffset>
      <VoiceId>&lt;audio:VSM_270_020_012&gt;</VoiceId>
      <JapaneseText>『大いなる実り』……だね</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>8</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>276640</PointerOffset>
      <VoiceId>&lt;audio:VSM_270_020_013&gt;</VoiceId>
      <JapaneseText>デリス・カーラーン
ってダオスの故郷だっけ</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>9</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>276728</PointerOffset>
      <VoiceId>&lt;audio:VSM_270_020_014&gt;</VoiceId>
      <JapaneseText>そう……でも、今は
もうないかもね</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>10</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>276804</PointerOffset>
      <VoiceId>&lt;audio:VSM_270_020_015&gt;</VoiceId>
      <JapaneseText>ない……？
なんで……？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>11</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>277068</PointerOffset>
      <VoiceId>&lt;audio:VSM_270_020_016&gt;</VoiceId>
      <JapaneseText></JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>12</Id>
      <BubbleId>0</BubbleId>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>277068</PointerOffset>
      <VoiceId>&lt;audio:VSM_270_020_017&gt;</VoiceId>
      <JapaneseText></JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>12</Id>
      <BubbleId>1</BubbleId>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>277068</PointerOffset>
      <VoiceId>&lt;audio:VSM_270_020_018&gt;</VoiceId>
      <JapaneseText>戦争で滅亡寸前になった。
だから、彼はアセリアに
来たんだよデリス・カーラーンの人々の命、
マナの源である『大いなる実り』
を故郷へ持ち帰るためでも、ダオスは
時空戦士に倒された</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>12</Id>
      <BubbleId>2</BubbleId>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>277176</PointerOffset>
      <VoiceId>&lt;audio:VSM_270_020_019&gt;</VoiceId>
      <JapaneseText>&lt;Cless&gt;え、じゃあ、
さんたちのせいで
ダオスの故郷が……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>15</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>277264</PointerOffset>
      <VoiceId>&lt;audio:VSM_270_020_020&gt;</VoiceId>
      <JapaneseText>間接的には
そういうことになるかな</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>16</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>277324</PointerOffset>
      <VoiceId>&lt;audio:VSM_270_020_021&gt;</VoiceId>
      <JapaneseText>…………</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>4</SpeakerId>
      <Id>17</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>277424</PointerOffset>
      <VoiceId>&lt;audio:VSM_270_020_022&gt;</VoiceId>
      <JapaneseText>&lt;Cless&gt;でも！　さんたちが、
悪いってわけじゃない</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>18</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>277556</PointerOffset>
      <VoiceId>&lt;audio:VSM_270_020_023&gt;</VoiceId>
      <JapaneseText></JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>19</Id>
      <BubbleId>0</BubbleId>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>277556</PointerOffset>
      <VoiceId>&lt;audio:VSM_270_020_024&gt;</VoiceId>
      <JapaneseText>……だねダオスのやり方も
決して正しくは
なかったんだからさ</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>19</Id>
      <BubbleId>1</BubbleId>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>277680</PointerOffset>
      <VoiceId>&lt;audio:VSM_270_020_025&gt;</VoiceId>
      <JapaneseText>でも、ダオスは
自分の故郷を救うために、
アセリアの人たちを襲ったんだ……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>4</SpeakerId>
      <Id>21</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>277956</PointerOffset>
      <VoiceId>&lt;audio:VSM_270_020_026&gt;</VoiceId>
      <JapaneseText></JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>22</Id>
      <BubbleId>0</BubbleId>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>277956</PointerOffset>
      <VoiceId>&lt;audio:VSM_270_020_027&gt;</VoiceId>
      <JapaneseText></JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>22</Id>
      <BubbleId>1</BubbleId>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>277956</PointerOffset>
      <VoiceId>&lt;audio:VSM_270_020_028&gt;</VoiceId>
      <JapaneseText>そ、世界樹を枯らす魔科学を
滅ぼして、世界樹になる
『大いなる実り』を手にするためでも……私にはやっぱり
どうしてもわかんない彼のような優しい人が、
どうしてあそこまで
非情になったのか……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>22</Id>
      <BubbleId>2</BubbleId>
      <Status>To Do</Status>
    </Entry>
