    <Entry>
      <PointerOffset>294612</PointerOffset>
      <VoiceId>&lt;audio:VSM_050_010_001&gt;</VoiceId>
      <JapaneseText>ここにイフリートが
いるんだね</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>1</Id>
      <OldPtr>278340</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>294736</PointerOffset>
      <VoiceId>&lt;audio:VSM_050_010_002&gt;</VoiceId>
      <JapaneseText>みたいだな……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>2</Id>
      <BubbleId>0</BubbleId>
      <OldPtr>278580</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>294736</PointerOffset>
      <VoiceId>&lt;audio:VSM_050_010_003&gt;</VoiceId>
      <JapaneseText>よし、さっさと探して、
来てもらおうぜ</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>2</Id>
      <BubbleId>1</BubbleId>
      <OldPtr>278580</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>294816</PointerOffset>
      <VoiceId>&lt;audio:VSM_050_010_004&gt;</VoiceId>
      <JapaneseText>来てもらうか……笑わせる</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>4</Id>
      <OldPtr>279432</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>294884</PointerOffset>
      <VoiceId>&lt;audio:VSM_050_010_005&gt;</VoiceId>
      <JapaneseText>クルールゥ……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>4</SpeakerId>
      <Id>5</Id>
      <OldPtr>280664</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>294948</PointerOffset>
      <VoiceId>&lt;audio:VSM_050_010_006&gt;</VoiceId>
      <JapaneseText>…………？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>6</Id>
      <OldPtr>281640</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>295044</PointerOffset>
      <VoiceId>&lt;audio:VSM_050_010_007&gt;</VoiceId>
      <JapaneseText>本当にそんな簡単な話だと
思っているのか？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>7</Id>
      <OldPtr>282600</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>295140</PointerOffset>
      <VoiceId>&lt;audio:VSM_050_010_008&gt;</VoiceId>
      <JapaneseText>あーっ、おまえ！
&lt;Red&gt;ヴァルハラ&lt;White&gt;の時の……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>8</Id>
      <OldPtr>282796</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>295264</PointerOffset>
      <VoiceId>&lt;audio:VSM_050_010_009&gt;</VoiceId>
      <JapaneseText>非力なあなたたちが、
精霊と等しく太刀打ちできる
はずもないでしょうに</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>5</SpeakerId>
      <Id>9</Id>
      <OldPtr>282936</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>295328</PointerOffset>
      <VoiceId>&lt;audio:VSM_050_010_010&gt;</VoiceId>
      <JapaneseText>待て……！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>10</Id>
      <OldPtr>283340</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>295396</PointerOffset>
      <VoiceId>&lt;audio:VSM_050_010_011&gt;</VoiceId>
      <JapaneseText>……消えた……？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>11</Id>
      <OldPtr>284060</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>295472</PointerOffset>
      <VoiceId>&lt;audio:VSM_050_010_012&gt;</VoiceId>
      <JapaneseText>一体、何なの、あレ……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>6</SpeakerId>
      <Id>12</Id>
      <OldPtr>284200</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>295532</PointerOffset>
      <VoiceId>&lt;audio:VSM_050_010_013&gt;</VoiceId>
      <JapaneseText>…………</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>13</Id>
      <OldPtr>284500</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>295672</PointerOffset>
      <VoiceId>&lt;audio:VSM_050_010_014&gt;</VoiceId>
      <JapaneseText>あんなヤツの言葉、
真に受けんなよ</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>14</Id>
      <BubbleId>0</BubbleId>
      <OldPtr>284816</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>295672</PointerOffset>
      <VoiceId>&lt;audio:VSM_050_010_015&gt;</VoiceId>
      <JapaneseText>コワかったら、
オレの後ろ隠れてろ</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>14</Id>
      <BubbleId>1</BubbleId>
      <OldPtr>284816</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>295752</PointerOffset>
      <VoiceId>&lt;audio:VSM_050_010_016&gt;</VoiceId>
      <JapaneseText>平気……
こわくなんてない</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>16</Id>
      <OldPtr>285012</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>295828</PointerOffset>
      <VoiceId>&lt;audio:VSM_050_010_017&gt;</VoiceId>
      <JapaneseText>……だったら、いいけど</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>17</Id>
      <OldPtr>285152</OldPtr>
      <Status>To Do</Status>
    </Entry>
