    <Entry>
      <PointerOffset>333276</PointerOffset>
      <VoiceId>&lt;audio:VSM_330_010_064&gt;</VoiceId>
      <JapaneseText>この強さが
あなたがたの生きてきた証</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>1</Id>
      <OldPtr>283728</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>333384</PointerOffset>
      <VoiceId>&lt;audio:VSM_330_010_065&gt;</VoiceId>
      <JapaneseText>過ちを受け止めた
あなたがたの覚悟、
見せてもらいました</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>2</Id>
      <OldPtr>283880</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>333480</PointerOffset>
      <VoiceId>&lt;audio:VSM_330_010_066&gt;</VoiceId>
      <JapaneseText>これで私の役目は終わりです。
さようなら……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>3</Id>
      <OldPtr>284032</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>333544</PointerOffset>
      <VoiceId>&lt;audio:VSM_330_010_067&gt;</VoiceId>
      <JapaneseText>エト……！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>4</Id>
      <OldPtr>286400</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>333624</PointerOffset>
      <VoiceId>&lt;audio:VSM_330_010_068&gt;</VoiceId>
      <JapaneseText>エトくんは
無事みたいだね</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>5</Id>
      <OldPtr>290340</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>333688</PointerOffset>
      <VoiceId>&lt;audio:VSM_330_010_069&gt;</VoiceId>
      <JapaneseText>ああ、うん</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>6</Id>
      <OldPtr>290564</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>333804</PointerOffset>
      <VoiceId>&lt;audio:VSM_330_010_070&gt;</VoiceId>
      <JapaneseText>……&lt;Cless&gt;さんたち、
こんなとこまでついて
きてくれて……あんがと</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>7</Id>
      <OldPtr>290856</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>333912</PointerOffset>
      <VoiceId>&lt;audio:VSM_330_010_071&gt;</VoiceId>
      <JapaneseText>いいや……
ここまで君たちと一緒に
旅ができてよかったよ</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>8</Id>
      <OldPtr>291204</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>333988</PointerOffset>
      <VoiceId>&lt;audio:VSM_330_010_072&gt;</VoiceId>
      <JapaneseText>わたしたちもです……！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>4</SpeakerId>
      <Id>9</Id>
      <OldPtr>291740</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>334112</PointerOffset>
      <VoiceId>&lt;audio:VSM_330_010_073&gt;</VoiceId>
      <JapaneseText>デリス・カーラーンで
何があったか……
それを知ることができましたし……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>5</SpeakerId>
      <Id>10</Id>
      <OldPtr>292076</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>334244</PointerOffset>
      <VoiceId>&lt;audio:VSM_330_010_074&gt;</VoiceId>
      <JapaneseText>うん……それに君たちが
いてくれたから、&lt;Cless&gt;や&lt;Mint&gt;、
&lt;Claus&gt;もこうして生きてる</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>6</SpeakerId>
      <Id>11</Id>
      <OldPtr>292584</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>334316</PointerOffset>
      <VoiceId>&lt;audio:VSM_330_010_075&gt;</VoiceId>
      <JapaneseText>ど、どういうことだ？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>7</SpeakerId>
      <Id>12</Id>
      <OldPtr>293196</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>334404</PointerOffset>
      <VoiceId>&lt;audio:VSM_330_010_076&gt;</VoiceId>
      <JapaneseText>え？　あ、気にしない、
気にしない</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>6</SpeakerId>
      <Id>13</Id>
      <OldPtr>294440</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>334504</PointerOffset>
      <VoiceId>&lt;audio:VSM_330_010_077&gt;</VoiceId>
      <JapaneseText>でも……ここで……
こんな形でお別れなんてさ……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>8</SpeakerId>
      <Id>14</Id>
      <OldPtr>295624</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>334600</PointerOffset>
      <VoiceId>&lt;audio:VSM_330_010_078&gt;</VoiceId>
      <JapaneseText>だが、これが、君たちの決意なら
否定はしない</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>7</SpeakerId>
      <Id>15</Id>
      <OldPtr>295848</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>334684</PointerOffset>
      <VoiceId>&lt;audio:VSM_330_010_079&gt;</VoiceId>
      <JapaneseText>……&lt;Dio&gt;さん、
&lt;Mel&gt;さん……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>9</SpeakerId>
      <Id>16</Id>
      <OldPtr>296128</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>334792</PointerOffset>
      <VoiceId>&lt;audio:VSM_330_010_080&gt;</VoiceId>
      <JapaneseText>私、忘れません、
あなたたちという
友達がいたことを……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>9</SpeakerId>
      <Id>17</Id>
      <OldPtr>296280</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>334884</PointerOffset>
      <VoiceId>&lt;audio:VSM_330_010_081&gt;</VoiceId>
      <JapaneseText>僕だって、
いや、みんなも
君たちの友達だ</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>18</Id>
      <OldPtr>296824</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>334952</PointerOffset>
      <VoiceId>&lt;audio:VSM_330_010_082&gt;</VoiceId>
      <JapaneseText>&lt;Cless&gt;さん……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>19</Id>
      <OldPtr>297224</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>335036</PointerOffset>
      <VoiceId>&lt;audio:VSM_330_010_083&gt;</VoiceId>
      <JapaneseText>ふたりとも……
消えかけて……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>10</SpeakerId>
      <Id>20</Id>
      <OldPtr>299148</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>335120</PointerOffset>
      <VoiceId>&lt;audio:VSM_330_010_084&gt;</VoiceId>
      <JapaneseText>もうお別れって
ことみたいだぜ</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>21</Id>
      <OldPtr>303304</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>335236</PointerOffset>
      <VoiceId>&lt;audio:VSM_330_010_085&gt;</VoiceId>
      <JapaneseText>ゴメンね、エト……
エトをひとり置き去りに
していくみたいになって</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>4</SpeakerId>
      <Id>22</Id>
      <OldPtr>303640</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>335340</PointerOffset>
      <VoiceId>&lt;audio:VSM_330_010_086&gt;</VoiceId>
      <JapaneseText>いやだよ……行かないで……
ずっと一緒に楽しく……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>11</SpeakerId>
      <Id>23</Id>
      <OldPtr>304084</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>335452</PointerOffset>
      <VoiceId>&lt;audio:VSM_330_010_087&gt;</VoiceId>
      <JapaneseText>なんだよ～、オレらの
決断受け止めるって
言ったじゃねーか！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>24</Id>
      <OldPtr>304748</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>335528</PointerOffset>
      <VoiceId>&lt;audio:VSM_330_010_088&gt;</VoiceId>
      <JapaneseText>だって……だってさ……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>11</SpeakerId>
      <Id>25</Id>
      <OldPtr>305076</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>335636</PointerOffset>
      <VoiceId>&lt;audio:VSM_330_010_089&gt;</VoiceId>
      <JapaneseText>わたしも……もっともっと、
エトと思い出作りたかったよ</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>4</SpeakerId>
      <Id>26</Id>
      <OldPtr>305468</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>335728</PointerOffset>
      <VoiceId>&lt;audio:VSM_330_010_090&gt;</VoiceId>
      <JapaneseText>こんなとこで、
お別れなんてイヤだよ……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>4</SpeakerId>
      <Id>27</Id>
      <OldPtr>306084</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>335800</PointerOffset>
      <VoiceId>&lt;audio:VSM_330_010_091&gt;</VoiceId>
      <JapaneseText>&lt;Mel&gt;まで何言っ……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>28</Id>
      <OldPtr>306808</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>335884</PointerOffset>
      <VoiceId>&lt;audio:VSM_330_010_092&gt;</VoiceId>
      <JapaneseText>……なんだよ……
決めたんだろ！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>29</Id>
      <OldPtr>306960</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>335952</PointerOffset>
      <VoiceId>&lt;audio:VSM_330_010_093&gt;</VoiceId>
      <JapaneseText>オレ、らは……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>30</Id>
      <OldPtr>307328</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>336060</PointerOffset>
      <VoiceId>&lt;audio:VSM_330_010_094&gt;</VoiceId>
      <JapaneseText>楽しかったよ、エト。
たくさんたくさん……
思い出ありがと</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>4</SpeakerId>
      <Id>31</Id>
      <OldPtr>307808</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>336160</PointerOffset>
      <VoiceId>&lt;audio:VSM_330_010_095&gt;</VoiceId>
      <JapaneseText>……最後の、最後に……
ツライ想いさせてゴメンな</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>32</Id>
      <OldPtr>308532</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>336244</PointerOffset>
      <VoiceId>&lt;audio:VSM_330_010_096&gt;</VoiceId>
      <JapaneseText>オレってやっぱ
親不孝もんかも</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>33</Id>
      <OldPtr>308948</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>336316</PointerOffset>
      <VoiceId>&lt;audio:VSM_330_010_097&gt;</VoiceId>
      <JapaneseText>そんなことない……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>11</SpeakerId>
      <Id>34</Id>
      <OldPtr>309540</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>336408</PointerOffset>
      <VoiceId>&lt;audio:VSM_330_010_098&gt;</VoiceId>
      <JapaneseText>&lt;Dio&gt;も、&lt;Mel&gt;も、
いい子だったよ……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>11</SpeakerId>
      <Id>35</Id>
      <OldPtr>309972</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>336520</PointerOffset>
      <VoiceId>&lt;audio:VSM_330_010_099&gt;</VoiceId>
      <JapaneseText>ぼくのかわいい双子だもん、
いい子じゃないはずが
ないでしょ</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>11</SpeakerId>
      <Id>36</Id>
      <OldPtr>310492</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>336604</PointerOffset>
      <VoiceId>&lt;audio:VSM_330_010_100&gt;</VoiceId>
      <JapaneseText>……でも、
これきりだなんて……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>11</SpeakerId>
      <Id>37</Id>
      <OldPtr>310644</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>336680</PointerOffset>
      <VoiceId>&lt;audio:VSM_330_010_101&gt;</VoiceId>
      <JapaneseText>これきりじゃないよ、エト</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>4</SpeakerId>
      <Id>38</Id>
      <OldPtr>311148</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>336764</PointerOffset>
      <VoiceId>&lt;audio:VSM_330_010_102&gt;</VoiceId>
      <JapaneseText>全然大丈夫だって。
また会える</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>39</Id>
      <OldPtr>311664</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>336856</PointerOffset>
      <VoiceId>&lt;audio:VSM_330_010_103&gt;</VoiceId>
      <JapaneseText>何言ってんの……
きみたちは……もう……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>11</SpeakerId>
      <Id>40</Id>
      <OldPtr>311992</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>336948</PointerOffset>
      <VoiceId>&lt;audio:VSM_330_010_104&gt;</VoiceId>
      <JapaneseText>ううん……
……そうだよ。
きっと、そう</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>4</SpeakerId>
      <Id>41</Id>
      <OldPtr>312396</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>337012</PointerOffset>
      <VoiceId>&lt;audio:VSM_330_010_105&gt;</VoiceId>
      <JapaneseText>また、いつか</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>42</Id>
      <OldPtr>312848</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>337076</PointerOffset>
      <VoiceId>&lt;audio:VSM_330_010_106&gt;</VoiceId>
      <JapaneseText>どこかで……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>4</SpeakerId>
      <Id>43</Id>
      <OldPtr>313196</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>337160</PointerOffset>
      <VoiceId>&lt;audio:VSM_330_010_107&gt;</VoiceId>
      <JapaneseText>&lt;Dio&gt;ーっ！！
&lt;Mel&gt;ーっ！！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>11</SpeakerId>
      <Id>44</Id>
      <OldPtr>314948</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>337228</PointerOffset>
      <VoiceId>&lt;audio:VSM_330_010_108&gt;</VoiceId>
      <JapaneseText>うっうううう……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>11</SpeakerId>
      <Id>45</Id>
      <OldPtr>315100</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>337288</PointerOffset>
      <VoiceId>&lt;audio:VSM_330_010_109&gt;</VoiceId>
      <JapaneseText>…………</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>10</SpeakerId>
      <Id>46</Id>
      <OldPtr>315744</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>337368</PointerOffset>
      <VoiceId>&lt;audio:VSM_330_010_110&gt;</VoiceId>
      <JapaneseText>いつかって
いつだよーっ！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>11</SpeakerId>
      <Id>47</Id>
      <OldPtr>315968</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
