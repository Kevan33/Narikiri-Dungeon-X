    <Entry>
      <PointerOffset>297512</PointerOffset>
      <VoiceId>&lt;audio:VSM_200_010_001&gt;</VoiceId>
      <JapaneseText>あなたたちは、
プルートの手下ですね！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>1</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>297632</PointerOffset>
      <VoiceId>&lt;audio:VSM_200_010_002&gt;</VoiceId>
      <JapaneseText>&lt;Suzu&gt;左様。
忍びの頭領、藤林と見た。
その命もらいうける！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>2</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>297720</PointerOffset>
      <VoiceId>&lt;audio:VSM_200_010_003&gt;</VoiceId>
      <JapaneseText>いけません、
ここは私に任せて……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>3</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>297828</PointerOffset>
      <VoiceId>&lt;audio:VSM_200_010_004&gt;</VoiceId>
      <JapaneseText>見てなさいって。この子たち、
なかなかの手練なんだから</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>4</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>297888</PointerOffset>
      <VoiceId>&lt;audio:VSM_200_010_005&gt;</VoiceId>
      <JapaneseText>え……？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>5</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>297952</PointerOffset>
      <VoiceId>&lt;audio:VSM_200_010_006&gt;</VoiceId>
      <JapaneseText>クルール！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>4</SpeakerId>
      <Id>6</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>298052</PointerOffset>
      <VoiceId>&lt;audio:VSM_200_010_007&gt;</VoiceId>
      <JapaneseText>こんなザコ相手に
手こずってらんねーから、
オレら</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>5</SpeakerId>
      <Id>7</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>298144</PointerOffset>
      <VoiceId>&lt;audio:VSM_200_010_008&gt;</VoiceId>
      <JapaneseText>今はヴォルトのところへ
行くんだもんね</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>6</SpeakerId>
      <Id>8</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>298244</PointerOffset>
      <VoiceId>&lt;audio:VSM_200_010_009&gt;</VoiceId>
      <JapaneseText>命知らずな奴らめ、
後悔させてやろう！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>9</Id>
      <Status>To Do</Status>
    </Entry>
