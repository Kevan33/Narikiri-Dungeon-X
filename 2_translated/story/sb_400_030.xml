    <Entry>
      <PointerOffset>291480</PointerOffset>
      <JapaneseText>うぇ～ん、
手加減してほしいのら～次は勝つのら～、
だから来るのら～</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>3</Id>
      <BubbleId>1</BubbleId>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>291640</PointerOffset>
      <JapaneseText>ノーム！
オレらに力を貸してくれ！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>5</Id>
      <Status>To Do</Status>
    </Entry>
