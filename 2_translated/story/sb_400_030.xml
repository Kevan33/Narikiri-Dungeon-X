    <Entry>
      <PointerOffset>291864</PointerOffset>
      <JapaneseText>&lt;Dio&gt;我、今、地の精に
ねがいたてまつる指輪の盟約のもと、
我に精霊を従わせたまえ我が名は</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>8</Id>
      <BubbleId>2</BubbleId>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>291932</PointerOffset>
      <JapaneseText>わかったのら～
