    <Entry>
      <PointerOffset>281112</PointerOffset>
      <VoiceId>&lt;audio:VSM_040_030_001&gt;</VoiceId>
      <JapaneseText>レスター博士が、
あんな人なんて……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>1</Id>
      <OldPtr>258520</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>281544</PointerOffset>
      <VoiceId>&lt;audio:VSM_040_030_006&gt;</VoiceId>
      <JapaneseText>でも、他にあてがないんだかラ。
さっき自分で言ったじゃない</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>2</Id>
      <OldPtr>259184</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>281612</PointerOffset>
      <VoiceId>&lt;audio:VSM_040_030_007&gt;</VoiceId>
      <JapaneseText>そう、だけど……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>3</Id>
      <OldPtr>259484</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>281772</PointerOffset>
      <VoiceId>&lt;audio:VSM_040_030_008Z&gt;</VoiceId>
      <JapaneseText>おや、&lt;Claus&gt;に客人か？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>4</SpeakerId>
      <Id>4</Id>
      <BubbleId>0</BubbleId>
      <OldPtr>259916</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>281772</PointerOffset>
      <VoiceId>&lt;audio:VSM_040_030_009Z&gt;</VoiceId>
      <JapaneseText>浮かない顔だな。
難癖つけられて、
追っ払われたってとこか</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>4</SpeakerId>
      <Id>4</Id>
      <BubbleId>1</BubbleId>
      <OldPtr>259916</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>281892</PointerOffset>
      <VoiceId>&lt;audio:VSM_040_030_010&gt;</VoiceId>
      <JapaneseText>はい、あの……わたしたち、
精霊のことで&lt;Claus&gt;さんに
相談があって……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>6</Id>
      <OldPtr>260700</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>281956</PointerOffset>
      <VoiceId>&lt;audio:VSM_040_030_011&gt;</VoiceId>
      <JapaneseText>あんた、誰？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>7</Id>
      <OldPtr>261068</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>282044</PointerOffset>
      <VoiceId>&lt;audio:VSM_040_030_012&gt;</VoiceId>
      <JapaneseText>ちょっと、&lt;Dio&gt;、
失礼でしょ……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>8</Id>
      <OldPtr>261432</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>282232</PointerOffset>
      <VoiceId>&lt;audio:VSM_040_030_013Z&gt;</VoiceId>
      <JapaneseText>僕はあの男の友人だ</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>4</SpeakerId>
      <Id>9</Id>
      <BubbleId>0</BubbleId>
      <OldPtr>261860</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>282232</PointerOffset>
      <VoiceId>&lt;audio:VSM_040_030_014Z&gt;</VoiceId>
      <JapaneseText>こちらこそ、友人が
失礼したね</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>4</SpeakerId>
      <Id>9</Id>
      <BubbleId>1</BubbleId>
      <OldPtr>261860</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>282232</PointerOffset>
      <VoiceId>&lt;audio:VSM_040_030_015Z&gt;</VoiceId>
      <JapaneseText>……本当は、
あんなヤツじゃないんだが……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>4</SpeakerId>
      <Id>9</Id>
      <BubbleId>2</BubbleId>
      <OldPtr>261860</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>282296</PointerOffset>
      <VoiceId>&lt;audio:VSM_040_030_016&gt;</VoiceId>
      <JapaneseText>…………？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>12</Id>
      <OldPtr>262336</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>282432</PointerOffset>
      <VoiceId>&lt;audio:VSM_040_030_017Z&gt;</VoiceId>
      <JapaneseText>学会の幹部連中に、目の前で
召喚術の論文を燃やされた
頃からずっとあんな調子だ</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>4</SpeakerId>
      <Id>13</Id>
      <OldPtr>262580</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>282496</PointerOffset>
      <VoiceId>&lt;audio:VSM_040_030_018&gt;</VoiceId>
      <JapaneseText>ひどい……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>14</Id>
      <OldPtr>263244</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>282908</PointerOffset>
      <VoiceId>&lt;audio:VSM_040_030_019Z&gt;</VoiceId>
      <JapaneseText>学会の連中は、精霊の存在なんて
眉唾もんだって思ってるからね。
これ見よがしに論文を燃やして……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>4</SpeakerId>
      <Id>15</Id>
      <BubbleId>0</BubbleId>
      <OldPtr>263384</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>282908</PointerOffset>
      <VoiceId>&lt;audio:VSM_040_030_020Z&gt;</VoiceId>
      <JapaneseText>ミラルドが出て行ってからは
もっとひどくなっていった</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>4</SpeakerId>
      <Id>15</Id>
      <BubbleId>1</BubbleId>
      <OldPtr>263384</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>282908</PointerOffset>
      <VoiceId>&lt;audio:VSM_040_030_021Z&gt;</VoiceId>
      <JapaneseText>……僕が同じ仕打ちを受けたら……
我慢できないだろうな</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>4</SpeakerId>
      <Id>15</Id>
      <BubbleId>2</BubbleId>
      <OldPtr>263384</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>282908</PointerOffset>
      <VoiceId>&lt;audio:VSM_040_030_022Z&gt;</VoiceId>
      <JapaneseText>ところで、&lt;Claus&gt;に何を
相談したいんだい？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>4</SpeakerId>
      <Id>15</Id>
      <BubbleId>3</BubbleId>
      <OldPtr>263384</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>282908</PointerOffset>
      <VoiceId>&lt;audio:VSM_040_030_023Z&gt;</VoiceId>
      <JapaneseText>僕でも力になれることは
ないかな？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>4</SpeakerId>
      <Id>15</Id>
      <BubbleId>4</BubbleId>
      <OldPtr>263384</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>283004</PointerOffset>
      <VoiceId>&lt;audio:VSM_040_030_024&gt;</VoiceId>
      <JapaneseText>イフリートってヤツの
いる洞窟へ行くんだよ</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>20</Id>
      <OldPtr>264124</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>283144</PointerOffset>
      <VoiceId>&lt;audio:VSM_040_030_025Z&gt;</VoiceId>
      <JapaneseText>イフリートだって！！
君たちだけで行くつもりかい？
あそこは迷いやすいし、危険だ！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>4</SpeakerId>
      <Id>21</Id>
      <OldPtr>264432</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>283228</PointerOffset>
      <VoiceId>&lt;audio:VSM_040_030_026Z&gt;</VoiceId>
      <JapaneseText>じゃあ、これをあげよう</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>4</SpeakerId>
      <Id>22</Id>
      <OldPtr>264752</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>283300</PointerOffset>
      <VoiceId>&lt;audio:VSM_040_030_027&gt;</VoiceId>
      <JapaneseText>ど、どうしてこれを？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>23</Id>
      <OldPtr>266068</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>283492</PointerOffset>
      <VoiceId>&lt;audio:VSM_040_030_028Z&gt;</VoiceId>
      <JapaneseText>君たちみたいな
子どもだけでは危険だろ。
だからさ</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>4</SpeakerId>
      <Id>24</Id>
      <BubbleId>0</BubbleId>
      <OldPtr>266376</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>283492</PointerOffset>
      <VoiceId>&lt;audio:VSM_040_030_029Z&gt;</VoiceId>
      <JapaneseText>本当は、僕が付いていってあげたい
んだけど……予定があってね……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>4</SpeakerId>
      <Id>24</Id>
      <BubbleId>1</BubbleId>
      <OldPtr>266376</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>283704</PointerOffset>
      <VoiceId>&lt;audio:VSM_040_030_030Z&gt;</VoiceId>
      <JapaneseText>水の力を宿しているこの剣なら
イフリートのいる&lt;Red&gt;熱砂の洞窟&lt;White&gt;の
魔物には効果があるはずだ</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>4</SpeakerId>
      <Id>26</Id>
      <BubbleId>0</BubbleId>
      <OldPtr>266516</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>283704</PointerOffset>
      <VoiceId>&lt;audio:VSM_040_030_031Z&gt;</VoiceId>
      <JapaneseText>さて、僕はあいつの顔でも
見てくるよ。じゃあね</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>4</SpeakerId>
      <Id>26</Id>
      <BubbleId>1</BubbleId>
      <OldPtr>266516</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>283920</PointerOffset>
      <VoiceId>&lt;audio:VSM_040_030_033&gt;</VoiceId>
      <JapaneseText>でも、だからって
&lt;Claus&gt;さんのあんな言い方……
ないと、思う……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>28</Id>
      <BubbleId>0</BubbleId>
      <OldPtr>268636</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>283920</PointerOffset>
      <VoiceId>&lt;audio:VSM_040_030_034&gt;</VoiceId>
      <JapaneseText>…………</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>28</Id>
      <BubbleId>1</BubbleId>
      <OldPtr>268636</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>284084</PointerOffset>
      <VoiceId>&lt;audio:VSM_040_030_035&gt;</VoiceId>
      <JapaneseText>よし、イフリート
連れてこようぜ！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>30</Id>
      <BubbleId>0</BubbleId>
      <OldPtr>269172</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>284084</PointerOffset>
      <VoiceId>&lt;audio:VSM_040_030_036&gt;</VoiceId>
      <JapaneseText>精霊連れてったら、レスター博士、
元気づけられっかもしんねー</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>30</Id>
      <BubbleId>1</BubbleId>
      <OldPtr>269172</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>284152</PointerOffset>
      <VoiceId>&lt;audio:VSM_040_030_037&gt;</VoiceId>
      <JapaneseText>そう、かな……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>32</Id>
      <OldPtr>269656</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>284264</PointerOffset>
      <VoiceId>&lt;audio:VSM_040_030_038&gt;</VoiceId>
      <JapaneseText>どっちにしろ、精霊の力が
必要だったんだしさ、
ついでついで</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>33</Id>
      <OldPtr>269964</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>284328</PointerOffset>
      <VoiceId>&lt;audio:VSM_040_030_039&gt;</VoiceId>
      <JapaneseText>クルールル！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>5</SpeakerId>
      <Id>34</Id>
      <OldPtr>270260</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>284396</PointerOffset>
      <VoiceId>&lt;audio:VSM_040_030_040&gt;</VoiceId>
      <JapaneseText>そうだね……うん</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>35</Id>
      <OldPtr>270732</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>284568</PointerOffset>
      <VoiceId>&lt;audio:VSM_040_030_041&gt;</VoiceId>
      <JapaneseText>&lt;Red&gt;熱砂の洞窟&lt;White&gt;の
イフリート、だっけ？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>36</Id>
      <BubbleId>0</BubbleId>
      <OldPtr>270872</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>284568</PointerOffset>
      <VoiceId>&lt;audio:VSM_040_030_042&gt;</VoiceId>
      <JapaneseText>粗暴で丸焦げにしちゃう
って言ってたけド……
気をつけないと……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>36</Id>
      <BubbleId>1</BubbleId>
      <OldPtr>270872</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>284716</PointerOffset>
      <VoiceId>&lt;audio:VSM_040_030_043&gt;</VoiceId>
      <JapaneseText>オレらには
『なりきり士』の力が
あんだから</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>38</Id>
      <BubbleId>0</BubbleId>
      <OldPtr>271436</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>284716</PointerOffset>
      <VoiceId>&lt;audio:VSM_040_030_044&gt;</VoiceId>
      <JapaneseText>全然だいじょーぶだって。
行こーぜ</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>38</Id>
      <BubbleId>1</BubbleId>
      <OldPtr>271436</OldPtr>
      <Status>To Do</Status>
    </Entry>
