    <Entry>
      <PointerOffset>298184</PointerOffset>
      <VoiceId>&lt;audio:VSM_170_040_020&gt;</VoiceId>
      <JapaneseText>退くぞ……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>1</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>298348</PointerOffset>
      <VoiceId>&lt;audio:VSM_170_040_022&gt;</VoiceId>
      <JapaneseText>……よかった……
ふたりとも、無事で……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>2</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>298428</PointerOffset>
      <VoiceId>&lt;audio:VSM_170_040_023&gt;</VoiceId>
      <JapaneseText>……ご、ごめん……
オレ……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>3</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>298512</PointerOffset>
      <VoiceId>&lt;audio:VSM_170_040_024&gt;</VoiceId>
      <JapaneseText>ううん……
わたしもごめんなさい</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>4</SpeakerId>
      <Id>4</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>298572</PointerOffset>
      <VoiceId>&lt;audio:VSM_170_040_025&gt;</VoiceId>
      <JapaneseText>え……？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>5</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>298720</PointerOffset>
      <VoiceId>&lt;audio:VSM_170_040_026&gt;</VoiceId>
      <JapaneseText></JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>4</SpeakerId>
      <Id>6</Id>
      <BubbleId>0</BubbleId>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>298720</PointerOffset>
      <VoiceId>&lt;audio:VSM_170_040_027&gt;</VoiceId>
      <JapaneseText>勝手に色々想像してたのは
わたしも同じだもんで、勝手にたくさん
怖がってて……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>4</SpeakerId>
      <Id>6</Id>
      <BubbleId>1</BubbleId>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>298852</PointerOffset>
      <VoiceId>&lt;audio:VSM_170_040_028&gt;</VoiceId>
      <JapaneseText>でも、そんな不安とかって、
思い過ごしだったのかなって
最近、思うようになったんだ</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>4</SpeakerId>
      <Id>8</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>298916</PointerOffset>
      <VoiceId>&lt;audio:VSM_170_040_029&gt;</VoiceId>
      <JapaneseText>思い過ごし？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>9</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>299088</PointerOffset>
      <VoiceId>&lt;audio:VSM_170_040_030&gt;</VoiceId>
      <JapaneseText></JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>4</SpeakerId>
      <Id>10</Id>
      <BubbleId>0</BubbleId>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>299088</PointerOffset>
      <VoiceId>&lt;audio:VSM_170_040_031&gt;</VoiceId>
      <JapaneseText>怖いって思ってたことが、
それほど怖くなかったりすごいって思ってたことが
それほどすごくなかったり……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>4</SpeakerId>
      <Id>10</Id>
      <BubbleId>1</BubbleId>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>299332</PointerOffset>
      <VoiceId>&lt;audio:VSM_170_040_032&gt;</VoiceId>
      <JapaneseText></JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>4</SpeakerId>
      <Id>12</Id>
      <BubbleId>0</BubbleId>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>299332</PointerOffset>
      <VoiceId>&lt;audio:VSM_170_040_033&gt;</VoiceId>
      <JapaneseText></JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>4</SpeakerId>
      <Id>12</Id>
      <BubbleId>1</BubbleId>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>299332</PointerOffset>
      <VoiceId>&lt;audio:VSM_170_040_034&gt;</VoiceId>
      <JapaneseText>たぶん……この先もたくさん
不安が出てきてそのたびに
逃げたくなるよ、きっとでも……逃げないで、
正面から向き合わなきゃ
何もわかんないままだってそう思った</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>4</SpeakerId>
      <Id>12</Id>
      <BubbleId>2</BubbleId>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>299448</PointerOffset>
      <VoiceId>&lt;audio:VSM_170_040_035&gt;</VoiceId>
      <JapaneseText>んなこと言って
向き合ってみて、やっぱ
コワかったらどーすんだ？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>15</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>299588</PointerOffset>
      <VoiceId>&lt;audio:VSM_170_040_036&gt;</VoiceId>
      <JapaneseText></JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>4</SpeakerId>
      <Id>16</Id>
      <BubbleId>0</BubbleId>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>299588</PointerOffset>
      <VoiceId>&lt;audio:VSM_170_040_037&gt;</VoiceId>
      <JapaneseText>そうだね……
そういうこともあるかも。
その時は…………どうしよっか？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>4</SpeakerId>
      <Id>16</Id>
      <BubbleId>1</BubbleId>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>299680</PointerOffset>
      <VoiceId>&lt;audio:VSM_170_040_038&gt;</VoiceId>
      <JapaneseText>な、なんだよ、それ！
考えてねーのかよ！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>18</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>299808</PointerOffset>
      <VoiceId>&lt;audio:VSM_170_040_039&gt;</VoiceId>
      <JapaneseText></JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>4</SpeakerId>
      <Id>19</Id>
      <BubbleId>0</BubbleId>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>299808</PointerOffset>
      <VoiceId>&lt;audio:VSM_170_040_040&gt;</VoiceId>
      <JapaneseText>その時は、その時かなってでも……なんとかなるよ、
きっと</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>4</SpeakerId>
      <Id>19</Id>
      <BubbleId>1</BubbleId>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>299956</PointerOffset>
      <VoiceId>&lt;audio:VSM_170_040_041&gt;</VoiceId>
      <JapaneseText></JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>21</Id>
      <BubbleId>0</BubbleId>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>299956</PointerOffset>
      <VoiceId>&lt;audio:VSM_170_040_042&gt;</VoiceId>
      <JapaneseText>なんとかなんて
ならねーよ、ったく……答え期待したオレが
バカみてーじゃんか</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>21</Id>
      <BubbleId>1</BubbleId>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>300020</PointerOffset>
      <VoiceId>&lt;audio:VSM_170_040_043&gt;</VoiceId>
      <JapaneseText>ゴメンね？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>4</SpeakerId>
      <Id>23</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>300092</PointerOffset>
      <VoiceId>&lt;audio:VSM_170_040_044&gt;</VoiceId>
      <JapaneseText>べつに。いーけどさ</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>24</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>300152</PointerOffset>
      <VoiceId>&lt;audio:VSM_170_040_045&gt;</VoiceId>
      <JapaneseText>…………</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>25</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>300220</PointerOffset>
      <VoiceId>&lt;audio:VSM_170_040_046&gt;</VoiceId>
      <JapaneseText>な、何の音！？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>26</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>300296</PointerOffset>
      <VoiceId>&lt;audio:VSM_170_040_047&gt;</VoiceId>
      <JapaneseText>家の中で聞こえた……！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>27</Id>
      <Status>To Do</Status>
