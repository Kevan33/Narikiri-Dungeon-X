    <Entry>
      <PointerOffset>322792</PointerOffset>
      <VoiceId>&lt;audio:VSM_100_060_001&gt;</VoiceId>
      <JapaneseText>災厄の元凶よ……
滅びよ……！</JapaneseText>
      <EnglishText>Sources of calamity... Perish!</EnglishText>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>1</Id>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset>323008</PointerOffset>
      <VoiceId>&lt;audio:VSM_100_060_004&gt;</VoiceId>
      <JapaneseText>くっ……
何なんだよ……？</JapaneseText>
      <EnglishText>Ughh... What's all this crap about?</EnglishText>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>2</Id>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset>323076</PointerOffset>
      <VoiceId>&lt;audio:VSM_100_060_005&gt;</VoiceId>
      <JapaneseText>ありがと、&lt;Couleur&gt;</JapaneseText>
      <EnglishText>Thanks, &lt;Couleur&gt;!</EnglishText>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>3</Id>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset>323140</PointerOffset>
      <VoiceId>&lt;audio:VSM_100_060_006&gt;</VoiceId>
      <JapaneseText>クルール！</JapaneseText>
      <EnglishText>Kururu!</EnglishText>
      <Notes/>
      <SpeakerId>4</SpeakerId>
      <Id>4</Id>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset>323204</PointerOffset>
      <VoiceId>&lt;audio:VSM_100_060_007&gt;</VoiceId>
      <JapaneseText>次は逃さぬ</JapaneseText>
      <EnglishText>You will not escape this time.</EnglishText>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>5</Id>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset>323340</PointerOffset>
      <VoiceId>&lt;audio:VSM_100_060_009&gt;</VoiceId>
      <JapaneseText>クルールゥーー！！</JapaneseText>
      <EnglishText>Kuruuuruuu!</EnglishText>
      <Notes/>
      <SpeakerId>4</SpeakerId>
      <Id>6</Id>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset>323408</PointerOffset>
      <VoiceId>&lt;audio:VSM_100_060_010&gt;</VoiceId>
      <JapaneseText>&lt;Couleur&gt;！</JapaneseText>
      <EnglishText>&lt;Couleur&gt;!</EnglishText>
      <Notes/>
      <SpeakerId>5</SpeakerId>
      <Id>7</Id>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset>323544</PointerOffset>
      <VoiceId>&lt;audio:VSM_100_060_012&gt;</VoiceId>
      <JapaneseText>退きなさい、ダオス</JapaneseText>
      <EnglishText>Stop at once, Dhaos.</EnglishText>
      <Notes/>
      <SpeakerId>6</SpeakerId>
      <Id>8</Id>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset>323608</PointerOffset>
      <VoiceId>&lt;audio:VSM_100_060_013&gt;</VoiceId>
      <JapaneseText>ノルン……！</JapaneseText>
      <EnglishText>Norn...!</EnglishText>
      <Notes/>
      <SpeakerId>7</SpeakerId>
      <Id>9</Id>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset>323680</PointerOffset>
      <VoiceId>&lt;audio:VSM_100_060_014&gt;</VoiceId>
      <JapaneseText>ダオス？　ノルン？</JapaneseText>
      <EnglishText>Dhaos? Norn?</EnglishText>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>10</Id>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset>323780</PointerOffset>
      <VoiceId>&lt;audio:VSM_100_060_015&gt;</VoiceId>
      <JapaneseText>彼らの罪を決すのは
まだ早いのではありませんか</JapaneseText>
      <EnglishText>The sins of these individuals
can't be judged as of yet.</EnglishText>
      <Notes/>
      <SpeakerId>8</SpeakerId>
      <Id>11</Id>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset>323840</PointerOffset>
      <VoiceId>&lt;audio:VSM_100_060_016&gt;</VoiceId>
      <JapaneseText>…………</JapaneseText>
      <EnglishText>...</EnglishText>
      <Notes/>
      <SpeakerId>9</SpeakerId>
      <Id>12</Id>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset>323948</PointerOffset>
      <VoiceId>&lt;audio:VSM_100_060_017&gt;</VoiceId>
      <JapaneseText>どうしてもというならば、
彼らの前に、まず
私を排しなさい</JapaneseText>
      <EnglishText>If you yearn to continue your assault,
you shall have to face me first.</EnglishText>
      <Notes/>
      <SpeakerId>8</SpeakerId>
      <Id>13</Id>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset>324016</PointerOffset>
      <VoiceId>&lt;audio:VSM_100_060_018&gt;</VoiceId>
      <JapaneseText>びっくりした……</JapaneseText>
      <EnglishText>That was way too close...</EnglishText>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>14</Id>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset>324120</PointerOffset>
      <VoiceId>&lt;audio:VSM_100_060_019&gt;</VoiceId>
      <JapaneseText>お久しぶりですね、エトス。
そして、&lt;Dio&gt;、&lt;Mel&gt;</JapaneseText>
      <EnglishText>It's been far too long, Ethos. Greetings &lt;Dio&gt;, &lt;Mel&gt;.</EnglishText>
      <Notes/>
      <SpeakerId>8</SpeakerId>
      <Id>15</Id>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset>324196</PointerOffset>
      <VoiceId>&lt;audio:VSM_100_060_020&gt;</VoiceId>
      <JapaneseText>あなたがノルンさん……</JapaneseText>
      <EnglishText>You are Miss Norn?</EnglishText>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>16</Id>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset>324388</PointerOffset>
      <VoiceId>&lt;audio:VSM_100_060_022&gt;</VoiceId>
      <JapaneseText>ご苦労様でした、
アルベルト</JapaneseText>
      <EnglishText>I applaud your efforts, Albert.</EnglishText>
      <Notes/>
      <SpeakerId>8</SpeakerId>
      <Id>17</Id>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset>324516</PointerOffset>
      <VoiceId>&lt;audio:VSM_100_060_023&gt;</VoiceId>
      <JapaneseText>まったく、扱いが悪いだ。
んま、いつもの事だから、
気にもしとらんけどな</JapaneseText>
      <EnglishText>Please, stop treating me like that. You can
count on me for anything, always.</EnglishText>
      <Notes/>
      <SpeakerId>10</SpeakerId>
      <Id>18</Id>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset>324620</PointerOffset>
      <VoiceId>&lt;audio:VSM_100_060_024&gt;</VoiceId>
      <JapaneseText>そしてエトスも。
この子たちをここまで
育ててくれて</JapaneseText>
      <EnglishText>Moreover, Ethos, you have my eternal
gratitude for nurturing these children.</EnglishText>
      <Notes/>
      <SpeakerId>8</SpeakerId>
      <Id>19</Id>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset>324684</PointerOffset>
      <VoiceId>&lt;audio:VSM_100_060_025&gt;</VoiceId>
      <JapaneseText>い、いえ……</JapaneseText>
      <EnglishText>It's n-nothing...</EnglishText>
      <Notes/>
      <SpeakerId>7</SpeakerId>
      <Id>20</Id>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset>324772</PointerOffset>
      <VoiceId>&lt;audio:VSM_100_060_026&gt;</VoiceId>
      <JapaneseText>あんたが
オレらの母ちゃんなのか？</JapaneseText>
      <EnglishText>Are you our mom?</EnglishText>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>21</Id>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset>325024</PointerOffset>
      <VoiceId>&lt;audio:VSM_100_060_027&gt;</VoiceId>
      <JapaneseText>いいえ。私は
あなた方の母親では
ありません</JapaneseText>
      <EnglishText>No. I am not your mother.</EnglishText>
      <Notes/>
      <SpeakerId>8</SpeakerId>
      <Id>22</Id>
      <BubbleId>0</BubbleId>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset>325024</PointerOffset>
      <VoiceId>&lt;audio:VSM_100_060_028&gt;</VoiceId>
      <JapaneseText>私は、
『希望のひとしずく』から
生まれた世界樹の守護者</JapaneseText>
      <EnglishText>I am the "Tear of Hope." I was
birthed to protect this world.</EnglishText>
      <Notes/>
      <SpeakerId>8</SpeakerId>
      <Id>22</Id>
      <BubbleId>1</BubbleId>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset>325024</PointerOffset>
      <VoiceId>&lt;audio:VSM_100_060_029&gt;</VoiceId>
      <JapaneseText>あなた方の生命を拾い上げ、
エトスに託した、
ただそれだけの者です</JapaneseText>
      <EnglishText>I found and entrusted you to Ethos.
There is nothng more to say.</EnglishText>
      <Notes/>
      <SpeakerId>8</SpeakerId>
      <Id>22</Id>
      <BubbleId>2</BubbleId>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset>325164</PointerOffset>
      <VoiceId>&lt;audio:VSM_100_060_030&gt;</VoiceId>
      <JapaneseText>ただそれだけ……</JapaneseText>
      <EnglishText>That's...it?</EnglishText>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>25</Id>
      <BubbleId>0</BubbleId>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset>325164</PointerOffset>
      <VoiceId>&lt;audio:VSM_100_060_031&gt;</VoiceId>
      <JapaneseText>あの、どうしてアルベルトさんを
わたしたちのところへ？</JapaneseText>
      <EnglishText>Excuse me, why did you
send Albert to our place?</EnglishText>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>25</Id>
      <BubbleId>1</BubbleId>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset>325452</PointerOffset>
      <VoiceId>&lt;audio:VSM_100_060_032&gt;</VoiceId>
      <JapaneseText>身寄りのないあなた方は、
この世界で誰にも頼らず、
ひとりで生きていかねばなりません</JapaneseText>
      <EnglishText>Without any relatives, you'd have no one
else to rely on. It would have been
irresponsible to send you off alone.</EnglishText>
      <Notes/>
      <SpeakerId>8</SpeakerId>
      <Id>27</Id>
      <BubbleId>0</BubbleId>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset>325452</PointerOffset>
      <VoiceId>&lt;audio:VSM_100_060_033&gt;</VoiceId>
      <JapaneseText>これはそのための試練です</JapaneseText>
      <EnglishText>You've been tested up until now.</EnglishText>
      <Notes/>
      <SpeakerId>8</SpeakerId>
      <Id>27</Id>
      <BubbleId>1</BubbleId>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset>325452</PointerOffset>
      <VoiceId>&lt;audio:VSM_100_060_034&gt;</VoiceId>
      <JapaneseText>『なりきり士』の力を
どう使うか……</JapaneseText>
      <EnglishText>That's why you've been bestowed
Roleplayer powers...</EnglishText>
      <Notes/>
      <SpeakerId>8</SpeakerId>
      <Id>27</Id>
      <BubbleId>2</BubbleId>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset>325452</PointerOffset>
      <VoiceId>&lt;audio:VSM_100_060_035&gt;</VoiceId>
      <JapaneseText>そこからあなた方が
どういう道を選ぶか</JapaneseText>
      <EnglishText>You've done excellently.</EnglishText>
      <Notes/>
      <SpeakerId>8</SpeakerId>
      <Id>27</Id>
      <BubbleId>3</BubbleId>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset>325548</PointerOffset>
      <VoiceId>&lt;audio:VSM_100_060_036&gt;</VoiceId>
      <JapaneseText>でも……でもっ！
彼らには
ぼくがついてます！</JapaneseText>
      <EnglishText>B-But...I've grown attached to them!</EnglishText>
      <Notes/>
      <SpeakerId>7</SpeakerId>
      <Id>31</Id>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset>325764</PointerOffset>
      <VoiceId>&lt;audio:VSM_100_060_037&gt;</VoiceId>
      <JapaneseText>確かに私は、まだ意思を持たない
小さな赤ん坊であったふたりを
見守る役目をあなたに与えました</JapaneseText>
      <EnglishText>My intention isn't to take them, for now.
I entrusted them to you as newborns and
you've watched over them ever since.</EnglishText>
      <Notes/>
      <SpeakerId>8</SpeakerId>
      <Id>32</Id>
      <BubbleId>0</BubbleId>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset>325764</PointerOffset>
      <VoiceId>&lt;audio:VSM_100_060_038&gt;</VoiceId>
      <JapaneseText>しかし、いつまでも
彼らと一緒にいられるとは
限りません</JapaneseText>
      <EnglishText>Although, I can't force you
to stay with them forever.</EnglishText>
      <Notes/>
      <SpeakerId>8</SpeakerId>
      <Id>32</Id>
      <BubbleId>1</BubbleId>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset>325884</PointerOffset>
      <VoiceId>&lt;audio:VSM_100_060_039&gt;</VoiceId>
      <JapaneseText>ぼくは……</JapaneseText>
      <EnglishText>I...</EnglishText>
      <Notes/>
      <SpeakerId>7</SpeakerId>
      <Id>34</Id>
      <BubbleId>0</BubbleId>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset>325884</PointerOffset>
      <VoiceId>&lt;audio:VSM_100_060_040&gt;</VoiceId>
      <JapaneseText>ぼくは
いつまでもふたりと
一緒に……</JapaneseText>
      <EnglishText>I want to go wherever they go!</EnglishText>
      <Notes/>
      <SpeakerId>7</SpeakerId>
      <Id>34</Id>
      <BubbleId>1</BubbleId>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset>326320</PointerOffset>
      <VoiceId>&lt;audio:VSM_100_060_045&gt;</VoiceId>
      <JapaneseText>いいでしょう。それが
あなた方の選択ならば、
これ以上は言いません</JapaneseText>
      <EnglishText>That's agreeable. If that's your decision,
then I have no say in the matter.</EnglishText>
      <Notes/>
      <SpeakerId>8</SpeakerId>
      <Id>36</Id>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset>326436</PointerOffset>
      <VoiceId>&lt;audio:VSM_100_060_046&gt;</VoiceId>
      <JapaneseText>それより、オレらには、
今しなきゃなんない
大事なことがあんだ！</JapaneseText>
      <EnglishText>Just drawing a tangent here, but there's something very 
important we're trying to do...! </EnglishText>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>37</Id>
      <Status>Problematic</Status>
    </Entry>
    <Entry>
      <PointerOffset>326524</PointerOffset>
      <VoiceId>&lt;audio:VSM_100_060_047&gt;</VoiceId>
      <JapaneseText>知っています。
『虹輪』のことですね</JapaneseText>
      <EnglishText>I'm aware. The Prism Ring.</EnglishText>
      <Notes/>
      <SpeakerId>8</SpeakerId>
      <Id>38</Id>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset>326708</PointerOffset>
      <VoiceId>&lt;audio:VSM_100_060_049&gt;</VoiceId>
      <JapaneseText>四大精霊を統括する
マクスウェルに会いなさい</JapaneseText>
      <EnglishText>To unify the Great Summon Spirits,
you will need to meet Maxwell.</EnglishText>
      <Notes/>
      <SpeakerId>8</SpeakerId>
      <Id>39</Id>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset>327240</PointerOffset>
      <VoiceId>&lt;audio:VSM_100_060_055&gt;</VoiceId>
      <JapaneseText>時空戦士&lt;Arche&gt;・クラインから
預かってきました</JapaneseText>
      <EnglishText>The Eternal Hero &lt;Arche&gt; Klein had
this prepared for your journey.</EnglishText>
      <Notes/>
      <SpeakerId>8</SpeakerId>
      <Id>40</Id>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset>327476</PointerOffset>
      <VoiceId>&lt;audio:VSM_100_060_057&gt;</VoiceId>
      <JapaneseText>この絵は
今から１００年前の世界と
行き来ができるようです</JapaneseText>
      <EnglishText>With this painting, you shall be
able to traverse to the world
of 100 years ago.</EnglishText>
      <Notes/>
      <SpeakerId>8</SpeakerId>
      <Id>41</Id>
      <BubbleId>0</BubbleId>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset>327476</PointerOffset>
      <VoiceId>&lt;audio:VSM_100_060_058&gt;</VoiceId>
      <JapaneseText>そこでマクスウェルを
探すとよいでしょう</JapaneseText>
      <EnglishText>You must journey there and find Maxwell.</EnglishText>
      <Notes/>
      <SpeakerId>8</SpeakerId>
      <Id>41</Id>
      <BubbleId>1</BubbleId>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset>327548</PointerOffset>
      <VoiceId>&lt;audio:VSM_100_060_059&gt;</VoiceId>
      <JapaneseText>探すって言っても……</JapaneseText>
      <EnglishText>You say we need to find him, but...</EnglishText>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>43</Id>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset>327636</PointerOffset>
      <VoiceId>&lt;audio:VSM_100_060_060&gt;</VoiceId>
      <JapaneseText>行けばわかるさ。
手がかり探そうぜ</JapaneseText>
      <EnglishText>We have to go! We finally have a lead!</EnglishText>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>44</Id>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset>327792</PointerOffset>
      <VoiceId>&lt;audio:VSM_100_060_061&gt;</VoiceId>
      <JapaneseText>ねぇ、ちょっと待って</JapaneseText>
      <EnglishText>Hey, wait a second...</EnglishText>
      <Notes/>
      <SpeakerId>7</SpeakerId>
      <Id>45</Id>
      <BubbleId>0</BubbleId>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset>327792</PointerOffset>
      <VoiceId>&lt;audio:VSM_100_060_062&gt;</VoiceId>
      <JapaneseText>さっき、ふたりを襲った男、
あなたはダオスだって
言ってたけド……</JapaneseText>
      <EnglishText>That man who attacked us a moment
ago... You called him Dhaos.</EnglishText>
      <Notes/>
      <SpeakerId>7</SpeakerId>
      <Id>45</Id>
      <BubbleId>1</BubbleId>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset>327904</PointerOffset>
      <VoiceId>&lt;audio:VSM_100_060_063&gt;</VoiceId>
      <JapaneseText>どうして、時空戦士に
倒されたダオスが
ここにいるか、ですね</JapaneseText>
      <EnglishText>You are wondering why Dhaos was here,
even though the Eternal Heroes defeated
him, am I correct?</EnglishText>
      <Notes/>
      <SpeakerId>8</SpeakerId>
      <Id>47</Id>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset>328008</PointerOffset>
      <VoiceId>&lt;audio:VSM_100_060_064&gt;</VoiceId>
      <JapaneseText>それと、どうして、
ふたりが彼に襲われたのか、
です</JapaneseText>
      <EnglishText>Why did he try to attack us?</EnglishText>
      <Notes/>
      <SpeakerId>7</SpeakerId>
      <Id>48</Id>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset>328216</PointerOffset>
      <VoiceId>&lt;audio:VSM_100_060_065&gt;</VoiceId>
      <JapaneseText>それはわたしたちが、
『虹輪』を出したのと
関係あるんですか？</JapaneseText>
      <EnglishText>Is it because we caused the
Prism Ring to appear?</EnglishText>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>49</Id>
      <BubbleId>0</BubbleId>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset>328216</PointerOffset>
      <VoiceId>&lt;audio:VSM_100_060_066&gt;</VoiceId>
      <JapaneseText>ノルンさんがあの人に
言った『罪』っていうのは、
そのことじゃないんですか？</JapaneseText>
      <EnglishText>You mentioned to him something
about "sins" we committed...
It has to do with that, right?</EnglishText>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>49</Id>
      <BubbleId>1</BubbleId>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset>328324</PointerOffset>
      <VoiceId>&lt;audio:VSM_100_060_067&gt;</VoiceId>
      <JapaneseText>……あなた方には、
その罪と向き合う覚悟が
ありますか？</JapaneseText>
      <EnglishText>...Children, do you have the resolve
to face the weight of your sins?</EnglishText>
      <Notes/>
      <SpeakerId>8</SpeakerId>
      <Id>51</Id>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset>328388</PointerOffset>
      <VoiceId>&lt;audio:VSM_100_060_068&gt;</VoiceId>
      <JapaneseText>もちろんです</JapaneseText>
      <EnglishText>Absolutely.</EnglishText>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>52</Id>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset>328460</PointerOffset>
      <VoiceId>&lt;audio:VSM_100_060_069&gt;</VoiceId>
      <JapaneseText>あ、オ、オレだって！</JapaneseText>
      <EnglishText>O-Of course!</EnglishText>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>53</Id>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset>328728</PointerOffset>
      <VoiceId>&lt;audio:VSM_100_060_070&gt;</VoiceId>
      <JapaneseText>そうですか……
わかりました</JapaneseText>
      <EnglishText>I see... I understand.</EnglishText>
      <Notes/>
      <SpeakerId>8</SpeakerId>
      <Id>54</Id>
      <BubbleId>0</BubbleId>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset>328728</PointerOffset>
      <VoiceId>&lt;audio:VSM_100_060_071&gt;</VoiceId>
      <JapaneseText>では、１００年前の世界に
着いたら、&lt;Red&gt;ユークリッド&lt;White&gt;の南、
&lt;Red&gt;トーティス村&lt;White&gt;へ行きなさい</JapaneseText>
      <EnglishText>When you arrive at the world of 100 years
ago, travel south from Euclid village and
you'll find the village of Totus.</EnglishText>
      <Notes/>
      <SpeakerId>8</SpeakerId>
      <Id>54</Id>
      <BubbleId>1</BubbleId>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset>328728</PointerOffset>
      <VoiceId>&lt;audio:VSM_100_060_072&gt;</VoiceId>
      <JapaneseText>そこに時空戦士の筆頭騎士だった
&lt;Cless&gt;・アルベインが住んでいます</JapaneseText>
      <EnglishText>There you'll meet the Eternal Hero swordsman &lt;Cless&gt; Albane.</EnglishText>
      <Notes/>
      <SpeakerId>8</SpeakerId>
      <Id>54</Id>
      <BubbleId>2</BubbleId>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset>328800</PointerOffset>
      <VoiceId>&lt;audio:VSM_100_060_073&gt;</VoiceId>
      <JapaneseText>&lt;Cless&gt;って、あの！？</JapaneseText>
      <EnglishText>We'll meet...&lt;Cless&gt;!?</EnglishText>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>57</Id>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset>328896</PointerOffset>
      <VoiceId>&lt;audio:VSM_100_060_074&gt;</VoiceId>
      <JapaneseText>ええ。彼にダオスの話を
聞くとよいでしょう</JapaneseText>
      <EnglishText>Yes. He's the one who observed Dhaos's dying words.</EnglishText>
      <Notes/>
      <SpeakerId>8</SpeakerId>
      <Id>58</Id>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset>329080</PointerOffset>
      <VoiceId>&lt;audio:VSM_100_060_075&gt;</VoiceId>
      <JapaneseText>私の『希望のひとしずく』で、
しばらくは暴走の影響も
抑えられるでしょう</JapaneseText>
      <EnglishText>With my Tear of Hope power, I can halt
the destruction of this world temporarily.</EnglishText>
      <Notes/>
      <SpeakerId>8</SpeakerId>
      <Id>59</Id>
      <BubbleId>0</BubbleId>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset>329080</PointerOffset>
      <VoiceId>&lt;audio:VSM_100_060_076&gt;</VoiceId>
      <JapaneseText>行きなさい。
１００年前の&lt;Red&gt;トーティス&lt;White&gt;へ</JapaneseText>
      <EnglishText>Make haste. Travel 100 years back
into the past and visit &lt;Red&gt;Totus&lt;White&gt;.</EnglishText>
      <Notes/>
      <SpeakerId>8</SpeakerId>
      <Id>59</Id>
      <BubbleId>1</BubbleId>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset>329144</PointerOffset>
      <VoiceId>&lt;audio:VSM_100_060_077&gt;</VoiceId>
      <JapaneseText>消えた……</JapaneseText>
      <EnglishText>She's gone...</EnglishText>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>61</Id>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset>329208</PointerOffset>
      <VoiceId>&lt;audio:VSM_100_060_078&gt;</VoiceId>
      <JapaneseText>クルールゥ～</JapaneseText>
      <EnglishText>Kuruuuruu...</EnglishText>
      <Notes/>
      <SpeakerId>4</SpeakerId>
      <Id>62</Id>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset>329276</PointerOffset>
      <VoiceId>&lt;audio:VSM_100_060_079&gt;</VoiceId>
      <JapaneseText>&lt;Couleur&gt;、平気？</JapaneseText>
      <EnglishText>&lt;Couleur&gt;, are you ok?</EnglishText>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>63</Id>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset>329372</PointerOffset>
      <VoiceId>&lt;audio:VSM_100_060_080&gt;</VoiceId>
      <JapaneseText>１００年前の&lt;Red&gt;トーティス&lt;White&gt;か……
行こうぜ</JapaneseText>
      <EnglishText>Let's go...to the &lt;Red&gt;Totus&lt;White&gt; of 100 years ago!</EnglishText>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>64</Id>
      <Status>Proofreading</Status>
    </Entry>
