      <PointerOffset>325764</PointerOffset>
      <VoiceId>&lt;audio:VSM_100_060_037&gt;</VoiceId>
      <JapaneseText></JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>8</SpeakerId>
      <Id>32</Id>
      <BubbleId>0</BubbleId>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>325764</PointerOffset>
      <VoiceId>&lt;audio:VSM_100_060_038&gt;</VoiceId>
      <JapaneseText>確かに私は、まだ意思を持たない
小さな赤ん坊であったふたりを
見守る役目をあなたに与えましたしかし、いつまでも
彼らと一緒にいられるとは
限りません</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>8</SpeakerId>
      <Id>32</Id>
      <BubbleId>1</BubbleId>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>325884</PointerOffset>
      <VoiceId>&lt;audio:VSM_100_060_039&gt;</VoiceId>
      <JapaneseText></JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>7</SpeakerId>
      <Id>34</Id>
      <BubbleId>0</BubbleId>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>325884</PointerOffset>
      <VoiceId>&lt;audio:VSM_100_060_040&gt;</VoiceId>
      <JapaneseText>ぼくは……ぼくは
いつまでもふたりと
一緒に……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>7</SpeakerId>
      <Id>34</Id>
      <BubbleId>1</BubbleId>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>326320</PointerOffset>
      <VoiceId>&lt;audio:VSM_100_060_045&gt;</VoiceId>
      <JapaneseText>いいでしょう。それが
あなた方の選択ならば、
これ以上は言いません</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>8</SpeakerId>
      <Id>36</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>326436</PointerOffset>
      <VoiceId>&lt;audio:VSM_100_060_046&gt;</VoiceId>
      <JapaneseText>それより、オレらには、
今しなきゃなんない
大事なことがあんだ！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>37</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>326524</PointerOffset>
      <VoiceId>&lt;audio:VSM_100_060_047&gt;</VoiceId>
      <JapaneseText>知っています。
『虹輪』のことですね</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>8</SpeakerId>
      <Id>38</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>326708</PointerOffset>
      <VoiceId>&lt;audio:VSM_100_060_049&gt;</VoiceId>
      <JapaneseText>四大精霊を統括する
