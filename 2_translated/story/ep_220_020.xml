    <Entry>
      <PointerOffset>310168</PointerOffset>
      <VoiceId>&lt;audio:VSM_220_020_001&gt;</VoiceId>
      <JapaneseText>どうやら里の者たちは、
敵地で命果てたようです……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>1</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>310276</PointerOffset>
      <VoiceId>&lt;audio:VSM_220_020_002&gt;</VoiceId>
      <JapaneseText>じゃあ、
プルートと戦う人が、
もうこの里にはいないの？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>2</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>310348</PointerOffset>
      <VoiceId>&lt;audio:VSM_220_020_003&gt;</VoiceId>
      <JapaneseText>やっぱ、オレらが……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>3</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>310592</PointerOffset>
      <VoiceId>&lt;audio:VSM_220_020_004&gt;</VoiceId>
      <JapaneseText></JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>4</Id>
      <BubbleId>0</BubbleId>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>310592</PointerOffset>
      <VoiceId>&lt;audio:VSM_220_020_005&gt;</VoiceId>
      <JapaneseText></JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>4</Id>
      <BubbleId>1</BubbleId>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>310592</PointerOffset>
      <VoiceId>&lt;audio:VSM_220_020_006&gt;</VoiceId>
      <JapaneseText>里の精鋭の力をもってしても
突破できなかったのですその敵地にこの少数で
潜入するなんて無茶ですどうしてこんな時に、
私は里を留守に
してしまったのでしょう……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>4</Id>
      <BubbleId>2</BubbleId>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>310672</PointerOffset>
      <VoiceId>&lt;audio:VSM_220_020_007&gt;</VoiceId>
      <JapaneseText>&lt;Rody&gt;、
行っちゃうのか？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>7</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>310744</PointerOffset>
      <VoiceId>&lt;audio:VSM_220_020_008&gt;</VoiceId>
      <JapaneseText>何もこんな時に……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>8</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>310820</PointerOffset>
      <VoiceId>&lt;audio:VSM_220_020_009&gt;</VoiceId>
      <JapaneseText>助けを呼んでくればいい？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>4</SpeakerId>
      <Id>9</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>310896</PointerOffset>
      <VoiceId>&lt;audio:VSM_220_020_010&gt;</VoiceId>
      <JapaneseText>助け？　一体誰を……？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>10</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>311012</PointerOffset>
      <VoiceId>&lt;audio:VSM_220_020_011&gt;</VoiceId>
      <JapaneseText>&lt;Suzu&gt;ちゃんが
ピンチだって言えば、
必ず飛んできてくれる人たち</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>4</SpeakerId>
      <Id>11</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>311072</PointerOffset>
      <VoiceId>&lt;audio:VSM_220_020_012&gt;</VoiceId>
      <JapaneseText>え……？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>12</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>311172</PointerOffset>
      <VoiceId>&lt;audio:VSM_220_020_013&gt;</VoiceId>
      <JapaneseText>……呼ぶったって、
あの指輪で過去に行って……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>13</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>311236</PointerOffset>
      <VoiceId>&lt;audio:VSM_220_020_014&gt;</VoiceId>
      <JapaneseText>まさか……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>5</SpeakerId>
      <Id>14</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>311324</PointerOffset>
      <VoiceId>&lt;audio:VSM_220_020_015&gt;</VoiceId>
      <JapaneseText>&lt;Suzu&gt;ちゃん！
ピンチなんだって！？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>6</SpeakerId>
      <Id>15</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>311400</PointerOffset>
      <VoiceId>&lt;audio:VSM_220_020_016&gt;</VoiceId>
      <JapaneseText>おまえ！　声が大きい！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>7</SpeakerId>
      <Id>16</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>311460</PointerOffset>
      <VoiceId>&lt;audio:VSM_220_020_017&gt;</VoiceId>
      <JapaneseText>皆さん！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>17</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>311524</PointerOffset>
      <VoiceId>&lt;audio:VSM_220_020_018&gt;</VoiceId>
      <JapaneseText>クルール！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>8</SpeakerId>
      <Id>18</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>311608</PointerOffset>
      <VoiceId>&lt;audio:VSM_220_020_019&gt;</VoiceId>
      <JapaneseText>呼んできたよ、助っ人さんたちを</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>4</SpeakerId>
      <Id>19</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>311688</PointerOffset>
      <VoiceId>&lt;audio:VSM_220_020_020&gt;</VoiceId>
      <JapaneseText>&lt;Suzu&gt;久しぶりだね、ちゃん</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>9</SpeakerId>
      <Id>20</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>311760</PointerOffset>
      <VoiceId>&lt;audio:VSM_220_020_021&gt;</VoiceId>
      <JapaneseText>ご無沙汰しています</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>10</SpeakerId>
      <Id>21</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>311852</PointerOffset>
      <VoiceId>&lt;audio:VSM_220_020_022&gt;</VoiceId>
      <JapaneseText>なんだ、君たちも
こんなところにいたのか</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>11</SpeakerId>
      <Id>22</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>311932</PointerOffset>
      <VoiceId>&lt;audio:VSM_220_020_023&gt;</VoiceId>
      <JapaneseText>その節は
お世話になりました</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>23</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>312156</PointerOffset>
      <VoiceId>&lt;audio:VSM_220_020_025&gt;</VoiceId>
      <JapaneseText>わざわざこんなところまで
来ていただいてしまって……
皆さん、大丈夫なのですか？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>24</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>312276</PointerOffset>
      <VoiceId>&lt;audio:VSM_220_020_026&gt;</VoiceId>
      <JapaneseText>&lt;Dio&gt;ああ。とりあえず、
こっちはひと段落ついたし。
たちのおかげでね</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>9</SpeakerId>
      <Id>25</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>312364</PointerOffset>
      <VoiceId>&lt;audio:VSM_220_020_027&gt;</VoiceId>
      <JapaneseText>私の方の研究も
まだ準備段階だしな</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>11</SpeakerId>
      <Id>26</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>312484</PointerOffset>
      <VoiceId>&lt;audio:VSM_220_020_028&gt;</VoiceId>
      <JapaneseText>&lt;Rody&gt;本当にありがとうございます。
さんも大切な力を
私のために……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>27</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>312592</PointerOffset>
      <VoiceId>&lt;audio:VSM_220_020_029&gt;</VoiceId>
      <JapaneseText>&lt;Mel&gt;これは私たちの世界のため。
ちゃんも言ってたっしょ</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>4</SpeakerId>
      <Id>28</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>312704</PointerOffset>
      <VoiceId>&lt;audio:VSM_220_020_030&gt;</VoiceId>
      <JapaneseText></JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>29</Id>
      <BubbleId>0</BubbleId>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>312704</PointerOffset>
      <VoiceId>&lt;audio:VSM_220_020_031&gt;</VoiceId>
      <JapaneseText>そうでした……でも、
ありがとうございます</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>29</Id>
      <BubbleId>1</BubbleId>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>312796</PointerOffset>
      <VoiceId>&lt;audio:VSM_220_020_032&gt;</VoiceId>
      <JapaneseText>んじゃあ、みんな
そろったし、行こうぜ！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>31</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>313032</PointerOffset>
      <VoiceId>&lt;audio:VSM_220_020_035&gt;</VoiceId>
      <JapaneseText>&lt;Red&gt;&lt;White&gt;ネルヴィの洞窟。
そこにプルートが</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>32</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>313100</PointerOffset>
      <VoiceId>&lt;audio:VSM_220_020_036&gt;</VoiceId>
      <JapaneseText>よし、行こうぜ！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>33</Id>
      <Status>To Do</Status>
    </Entry>
