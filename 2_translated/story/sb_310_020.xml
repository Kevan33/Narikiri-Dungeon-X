    <Section>Main</Section>
    <Entry>
      <PointerOffset>276640</PointerOffset>
      <JapaneseText>みなさん、
湯加減はいかがですか？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>1</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>276720</PointerOffset>
      <JapaneseText>バーッチリだよ、&lt;Suzu&gt;ちゃん！
ありがとうね</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>2</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>276808</PointerOffset>
      <JapaneseText>いえ、それでは、
また何かありましたら、
お呼びください</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>3</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>276900</PointerOffset>
      <JapaneseText>しっかしさ、&lt;Mint&gt;の胸ぇ～
まーた大きくなったんじゃない？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>4</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>276972</PointerOffset>
      <JapaneseText>そ、そんなことありません、
たぶん……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>4</SpeakerId>
      <Id>5</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>277048</PointerOffset>
      <JapaneseText>そのわりには、
法衣の前がキツそうだね∀</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>6</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>277152</PointerOffset>
      <JapaneseText>そういう&lt;Rody&gt;さんだって
大きいし、すっごく見せてるし
………………</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>5</SpeakerId>
      <Id>7</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>277252</PointerOffset>
      <JapaneseText>あたしの場合は
動きやすさが重要だからね。
見た目は気にしないんだ</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>8</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>277380</PointerOffset>
      <JapaneseText>なーにが、見た目は気にしないよ。
そんだけハデに露出しておいて
男どもに見られたいだけでしょ？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>9</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>277480</PointerOffset>
      <JapaneseText>あら～、嫉妬かしら？
だったら、&lt;Chester&gt;の前で
私の服着てあげれば？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>10</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>277552</PointerOffset>
      <JapaneseText>あ、あんな格好
できるわけないでしょ！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>11</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>277628</PointerOffset>
      <JapaneseText>えー、でも&lt;Arche&gt;さん、
案外似合うかも？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>5</SpeakerId>
      <Id>12</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>277748</PointerOffset>
      <JapaneseText>ちょっと、&lt;Mel&gt;ちゃん！
あの服は胸があるから着れるの！
&lt;Mint&gt;ぐらいだよ、似合うの！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>13</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>277836</PointerOffset>
      <JapaneseText>わ、わたしがですか……？
あの&lt;Rody&gt;さんの服を……？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>4</SpeakerId>
      <Id>14</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>277932</PointerOffset>
      <JapaneseText>そうよ～。
&lt;Cless&gt;のおかげで大きくなってる
その胸があれば、ね？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>15</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>278036</PointerOffset>
      <JapaneseText>おい、お前のおかげって
どういうことだ？
お前&lt;Mint&gt;に何かしてるのか？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>6</SpeakerId>
      <Id>16</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>278124</PointerOffset>
      <JapaneseText>ちょ、ちょっと待ってって。
別に、&lt;Mint&gt;には、何も……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>7</SpeakerId>
      <Id>17</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>278212</PointerOffset>
      <JapaneseText>ほんとうかー？
案外ふたりっきりの時に、
何か、こう……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>8</SpeakerId>
      <Id>18</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>278296</PointerOffset>
      <JapaneseText>おまえ、今、
何か思い出したな？
言え、白状しろ！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>6</SpeakerId>
      <Id>19</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>278368</PointerOffset>
      <JapaneseText>&lt;Rody&gt;の服を
&lt;Mint&gt;さんが着る……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>9</SpeakerId>
      <Id>20</Id>
      <Status>To Do</Status>
    </Entry>
