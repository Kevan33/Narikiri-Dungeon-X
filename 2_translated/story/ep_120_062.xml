    <Entry>
      <PointerOffset>298016</PointerOffset>
      <VoiceId>&lt;audio:VSM_120_060_064&gt;</VoiceId>
      <JapaneseText>完了じゃ</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>1</Id>
      <OldPtr>278676</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>298088</PointerOffset>
      <VoiceId>&lt;audio:VSM_120_060_065&gt;</VoiceId>
      <JapaneseText>もう、だめ、かも……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>2</Id>
      <OldPtr>278816</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>298180</PointerOffset>
      <VoiceId>&lt;audio:VSM_120_060_066&gt;</VoiceId>
      <JapaneseText>はぁはぁ……
ちょ……
ひと、やすみ……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>3</Id>
      <OldPtr>278956</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>298268</PointerOffset>
      <VoiceId>&lt;audio:VSM_120_060_067&gt;</VoiceId>
      <JapaneseText>終わった……んだよね？
よかった……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>4</SpeakerId>
      <Id>4</Id>
      <OldPtr>279096</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>298380</PointerOffset>
      <VoiceId>&lt;audio:VSM_120_060_068&gt;</VoiceId>
      <JapaneseText>あの……洞窟の途中に
閉じ込められてる
妖精がいたんだけド……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>4</SpeakerId>
      <Id>5</Id>
      <OldPtr>279452</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>298476</PointerOffset>
      <VoiceId>&lt;audio:VSM_120_060_069&gt;</VoiceId>
      <JapaneseText>妖精……？
おお、すっかり
忘れとった</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>6</Id>
      <OldPtr>279592</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>298620</PointerOffset>
      <VoiceId>&lt;audio:VSM_120_060_070&gt;</VoiceId>
      <JapaneseText>あ、あれ……？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>5</SpeakerId>
      <Id>7</Id>
      <BubbleId>0</BubbleId>
      <OldPtr>281000</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>298620</PointerOffset>
      <VoiceId>&lt;audio:VSM_120_060_071&gt;</VoiceId>
      <JapaneseText>あぁっ！！　おまえ！！
よくも僕を閉じ込めて
くれたな！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>5</SpeakerId>
      <Id>7</Id>
      <BubbleId>1</BubbleId>
      <OldPtr>281000</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>298720</PointerOffset>
      <VoiceId>&lt;audio:VSM_120_060_072&gt;</VoiceId>
      <JapaneseText>え……
この子を閉じ込めたの
ってマクスウェル？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>4</SpeakerId>
      <Id>9</Id>
      <OldPtr>281140</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>298828</PointerOffset>
      <VoiceId>&lt;audio:VSM_120_060_073&gt;</VoiceId>
      <JapaneseText>どうじゃ、これに懲りたら
イタズラはよすんじゃぞ</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>10</Id>
      <OldPtr>281280</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>298920</PointerOffset>
      <VoiceId>&lt;audio:VSM_120_060_074&gt;</VoiceId>
      <JapaneseText>やなこったー！！
ベロベロベ～！！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>5</SpeakerId>
      <Id>11</Id>
      <OldPtr>281420</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>298992</PointerOffset>
      <VoiceId>&lt;audio:VSM_120_060_075&gt;</VoiceId>
      <JapaneseText>あ、ちょっと待って！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>4</SpeakerId>
      <Id>12</Id>
      <OldPtr>282376</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>299180</PointerOffset>
      <VoiceId>&lt;audio:VSM_120_060_076&gt;</VoiceId>
      <JapaneseText>まったく、困ったやつじゃのう</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>13</Id>
      <BubbleId>0</BubbleId>
      <OldPtr>282572</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>299180</PointerOffset>
      <VoiceId>&lt;audio:VSM_120_060_077&gt;</VoiceId>
      <JapaneseText>あまりにイタズラが過ぎるから、
閉じ込めておいたんじゃが
あの調子じゃ反省しとらんの</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>13</Id>
      <BubbleId>1</BubbleId>
      <OldPtr>282572</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>299280</PointerOffset>
      <VoiceId>&lt;audio:VSM_120_060_078&gt;</VoiceId>
      <JapaneseText>せっかく、
色々教えてもらえると
思ってたのに……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>4</SpeakerId>
      <Id>15</Id>
      <OldPtr>282832</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>299428</PointerOffset>
      <VoiceId>&lt;audio:VSM_120_060_079&gt;</VoiceId>
      <JapaneseText>休憩したら……
&lt;Red&gt;トーティス村&lt;White&gt;に戻んなきゃ……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>16</Id>
      <BubbleId>0</BubbleId>
      <OldPtr>283028</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>299428</PointerOffset>
      <VoiceId>&lt;audio:VSM_120_060_080&gt;</VoiceId>
      <JapaneseText>&lt;Cless&gt;さんに
会いに行こう……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>16</Id>
      <BubbleId>1</BubbleId>
      <OldPtr>283028</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>299516</PointerOffset>
      <VoiceId>&lt;audio:VSM_120_060_081&gt;</VoiceId>
      <JapaneseText>そう言えば……
そっちもあったね……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>18</Id>
      <OldPtr>283364</OldPtr>
      <Status>To Do</Status>
    </Entry>
