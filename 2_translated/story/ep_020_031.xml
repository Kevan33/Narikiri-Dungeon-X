    <Entry>
      <PointerOffset>297180</PointerOffset>
      <VoiceId>&lt;audio:VSM_020_030_019&gt;</VoiceId>
      <JapaneseText>わぷ……！
お、おまえ、だいじょーぶか？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>3</Id>
