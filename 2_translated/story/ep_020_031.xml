    <Entry>
      <PointerOffset>297316</PointerOffset>
      <VoiceId>&lt;audio:VSM_020_030_021&gt;</VoiceId>
      <JapaneseText>来たか……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>5</Id>
      <OldPtr>280952</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>297408</PointerOffset>
      <VoiceId>&lt;audio:VSM_020_030_022&gt;</VoiceId>
      <JapaneseText>あの仮面ヤローか、
こいつ操ってんの？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>6</Id>
      <OldPtr>281092</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>297488</PointerOffset>
      <VoiceId>&lt;audio:VSM_020_030_023&gt;</VoiceId>
      <JapaneseText>&lt;Dio&gt;！
また無茶して……！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>4</SpeakerId>
      <Id>7</Id>
      <OldPtr>281600</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>297608</PointerOffset>
      <VoiceId>&lt;audio:VSM_020_030_024&gt;</VoiceId>
      <JapaneseText>無茶かどーか、
試してみよーぜ！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>8</Id>
      <BubbleId>0</BubbleId>
      <OldPtr>281844</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>297608</PointerOffset>
      <VoiceId>&lt;audio:VSM_020_030_025&gt;</VoiceId>
      <JapaneseText>出でよ、タンス！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>8</Id>
      <BubbleId>1</BubbleId>
      <OldPtr>281844</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>297712</PointerOffset>
      <VoiceId>&lt;audio:VSM_020_030_026&gt;</VoiceId>
      <JapaneseText>ぐっ、おめぇ、
またタンスって
いいやがっただな！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>5</SpeakerId>
      <Id>10</Id>
      <OldPtr>282588</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>297800</PointerOffset>
      <VoiceId>&lt;audio:VSM_020_030_027&gt;</VoiceId>
      <JapaneseText>いーから！
今ある服、出してくれ！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>11</Id>
      <OldPtr>283060</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>297904</PointerOffset>
      <VoiceId>&lt;audio:VSM_020_030_028&gt;</VoiceId>
      <JapaneseText>だぁ～～！
ま、魔物がいるべ！
さっさと着替えれ！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>5</SpeakerId>
      <Id>12</Id>
      <OldPtr>283528</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>297988</PointerOffset>
      <VoiceId>&lt;audio:VSM_020_030_029&gt;</VoiceId>
      <JapaneseText>よし！　行くぞ、
変身の合言葉！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>13</Id>
      <OldPtr>284540</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>298144</PointerOffset>
      <VoiceId>&lt;audio:VSM_020_030_031&gt;</VoiceId>
      <JapaneseText>なりきり！　クロぉスシフトっ！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>14</Id>
