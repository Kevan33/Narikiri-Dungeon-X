    <Entry>
      <PointerOffset>273420</PointerOffset>
      <JapaneseText>我は天の戦場を駆けし戦乙女女神との盟約により、
我が主の槍、
しばし汝らに預けよう！ありがたく受け取れ！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>3</Id>
      <BubbleId>2</BubbleId>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>273484</PointerOffset>
      <JapaneseText>だ、大丈夫なのか、
これ……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>6</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>273552</PointerOffset>
      <JapaneseText>これは……
グーングニルの槍……！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>4</SpeakerId>
      <Id>7</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>273600</PointerOffset>
      <JapaneseText>グーングニル？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>8</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>273644</PointerOffset>
      <JapaneseText>あぁ……</JapaneseText>
