  <Strings>
    <Section>Main</Section>
    <Entry>
      <PointerOffset>267944</PointerOffset>
      <JapaneseText>な、なんと！
すべての精霊を従えたのか！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>1</Id>
      <BubbleId>0</BubbleId>
      <OldPtr>258224</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>267944</PointerOffset>
      <JapaneseText>こ、これはすさまじい
宣伝になったわい！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>1</Id>
      <BubbleId>1</BubbleId>
      <OldPtr>258224</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>267944</PointerOffset>
      <JapaneseText>いや、本当にありがとう</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>1</Id>
      <BubbleId>2</BubbleId>
      <OldPtr>258224</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>267944</PointerOffset>
      <JapaneseText>お前さんらにうさギルドの栄誉称号
うさギルダーを授与しよう</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>1</Id>
      <BubbleId>3</BubbleId>
      <OldPtr>258224</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>267944</PointerOffset>
      <JapaneseText>もうそんなモンと、感謝の言葉しか
ないんじゃが……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>1</Id>
      <BubbleId>4</BubbleId>
      <OldPtr>258224</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>267944</PointerOffset>
      <JapaneseText>もう一度言わせてくれい。
本当に、ありがとう</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>1</Id>
      <BubbleId>5</BubbleId>
      <OldPtr>258224</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>268040</PointerOffset>
      <JapaneseText>う、うーん……
かわいらしすぎるんで
オレは遠慮しようかな……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>7</Id>
      <OldPtr>258364</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>268144</PointerOffset>
      <JapaneseText>そうかの？
このふぁんしーさがわからんとは
まだまだじゃのお</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>8</Id>
      <OldPtr>258504</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>268408</PointerOffset>
      <JapaneseText>さて、この世界での役目を終えたし、
そろそろダングレストに戻るかの～</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>9</Id>
      <BubbleId>0</BubbleId>
      <OldPtr>258644</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>268408</PointerOffset>
      <JapaneseText>時空転移用の井戸は、っと……
&lt;Red&gt;ヴァルハラ&lt;White&gt;じゃったかの……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>9</Id>
      <BubbleId>1</BubbleId>
      <OldPtr>258644</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>268408</PointerOffset>
      <JapaneseText>おっと！　なんでもないぞい？
今のは聞かなかったことに
しといてくれぃ</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>9</Id>
      <BubbleId>2</BubbleId>
      <OldPtr>258644</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>268408</PointerOffset>
      <JapaneseText>ふおっふおっふおっ</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>9</Id>
      <BubbleId>3</BubbleId>
      <OldPtr>258644</OldPtr>
      <Status>To Do</Status>
    </Entry>
