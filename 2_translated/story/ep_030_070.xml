    <Entry>
      <PointerOffset>275372</PointerOffset>
      <VoiceId>&lt;audio:VSM_030_070_005&gt;</VoiceId>
      <JapaneseText>本当に平気かな？精霊に会うとか、
その……２００年前の
世界とか……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>4</Id>
      <BubbleId>1</BubbleId>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>275748</PointerOffset>
      <VoiceId>&lt;audio:VSM_030_070_009&gt;</VoiceId>
      <JapaneseText></JapaneseText>
      <EnglishText/>
