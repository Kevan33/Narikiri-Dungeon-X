      <SpeakerId>3</SpeakerId>
      <Id>6</Id>
      <BubbleId>0</BubbleId>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>275748</PointerOffset>
      <VoiceId>&lt;audio:VSM_030_070_010&gt;</VoiceId>
      <JapaneseText>……じゃあ、
この時代で魔術の暴走を
止める手段探す？見つかるかどうかは
わからないけド……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>6</Id>
      <BubbleId>1</BubbleId>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>275932</PointerOffset>
      <VoiceId>&lt;audio:VSM_030_070_011&gt;</VoiceId>
      <JapaneseText></JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>8</Id>
      <BubbleId>0</BubbleId>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>275932</PointerOffset>
      <VoiceId>&lt;audio:VSM_030_070_012&gt;</VoiceId>
      <JapaneseText>ちょっと待てよ、
目の前にうまくいく方法が
あんだぜ！なのに、なんで
どうなるかわかんない
そっちの方法取んだよ？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>8</Id>
      <BubbleId>1</BubbleId>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>276260</PointerOffset>
      <VoiceId>&lt;audio:VSM_030_070_015&gt;</VoiceId>
      <JapaneseText></JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>10</Id>
      <BubbleId>0</BubbleId>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>276260</PointerOffset>
      <VoiceId>&lt;audio:VSM_030_070_016&gt;</VoiceId>
      <JapaneseText>ゴメン……
今のなしねそんなこと言ってる場合
じゃないんだもん</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>10</Id>
      <BubbleId>1</BubbleId>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>276336</PointerOffset>
      <VoiceId>&lt;audio:VSM_030_070_017&gt;</VoiceId>
      <JapaneseText>……んじゃ、いんだな？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>12</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>276408</PointerOffset>
      <VoiceId>&lt;audio:VSM_030_070_018&gt;</VoiceId>
      <JapaneseText>うん。
さ、行こ？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>13</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>276480</PointerOffset>
      <VoiceId>&lt;audio:VSM_030_070_019&gt;</VoiceId>
      <JapaneseText>……終わったのか？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>14</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>276580</PointerOffset>
      <VoiceId>&lt;audio:VSM_030_070_020&gt;</VoiceId>
      <JapaneseText>みたい……
ちょっと空気が
違うっぽく感じる……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>15</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>276820</PointerOffset>
      <VoiceId>&lt;audio:VSM_030_070_023&gt;</VoiceId>
      <JapaneseText>う～ん……とりあえず、
外出てみたら
なんかわかるかも</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>16</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>276920</PointerOffset>
      <VoiceId>&lt;audio:VSM_030_070_024&gt;</VoiceId>
      <JapaneseText>&lt;Arche&gt;&lt;Red&gt;&lt;White&gt;さん、
ユークリッド村って
