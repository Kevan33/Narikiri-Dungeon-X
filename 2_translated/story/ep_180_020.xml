    <Entry>
      <PointerOffset>288764</PointerOffset>
      <VoiceId>&lt;audio:VSM_180_020_001&gt;</VoiceId>
      <JapaneseText>何だ？　これ？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>1</Id>
      <OldPtr>258940</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>288864</PointerOffset>
      <VoiceId>&lt;audio:VSM_180_020_002&gt;</VoiceId>
      <JapaneseText>コンピュータルームのある
建物に入るための鍵だね</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>2</Id>
      <OldPtr>259180</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>288928</PointerOffset>
      <VoiceId>&lt;audio:VSM_180_020_003&gt;</VoiceId>
      <JapaneseText>へえ……？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>3</Id>
      <OldPtr>259688</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>289000</PointerOffset>
      <VoiceId>&lt;audio:VSM_180_020_004&gt;</VoiceId>
      <JapaneseText>クー！　クルール！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>4</Id>
      <OldPtr>260044</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>289068</PointerOffset>
      <VoiceId>&lt;audio:VSM_180_020_005&gt;</VoiceId>
      <JapaneseText>&lt;Rody&gt;さん！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>4</SpeakerId>
      <Id>5</Id>
      <OldPtr>265032</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>289152</PointerOffset>
      <VoiceId>&lt;audio:VSM_180_020_006&gt;</VoiceId>
      <JapaneseText>あゃ？
これは皆さん、おそろいで</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>5</SpeakerId>
      <Id>6</Id>
      <OldPtr>265460</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>289240</PointerOffset>
      <VoiceId>&lt;audio:VSM_180_020_007&gt;</VoiceId>
      <JapaneseText>どうしてここに？
ダオスはいねーよ？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>7</Id>
      <OldPtr>265724</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>289560</PointerOffset>
      <VoiceId>&lt;audio:VSM_180_020_010&gt;</VoiceId>
      <JapaneseText>ダオスを追って、
時間の狭間のお城まで
行ったんだけど</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>5</SpeakerId>
      <Id>8</Id>
      <BubbleId>0</BubbleId>
      <OldPtr>265920</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>289560</PointerOffset>
      <VoiceId>&lt;audio:VSM_180_020_011&gt;</VoiceId>
      <JapaneseText>ダオスに時間を
飛ばされて気付いたら、
この時代にいたんだよね</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>5</SpeakerId>
      <Id>8</Id>
      <BubbleId>1</BubbleId>
      <OldPtr>265920</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>289668</PointerOffset>
      <VoiceId>&lt;audio:VSM_180_020_012&gt;</VoiceId>
      <JapaneseText>じゃあ、
まだダオスには会えていない
ということなんですね</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>6</SpeakerId>
      <Id>10</Id>
      <OldPtr>266124</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>289804</PointerOffset>
      <VoiceId>&lt;audio:VSM_180_020_013&gt;</VoiceId>
      <JapaneseText>&lt;Mel&gt;ちゃん、固いってば</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>5</SpeakerId>
      <Id>11</Id>
      <BubbleId>0</BubbleId>
      <OldPtr>266612</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>289804</PointerOffset>
      <VoiceId>&lt;audio:VSM_180_020_014&gt;</VoiceId>
      <JapaneseText>敬語じゃなく、
もっとやわらかくいこうぜ？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>5</SpeakerId>
      <Id>11</Id>
      <BubbleId>1</BubbleId>
      <OldPtr>266612</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>289908</PointerOffset>
      <VoiceId>&lt;audio:VSM_180_020_015&gt;</VoiceId>
      <JapaneseText>……ダオスは僕たちが倒した。
もう君が追う必要はない</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>13</Id>
      <OldPtr>267784</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>289996</PointerOffset>
      <VoiceId>&lt;audio:VSM_180_020_016&gt;</VoiceId>
      <JapaneseText>必要があるかどうかは、
自分で決める</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>5</SpeakerId>
      <Id>14</Id>
      <OldPtr>268848</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>290084</PointerOffset>
      <VoiceId>&lt;audio:VSM_180_020_017&gt;</VoiceId>
      <JapaneseText>ところで、
みんなはなんでここに？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>5</SpeakerId>
      <Id>15</Id>
      <OldPtr>269484</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>290184</PointerOffset>
      <VoiceId>&lt;audio:VSM_180_020_018&gt;</VoiceId>
      <JapaneseText>時間転移装置で
オレらの元の時代に
戻るためだよ</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>16</Id>
      <OldPtr>269848</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>290300</PointerOffset>
      <VoiceId>&lt;audio:VSM_180_020_019&gt;</VoiceId>
      <JapaneseText>オレたちは付き添いさ</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>7</SpeakerId>
      <Id>17</Id>
      <BubbleId>0</BubbleId>
      <OldPtr>270188</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>290300</PointerOffset>
      <VoiceId>&lt;audio:VSM_180_020_020&gt;</VoiceId>
      <JapaneseText>おまえは何してるんだ？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>7</SpeakerId>
      <Id>17</Id>
      <BubbleId>1</BubbleId>
      <OldPtr>270188</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>290376</PointerOffset>
      <VoiceId>&lt;audio:VSM_180_020_021&gt;</VoiceId>
      <JapaneseText>んーと……見物、かな？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>5</SpeakerId>
      <Id>19</Id>
      <OldPtr>270608</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>290448</PointerOffset>
      <VoiceId>&lt;audio:VSM_180_020_022&gt;</VoiceId>
      <JapaneseText>なんだよ、遊びかよ</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>20</Id>
      <OldPtr>271208</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>290548</PointerOffset>
      <VoiceId>&lt;audio:VSM_180_020_023&gt;</VoiceId>
      <JapaneseText>遊びじゃなくて歴史の勉強。
仲良く一緒しようよ？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>5</SpeakerId>
      <Id>21</Id>
      <OldPtr>272216</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>290684</PointerOffset>
      <VoiceId>&lt;audio:VSM_180_020_024&gt;</VoiceId>
      <JapaneseText>いたい、いたい……！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>22</Id>
      <BubbleId>0</BubbleId>
      <OldPtr>273304</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>290684</PointerOffset>
      <VoiceId>&lt;audio:VSM_180_020_025&gt;</VoiceId>
      <JapaneseText>うわっ、な、なんか
フニフニするのが
顔に……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>22</Id>
      <BubbleId>1</BubbleId>
      <OldPtr>273304</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>290752</PointerOffset>
      <VoiceId>&lt;audio:VSM_180_020_026&gt;</VoiceId>
      <JapaneseText>さ、行きましょ</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>6</SpeakerId>
      <Id>24</Id>
      <OldPtr>276480</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>290876</PointerOffset>
      <VoiceId>&lt;audio:VSM_180_020_027&gt;</VoiceId>
      <JapaneseText>乱暴してると、
&lt;Mel&gt;ちゃんのかわいいおてて、
ゴツゴツになっちゃうよ？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>5</SpeakerId>
      <Id>25</Id>
      <OldPtr>277392</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>290940</PointerOffset>
      <VoiceId>&lt;audio:VSM_180_020_028&gt;</VoiceId>
      <JapaneseText>いいんです！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>6</SpeakerId>
      <Id>26</Id>
      <OldPtr>278060</OldPtr>
      <Status>To Do</Status>
    </Entry>
