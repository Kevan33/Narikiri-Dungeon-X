    <Entry>
      <PointerOffset>285912</PointerOffset>
      <VoiceId>&lt;audio:VSM_080_050_000Z&gt;</VoiceId>
      <JapaneseText>この街はずっと
こんな調子さ</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>1</Id>
      <OldPtr>259260</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>286036</PointerOffset>
      <VoiceId>&lt;audio:VSM_080_050_001Z&gt;</VoiceId>
      <JapaneseText>こんなに貧しいのに、
ここの人々は何の見返りもなく
僕を受け容れてくれた</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>2</Id>
      <OldPtr>260352</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>286124</PointerOffset>
      <VoiceId>&lt;audio:VSM_080_050_002Z&gt;</VoiceId>
      <JapaneseText>僕はエルフだ。
だが、魔術が使えない</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>3</Id>
      <OldPtr>260748</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>286224</PointerOffset>
      <VoiceId>&lt;audio:VSM_080_050_003&gt;</VoiceId>
      <JapaneseText>それって、
『レスネス』ってヤツ？
前に本で読んだ</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>4</Id>
      <OldPtr>261088</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>286304</PointerOffset>
      <VoiceId>&lt;audio:VSM_080_050_004&gt;</VoiceId>
      <JapaneseText>レス、ネス……？
何それ？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>5</Id>
      <OldPtr>261332</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>286412</PointerOffset>
      <VoiceId>&lt;audio:VSM_080_050_005&gt;</VoiceId>
      <JapaneseText>魔術使えないエルフ。
百年にひとりしか
生まれねんだって</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>6</Id>
      <OldPtr>261576</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>286584</PointerOffset>
      <VoiceId>&lt;audio:VSM_080_050_006Z&gt;</VoiceId>
      <JapaneseText>よく知っているね</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>7</Id>
      <BubbleId>0</BubbleId>
      <OldPtr>262036</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>286584</PointerOffset>
      <VoiceId>&lt;audio:VSM_080_050_007Z&gt;</VoiceId>
      <JapaneseText>『レスネス』はエルフの里を
不幸にするとされていて、
生まれるとすぐ里を追い出される</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>7</Id>
      <BubbleId>1</BubbleId>
      <OldPtr>262036</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>286664</PointerOffset>
      <VoiceId>&lt;audio:VSM_080_050_008&gt;</VoiceId>
      <JapaneseText>じゃあ、
バジルさんも……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>9</Id>
      <OldPtr>262176</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>286828</PointerOffset>
      <VoiceId>&lt;audio:VSM_080_050_009Z&gt;</VoiceId>
      <JapaneseText>そう。居場所をなくした僕は
この街に流れついた</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>10</Id>
      <BubbleId>0</BubbleId>
      <OldPtr>262316</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>286828</PointerOffset>
      <VoiceId>&lt;audio:VSM_080_050_010Z&gt;</VoiceId>
      <JapaneseText>よそ者の僕にも
ここの人たちはよくしてくれた</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>10</Id>
      <BubbleId>1</BubbleId>
      <OldPtr>262316</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>286924</PointerOffset>
      <VoiceId>&lt;audio:VSM_080_050_011&gt;</VoiceId>
      <JapaneseText>だから、
アルヴァニスタじゃなくて
ここに？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>12</Id>
      <OldPtr>262456</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>287108</PointerOffset>
      <VoiceId>&lt;audio:VSM_080_050_012Z&gt;</VoiceId>
      <JapaneseText>ああ。ここの方が
居心地がいいからね</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>13</Id>
      <BubbleId>0</BubbleId>
      <OldPtr>262596</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>287108</PointerOffset>
      <VoiceId>&lt;audio:VSM_080_050_013Z&gt;</VoiceId>
      <JapaneseText>それに、一番大切なことを
教えられる気がするんだ。
自分が今、何をするべきか</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>13</Id>
      <BubbleId>1</BubbleId>
      <OldPtr>262596</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>287180</PointerOffset>
      <VoiceId>&lt;audio:VSM_080_050_014&gt;</VoiceId>
      <JapaneseText>それが
魔術の研究？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>15</Id>
      <OldPtr>262736</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>287396</PointerOffset>
      <VoiceId>&lt;audio:VSM_080_050_015Z&gt;</VoiceId>
      <JapaneseText>人も『レスネス』も関係なく、
魔術を使えるようになるための
技術の研究さ</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>16</Id>
      <BubbleId>0</BubbleId>
      <OldPtr>262876</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>287396</PointerOffset>
      <VoiceId>&lt;audio:VSM_080_050_016Z&gt;</VoiceId>
      <JapaneseText>魔術がもっとなじめば、
きっとこの村を、いや世界を
もっと豊かにできるんだ</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>16</Id>
      <BubbleId>1</BubbleId>
      <OldPtr>262876</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>287472</PointerOffset>
      <VoiceId>&lt;audio:VSM_080_050_017&gt;</VoiceId>
      <JapaneseText>でっかい夢だな、それ……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>18</Id>
      <OldPtr>263016</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>287612</PointerOffset>
      <VoiceId>&lt;audio:VSM_080_050_018Z&gt;</VoiceId>
      <JapaneseText>どんな大きな夢でも
思い続けなければ叶わない</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>19</Id>
      <BubbleId>0</BubbleId>
      <OldPtr>263156</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>287612</PointerOffset>
      <VoiceId>&lt;audio:VSM_080_050_019Z&gt;</VoiceId>
      <JapaneseText>信じることが
大切なんだ</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>19</Id>
      <BubbleId>1</BubbleId>
      <OldPtr>263156</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>287692</PointerOffset>
      <VoiceId>&lt;audio:VSM_080_050_020&gt;</VoiceId>
      <JapaneseText>信じること、か。う～ん……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>21</Id>
      <OldPtr>263404</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>287840</PointerOffset>
      <VoiceId>&lt;audio:VSM_080_050_022Z&gt;</VoiceId>
      <JapaneseText>君には
そういう夢はないのかい？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>22</Id>
      <OldPtr>263544</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>287924</PointerOffset>
      <VoiceId>&lt;audio:VSM_080_050_023&gt;</VoiceId>
      <JapaneseText>オレ……？
オレはええっと……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>23</Id>
      <OldPtr>263740</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>287992</PointerOffset>
      <VoiceId>&lt;audio:VSM_080_050_024&gt;</VoiceId>
      <JapaneseText>何かになりたい！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>24</Id>
      <OldPtr>264756</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>288076</PointerOffset>
      <VoiceId>&lt;audio:VSM_080_050_025&gt;</VoiceId>
      <JapaneseText>何かって……
きみは、もう……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>4</SpeakerId>
      <Id>25</Id>
      <OldPtr>265188</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>288220</PointerOffset>
      <VoiceId>&lt;audio:VSM_080_050_026&gt;</VoiceId>
      <JapaneseText>じゃなくって！　どうすりゃいいかは
わかんねーけど、自分の足で
歩いてけるようになりたいんだ</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>26</Id>
      <OldPtr>265544</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>288284</PointerOffset>
      <VoiceId>&lt;audio:VSM_080_050_027&gt;</VoiceId>
      <JapaneseText>それで……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>27</Id>
      <OldPtr>265952</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>288452</PointerOffset>
      <VoiceId>&lt;audio:VSM_080_050_028Z&gt;</VoiceId>
      <JapaneseText>ハハッ、
ゆっくり考えればいいさ。
君の未来は真っ白だ</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>28</Id>
      <BubbleId>0</BubbleId>
      <OldPtr>266620</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>288452</PointerOffset>
      <VoiceId>&lt;audio:VSM_080_050_029Z&gt;</VoiceId>
      <JapaneseText>君はまだ
どんなものにでも
なれるんだからさ</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>28</Id>
      <BubbleId>1</BubbleId>
      <OldPtr>266620</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>288536</PointerOffset>
      <VoiceId>&lt;audio:VSM_080_050_030&gt;</VoiceId>
      <JapaneseText>真っ白……
どんなもんにでも……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>30</Id>
      <OldPtr>267536</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>288692</PointerOffset>
      <VoiceId>&lt;audio:VSM_080_050_031Z&gt;</VoiceId>
      <JapaneseText>強く願い続ければ、
どんな気持ちでも叶う、
そう思うんだ</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>31</Id>
      <BubbleId>0</BubbleId>
      <OldPtr>267872</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>288692</PointerOffset>
      <VoiceId>&lt;audio:VSM_080_050_032Z&gt;</VoiceId>
      <JapaneseText>だから、
がんばれよ、&lt;Dio&gt;！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>31</Id>
      <BubbleId>1</BubbleId>
      <OldPtr>267872</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>288764</PointerOffset>
      <VoiceId>&lt;audio:VSM_080_050_033&gt;</VoiceId>
      <JapaneseText>あ、う、うん……！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>33</Id>
      <OldPtr>268608</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>288992</PointerOffset>
      <VoiceId>&lt;audio:VSM_080_050_034Z&gt;</VoiceId>
      <JapaneseText>僕も人を応援している場合じゃ
ないんだけど</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>34</Id>
      <BubbleId>0</BubbleId>
      <OldPtr>269040</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>288992</PointerOffset>
      <VoiceId>&lt;audio:VSM_080_050_035Z&gt;</VoiceId>
      <JapaneseText>でも、&lt;Claus&gt;もまた
やる気になってくれたし、
研究も進展すると思う。</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>34</Id>
      <BubbleId>1</BubbleId>
      <OldPtr>269040</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>288992</PointerOffset>
      <VoiceId>&lt;audio:VSM_080_050_036Z&gt;</VoiceId>
      <JapaneseText>魔科学があれば
もう少し……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>34</Id>
      <BubbleId>2</BubbleId>
      <OldPtr>269040</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>289052</PointerOffset>
      <VoiceId>&lt;audio:VSM_080_050_037&gt;</VoiceId>
      <JapaneseText>魔科学？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>37</Id>
      <OldPtr>269632</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>289120</PointerOffset>
      <VoiceId>&lt;audio:VSM_080_050_038Z&gt;</VoiceId>
      <JapaneseText>ん？　いや……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>38</Id>
      <OldPtr>269772</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>289200</PointerOffset>
      <VoiceId>&lt;audio:VSM_080_050_039&gt;</VoiceId>
      <JapaneseText>&lt;Rody&gt;、何をやってるんだ？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>5</SpeakerId>
      <Id>39</Id>
      <OldPtr>270328</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>289292</PointerOffset>
      <VoiceId>&lt;audio:VSM_080_050_040&gt;</VoiceId>
      <JapaneseText>ん？　空がきれいだなって
見とれてたんだ</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>6</SpeakerId>
      <Id>40</Id>
      <OldPtr>270988</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>289400</PointerOffset>
      <VoiceId>&lt;audio:VSM_080_050_041&gt;</VoiceId>
      <JapaneseText>さてと……どこか
泊まれるところを
借りられないだろうか</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>5</SpeakerId>
      <Id>41</Id>
      <OldPtr>271356</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>289492</PointerOffset>
      <VoiceId>&lt;audio:VSM_080_050_042Z&gt;</VoiceId>
      <JapaneseText>そうか、よかったら、
うちを使ってくれ</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>42</Id>
      <OldPtr>271664</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>289616</PointerOffset>
      <VoiceId>&lt;audio:VSM_080_050_043Z&gt;</VoiceId>
      <JapaneseText>ふたりともおはよう</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>43</Id>
      <BubbleId>0</BubbleId>
      <OldPtr>273820</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>289616</PointerOffset>
      <VoiceId>&lt;audio:VSM_080_050_044Z&gt;</VoiceId>
      <JapaneseText>アルヴァニスタから
返信があったよ</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>43</Id>
      <BubbleId>1</BubbleId>
      <OldPtr>273820</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>289708</PointerOffset>
      <VoiceId>&lt;audio:VSM_080_050_045&gt;</VoiceId>
      <JapaneseText>それで、
ウンディーネんとこへ
行けんだな</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>45</Id>
      <OldPtr>273960</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>289804</PointerOffset>
      <VoiceId>&lt;audio:VSM_080_050_046Z&gt;</VoiceId>
      <JapaneseText>ああ、北の海の&lt;Red&gt;浸食洞&lt;White&gt;の
立ち入り許可証だ</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>46</Id>
      <OldPtr>274100</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>289884</PointerOffset>
      <VoiceId>&lt;audio:VSM_080_050_047&gt;</VoiceId>
      <JapaneseText>サンキュー、
バジルさん！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>47</Id>
      <OldPtr>274352</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>289956</PointerOffset>
      <VoiceId>&lt;audio:VSM_080_050_048&gt;</VoiceId>
      <JapaneseText>ありがとうございます</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>48</Id>
