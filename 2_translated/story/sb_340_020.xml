      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>23</Id>
      <OldPtr>263352</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>287448</PointerOffset>
      <JapaneseText>挑戦者は&lt;Mint&gt;・アドネード。
