      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>48</Id>
      <BubbleId>1</BubbleId>
      <OldPtr>265988</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
