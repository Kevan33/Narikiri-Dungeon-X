      <SpeakerId>5</SpeakerId>
      <Id>19</Id>
      <OldPtr>262884</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>287092</PointerOffset>
      <JapaneseText>挑戦者は&lt;Cless&gt;・アルベイン！
