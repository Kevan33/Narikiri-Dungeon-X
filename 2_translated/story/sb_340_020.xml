      <EnglishText/>
      <Notes/>
      <SpeakerId>8</SpeakerId>
      <Id>31</Id>
      <OldPtr>264148</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>287920</PointerOffset>
