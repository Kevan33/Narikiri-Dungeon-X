      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>15</Id>
      <BubbleId>0</BubbleId>
      <OldPtr>262464</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>286724</PointerOffset>
      <JapaneseText>誰だ、こんなの入れたのは！
