      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>33</Id>
      <BubbleId>0</BubbleId>
      <OldPtr>264476</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>288084</PointerOffset>
      <JapaneseText>既に２００歳を越える
