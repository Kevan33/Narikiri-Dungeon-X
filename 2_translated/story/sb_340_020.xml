      <EnglishText/>
      <Notes/>
      <SpeakerId>9</SpeakerId>
      <Id>35</Id>
      <OldPtr>264616</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>288248</PointerOffset>
      <JapaneseText>聞きたくありません。
ハーフエルフなんだから、
