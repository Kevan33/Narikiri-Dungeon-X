      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>7</Id>
      <BubbleId>0</BubbleId>
      <OldPtr>261528</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>286124</PointerOffset>
      <JapaneseText>そんな小さな体で、
本当にやれるのか？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>7</Id>
      <BubbleId>1</BubbleId>
      <OldPtr>261528</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>286172</PointerOffset>
      <JapaneseText>がんばります！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>9</Id>
      <OldPtr>261668</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>286272</PointerOffset>
      <JapaneseText>うーん！　いいっ！
健気だ、可憐だ、
がんばってほしいところ！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>10</Id>
      <OldPtr>261808</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>286408</PointerOffset>
      <JapaneseText>挑戦者は&lt;Rondoline&gt;・Ｅ……
