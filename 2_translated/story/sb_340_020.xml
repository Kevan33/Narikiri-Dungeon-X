      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>33</Id>
      <BubbleId>1</BubbleId>
      <OldPtr>264476</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>288156</PointerOffset>
      <JapaneseText>でしょー♪
