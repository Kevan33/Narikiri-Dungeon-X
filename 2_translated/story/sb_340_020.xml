私が骨を拾おう！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>48</Id>
      <BubbleId>0</BubbleId>
      <OldPtr>265988</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>289216</PointerOffset>
