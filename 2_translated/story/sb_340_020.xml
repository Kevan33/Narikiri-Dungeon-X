      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>20</Id>
      <BubbleId>0</BubbleId>
      <OldPtr>263072</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>287092</PointerOffset>
      <JapaneseText>この闘技場でも
大活躍を見せたことが
あるのだそうです！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>20</Id>
      <BubbleId>1</BubbleId>
      <OldPtr>263072</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>287152</PointerOffset>
