      <Notes/>
      <SpeakerId>5</SpeakerId>
      <Id>17</Id>
      <OldPtr>262604</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>286876</PointerOffset>
      <JapaneseText>いや、しかしっ！
