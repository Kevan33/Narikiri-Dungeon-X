      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>24</Id>
      <BubbleId>0</BubbleId>
      <OldPtr>263540</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>287448</PointerOffset>
      <JapaneseText>今回はひとりで参戦！
戦いは苦手という&lt;Mint&gt;さん、
意気込みはいかに！？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>24</Id>
      <BubbleId>1</BubbleId>
      <OldPtr>263540</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>287520</PointerOffset>
