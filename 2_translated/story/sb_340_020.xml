ぱっとしません！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>29</Id>
      <BubbleId>1</BubbleId>
      <OldPtr>264008</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>287812</PointerOffset>
