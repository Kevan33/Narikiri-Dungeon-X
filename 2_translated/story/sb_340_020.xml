      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>32</Id>
      <OldPtr>264288</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>288084</PointerOffset>
