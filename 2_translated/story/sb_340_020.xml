      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>6</Id>
      <OldPtr>261340</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>286124</PointerOffset>
      <JapaneseText>挑戦者は&lt;Mel&gt;！
