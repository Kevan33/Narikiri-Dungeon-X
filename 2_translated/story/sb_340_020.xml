      <SpeakerId>6</SpeakerId>
      <Id>22</Id>
      <OldPtr>263212</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>287256</PointerOffset>
      <JapaneseText>さぁ、その時のようには
