      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>3</Id>
      <BubbleId>1</BubbleId>
      <OldPtr>261060</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>285880</PointerOffset>
      <JapaneseText>子どもだってなめてたら、
