      <EnglishText/>
      <Notes/>
      <SpeakerId>7</SpeakerId>
      <Id>26</Id>
      <OldPtr>263680</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>287632</PointerOffset>
      <JapaneseText>初々しい！　多くは
