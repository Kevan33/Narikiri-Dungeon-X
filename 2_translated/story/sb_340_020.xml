      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>36</Id>
      <OldPtr>264756</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>288436</PointerOffset>
      <JapaneseText>挑戦者は&lt;Claus&gt;・Ｆ・
レスター！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>37</Id>
      <BubbleId>0</BubbleId>
      <OldPtr>264944</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>288436</PointerOffset>
      <JapaneseText>偉大な研究者として、そして
変人として後世にずいぶん、
名前を残していらっしゃいます</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>37</Id>
      <BubbleId>1</BubbleId>
      <OldPtr>264944</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>288436</PointerOffset>
      <JapaneseText>その戦いぶりはいかばかりか！？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>37</Id>
      <BubbleId>2</BubbleId>
      <OldPtr>264944</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>288500</PointerOffset>
