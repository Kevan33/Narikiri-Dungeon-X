      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>3</Id>
      <BubbleId>0</BubbleId>
      <OldPtr>261060</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>285804</PointerOffset>
      <JapaneseText>ってまだ子どもじゃないか……</JapaneseText>
