どこまで通用するか！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>14</Id>
      <OldPtr>262276</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>286724</PointerOffset>
