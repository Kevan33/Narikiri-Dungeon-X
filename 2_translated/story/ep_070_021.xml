    <Section>Main</Section>
    <Entry>
      <PointerOffset>276284</PointerOffset>
      <VoiceId>&lt;audio:VSM_070_020_008&gt;</VoiceId>
      <JapaneseText>あ、こいつ……！</JapaneseText>
      <EnglishText>Hey! You...!</EnglishText>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>1</Id>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset>276352</PointerOffset>
      <VoiceId>&lt;audio:VSM_070_020_009&gt;</VoiceId>
      <JapaneseText>たす、たすけ……</JapaneseText>
      <EnglishText>H-Help...</EnglishText>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>2</Id>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset>276432</PointerOffset>
      <VoiceId>&lt;audio:VSM_070_020_010&gt;</VoiceId>
      <JapaneseText>くっ……
……あいつら～！</JapaneseText>
      <EnglishText>Ugh! That little bastard!</EnglishText>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>3</Id>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset>276528</PointerOffset>
      <VoiceId>&lt;audio:VSM_070_020_011&gt;</VoiceId>
      <JapaneseText>ふたりとも、
もう少し冷静になった方がいい</JapaneseText>
      <EnglishText>Guys, it's better to keep your heads cool.</EnglishText>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>4</Id>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset>276632</PointerOffset>
      <VoiceId>&lt;audio:VSM_070_020_012&gt;</VoiceId>
      <JapaneseText>だって……
エトにもしものことが
あったら、わたし……</JapaneseText>
      <EnglishText>But...if something happens to Eto...I...</EnglishText>
      <Notes/>
      <SpeakerId>4</SpeakerId>
      <Id>5</Id>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset>276700</PointerOffset>
      <VoiceId>&lt;audio:VSM_070_020_013&gt;</VoiceId>
      <JapaneseText>行こう、早く！</JapaneseText>
      <EnglishText>Let's hurry on!</EnglishText>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>6</Id>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset>276864</PointerOffset>
      <VoiceId>&lt;audio:VSM_070_020_014&gt;</VoiceId>
      <JapaneseText>落ち着きなさいってば</JapaneseText>
      <EnglishText>Calm down.</EnglishText>
      <Notes/>
      <SpeakerId>5</SpeakerId>
      <Id>7</Id>
      <BubbleId>0</BubbleId>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset>276864</PointerOffset>
      <VoiceId>&lt;audio:VSM_070_020_015&gt;</VoiceId>
      <JapaneseText>私たちじゃ、あの子みたいに
君たちの心の支えに
なんないかもしんないけどさ</JapaneseText>
      <EnglishText>You can't let your feelings
overcome you like that.</EnglishText>
      <Notes/>
      <SpeakerId>5</SpeakerId>
      <Id>7</Id>
      <BubbleId>1</BubbleId>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset>276940</PointerOffset>
      <VoiceId>&lt;audio:VSM_070_020_016&gt;</VoiceId>
      <JapaneseText>そんなのと違くて……！</JapaneseText>
      <EnglishText>It's not like that...</EnglishText>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>9</Id>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset>277008</PointerOffset>
      <VoiceId>&lt;audio:VSM_070_020_017&gt;</VoiceId>
      <JapaneseText>わ～かってるって</JapaneseText>
      <EnglishText>I know, I know!</EnglishText>
      <Notes/>
      <SpeakerId>5</SpeakerId>
      <Id>10</Id>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset>277112</PointerOffset>
      <VoiceId>&lt;audio:VSM_070_020_018&gt;</VoiceId>
      <JapaneseText>&lt;Dio&gt;は
がんばってんだね。
&lt;Mel&gt;とあの子のために</JapaneseText>
      <EnglishText>&lt;Dio&gt;, you're trying your best to
support your sister, aren'tcha?</EnglishText>
      <Notes/>
      <SpeakerId>5</SpeakerId>
      <Id>11</Id>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset>277172</PointerOffset>
      <VoiceId>&lt;audio:VSM_070_020_019&gt;</VoiceId>
      <JapaneseText>え……？</JapaneseText>
      <EnglishText>What...?</EnglishText>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>12</Id>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset>277264</PointerOffset>
      <VoiceId>&lt;audio:VSM_070_020_020&gt;</VoiceId>
      <JapaneseText>だからって
ムチャすんのは
違うんだよ？</JapaneseText>
      <EnglishText>But don't you think acting
like that is a little too rash?</EnglishText>
      <Notes/>
      <SpeakerId>5</SpeakerId>
      <Id>13</Id>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset>277324</PointerOffset>
      <VoiceId>&lt;audio:VSM_070_020_021&gt;</VoiceId>
      <JapaneseText>…………</JapaneseText>
      <EnglishText>...</EnglishText>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>14</Id>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset>277440</PointerOffset>
      <VoiceId>&lt;audio:VSM_070_020_022&gt;</VoiceId>
      <JapaneseText>君たちが取り乱せば、
ノームを刺激してしまう。
落ち着いた方がいい</JapaneseText>
      <EnglishText>While you were distracted, Gnome retreated
further into the cave. Please, calm down.</EnglishText>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>15</Id>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset>277504</PointerOffset>
      <VoiceId>&lt;audio:VSM_070_020_023&gt;</VoiceId>
      <JapaneseText>……わかった</JapaneseText>
      <EnglishText>Got it...</EnglishText>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>16</Id>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset>277564</PointerOffset>
      <VoiceId>&lt;audio:VSM_070_020_024&gt;</VoiceId>
      <JapaneseText>はい……</JapaneseText>
      <EnglishText>Ok...</EnglishText>
      <Notes/>
      <SpeakerId>4</SpeakerId>
      <Id>17</Id>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset>277640</PointerOffset>
      <VoiceId>&lt;audio:VSM_070_020_025&gt;</VoiceId>
      <JapaneseText>んぉし。じゃ、行こ～ぜ</JapaneseText>
      <EnglishText>All righty then, let's go!</EnglishText>
      <Notes/>
      <SpeakerId>5</SpeakerId>
      <Id>18</Id>
      <Status>Proofreading</Status>
    </Entry>
