    <Entry>
      <PointerOffset>270816</PointerOffset>
      <VoiceId>&lt;audio:VSM_290_030_010&gt;</VoiceId>
      <JapaneseText>いえ……お父様は
喜んでくれるかしら？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>9</Id>
      <BubbleId>1</BubbleId>
      <Status>To Do</Status>
    </Entry>
