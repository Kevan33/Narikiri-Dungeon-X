    <Entry>
      <PointerOffset>270520</PointerOffset>
      <VoiceId>&lt;audio:VSM_290_030_005&gt;</VoiceId>
      <JapaneseText>名誉、というものかしらでも、そんなもの
特別欲しいと
思ったわけじゃない</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>4</Id>
      <BubbleId>1</BubbleId>
      <Status>To Do</Status>
