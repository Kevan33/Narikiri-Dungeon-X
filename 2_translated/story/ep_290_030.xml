    <Entry>
      <PointerOffset>270644</PointerOffset>
      <VoiceId>&lt;audio:VSM_290_030_007&gt;</VoiceId>
      <JapaneseText>……私が欲しかったのは…………誰かの喜ぶ顔……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>6</Id>
      <BubbleId>1</BubbleId>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>270704</PointerOffset>
      <VoiceId>&lt;audio:VSM_290_030_008&gt;</VoiceId>
      <JapaneseText>え……？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>8</Id>
      <Status>To Do</Status>
    </Entry>
