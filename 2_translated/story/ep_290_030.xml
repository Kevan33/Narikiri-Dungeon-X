    <Entry>
      <PointerOffset>270372</PointerOffset>
      <VoiceId>&lt;audio:VSM_290_030_003&gt;</VoiceId>
      <JapaneseText>おめでとうございます！
測定値は想定の1.18倍です！この偉大な発明は
博士の名前を歴史上に
刻むことでしょう</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>2</Id>
      <BubbleId>1</BubbleId>
      <Status>To Do</Status>
    </Entry>
