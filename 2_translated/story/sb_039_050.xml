    </Entry>
    <Entry>
      <PointerOffset>303488</PointerOffset>
      <JapaneseText>魚に…………えーいっ！！
とにかく使えっ！包丁、逆から読んで
ちょーほー！
……調法するのよ！では、サラバっ！！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>29</Id>
      <BubbleId>3</BubbleId>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>303536</PointerOffset>
      <JapaneseText>……疲れた……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>33</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>303608</PointerOffset>
      <JapaneseText>でも、いいもの
いただいちゃったね♪</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>34</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>303680</PointerOffset>
      <JapaneseText>ああ……
ありがたく
使わせてもらおうぜ</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>35</Id>
      <Status>To Do</Status>
