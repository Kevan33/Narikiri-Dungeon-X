  <Strings>
    <Section>Main</Section>
    <Entry>
      <PointerOffset>270468</PointerOffset>
      <JapaneseText>お、ＣＰを手に入れてるだな。
もうわかってるかもしんねーが、
改めて説明するだでよ</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>1</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>270544</PointerOffset>
      <JapaneseText>戦闘をするとＣＰというのが
もらえるだ</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>2</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>270648</PointerOffset>
      <JapaneseText>このＣＰちゅーのは、
その時に着ていた
コスチュームごとに溜まるだ</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>3</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>270740</PointerOffset>
      <JapaneseText>つまり、ＣＰは
コスチュームの熟練度とも
言えるだーよ</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>4</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>270828</PointerOffset>
      <JapaneseText>ＣＰが溜まっていくと、
段階的にランクアップするだ</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>5</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>270936</PointerOffset>
      <JapaneseText>ランクアップごとに、
おめえらはスキルや術技を
覚えることができるだよ</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>6</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>270348</PointerOffset>
      <VoiceId>&lt;audio:VSM_030_045_012&gt;</VoiceId>
      <JapaneseText>ほ～れ、おめぇらみたいな
ぼんくらでも簡単にできるだべ。
と、まぁ、こんなところだーよ</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>7</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>271124</PointerOffset>
      <JapaneseText>ああ、それと移動中にマップが見えると
思うんだけんども</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>8</Id>
      <BubbleId>0</BubbleId>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>271124</PointerOffset>
      <JapaneseText>その表示は　&lt;L&gt;　で
大きさを変えることができるだ</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>8</Id>
      <BubbleId>1</BubbleId>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>271124</PointerOffset>
      <JapaneseText>どだ！おらの耳寄り情報に
た～んと感謝せぇよ</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>8</Id>
      <BubbleId>2</BubbleId>
      <Status>To Do</Status>
    </Entry>
  </Strings>
