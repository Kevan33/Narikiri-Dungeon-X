    <Entry>
      <PointerOffset>295088</PointerOffset>
      <VoiceId>&lt;audio:VSS_039_040_000&gt;</VoiceId>
      <JapaneseText>相変わらずここ、
暑いよな……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>1</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>295180</PointerOffset>
      <VoiceId>&lt;audio:VSS_039_040_001&gt;</VoiceId>
      <JapaneseText>どこか影に
入って涼んだ方が
いいかも……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>2</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>295244</PointerOffset>
      <VoiceId>&lt;audio:VSS_039_040_002&gt;</VoiceId>
      <JapaneseText>きゃっ！！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>3</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>295336</PointerOffset>
      <VoiceId>&lt;audio:VSS_039_040_003&gt;</VoiceId>
      <JapaneseText>私を呼んでくれて
サンキュー！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>4</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>295408</PointerOffset>
      <VoiceId>&lt;audio:VSS_039_040_004&gt;</VoiceId>
      <JapaneseText>呼んでねーって……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>5</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>295480</PointerOffset>
      <VoiceId>&lt;audio:VSS_039_040_005&gt;</VoiceId>
      <JapaneseText>この人……えっと……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>6</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>295736</PointerOffset>
      <VoiceId>&lt;audio:VSS_039_040_006&gt;</VoiceId>
      <JapaneseText>ワンダーシェフ、
ここに参上！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>7</Id>
      <BubbleId>0</BubbleId>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>295736</PointerOffset>
      <VoiceId>&lt;audio:VSS_039_040_007&gt;</VoiceId>
      <JapaneseText>暑くてとんがりぎみの
こーんな君の気持ち、
直すわよ、すぐにも今にも！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>7</Id>
      <BubbleId>1</BubbleId>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>295736</PointerOffset>
      <VoiceId>&lt;audio:VSS_039_040_008&gt;</VoiceId>
      <JapaneseText>血も心も暑くたぎるあなたに
今日紹介するのは
こちらの商品！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>7</Id>
      <BubbleId>2</BubbleId>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>295848</PointerOffset>
      <VoiceId>&lt;audio:VSS_039_040_009&gt;</VoiceId>
      <JapaneseText>もしかして、冷たい、
アイスクリームとか
シャーベットとか！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>10</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>296008</PointerOffset>
      <VoiceId>&lt;audio:VSS_039_040_010&gt;</VoiceId>
      <JapaneseText>残念、惜しい！
今日持ってきたのは
こくがあってまろやかな……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>11</Id>
      <BubbleId>0</BubbleId>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>296008</PointerOffset>
      <VoiceId>&lt;audio:VSS_039_040_011&gt;</VoiceId>
      <JapaneseText>マーボーカレーよ！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>11</Id>
      <BubbleId>1</BubbleId>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>296076</PointerOffset>
      <VoiceId>&lt;audio:VSS_039_040_012&gt;</VoiceId>
      <JapaneseText>惜しくねーし……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>13</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>296276</PointerOffset>
      <VoiceId>&lt;audio:VSS_039_040_013&gt;</VoiceId>
      <JapaneseText>暑い時こそ辛いもの！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>14</Id>
      <BubbleId>0</BubbleId>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>296276</PointerOffset>
      <VoiceId>&lt;audio:VSS_039_040_014&gt;</VoiceId>
      <JapaneseText>辛いもの食べて元気になって
このホットな陽気を
乗り切れ、若人！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>14</Id>
      <BubbleId>1</BubbleId>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>296276</PointerOffset>
      <VoiceId>&lt;audio:VSS_039_040_015&gt;</VoiceId>
      <JapaneseText>……どうかしら？？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>14</Id>
      <BubbleId>2</BubbleId>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>296344</PointerOffset>
      <VoiceId>&lt;audio:VSS_039_040_016&gt;</VoiceId>
      <JapaneseText>……えええ……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>17</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>296464</PointerOffset>
      <VoiceId>&lt;audio:VSS_039_040_017&gt;</VoiceId>
      <JapaneseText>ふん、いいわよ、
後で、く、くれーって言っても
あげないから！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>18</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>296592</PointerOffset>
      <VoiceId>&lt;audio:VSS_039_040_018&gt;</VoiceId>
      <JapaneseText>わ、わかったよ、
食えばいいんだろ</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>19</Id>
      <BubbleId>0</BubbleId>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>296592</PointerOffset>
      <VoiceId>&lt;audio:VSS_039_040_019&gt;</VoiceId>
      <JapaneseText>んぐ、もぐもぐもぐ……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>19</Id>
      <BubbleId>1</BubbleId>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>296656</PointerOffset>
      <VoiceId>&lt;audio:VSS_039_040_020&gt;</VoiceId>
      <JapaneseText>どう……？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>21</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>296880</PointerOffset>
      <VoiceId>&lt;audio:VSS_039_040_021&gt;</VoiceId>
      <JapaneseText>う……うめぇ！！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>22</Id>
      <BubbleId>0</BubbleId>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>296880</PointerOffset>
      <VoiceId>&lt;audio:VSS_039_040_022&gt;</VoiceId>
      <JapaneseText>……カレーの辛さに、
マーボーのまろやかな
甘さがからんでて</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>22</Id>
      <BubbleId>1</BubbleId>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>296880</PointerOffset>
      <VoiceId>&lt;audio:VSS_039_040_023&gt;</VoiceId>
      <JapaneseText>なんてか、
『おいしさとやすらぎを』
感じる味だな、これは！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>22</Id>
      <BubbleId>2</BubbleId>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>296980</PointerOffset>
      <VoiceId>&lt;audio:VSS_039_040_024&gt;</VoiceId>
      <JapaneseText>おいしさとやすらぎを？
わたしも……食べていい？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>25</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>297044</PointerOffset>
      <VoiceId>&lt;audio:VSS_039_040_025&gt;</VoiceId>
      <JapaneseText>ああ、ほら</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>26</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>297148</PointerOffset>
      <VoiceId>&lt;audio:VSS_039_040_026&gt;</VoiceId>
      <JapaneseText>んん……
もぐもぐもぐもぐ……
もぐもぐもぐもぐ……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>27</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>297276</PointerOffset>
      <VoiceId>&lt;audio:VSS_039_040_027&gt;</VoiceId>
      <JapaneseText>おいしさとやすらぎを
運ぶ、ワンダーシェフ、
次はあなたのおたくに！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>28</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>297376</PointerOffset>
      <VoiceId>&lt;audio:VSS_039_040_028&gt;</VoiceId>
      <JapaneseText>……んぐっ……
おたくって……
エトスハウスに！？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>29</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>297468</PointerOffset>
      <VoiceId>&lt;audio:VSS_039_040_029&gt;</VoiceId>
      <JapaneseText>そう、ハウスに！
さらばっ！！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>30</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>297556</PointerOffset>
      <VoiceId>&lt;audio:VSS_039_040_030&gt;</VoiceId>
      <JapaneseText>……エトスハウスまで
来られてもなぁ</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>31</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>297700</PointerOffset>
      <VoiceId>&lt;audio:VSS_039_040_031&gt;</VoiceId>
      <JapaneseText>ちょっと大変かも……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>32</Id>
      <BubbleId>0</BubbleId>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>297700</PointerOffset>
      <VoiceId>&lt;audio:VSS_039_040_032&gt;</VoiceId>
      <JapaneseText>それにしても……
あの人、一体、
何者なんだろ……？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>32</Id>
      <BubbleId>1</BubbleId>
      <Status>To Do</Status>
    </Entry>
