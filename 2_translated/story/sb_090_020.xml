    </Entry>
    <Entry>
      <PointerOffset>269660</PointerOffset>
      <JapaneseText>じ、じゃあもう少し</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
