      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>269608</PointerOffset>
      <JapaneseText>そうじゃないとまだまだ
ソースとして弱い。弱すぎる</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>10</Id>
