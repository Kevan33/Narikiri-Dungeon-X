    <Entry>
      <PointerOffset>280032</PointerOffset>
      <VoiceId>&lt;audio:VSM_320_050_003&gt;</VoiceId>
      <JapaneseText>オレたちは……大樹カーラーンを
枯らしてしまったおまえはオレだ。
つまり、おまえたちも同罪だ！自分たちだけが
いい子になれるなんて思うなよ！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>1</Id>
      <BubbleId>2</BubbleId>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>280136</PointerOffset>
      <VoiceId>&lt;audio:VSM_320_050_004&gt;</VoiceId>
      <JapaneseText>わかってる……
だから、おまえらに
会いに来たんだろ</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>4</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>280236</PointerOffset>
      <VoiceId>&lt;audio:VSM_320_050_005&gt;</VoiceId>
      <JapaneseText>おまえたちの手で、
オレたちを断罪するつもりか</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>5</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>280336</PointerOffset>
      <VoiceId>&lt;audio:VSM_320_050_006&gt;</VoiceId>
      <JapaneseText>できるはずがない。
わたしたちはあなたたち</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>6</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>280496</PointerOffset>
      <VoiceId>&lt;audio:VSM_320_050_007&gt;</VoiceId>
      <JapaneseText></JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>7</Id>
      <BubbleId>0</BubbleId>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>280496</PointerOffset>
      <VoiceId>&lt;audio:VSM_320_050_008&gt;</VoiceId>
      <JapaneseText>そうだよ、おまえらは
オレらだだから、自分たちで決める。
何が悪くて、何がそうじゃないのか</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>7</Id>
      <BubbleId>1</BubbleId>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>280748</PointerOffset>
      <VoiceId>&lt;audio:VSM_320_050_009&gt;</VoiceId>
      <JapaneseText></JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>4</SpeakerId>
      <Id>9</Id>
      <BubbleId>0</BubbleId>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>280748</PointerOffset>
      <VoiceId>&lt;audio:VSM_320_050_010&gt;</VoiceId>
      <JapaneseText></JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>4</SpeakerId>
      <Id>9</Id>
      <BubbleId>1</BubbleId>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>280748</PointerOffset>
      <VoiceId>&lt;audio:VSM_320_050_011&gt;</VoiceId>
      <JapaneseText>ちゃんと自分の心に
素直に向き合う不安も恐怖も、
憎しみも悲しみも……
すべての感情に意味があるだからたとえ、不安でも
怖くても、わたしの
本当のところと向き合うよ</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>4</SpeakerId>
      <Id>9</Id>
      <BubbleId>2</BubbleId>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>280856</PointerOffset>
      <VoiceId>&lt;audio:VSM_320_050_012&gt;</VoiceId>
      <JapaneseText>大した不安も恐怖も
味わったことないヤツが、
粋がるなよ</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>12</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>280980</PointerOffset>
      <VoiceId>&lt;audio:VSM_320_050_013&gt;</VoiceId>
      <JapaneseText>わたしたちが味わった
過酷な状況など、まるで
知りもしない温室育ちが</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>13</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>281168</PointerOffset>
      <VoiceId>&lt;audio:VSM_320_050_014&gt;</VoiceId>
      <JapaneseText></JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>14</Id>
      <BubbleId>0</BubbleId>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>281168</PointerOffset>
      <VoiceId>&lt;audio:VSM_320_050_015&gt;</VoiceId>
      <JapaneseText></JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>14</Id>
      <BubbleId>1</BubbleId>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>281168</PointerOffset>
      <VoiceId>&lt;audio:VSM_320_050_016&gt;</VoiceId>
      <JapaneseText>ああ、知らねーよだから、オレらは
こうして来たんだおまえらの……
いや自分の憎しみの心を
知るために</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>14</Id>
      <BubbleId>2</BubbleId>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>281276</PointerOffset>
      <VoiceId>&lt;audio:VSM_320_050_017&gt;</VoiceId>
      <JapaneseText>あなたたちと対面することで、
自分自身と向き合うために</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>4</SpeakerId>
      <Id>17</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>281376</PointerOffset>
      <VoiceId>&lt;audio:VSM_320_050_018&gt;</VoiceId>
      <JapaneseText>だったら、来い。
オレたちはもう
すぐそこにいる</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>18</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>281436</PointerOffset>
      <VoiceId>&lt;audio:VSM_320_050_019&gt;</VoiceId>
      <JapaneseText>行こうぜ</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>19</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>281496</PointerOffset>
      <VoiceId>&lt;audio:VSM_320_050_020&gt;</VoiceId>
      <JapaneseText>うん……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>4</SpeakerId>
      <Id>20</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>281560</PointerOffset>
      <VoiceId>&lt;audio:VSM_320_050_021&gt;</VoiceId>
      <JapaneseText>コワいか？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>21</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>281640</PointerOffset>
      <VoiceId>&lt;audio:VSM_320_050_022&gt;</VoiceId>
      <JapaneseText>&lt;Dio&gt;こそ、
声震えてるよ</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>4</SpeakerId>
      <Id>22</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>281732</PointerOffset>
      <VoiceId>&lt;audio:VSM_320_050_023&gt;</VoiceId>
      <JapaneseText>しょーがねーだろ。
……コワいんだから</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>23</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>281816</PointerOffset>
      <VoiceId>&lt;audio:VSM_320_050_024&gt;</VoiceId>
      <JapaneseText>&lt;Dio&gt;なのに、
正直すぎて変なの</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>4</SpeakerId>
      <Id>24</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>281880</PointerOffset>
      <VoiceId>&lt;audio:VSM_320_050_025&gt;</VoiceId>
      <JapaneseText>うっせぇ……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>25</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>281956</PointerOffset>
      <VoiceId>&lt;audio:VSM_320_050_026&gt;</VoiceId>
      <JapaneseText>……エト、怒んないかな</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>4</SpeakerId>
      <Id>26</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>282076</PointerOffset>
      <VoiceId>&lt;audio:VSM_320_050_027&gt;</VoiceId>
      <JapaneseText></JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>27</Id>
      <BubbleId>0</BubbleId>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>282076</PointerOffset>
      <VoiceId>&lt;audio:VSM_320_050_028&gt;</VoiceId>
      <JapaneseText>怒るかもなでも、オレらは……
決めたんだから……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>27</Id>
      <BubbleId>1</BubbleId>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>282148</PointerOffset>
      <VoiceId>&lt;audio:VSM_320_050_029&gt;</VoiceId>
      <JapaneseText>うん、行こう……！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>4</SpeakerId>
      <Id>29</Id>
      <Status>To Do</Status>
    </Entry>
