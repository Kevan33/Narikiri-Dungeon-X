    </Entry>
    <Entry>
      <PointerOffset>293700</PointerOffset>
      <JapaneseText>無念……私の負けだふっ……傷つき倒れるのは
私のほうだったか</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>13</Id>
      <BubbleId>1</BubbleId>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>293860</PointerOffset>
      <JapaneseText>フラムベルク！
オレらに力を貸してくれ！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
