    <Entry>
      <PointerOffset>275656</PointerOffset>
      <JapaneseText>本当にありがとう！
おかげでお店も大助かり！
店長も喜んでたわ</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>1</Id>
      <OldPtr>261148</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>275728</PointerOffset>
      <JapaneseText>次はあたし、
やってみよっかなぁ……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>2</Id>
      <OldPtr>261404</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>275784</PointerOffset>
      <JapaneseText>どうしたんだよ、急に</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>3</Id>
      <OldPtr>262156</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>275856</PointerOffset>
      <JapaneseText>だってさ、なんか、
面白そうなんだもん</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>4</Id>
      <OldPtr>262388</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>275984</PointerOffset>
      <JapaneseText>面白そうって……あのなぁ……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>5</Id>
      <BubbleId>0</BubbleId>
      <OldPtr>262528</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>275984</PointerOffset>
      <JapaneseText>ウェイトレスはお店の華だぞ？
わかってのか？
欠かせない要素だぞ？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>5</Id>
      <BubbleId>1</BubbleId>
      <OldPtr>262528</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>276060</PointerOffset>
      <JapaneseText>何よっ！
あたしじゃ役者不足だっての！？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>7</Id>
      <OldPtr>263016</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>276116</PointerOffset>
      <JapaneseText>わかってるじゃないか</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>8</Id>
      <OldPtr>263156</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>276196</PointerOffset>
      <JapaneseText>なにさ！
&lt;Chester&gt;のおたんこなす！
……ふんだ！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>9</Id>
      <OldPtr>263400</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>276248</PointerOffset>
      <JapaneseText>あ、え、えっと……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>4</SpeakerId>
      <Id>10</Id>
      <OldPtr>263660</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>276324</PointerOffset>
      <JapaneseText>いいから、いいから。
いつものことだって</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>5</SpeakerId>
      <Id>11</Id>
      <OldPtr>263900</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>276412</PointerOffset>
      <JapaneseText>……でも、&lt;Mel&gt;ちゃん、
本当に生き生きと
働いてたよね</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>5</SpeakerId>
      <Id>12</Id>
      <OldPtr>264148</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>276672</PointerOffset>
      <JapaneseText>なりきり士廃業したら
いつでも来いって、店長が
スカウトしたがってたわ</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>13</Id>
      <OldPtr>264824</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>276732</PointerOffset>
      <JapaneseText>あ、あはは……
ど、どうも</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>4</SpeakerId>
      <Id>14</Id>
      <OldPtr>265464</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>276844</PointerOffset>
      <JapaneseText>でもこれで終わりじゃないからね！
またいつでも来てね！
待ってるよ！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>15</Id>
      <OldPtr>265604</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>276884</PointerOffset>
      <JapaneseText>はい！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>4</SpeakerId>
      <Id>16</Id>
      <OldPtr>265744</OldPtr>
      <Status>To Do</Status>
    </Entry>
