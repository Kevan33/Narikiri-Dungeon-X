    <Entry>
      <PointerOffset>292344</PointerOffset>
      <VoiceId>&lt;audio:VSM_060_030_002&gt;</VoiceId>
      <JapaneseText>シルフ！　だ！私のことを覚えているなら、
姿を現してほしい！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>1</Id>
      <BubbleId>1</BubbleId>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>292452</PointerOffset>
      <VoiceId>&lt;audio:VSM_060_030_003&gt;</VoiceId>
      <JapaneseText>&lt;Claus&gt;覚えています、。
ダオス戦役の折、
ともに戦った勇士</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>3</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>292556</PointerOffset>
      <VoiceId>&lt;audio:VSM_060_030_004&gt;</VoiceId>
      <JapaneseText>光栄だ。過去のよしみで
頼みを聞いてもらいたいのだが</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>4</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>292648</PointerOffset>
      <VoiceId>&lt;audio:VSM_060_030_005&gt;</VoiceId>
      <JapaneseText>まずは
話を聞きましょう。
何でしょうか？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>5</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>292752</PointerOffset>
      <VoiceId>&lt;audio:VSM_060_030_006&gt;</VoiceId>
      <JapaneseText>我々におまえの精霊晶核を
分けてもらえないだろうか</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>6</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>292876</PointerOffset>
      <VoiceId>&lt;audio:VSM_060_030_007&gt;</VoiceId>
      <JapaneseText></JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>7</Id>
      <BubbleId>0</BubbleId>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>292876</PointerOffset>
      <VoiceId>&lt;audio:VSM_060_030_008&gt;</VoiceId>
      <JapaneseText>精霊晶核を……わかりました。
チャンスを与えましょう</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>7</Id>
      <BubbleId>1</BubbleId>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>292988</PointerOffset>
      <VoiceId>&lt;audio:VSM_060_030_009&gt;</VoiceId>
      <JapaneseText></JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>9</Id>
      <BubbleId>0</BubbleId>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>292988</PointerOffset>
      <VoiceId>&lt;audio:VSM_060_030_010&gt;</VoiceId>
      <JapaneseText>チャンス？やっぱタダじゃもらえねーの？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>9</Id>
      <BubbleId>1</BubbleId>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>293200</PointerOffset>
      <VoiceId>&lt;audio:VSM_060_030_011&gt;</VoiceId>
      <JapaneseText></JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>11</Id>
      <BubbleId>0</BubbleId>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>293200</PointerOffset>
      <VoiceId>&lt;audio:VSM_060_030_012&gt;</VoiceId>
      <JapaneseText>精霊晶核は、私たち自身の分身、
あるいは卵とも言える
大切なものです私たちの風に翻弄されず、
打ち勝つことができれば、
精霊晶核を与えましょう</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>11</Id>
      <BubbleId>1</BubbleId>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>293280</PointerOffset>
      <VoiceId>&lt;audio:VSM_060_030_013&gt;</VoiceId>
      <JapaneseText>やっぱり、
また戦うんだ……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>4</SpeakerId>
      <Id>13</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>293352</PointerOffset>
      <VoiceId>&lt;audio:VSM_060_030_014&gt;</VoiceId>
      <JapaneseText>よし！　やってやる！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>14</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>293492</PointerOffset>
      <VoiceId>&lt;audio:VSM_060_030_016&gt;</VoiceId>
      <JapaneseText>来なさい</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>15</Id>
      <Status>To Do</Status>
    </Entry>
