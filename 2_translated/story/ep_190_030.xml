    <Entry>
      <PointerOffset>302628</PointerOffset>
      <VoiceId>&lt;audio:VSM_190_030_001&gt;</VoiceId>
      <JapaneseText>申し遅れました。わたし、
この里の忍びたちを率いる
頭領、藤林&lt;Suzu&gt;と申します</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>1</Id>
      <BubbleId>0</BubbleId>
      <OldPtr>278136</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>302628</PointerOffset>
      <VoiceId>&lt;audio:VSM_190_030_002&gt;</VoiceId>
      <JapaneseText>おふたりのことは、
&lt;Rody&gt;さんから聞きました</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>1</Id>
      <BubbleId>1</BubbleId>
      <OldPtr>278136</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>302704</PointerOffset>
      <VoiceId>&lt;audio:VSM_190_030_003&gt;</VoiceId>
      <JapaneseText>忍び？　この里って……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>3</Id>
      <OldPtr>278716</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>302800</PointerOffset>
      <VoiceId>&lt;audio:VSM_190_030_004&gt;</VoiceId>
      <JapaneseText>&lt;Suzu&gt;って……
もしかして、時空戦士の……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>4</Id>
      <OldPtr>278912</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>302884</PointerOffset>
      <VoiceId>&lt;audio:VSM_190_030_005&gt;</VoiceId>
      <JapaneseText>え……率いるって、
その歳で……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>5</Id>
      <OldPtr>279688</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>302972</PointerOffset>
      <VoiceId>&lt;audio:VSM_190_030_006&gt;</VoiceId>
      <JapaneseText>ほらほら、
いっきに色々質問しない</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>4</SpeakerId>
      <Id>6</Id>
      <OldPtr>279884</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>303060</PointerOffset>
      <VoiceId>&lt;audio:VSM_190_030_007&gt;</VoiceId>
      <JapaneseText>&lt;Rody&gt;さんは
なんでここにいるの？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>7</Id>
      <OldPtr>280340</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>303156</PointerOffset>
      <VoiceId>&lt;audio:VSM_190_030_008&gt;</VoiceId>
      <JapaneseText>待てよ……オレら、
元の時代に戻れてなくね？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>8</Id>
      <OldPtr>280868</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>303256</PointerOffset>
      <VoiceId>&lt;audio:VSM_190_030_009&gt;</VoiceId>
      <JapaneseText>はい、落ち着いて！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>4</SpeakerId>
      <Id>9</Id>
      <BubbleId>0</BubbleId>
      <OldPtr>281404</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>303256</PointerOffset>
      <VoiceId>&lt;audio:VSM_190_030_010&gt;</VoiceId>
      <JapaneseText>深呼吸～！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>4</SpeakerId>
      <Id>9</Id>
      <BubbleId>1</BubbleId>
      <OldPtr>281404</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>303388</PointerOffset>
      <VoiceId>&lt;audio:VSM_190_030_011&gt;</VoiceId>
      <JapaneseText>はい……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>4</SpeakerId>
      <Id>11</Id>
      <BubbleId>0</BubbleId>
      <OldPtr>282280</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>303388</PointerOffset>
      <VoiceId>&lt;audio:VSM_190_030_012&gt;</VoiceId>
      <JapaneseText>&lt;Suzu&gt;ちゃん、もう一度、
事情を話してあげてちょうだい</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>4</SpeakerId>
      <Id>11</Id>
      <BubbleId>1</BubbleId>
      <OldPtr>282280</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>303604</PointerOffset>
      <VoiceId>&lt;audio:VSM_190_030_013&gt;</VoiceId>
      <JapaneseText>あ、はい……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>5</SpeakerId>
      <Id>13</Id>
      <BubbleId>0</BubbleId>
      <OldPtr>282800</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>303604</PointerOffset>
      <VoiceId>&lt;audio:VSM_190_030_014&gt;</VoiceId>
      <JapaneseText>実は最近、
魔界の王プルートが
この世界に侵攻してきたのです</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>5</SpeakerId>
      <Id>13</Id>
      <BubbleId>1</BubbleId>
      <OldPtr>282800</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>303604</PointerOffset>
      <VoiceId>&lt;audio:VSM_190_030_015&gt;</VoiceId>
      <JapaneseText>そのせいで、地上の半分が、
今、瘴気の中に沈んでいます</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>5</SpeakerId>
      <Id>13</Id>
      <BubbleId>2</BubbleId>
      <OldPtr>282800</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>303696</PointerOffset>
      <VoiceId>&lt;audio:VSM_190_030_016&gt;</VoiceId>
      <JapaneseText>じゃあ、みんな瘴気に
飲まれたのか！？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>16</Id>
      <OldPtr>283304</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>303804</PointerOffset>
      <VoiceId>&lt;audio:VSM_190_030_017&gt;</VoiceId>
      <JapaneseText>避難した方もいますが、
瘴気に飲まれてしまった方も
います</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>5</SpeakerId>
      <Id>17</Id>
      <OldPtr>283500</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>303916</PointerOffset>
      <VoiceId>&lt;audio:VSM_190_030_018&gt;</VoiceId>
      <JapaneseText>それとわたしたちが
捕まったことって
何か関係あるんですか？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>18</Id>
      <OldPtr>283696</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>304104</PointerOffset>
      <VoiceId>&lt;audio:VSM_190_030_019&gt;</VoiceId>
      <JapaneseText>我々はその魔界の軍団と
戦っています</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>5</SpeakerId>
      <Id>19</Id>
      <BubbleId>0</BubbleId>
      <OldPtr>283892</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>304104</PointerOffset>
      <VoiceId>&lt;audio:VSM_190_030_020&gt;</VoiceId>
      <JapaneseText>プルートの居場所がわからず、
その部下から話を聞くため、
生け捕りにしようかと……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>5</SpeakerId>
      <Id>19</Id>
      <BubbleId>1</BubbleId>
      <OldPtr>283892</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>304220</PointerOffset>
      <VoiceId>&lt;audio:VSM_190_030_021&gt;</VoiceId>
      <JapaneseText>え……それってもしかして、
わたしたちを魔族と間違えた、
とか？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>21</Id>
      <OldPtr>284096</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>304348</PointerOffset>
      <VoiceId>&lt;audio:VSM_190_030_022&gt;</VoiceId>
      <JapaneseText>……すみません。
人気のない場所に子どもふたりで
いらしたので怪しく思い……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>5</SpeakerId>
      <Id>22</Id>
      <OldPtr>284236</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>304516</PointerOffset>
      <VoiceId>&lt;audio:VSM_190_030_024&gt;</VoiceId>
      <JapaneseText>本当にすみません……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>5</SpeakerId>
      <Id>23</Id>
      <OldPtr>284544</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>304628</PointerOffset>
      <VoiceId>&lt;audio:VSM_190_030_025&gt;</VoiceId>
      <JapaneseText>頭領、アーリィが
再び闇に閉ざされたとの
報告が……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>6</SpeakerId>
      <Id>24</Id>
      <OldPtr>285272</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>304720</PointerOffset>
      <VoiceId>&lt;audio:VSM_190_030_026&gt;</VoiceId>
      <JapaneseText>ダオスが現れた時と
同じ現象ですね……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>5</SpeakerId>
      <Id>25</Id>
      <OldPtr>285412</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>304840</PointerOffset>
      <VoiceId>&lt;audio:VSM_190_030_027&gt;</VoiceId>
      <JapaneseText>プルートと何か関係がある
かもしれません。
調査に向かいます</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>6</SpeakerId>
      <Id>26</Id>
      <OldPtr>285552</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>304908</PointerOffset>
      <VoiceId>&lt;audio:VSM_190_030_028&gt;</VoiceId>
      <JapaneseText>まかせました……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>5</SpeakerId>
      <Id>27</Id>
      <OldPtr>285692</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>305012</PointerOffset>
      <VoiceId>&lt;audio:VSM_190_030_029&gt;</VoiceId>
      <JapaneseText>エトとも&lt;Couleur&gt;とも
はなればなれに
なっちゃったし……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>28</Id>
      <OldPtr>286456</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>305088</PointerOffset>
      <VoiceId>&lt;audio:VSM_190_030_030&gt;</VoiceId>
      <JapaneseText>&lt;Couleur&gt;？
それって……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>5</SpeakerId>
      <Id>29</Id>
      <OldPtr>286652</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>305152</PointerOffset>
      <VoiceId>&lt;audio:VSM_190_030_031&gt;</VoiceId>
      <JapaneseText>クルール！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>7</SpeakerId>
      <Id>30</Id>
      <OldPtr>287580</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>305232</PointerOffset>
      <VoiceId>&lt;audio:VSM_190_030_032&gt;</VoiceId>
      <JapaneseText>うぉっと……！
おまえ……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>31</Id>
      <OldPtr>288780</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>305308</PointerOffset>
      <VoiceId>&lt;audio:VSM_190_030_033&gt;</VoiceId>
      <JapaneseText>クルール！　クルール！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>7</SpeakerId>
      <Id>32</Id>
      <OldPtr>289132</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>305440</PointerOffset>
      <VoiceId>&lt;audio:VSM_190_030_034&gt;</VoiceId>
      <JapaneseText>おまえ、体があったかい……！
まさか……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>33</Id>
      <BubbleId>0</BubbleId>
      <OldPtr>289620</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>305440</PointerOffset>
      <VoiceId>&lt;audio:VSM_190_030_035&gt;</VoiceId>
      <JapaneseText>……風呂入ってたな！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>33</Id>
      <BubbleId>1</BubbleId>
      <OldPtr>289620</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>305504</PointerOffset>
      <VoiceId>&lt;audio:VSM_190_030_036&gt;</VoiceId>
      <JapaneseText>クルクル♪</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>7</SpeakerId>
      <Id>35</Id>
      <OldPtr>290056</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>305584</PointerOffset>
      <VoiceId>&lt;audio:VSM_190_030_037&gt;</VoiceId>
      <JapaneseText>それじゃあ、
エトも一緒に？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>36</Id>
      <OldPtr>290884</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>305664</PointerOffset>
      <VoiceId>&lt;audio:VSM_190_030_038&gt;</VoiceId>
      <JapaneseText>いえ……
その子の他には誰も</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>5</SpeakerId>
      <Id>37</Id>
      <OldPtr>291416</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>305808</PointerOffset>
      <VoiceId>&lt;audio:VSM_190_030_040&gt;</VoiceId>
      <JapaneseText>どこ行っちゃったんだろう……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>38</Id>
      <OldPtr>291556</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>305952</PointerOffset>
      <VoiceId>&lt;audio:VSM_190_030_041&gt;</VoiceId>
      <JapaneseText>重ね重ねお詫び申し上げます</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>5</SpeakerId>
      <Id>39</Id>
      <BubbleId>0</BubbleId>
      <OldPtr>291876</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>305952</PointerOffset>
      <VoiceId>&lt;audio:VSM_190_030_042&gt;</VoiceId>
      <JapaneseText>我が一族が
お力を貸せれば
よいのでしょうが……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>5</SpeakerId>
      <Id>39</Id>
      <BubbleId>1</BubbleId>
      <OldPtr>291876</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>306100</PointerOffset>
      <VoiceId>&lt;audio:VSM_190_030_043&gt;</VoiceId>
      <JapaneseText>わかってます</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>41</Id>
      <BubbleId>0</BubbleId>
      <OldPtr>292204</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>306100</PointerOffset>
      <VoiceId>&lt;audio:VSM_190_030_044&gt;</VoiceId>
      <JapaneseText>&lt;Suzu&gt;さんの一族は、
魔界の勢力と戦わなきゃ
いけないんですよね</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>41</Id>
      <BubbleId>1</BubbleId>
      <OldPtr>292204</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>306196</PointerOffset>
      <VoiceId>&lt;audio:VSM_190_030_045&gt;</VoiceId>
      <JapaneseText>いえ……
せめて私だけでも
あなたたちの助けに</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>5</SpeakerId>
      <Id>43</Id>
      <OldPtr>292344</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>306300</PointerOffset>
      <VoiceId>&lt;audio:VSM_190_030_046&gt;</VoiceId>
      <JapaneseText>でも、&lt;Suzu&gt;さんは頭領なんですよね？
……いいの？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>44</Id>
      <OldPtr>292484</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>306388</PointerOffset>
      <VoiceId>&lt;audio:VSM_190_030_047&gt;</VoiceId>
      <JapaneseText>失態の責任は
頭領である私が取ります</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>5</SpeakerId>
      <Id>45</Id>
      <OldPtr>292624</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>306524</PointerOffset>
      <VoiceId>&lt;audio:VSM_190_030_048&gt;</VoiceId>
      <JapaneseText>よし、んじゃ、決まり</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>4</SpeakerId>
      <Id>46</Id>
      <BubbleId>0</BubbleId>
      <OldPtr>292764</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>306524</PointerOffset>
      <VoiceId>&lt;audio:VSM_190_030_049&gt;</VoiceId>
      <JapaneseText>エトちゃんを探しに
もう一回、&lt;Red&gt;トール&lt;White&gt;へ行こ</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>4</SpeakerId>
      <Id>46</Id>
      <BubbleId>1</BubbleId>
      <OldPtr>292764</OldPtr>
      <Status>To Do</Status>
    </Entry>
