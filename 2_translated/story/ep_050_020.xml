    <Entry>
      <PointerOffset>268136</PointerOffset>
      <VoiceId>&lt;audio:VSM_050_020_006&gt;</VoiceId>
      <JapaneseText>気になるような
怪しいところがあれば、
まず打って試してみれひょっとすっど、
先に進む大きな助けに
なってくれるかもしんね</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>5</Id>
      <BubbleId>1</BubbleId>
      <Status>To Do</Status>
