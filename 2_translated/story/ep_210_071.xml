    <Entry>
      <PointerOffset>285908</PointerOffset>
      <VoiceId>&lt;audio:VSM_210_070_052&gt;</VoiceId>
      <JapaneseText>んだよ……も
同じこと考えてたのかこの世界が、
まんまオレらの世界の
過去なんだもんなプルートっての、
ほっといたら、世界が
ろくなことんなんねーし</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>4</SpeakerId>
      <Id>23</Id>
      <BubbleId>2</BubbleId>
      <Status>To Do</Status>
