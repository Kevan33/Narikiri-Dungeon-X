    <Entry>
      <PointerOffset>283516</PointerOffset>
      <VoiceId>&lt;audio:VSM_210_070_022&gt;</VoiceId>
      <JapaneseText>領域・荒らす
許さない・
領域・荒らす……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>1</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>283612</PointerOffset>
      <VoiceId>&lt;audio:VSM_210_070_023&gt;</VoiceId>
      <JapaneseText>ゴメンなさい……
エトがお邪魔しちゃって……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>2</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>283752</PointerOffset>
      <VoiceId>&lt;audio:VSM_210_070_024&gt;</VoiceId>
      <JapaneseText></JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>3</Id>
      <BubbleId>0</BubbleId>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>283752</PointerOffset>
      <VoiceId>&lt;audio:VSM_210_070_025&gt;</VoiceId>
      <JapaneseText></JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>3</Id>
      <BubbleId>1</BubbleId>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>283752</PointerOffset>
      <VoiceId>&lt;audio:VSM_210_070_026&gt;</VoiceId>
      <JapaneseText>…………許す・おまえ・許す外・闇・
漏れた・動揺</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>3</Id>
      <BubbleId>2</BubbleId>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>283856</PointerOffset>
      <VoiceId>&lt;audio:VSM_210_070_027&gt;</VoiceId>
      <JapaneseText>外が闇に包まれたのは、
シャドウの動揺が原因だって</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>6</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>284044</PointerOffset>
      <VoiceId>&lt;audio:VSM_210_070_029&gt;</VoiceId>
      <JapaneseText>ダオスの時も確か、
同じ原因でアーリィが
闇に包まれていました</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>7</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>284108</PointerOffset>
      <VoiceId>&lt;audio:VSM_210_070_030&gt;</VoiceId>
      <JapaneseText>我・去る</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>8</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>284336</PointerOffset>
      <VoiceId>&lt;audio:VSM_210_070_033&gt;</VoiceId>
      <JapaneseText>……はぁ……
最後まで何考えてっか
わかんなかったな</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>4</SpeakerId>
      <Id>9</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>284500</PointerOffset>
      <VoiceId>&lt;audio:VSM_210_070_035&gt;</VoiceId>
      <JapaneseText>はレ……？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>5</SpeakerId>
      <Id>10</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>284564</PointerOffset>
      <VoiceId>&lt;audio:VSM_210_070_036&gt;</VoiceId>
      <JapaneseText>エト……！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>11</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>284636</PointerOffset>
      <VoiceId>&lt;audio:VSM_210_070_037&gt;</VoiceId>
      <JapaneseText>&lt;Dio&gt;&lt;Mel&gt;！　！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>5</SpeakerId>
      <Id>12</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>284728</PointerOffset>
      <VoiceId>&lt;audio:VSM_210_070_038&gt;</VoiceId>
      <JapaneseText>ふたりとも大丈夫だった？
けがはない？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>5</SpeakerId>
      <Id>13</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>284808</PointerOffset>
      <VoiceId>&lt;audio:VSM_210_070_039&gt;</VoiceId>
      <JapaneseText>こっちのが
心配したっての</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>4</SpeakerId>
      <Id>14</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>284908</PointerOffset>
      <VoiceId>&lt;audio:VSM_210_070_040&gt;</VoiceId>
      <JapaneseText>でも、ぼく、ずっと
ふたりのこと
探してたかラ……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>5</SpeakerId>
      <Id>15</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>284988</PointerOffset>
      <VoiceId>&lt;audio:VSM_210_070_041&gt;</VoiceId>
      <JapaneseText>それでここに
迷い込んだの？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>16</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>285256</PointerOffset>
      <VoiceId>&lt;audio:VSM_210_070_044&gt;</VoiceId>
      <JapaneseText>申し訳ありません。
私どもの手違いで、おふたりを
連れ去ってしまったばかりに……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>17</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>285352</PointerOffset>
      <VoiceId>&lt;audio:VSM_210_070_045&gt;</VoiceId>
      <JapaneseText>あ、え……あ、はい、
キョーシュクです……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>5</SpeakerId>
      <Id>18</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>285456</PointerOffset>
      <VoiceId>&lt;audio:VSM_210_070_046&gt;</VoiceId>
      <JapaneseText>さて、ヴォルトもいるし、
これで元の時代にも戻れるぜ</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>6</SpeakerId>
      <Id>19</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>285540</PointerOffset>
      <VoiceId>&lt;audio:VSM_210_070_047&gt;</VoiceId>
      <JapaneseText>&lt;Suzu&gt;オレさ……
ちゃん手伝うよ</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>4</SpeakerId>
      <Id>20</Id>
      <Status>To Do</Status>
    </Entry>
