    <Entry>
      <PointerOffset>286000</PointerOffset>
      <VoiceId>&lt;audio:VSM_210_070_053&gt;</VoiceId>
      <JapaneseText>おし……ほんじゃ、
私も一緒に行くかな</JapaneseText>
      <EnglishText/>
      <Notes/>
