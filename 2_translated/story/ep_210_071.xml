    <Entry>
      <PointerOffset>285668</PointerOffset>
      <VoiceId>&lt;audio:VSM_210_070_049&gt;</VoiceId>
      <JapaneseText>あ、わたしも！だって、今の状態って
他人事じゃないでしょ</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>21</Id>
      <BubbleId>1</BubbleId>
      <Status>To Do</Status>
