    <Entry>
      <PointerOffset>308044</PointerOffset>
      <VoiceId>&lt;audio:VSM_030_060_014&gt;</VoiceId>
      <JapaneseText>トドメっ！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>2</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>308160</PointerOffset>
      <VoiceId>&lt;audio:VSM_030_060_015&gt;</VoiceId>
      <JapaneseText>わー！！　待って待って待って、
タイム！　ストーップ！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>3</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>308328</PointerOffset>
      <VoiceId>&lt;audio:VSM_030_060_017&gt;</VoiceId>
      <JapaneseText>冗談！　ジョークだってば！
も～</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>4</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>308440</PointerOffset>
      <VoiceId>&lt;audio:VSM_030_060_018&gt;</VoiceId>
      <JapaneseText>街荒らしたり、
魔術暴走させたりして、
ジョークですむかよ！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>5</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
