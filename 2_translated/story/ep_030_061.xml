    <Entry>
      <PointerOffset>312656</PointerOffset>
      <VoiceId>&lt;audio:VSM_030_060_068&gt;</VoiceId>
      <JapaneseText>ありがとうございます、&lt;Arche&gt;</JapaneseText>
      <EnglishText>Thank you very much, &lt;Arche&gt;. </EnglishText>
      <Notes/>
      <SpeakerId>6</SpeakerId>
      <Id>48</Id>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset>312752</PointerOffset>
      <VoiceId>&lt;audio:VSM_030_060_069&gt;</VoiceId>
      <JapaneseText>どういたしまして。
でもさ、なんなの、これ？</JapaneseText>
      <EnglishText>There's nothing to it. But let me ask,
what are you really up to? </EnglishText>
      <Notes/>
      <SpeakerId>4</SpeakerId>
      <Id>49</Id>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset>312848</PointerOffset>
      <VoiceId>&lt;audio:VSM_030_060_070&gt;</VoiceId>
      <JapaneseText>それはいずれわかるでしょう。
今はこれで……</JapaneseText>
      <EnglishText>That will be revealed in due time...</EnglishText>
      <Notes/>
      <SpeakerId>6</SpeakerId>
      <Id>50</Id>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset>312932</PointerOffset>
      <VoiceId>&lt;audio:VSM_030_060_071&gt;</VoiceId>
      <JapaneseText>え……？
あ、あれ、ちょっと……</JapaneseText>
      <EnglishText>Eh...? H-Hey! Wait a second...! </EnglishText>
      <Notes/>
      <SpeakerId>4</SpeakerId>
      <Id>51</Id>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset>312992</PointerOffset>
      <VoiceId>&lt;audio:VSM_030_060_072&gt;</VoiceId>
      <JapaneseText>もお……</JapaneseText>
      <EnglishText>Aww, man... </EnglishText>
      <Notes/>
      <SpeakerId>4</SpeakerId>
      <Id>52</Id>
      <Status>Proofreading</Status>
    </Entry>
