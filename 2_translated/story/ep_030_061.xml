      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>30</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>311224</PointerOffset>
      <VoiceId>&lt;audio:VSM_030_060_050&gt;</VoiceId>
      <JapaneseText>あはは、博士だって</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>4</SpeakerId>
      <Id>31</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>311424</PointerOffset>
      <VoiceId>&lt;audio:VSM_030_060_052&gt;</VoiceId>
      <JapaneseText>……ってことは、じゃあ
レスター博士も、
どっかで生きてんのか？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>32</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>311512</PointerOffset>
      <VoiceId>&lt;audio:VSM_030_060_053&gt;</VoiceId>
      <JapaneseText>ん～。半分アタリで
半分はずれ、かな</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>4</SpeakerId>
      <Id>33</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>311580</PointerOffset>
      <VoiceId>&lt;audio:VSM_030_060_054&gt;</VoiceId>
      <JapaneseText>……はい、コレ</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>4</SpeakerId>
      <Id>34</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>311716</PointerOffset>
      <VoiceId>&lt;audio:VSM_030_060_055&gt;</VoiceId>
      <JapaneseText>この絵に強く念じると、
なんと！　２００年前の世界と
カンタンに行き来できちゃうのだ</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>4</SpeakerId>
      <Id>35</Id>
      <Status>To Do</Status>
