      <Id>23</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>310152</PointerOffset>
      <VoiceId>&lt;audio:VSM_030_060_037&gt;</VoiceId>
      <JapaneseText>ん？　ん？　どったの？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>4</SpeakerId>
      <Id>24</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>310244</PointerOffset>
      <VoiceId>&lt;audio:VSM_030_060_038&gt;</VoiceId>
      <JapaneseText>……やっぱ四大精霊
探すっきゃねーな……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>25</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>310940</PointerOffset>
      <VoiceId>&lt;audio:VSM_030_060_047&gt;</VoiceId>
      <JapaneseText>最近じゃみんな、
人目のないところに
隠れ住んでるって言うからね～</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>4</SpeakerId>
      <Id>26</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>310668</PointerOffset>
      <VoiceId>&lt;audio:VSM_030_060_044&gt;</VoiceId>
      <JapaneseText>どっ、どこに！？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>5</SpeakerId>
      <Id>27</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>310760</PointerOffset>
      <VoiceId>&lt;audio:VSM_030_060_045&gt;</VoiceId>
      <JapaneseText>さあ。それはあたしには
わっかりませーん</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>4</SpeakerId>
      <Id>28</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>311048</PointerOffset>
      <VoiceId>&lt;audio:VSM_030_060_048&gt;</VoiceId>
      <JapaneseText>&lt;Claus&gt;ま、でも餅は餅屋って言うしぃ、
に聞いてくれば？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>4</SpeakerId>
      <Id>29</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>311152</PointerOffset>
      <VoiceId>&lt;audio:VSM_030_060_049&gt;</VoiceId>
      <JapaneseText>&lt;Claus&gt;&lt;Claus&gt;？　それって……
