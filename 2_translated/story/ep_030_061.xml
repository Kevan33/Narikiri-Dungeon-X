    <Entry>
      <PointerOffset>308660</PointerOffset>
      <VoiceId>&lt;audio:VSM_030_060_021&gt;</VoiceId>
      <JapaneseText>待ってよ！そりゃ、イタズラしてたけど、
そーんなひどいこと
してないつもりだよ？それに、
その魔術の暴走なんて
知らないよ？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>6</Id>
      <BubbleId>2</BubbleId>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>308768</PointerOffset>
      <VoiceId>&lt;audio:VSM_030_060_022&gt;</VoiceId>
      <JapaneseText>じゃあ、
ブライトローズさんの
しわざじゃないんですか？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>9</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>308892</PointerOffset>
      <VoiceId>&lt;audio:VSM_030_060_023&gt;</VoiceId>
      <JapaneseText>&lt;Arche&gt;明るい薔薇色（ブライトローズ）？
あたしの名前は
・クライン</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>10</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>308964</PointerOffset>
      <VoiceId>&lt;audio:VSM_030_060_024&gt;</VoiceId>
      <JapaneseText>&lt;Arche&gt;……って……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>11</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>309072</PointerOffset>
      <VoiceId>&lt;audio:VSM_030_060_025&gt;</VoiceId>
      <JapaneseText>えーっ！　もしかして……
ダオスを倒したっていう……？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>12</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>309176</PointerOffset>
      <VoiceId>&lt;audio:VSM_030_060_026&gt;</VoiceId>
      <JapaneseText>そうそう……あれ？
あたしってば、
けっこう有名人？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>4</SpeakerId>
      <Id>13</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>309240</PointerOffset>
      <VoiceId>&lt;audio:VSM_030_060_027&gt;</VoiceId>
      <JapaneseText>えっと……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>14</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>309300</PointerOffset>
      <VoiceId>&lt;audio:VSM_030_060_028&gt;</VoiceId>
      <JapaneseText>誰……？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>15</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>309408</PointerOffset>
      <VoiceId>&lt;audio:VSM_030_060_029&gt;</VoiceId>
      <JapaneseText>５０年前、魔王ダオスを
倒した英雄、時空戦士の
ひとりだよ</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>16</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>309508</PointerOffset>
      <VoiceId>&lt;audio:VSM_030_060_030&gt;</VoiceId>
      <JapaneseText>５０年前？
でも、そんな歳には
見えないけど……？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>17</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>309608</PointerOffset>
      <VoiceId>&lt;audio:VSM_030_060_031&gt;</VoiceId>
      <JapaneseText>あたし、これでもいちおー、
ハーフエルフだかんね</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>4</SpeakerId>
      <Id>18</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>309708</PointerOffset>
      <VoiceId>&lt;audio:VSM_030_060_032&gt;</VoiceId>
      <JapaneseText>エルフの一族の寿命が長いって
マジだったんだ……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>19</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>309820</PointerOffset>
      <VoiceId>&lt;audio:VSM_030_060_033&gt;</VoiceId>
      <JapaneseText>&lt;Arche&gt;&lt;Red&gt;&lt;White&gt;その、さんは
ヴァルハラのこと、
知らないんですね？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>20</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>309912</PointerOffset>
      <VoiceId>&lt;audio:VSM_030_060_034&gt;</VoiceId>
      <JapaneseText>&lt;Red&gt;&lt;White&gt;最近、ヴァルハラには
行ってないしね</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>4</SpeakerId>
      <Id>21</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>310012</PointerOffset>
      <VoiceId>&lt;audio:VSM_030_060_035&gt;</VoiceId>
      <JapaneseText>じゃあ、あれはやっぱり、
わたしの魔術のせい……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>22</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>310076</PointerOffset>
      <VoiceId>&lt;audio:VSM_030_060_036&gt;</VoiceId>
