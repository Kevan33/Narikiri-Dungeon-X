    <Entry>
      <PointerOffset>309708</PointerOffset>
      <VoiceId>&lt;audio:VSM_030_060_032&gt;</VoiceId>
      <JapaneseText>エルフの一族の寿命が長いって
マジだったんだ……</JapaneseText>
      <EnglishText>Amazing! I've never seen an Elf before... </EnglishText>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>19</Id>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset>309820</PointerOffset>
      <VoiceId>&lt;audio:VSM_030_060_033&gt;</VoiceId>
      <JapaneseText>その、&lt;Arche&gt;さんは
