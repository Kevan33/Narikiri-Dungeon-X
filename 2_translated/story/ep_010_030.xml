    <Entry>
      <PointerOffset>274472</PointerOffset>
      <VoiceId>&lt;audio:VSM_010_030_009&gt;</VoiceId>
      <JapaneseText>あんだ、おめぇら、
人のことジロジロ見てはっはっはぁ～ん、
このアルベルト様の格好良さに
見とれてるんだべな？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>5</Id>
      <BubbleId>1</BubbleId>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>274540</PointerOffset>
      <VoiceId>&lt;audio:VSM_010_030_010&gt;</VoiceId>
      <JapaneseText>アルベルト……？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>4</SpeakerId>
      <Id>7</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>274696</PointerOffset>
      <VoiceId>&lt;audio:VSM_010_030_011&gt;</VoiceId>
      <JapaneseText></JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>5</SpeakerId>
      <Id>8</Id>
      <BubbleId>0</BubbleId>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>274696</PointerOffset>
      <VoiceId>&lt;audio:VSM_010_030_012&gt;</VoiceId>
      <JapaneseText>んだんだ、そうだどノルン様のお達しで、
おめぇらのとこに来てやっただ。
感謝せぇよ</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>5</SpeakerId>
      <Id>8</Id>
      <BubbleId>1</BubbleId>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>274780</PointerOffset>
      <VoiceId>&lt;audio:VSM_010_030_013&gt;</VoiceId>
      <JapaneseText>ノルンの……！？
どういうこと？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>10</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>274952</PointerOffset>
      <VoiceId>&lt;audio:VSM_010_030_014&gt;</VoiceId>
      <JapaneseText></JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>5</SpeakerId>
      <Id>11</Id>
      <BubbleId>0</BubbleId>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>274952</PointerOffset>
      <VoiceId>&lt;audio:VSM_010_030_015&gt;</VoiceId>
      <JapaneseText>あ～ぁ、
長旅してきたもんで、
腹減っちまっただなぁふかし芋の
ひとつやふたつ、
出てこんもんか？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>5</SpeakerId>
      <Id>11</Id>
      <BubbleId>1</BubbleId>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>275040</PointerOffset>
      <VoiceId>&lt;audio:VSM_010_030_016&gt;</VoiceId>
      <JapaneseText>じゃ、じゃあ……
ひとまず中に……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>13</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>275156</PointerOffset>
      <VoiceId>&lt;audio:VSM_010_030_017&gt;</VoiceId>
      <JapaneseText>あー、そったら中行くだが。
芋だけじゃなく、
茶も出すんだど</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>5</SpeakerId>
      <Id>14</Id>
      <Status>To Do</Status>
    </Entry>
