    <Entry>
      <PointerOffset>274224</PointerOffset>
      <VoiceId>&lt;audio:VSM_010_030_006&gt;</VoiceId>
      <JapaneseText>ぷっは～、
びっくらこいた、
おどろいた、と危うくバラバラになるとこだど。
帰ったら文句言ってやんねぇと、
ぶつぶつぶつ、と…</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>3</Id>
      <BubbleId>1</BubbleId>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>274472</PointerOffset>
      <VoiceId>&lt;audio:VSM_010_030_008&gt;</VoiceId>
