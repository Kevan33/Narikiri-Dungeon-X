  <Strings>
    <Section>Main</Section>
    <Entry>
      <PointerOffset>291036</PointerOffset>
      <JapaneseText>ようこそ、
いらっしゃいました</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>1</Id>
      <OldPtr>277780</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>291236</PointerOffset>
      <JapaneseText>……私は戦うことを
好みません</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>2</Id>
      <BubbleId>0</BubbleId>
      <OldPtr>279184</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>291236</PointerOffset>
      <JapaneseText>戦う理由がないなら、
なおさらです</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>2</Id>
      <BubbleId>1</BubbleId>
      <OldPtr>279184</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>291236</PointerOffset>
      <JapaneseText>しかし、あなた方のほうに
事情がおありのようですね</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>2</Id>
      <BubbleId>2</BubbleId>
      <OldPtr>279184</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>291236</PointerOffset>
      <JapaneseText>お相手しましょう</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>2</Id>
      <BubbleId>3</BubbleId>
      <OldPtr>279184</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>291236</PointerOffset>
      <JapaneseText>準備はいいですか？
では、行きますよ</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>2</Id>
      <BubbleId>4</BubbleId>
      <OldPtr>279184</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>291304</PointerOffset>
      <JapaneseText>ご苦労様でした。
またおいでなさい</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>7</Id>
      <OldPtr>280080</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>291372</PointerOffset>
      <JapaneseText>ルナ！
オレらに力を貸してくれ！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>8</Id>
      <OldPtr>280320</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>291472</PointerOffset>
      <JapaneseText>いいでしょう……
あなた方の行く道を照らし、
導く月の光となりましょう</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>9</Id>
      <OldPtr>280460</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>291596</PointerOffset>
      <JapaneseText>我、今、月の精に
ねがいたてまつる</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>10</Id>
      <BubbleId>0</BubbleId>
      <OldPtr>280712</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>291596</PointerOffset>
      <JapaneseText>指輪の盟約のもと、
我に精霊を従わせたまえ</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>10</Id>
      <BubbleId>1</BubbleId>
      <OldPtr>280712</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>291596</PointerOffset>
      <JapaneseText>我が名は&lt;Dio&gt;</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>10</Id>
      <BubbleId>2</BubbleId>
      <OldPtr>280712</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>291684</PointerOffset>
      <JapaneseText>困難な時、我が名を呼びなさい。
あなた方の助けになります</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>13</Id>
      <OldPtr>280852</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>291904</PointerOffset>
      <JapaneseText>申し訳ありませんが、
契約の指輪がなくては、
力貸すこと叶いません</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>14</Id>
      <BubbleId>0</BubbleId>
      <OldPtr>281644</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>291904</PointerOffset>
      <JapaneseText>ムーンストーンを
持ってきてください</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>14</Id>
      <BubbleId>1</BubbleId>
      <OldPtr>281644</OldPtr>
      <Status>To Do</Status>
    </Entry>
