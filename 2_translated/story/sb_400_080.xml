    <Entry>
      <PointerOffset>296080</PointerOffset>
      <JapaneseText>うわっ！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>1</Id>
      <OldPtr>278848</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>296164</PointerOffset>
      <JapaneseText>なんだよ、頭悪いくせに
なかなかやるじゃんよ</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>2</Id>
      <OldPtr>280496</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>296276</PointerOffset>
      <JapaneseText>あんなもんでオレたちの
ジャマできるって思ってる
そっちが頭悪いんじゃないか？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>3</Id>
      <OldPtr>280636</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>296324</PointerOffset>
      <JapaneseText>なんだと！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>4</Id>
      <OldPtr>280888</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>296380</PointerOffset>
      <JapaneseText>&lt;Dio&gt;、やめなさい！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>5</Id>
      <OldPtr>281028</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>296428</PointerOffset>
      <JapaneseText>だってさ……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>6</Id>
      <OldPtr>281704</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>296500</PointerOffset>
      <JapaneseText>アルテミスも、
もういいかげんに
しなさい</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>4</SpeakerId>
      <Id>7</Id>
      <OldPtr>281844</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>296544</PointerOffset>
      <JapaneseText>ルナ……！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>5</SpeakerId>
      <Id>8</Id>
      <OldPtr>282408</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>296596</PointerOffset>
      <JapaneseText>だってさ……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>9</Id>
