      <SpeakerId>1</SpeakerId>
      <Id>13</Id>
      <OldPtr>283868</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>296988</PointerOffset>
      <JapaneseText>寂しいんだね、あの子</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>14</Id>
      <BubbleId>0</BubbleId>
      <OldPtr>284008</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>296988</PointerOffset>
      <JapaneseText>誰にも必要とされなくて、
誰にも相手されなくて</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>14</Id>
      <BubbleId>1</BubbleId>
      <OldPtr>284008</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>296988</PointerOffset>
      <JapaneseText>必要とされる人や
ちやほやされる人に
嫉妬して……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>14</Id>
      <BubbleId>2</BubbleId>
      <OldPtr>284008</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>296988</PointerOffset>
      <JapaneseText>気持ちがささくれだって、
だかラ……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>14</Id>
      <BubbleId>3</BubbleId>
      <OldPtr>284008</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>296988</PointerOffset>
      <JapaneseText>ぼくもそうだったから、
わかるんだ</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>14</Id>
      <BubbleId>4</BubbleId>
      <OldPtr>284008</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>297044</PointerOffset>
      <JapaneseText>そっか……
そうだよね</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>5</SpeakerId>
      <Id>19</Id>
      <OldPtr>284392</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
