      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>296652</PointerOffset>
      <JapaneseText>皆さんをお通ししなさい</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>4</SpeakerId>
      <Id>10</Id>
      <OldPtr>282688</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
