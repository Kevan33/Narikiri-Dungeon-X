    <Entry>
      <PointerOffset>271572</PointerOffset>
      <VoiceId>&lt;audio:VSM_100_020_004&gt;</VoiceId>
      <JapaneseText>木が……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>1</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>271640</PointerOffset>
      <VoiceId>&lt;audio:VSM_100_020_005&gt;</VoiceId>
      <JapaneseText>どういうこと？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>2</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>271756</PointerOffset>
      <VoiceId>&lt;audio:VSM_100_020_006&gt;</VoiceId>
      <JapaneseText>前に『虹輪』は
マナを消費しつくすって
魔術師さんが言ってたけど</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>3</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>271836</PointerOffset>
      <VoiceId>&lt;audio:VSM_100_020_007&gt;</VoiceId>
      <JapaneseText>まさか、
魔術の暴走が原因？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>4</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>271924</PointerOffset>
      <VoiceId>&lt;audio:VSM_100_020_008&gt;</VoiceId>
      <JapaneseText>鳥や動物の鳴き声も
聞こえない……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>5</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>272000</PointerOffset>
      <VoiceId>&lt;audio:VSM_100_020_009&gt;</VoiceId>
      <JapaneseText>クルール！　クルール！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>4</SpeakerId>
      <Id>6</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>272092</PointerOffset>
      <VoiceId>&lt;audio:VSM_100_020_010&gt;</VoiceId>
      <JapaneseText>そうだね、
早く魔術の暴走を
止めないと！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>7</Id>
      <Status>To Do</Status>
    </Entry>
