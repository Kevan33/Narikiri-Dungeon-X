    <Entry>
      <PointerOffset>271172</PointerOffset>
      <VoiceId>&lt;audio:VSM_140_040_003&gt;</VoiceId>
      <JapaneseText>ターゲットは
ヴァルハラ村を拠点とする
革命組織『シグルド』そのリーダーである
『ブレイナー』の捕獲だ何か質問は？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>1</Id>
      <BubbleId>2</BubbleId>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>271240</PointerOffset>
      <VoiceId>&lt;audio:VSM_140_040_004&gt;</VoiceId>
      <JapaneseText>現在の戦況は？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>4</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>271440</PointerOffset>
      <VoiceId>&lt;audio:VSM_140_040_005&gt;</VoiceId>
      <JapaneseText></JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>5</Id>
      <BubbleId>0</BubbleId>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>271440</PointerOffset>
      <VoiceId>&lt;audio:VSM_140_040_006&gt;</VoiceId>
      <JapaneseText>敵の魔科学兵器に
苦戦させられていますが、
現在、我が軍優勢です街入り口をふさいでいる
バリケードが破られるのも
時間の問題です</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>5</Id>
      <BubbleId>1</BubbleId>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>271568</PointerOffset>
      <VoiceId>&lt;audio:VSM_140_040_007&gt;</VoiceId>
      <JapaneseText></JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>7</Id>
      <BubbleId>0</BubbleId>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>271568</PointerOffset>
      <VoiceId>&lt;audio:VSM_140_040_008&gt;</VoiceId>
      <JapaneseText>&lt;Cless&gt;戦端が開いたら、
一気にたたみこむぞ様、お願いします</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>7</Id>
      <BubbleId>1</BubbleId>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>271624</PointerOffset>
      <VoiceId>&lt;audio:VSM_140_040_009&gt;</VoiceId>
      <JapaneseText>ああ</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>9</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
