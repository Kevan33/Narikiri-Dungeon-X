    <Entry>
      <PointerOffset>271768</PointerOffset>
      <VoiceId>&lt;audio:VSM_140_040_011&gt;</VoiceId>
      <JapaneseText>ご報告します！我が軍の先鋒が、
街南口のバリケードを
突破しました！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>4</SpeakerId>
      <Id>10</Id>
      <BubbleId>1</BubbleId>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>271864</PointerOffset>
      <VoiceId>&lt;audio:VSM_140_040_012&gt;</VoiceId>
      <JapaneseText>よし、全戦力を街へ向かわせろ！
総力戦だ！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>12</Id>
      <Status>To Do</Status>
    </Entry>
