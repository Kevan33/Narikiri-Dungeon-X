    <Section>Main</Section>
    <Entry>
      <PointerOffset>272356</PointerOffset>
      <VoiceId>&lt;audio:VSM_130_030_028&gt;</VoiceId>
      <JapaneseText>君みたいな子どもに
負けるなんて……</JapaneseText>
      <EnglishText>Seems like...I lost to a child...</EnglishText>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>1</Id>
      <BubbleId>0</BubbleId>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset>272356</PointerOffset>
      <VoiceId>&lt;audio:VSM_130_030_029&gt;</VoiceId>
      <JapaneseText>僕も腕がなまったかな……</JapaneseText>
      <EnglishText>My sword skills have grown rusty...</EnglishText>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>1</Id>
      <BubbleId>1</BubbleId>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset>272468</PointerOffset>
      <VoiceId>&lt;audio:VSM_130_030_030&gt;</VoiceId>
      <JapaneseText>約束どおりに、
オレに手伝い任せて
&lt;Mint&gt;さんに会いにいけよ！</JapaneseText>
      <EnglishText>Now you can leave the work
to me and meet with &lt;Mint&gt;.
A promise is a promise!</EnglishText>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>3</Id>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset>272580</PointerOffset>
      <VoiceId>&lt;audio:VSM_130_030_031&gt;</VoiceId>
      <JapaneseText>わかった……</JapaneseText>
      <EnglishText>I understand...</EnglishText>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>4</Id>
      <BubbleId>0</BubbleId>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset>272580</PointerOffset>
      <VoiceId>&lt;audio:VSM_130_030_032&gt;</VoiceId>
      <JapaneseText>……本当に……
ありがとう……</JapaneseText>
      <EnglishText>Thank you... Really, thank you...</EnglishText>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>4</Id>
      <BubbleId>1</BubbleId>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset>272740</PointerOffset>
      <VoiceId>&lt;audio:VSM_130_030_033&gt;</VoiceId>
      <JapaneseText>……やっぱ、
英雄に勝つなんて……
無理だったのか……？</JapaneseText>
      <EnglishText>Is...winning against a hero...impossible?</EnglishText>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>6</Id>
      <BubbleId>0</BubbleId>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset>272740</PointerOffset>
      <VoiceId>&lt;audio:VSM_130_030_034&gt;</VoiceId>
      <JapaneseText>いや……もう一度……
もう一度だけ！</JapaneseText>
      <EnglishText>No...Let's do it again! I'll win next time!</EnglishText>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>6</Id>
      <BubbleId>1</BubbleId>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset>272828</PointerOffset>
      <VoiceId>&lt;audio:VSM_130_030_035&gt;</VoiceId>
      <JapaneseText>はぁはぁ……
もう、やらないよ……</JapaneseText>
      <EnglishText>Hah...Hah...Not again...</EnglishText>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>8</Id>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset>272892</PointerOffset>
      <VoiceId>&lt;audio:VSM_130_030_036&gt;</VoiceId>
      <JapaneseText>くっ……！</JapaneseText>
      <EnglishText>Guh...!</EnglishText>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>9</Id>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset>272988</PointerOffset>
      <VoiceId>&lt;audio:VSM_130_030_037&gt;</VoiceId>
      <JapaneseText>……でも……
君の好意は素直に受け取る……</JapaneseText>
      <EnglishText>...Your attacks were pretty strong.</EnglishText>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>10</Id>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset>273052</PointerOffset>
      <VoiceId>&lt;audio:VSM_130_030_038&gt;</VoiceId>
      <JapaneseText>……え……？</JapaneseText>
      <EnglishText>What?</EnglishText>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>11</Id>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset>273152</PointerOffset>
      <VoiceId>&lt;audio:VSM_130_030_039&gt;</VoiceId>
      <JapaneseText>君、なかなか強いしね……
任せても、いい、かな？</JapaneseText>
      <EnglishText>You really are strong... I can
leave the rest to you, right?</EnglishText>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>12</Id>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset>273216</PointerOffset>
      <VoiceId>&lt;audio:VSM_130_030_040&gt;</VoiceId>
      <JapaneseText>やった……！</JapaneseText>
      <EnglishText>Yes...!</EnglishText>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>13</Id>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset>273288</PointerOffset>
      <VoiceId>&lt;audio:VSM_130_030_041&gt;</VoiceId>
      <JapaneseText>本当に……ありがとう</JapaneseText>
      <EnglishText>Thank you... Really, thank you...</EnglishText>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>14</Id>
      <Status>Proofreading</Status>
    </Entry>
