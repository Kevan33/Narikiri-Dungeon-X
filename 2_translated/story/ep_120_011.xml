    <Entry>
      <PointerOffset>293536</PointerOffset>
      <VoiceId>&lt;audio:VSM_120_010_014&gt;</VoiceId>
      <JapaneseText>なんだ、おまえら、
強いじゃないか</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>1</Id>
      <OldPtr>277892</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>293604</PointerOffset>
      <VoiceId>&lt;audio:VSM_120_010_015&gt;</VoiceId>
      <JapaneseText>だから言ったろ</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>2</Id>
      <OldPtr>278316</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>293696</PointerOffset>
      <VoiceId>&lt;audio:VSM_120_010_016&gt;</VoiceId>
      <JapaneseText>アミィにもこれぐらい
力があったら……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>3</Id>
      <OldPtr>279000</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>293824</PointerOffset>
      <VoiceId>&lt;audio:VSM_120_010_017&gt;</VoiceId>
      <JapaneseText>……いや……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>4</Id>
      <BubbleId>0</BubbleId>
      <OldPtr>279252</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>293824</PointerOffset>
      <VoiceId>&lt;audio:VSM_120_010_018&gt;</VoiceId>
      <JapaneseText>でも、
叩きのめすばっかりが、
力じゃないぜ</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>4</Id>
      <BubbleId>1</BubbleId>
      <OldPtr>279252</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>294036</PointerOffset>
      <VoiceId>&lt;audio:VSM_120_010_021&gt;</VoiceId>
      <JapaneseText>これは？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>6</Id>
      <OldPtr>280208</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>294136</PointerOffset>
      <VoiceId>&lt;audio:VSM_120_010_022&gt;</VoiceId>
      <JapaneseText>魔物を捕まえる魔物使いの服だよ。
気分出るだろ？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>7</Id>
      <OldPtr>280348</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>294228</PointerOffset>
      <VoiceId>&lt;audio:VSM_120_010_023&gt;</VoiceId>
      <JapaneseText>そっか、これで
『なりきり』すれば……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>8</Id>
      <OldPtr>281244</OldPtr>
      <Status>To Do</Status>
    </Entry>
