    <Section>Main</Section>
    <Entry>
      <PointerOffset>270936</PointerOffset>
      <VoiceId>&lt;audio:VSM_280_030_001&gt;</VoiceId>
      <JapaneseText>平原北東軍全滅！
北ルティカ要塞陥落！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>1</Id>
      <OldPtr>258996</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>271004</PointerOffset>
      <VoiceId>&lt;audio:VSM_280_030_002&gt;</VoiceId>
      <JapaneseText>被害状況は？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>2</Id>
      <OldPtr>259136</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>271108</PointerOffset>
      <VoiceId>&lt;audio:VSM_280_030_003&gt;</VoiceId>
      <JapaneseText>味方兵２万３０００が死亡、
生存者はわずか８００！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>3</Id>
      <OldPtr>259276</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>271228</PointerOffset>
      <VoiceId>&lt;audio:VSM_280_030_004&gt;</VoiceId>
      <JapaneseText>たった今、水上都市バチス、
パレスセダム軍に
占領されたとの連絡が！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>4</Id>
      <OldPtr>259560</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>271300</PointerOffset>
      <VoiceId>&lt;audio:VSM_280_030_005&gt;</VoiceId>
      <JapaneseText>駐留軍はどうした？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>5</Id>
      <OldPtr>260092</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>271408</PointerOffset>
      <VoiceId>&lt;audio:VSM_280_030_006&gt;</VoiceId>
      <JapaneseText>詳細は不明です！
しかし、敵軍に
投降したのでは、と……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>6</Id>
      <OldPtr>260344</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>271500</PointerOffset>
      <VoiceId>&lt;audio:VSM_280_030_007&gt;</VoiceId>
      <JapaneseText>このままでは我が軍は
全滅してしまいます！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>4</SpeakerId>
      <Id>7</Id>
      <OldPtr>260644</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>271588</PointerOffset>
      <VoiceId>&lt;audio:VSM_280_030_008&gt;</VoiceId>
      <JapaneseText>今、ここで
退くわけにはいかない</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>8</Id>
      <OldPtr>260840</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>271668</PointerOffset>
      <VoiceId>&lt;audio:VSM_280_030_009&gt;</VoiceId>
      <JapaneseText>将軍に停戦を
ご進言ください</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>4</SpeakerId>
      <Id>9</Id>
      <OldPtr>260980</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>271752</PointerOffset>
      <VoiceId>&lt;audio:VSM_280_030_010&gt;</VoiceId>
      <JapaneseText>停戦を……
いや、しかし……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>10</Id>
      <OldPtr>261176</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>271816</PointerOffset>
      <VoiceId>&lt;audio:VSM_280_030_011&gt;</VoiceId>
      <JapaneseText>ご決断を……！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>4</SpeakerId>
      <Id>11</Id>
      <OldPtr>261520</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>271884</PointerOffset>
      <VoiceId>&lt;audio:VSM_280_030_012&gt;</VoiceId>
      <JapaneseText>……わかった</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>12</Id>
      <OldPtr>261844</OldPtr>
      <Status>To Do</Status>
    </Entry>
