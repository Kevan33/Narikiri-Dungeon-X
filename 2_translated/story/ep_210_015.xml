    <Entry>
      <PointerOffset>273288</PointerOffset>
      <JapaneseText>どうした？　&lt;Suzu&gt;ちゃん</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>1</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>273432</PointerOffset>
      <JapaneseText>……ここから先は、
更に危険な戦いとなるでしょう</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>2</Id>
      <BubbleId>0</BubbleId>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>273432</PointerOffset>
      <JapaneseText>少しでも戦いを有利に進める為、
一つ、忍びの極意をお伝えします</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>2</Id>
      <BubbleId>1</BubbleId>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>273532</PointerOffset>
      <JapaneseText>数多の技をより自在に扱う力、
皆さんなら必ず使いこなせるはずです</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>4</Id>
      <Status>To Do</Status>
    </Entry>
