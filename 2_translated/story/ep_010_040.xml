    <Entry>
      <PointerOffset>296131</PointerOffset>
      <JapaneseText>『なりきり士』の説明を聞きますか？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <Id>10</Id>
      <Status>To Do</Status>
