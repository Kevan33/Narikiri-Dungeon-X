  <Strings>
    <Section>Main</Section>
    <Entry>
      <PointerOffset>288652</PointerOffset>
      <VoiceId>&lt;audio:VSM_010_040_001&gt;</VoiceId>
      <JapaneseText>へっへっへっへぇ～。
やっとこ落ち着いただ～</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>1</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>288740</PointerOffset>
      <VoiceId>&lt;audio:VSM_010_040_002&gt;</VoiceId>
      <JapaneseText>ところでさっきの話の
続きだけド……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>2</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>288980</PointerOffset>
      <VoiceId>&lt;audio:VSM_010_040_003&gt;</VoiceId>
      <JapaneseText></JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>3</Id>
      <BubbleId>0</BubbleId>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>288980</PointerOffset>
      <VoiceId>&lt;audio:VSM_010_040_004&gt;</VoiceId>
      <JapaneseText></JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>3</Id>
      <BubbleId>1</BubbleId>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>288980</PointerOffset>
      <VoiceId>&lt;audio:VSM_010_040_005&gt;</VoiceId>
      <JapaneseText>わーってるだぁ、
せかすでねーって。
んだば……おめぇら
もう１３歳だなや？そういうことで、そろそろ
『なりきり士』の仕事を始める
年頃なわけだーよ</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>3</Id>
      <BubbleId>2</BubbleId>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>289052</PointerOffset>
      <VoiceId>&lt;audio:VSM_010_040_006&gt;</VoiceId>
      <JapaneseText>『なりきり士』……？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>6</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>289380</PointerOffset>
      <VoiceId>&lt;audio:VSM_010_040_007&gt;</VoiceId>
      <JapaneseText></JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>7</Id>
      <BubbleId>0</BubbleId>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>289380</PointerOffset>
      <VoiceId>&lt;audio:VSM_010_040_008&gt;</VoiceId>
      <JapaneseText></JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>7</Id>
      <BubbleId>1</BubbleId>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>289380</PointerOffset>
      <VoiceId>&lt;audio:VSM_010_040_009&gt;</VoiceId>
      <JapaneseText>おぉ『なりきり士』っつーのは、
その服装の人になりきる力を
持った人間のことを言うだ剣士の服を着れば立派な剣士で、
魔法使いの服を着てみれば、
魔法使いになれるっつー具合だおめぇらふたりには、
そんだら力が生まれたときから
宿っとるんだーよ</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>7</Id>
      <BubbleId>2</BubbleId>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>289456</PointerOffset>
      <VoiceId>&lt;audio:VSM_010_040_010&gt;</VoiceId>
      <JapaneseText>わたしたちに？　まさか？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>4</SpeakerId>
      <Id>10</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>289572</PointerOffset>
      <VoiceId>&lt;audio:VSM_010_040_011&gt;</VoiceId>
      <JapaneseText>はん！
おらが信じられねぇってが？
このおらをか？　あ～ん？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>11</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>289948</PointerOffset>
      <VoiceId>&lt;audio:VSM_010_040_013&gt;</VoiceId>
      <JapaneseText></JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>12</Id>
      <BubbleId>0</BubbleId>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>289948</PointerOffset>
      <VoiceId>&lt;audio:VSM_010_040_014&gt;</VoiceId>
      <JapaneseText></JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>12</Id>
      <BubbleId>1</BubbleId>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>289948</PointerOffset>
      <VoiceId>&lt;audio:VSM_010_040_015&gt;</VoiceId>
      <JapaneseText>グダグダ言ってねぇで、
おらの中の服、
着てみりゃわかるだ！とにかく、『なりきり士』の力で
困ってる人たちを
助ける仕事をするんだどノルン様はそれをおめぇらに
期待しとるっちゅーわけだ</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>12</Id>
      <BubbleId>2</BubbleId>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>290224</PointerOffset>
      <VoiceId>&lt;audio:VSM_010_040_017&gt;</VoiceId>
      <JapaneseText></JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>15</Id>
      <BubbleId>0</BubbleId>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>290224</PointerOffset>
      <VoiceId>&lt;audio:VSM_010_040_018&gt;</VoiceId>
      <JapaneseText></JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>15</Id>
      <BubbleId>1</BubbleId>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>290224</PointerOffset>
      <VoiceId>&lt;audio:VSM_010_040_019&gt;</VoiceId>
      <JapaneseText>それ……すごいいいかも！オレ、困ってる人、
助けに行くよ！オレ、外に出る！
『なりきり士』の仕事する！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>15</Id>
      <BubbleId>2</BubbleId>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>290980</PointerOffset>
      <VoiceId>&lt;audio:VSM_010_040_028&gt;</VoiceId>
      <JapaneseText>&lt;Dio&gt;</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>4</SpeakerId>
      <Id>18</Id>
      <BubbleId>0</BubbleId>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>290980</PointerOffset>
      <VoiceId>&lt;audio:VSM_010_040_029&gt;</VoiceId>
      <JapaneseText>そんなの……
ひとりだけで
行かせられると思う？すぐ無茶するし、
危なっかしいし……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>4</SpeakerId>
      <Id>18</Id>
      <BubbleId>1</BubbleId>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>291308</PointerOffset>
      <VoiceId>&lt;audio:VSM_010_040_033&gt;</VoiceId>
      <JapaneseText>わかった……
わたしも一緒に行く</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>4</SpeakerId>
      <Id>20</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>291376</PointerOffset>
      <VoiceId>&lt;audio:VSM_010_040_034&gt;</VoiceId>
      <JapaneseText>おまえも……！？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>21</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>291888</PointerOffset>
      <VoiceId>&lt;audio:VSM_010_040_040&gt;</VoiceId>
      <JapaneseText>うん。いいよ……
行っておいで</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>22</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>291948</PointerOffset>
      <VoiceId>&lt;audio:VSM_010_040_041&gt;</VoiceId>
      <JapaneseText>っしゃ！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>23</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>292032</PointerOffset>
      <VoiceId>&lt;audio:VSM_010_040_042&gt;</VoiceId>
      <JapaneseText>何言ってるの。
エトも一緒だよ？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>4</SpeakerId>
      <Id>24</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>292116</PointerOffset>
      <VoiceId>&lt;audio:VSM_010_040_043&gt;</VoiceId>
      <JapaneseText>え……ぼくも……
行っていいの？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>25</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>292180</PointerOffset>
      <VoiceId>&lt;audio:VSM_010_040_044&gt;</VoiceId>
      <JapaneseText>一緒に行こ！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>4</SpeakerId>
      <Id>26</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>292336</PointerOffset>
      <VoiceId>&lt;audio:VSM_010_040_045&gt;</VoiceId>
      <JapaneseText></JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>27</Id>
      <BubbleId>0</BubbleId>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>292336</PointerOffset>
      <VoiceId>&lt;audio:VSM_010_040_046&gt;</VoiceId>
      <JapaneseText>&lt;Dio&gt;&lt;Mel&gt;そっか……うん！　とは
ぼくの可愛い双子だもん。
ぼくも一緒でなきゃね！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>27</Id>
      <BubbleId>1</BubbleId>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>292580</PointerOffset>
      <VoiceId>&lt;audio:VSM_010_040_048&gt;</VoiceId>
      <JapaneseText></JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>29</Id>
      <BubbleId>0</BubbleId>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>292580</PointerOffset>
      <VoiceId>&lt;audio:VSM_010_040_049&gt;</VoiceId>
      <JapaneseText>あ？　話はまとまっただな？
んだら、準備してやるだよ『なりきり士』のことを
教えてほしいだか？
ん？　ん？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>29</Id>
      <BubbleId>1</BubbleId>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>295116</PointerOffset>
      <JapaneseText>&lt;TRIANGLE&gt;まずでメニューを開くだ</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>31</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>295236</PointerOffset>
      <JapaneseText>『コスチューム』の項目で、
服を着ることができるだーよ。
今は１着ずつしかないんだど</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>32</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>295332</PointerOffset>
      <JapaneseText>『コスチューム』は世界の
どこかに落ちてたりする
もんだーよ</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>33</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>295428</PointerOffset>
      <JapaneseText>服を着替えっと、
その服の格好に応じた
戦闘特性になるだで</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>34</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>295540</PointerOffset>
      <JapaneseText>おめぇらにわかりやすく教えっと、
『剣士』だと、
剣士としての能力が上がるだ</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>35</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>295652</PointerOffset>
      <JapaneseText>つまりだ、本物の剣士と同じよう
に剣を振って攻撃ができるように
なるんだでよ</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>36</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>295760</PointerOffset>
      <JapaneseText>でもただただ『コスチューム』
を集めて、着てるだけでは
芸がないんだべ</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>37</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>295876</PointerOffset>
      <JapaneseText>戦闘でもらえるＣＰっちゅーの
を溜めると、熟練度が上がって
スキルが開放できるだ</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>38</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>293460</PointerOffset>
      <VoiceId>&lt;audio:VSM_010_040_057&gt;</VoiceId>
      <JapaneseText></JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>39</Id>
      <BubbleId>0</BubbleId>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>293460</PointerOffset>
      <VoiceId>&lt;audio:VSM_010_040_058&gt;</VoiceId>
      <JapaneseText>とまぁ、こんなところだ。おらが
こんな説明までせねばなんねぇ
とはまったくめんどうくせぇそれから、おらは豆粒みたいに
ちっちゃくなって
おめぇらについてくだーよ</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>39</Id>
      <BubbleId>1</BubbleId>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>293916</PointerOffset>
      <VoiceId>&lt;audio:VSM_010_040_061&gt;</VoiceId>
      <JapaneseText></JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>41</Id>
      <BubbleId>0</BubbleId>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>293916</PointerOffset>
      <VoiceId>&lt;audio:VSM_010_040_062&gt;</VoiceId>
      <JapaneseText>あー、あとな、おらは、
魔物のいるところは、
絶対出ていがねぇからなどうしても着替えてぇなら、
魔物のいない町中とか、
安全な場所にするだよ</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>41</Id>
      <BubbleId>1</BubbleId>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>293984</PointerOffset>
      <VoiceId>&lt;audio:VSM_010_040_063&gt;</VoiceId>
      <JapaneseText>さ！　行くか！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>43</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>294056</PointerOffset>
      <VoiceId>&lt;audio:VSM_010_040_064&gt;</VoiceId>
      <JapaneseText>行くって……どこへ？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>4</SpeakerId>
      <Id>44</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>294268</PointerOffset>
      <VoiceId>&lt;audio:VSM_010_040_067&gt;</VoiceId>
      <JapaneseText>&lt;Red&gt;&lt;White&gt;ヴァルハラ村はどうかな？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>45</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>294340</PointerOffset>
      <VoiceId>&lt;audio:VSM_010_040_068&gt;</VoiceId>
      <JapaneseText>&lt;Red&gt;&lt;White&gt;ヴァルハラ村？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>46</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>294560</PointerOffset>
      <VoiceId>&lt;audio:VSM_010_040_069&gt;</VoiceId>
      <JapaneseText></JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>47</Id>
      <BubbleId>0</BubbleId>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>294560</PointerOffset>
      <VoiceId>&lt;audio:VSM_010_040_070&gt;</VoiceId>
      <JapaneseText>そう。ヴァルハラ平原に貧しい人たちが
移り住んで作った村なんだけドたくさん人が集まってる場所
なんだから、困ってる人だって
きっといるんじゃないのかな</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>47</Id>
      <BubbleId>1</BubbleId>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>294640</PointerOffset>
      <VoiceId>&lt;audio:VSM_010_040_071&gt;</VoiceId>
      <JapaneseText>んじゃー
そこ行ってみようぜ</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>49</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>295052</PointerOffset>
      <VoiceId>&lt;audio:VSM_010_040_077&gt;</VoiceId>
      <JapaneseText>あなたたちの旅立ちに
祝福を……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>5</SpeakerId>
      <Id>50</Id>
      <Status>To Do</Status>
    </Entry>
