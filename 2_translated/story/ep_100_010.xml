    <Entry>
      <PointerOffset>272040</PointerOffset>
      <VoiceId>&lt;audio:VSM_100_010_001&gt;</VoiceId>
      <JapaneseText>元の時代に……
戻ってきた？</JapaneseText>
      <EnglishText>Are we back to our own time period?</EnglishText>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>1</Id>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset>272108</PointerOffset>
      <VoiceId>&lt;audio:VSM_100_010_002&gt;</VoiceId>
      <JapaneseText>あ、絵が……！</JapaneseText>
      <EnglishText>Oh, no! The painting...!</EnglishText>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>2</Id>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset>272188</PointerOffset>
      <VoiceId>&lt;audio:VSM_100_010_003&gt;</VoiceId>
      <JapaneseText>……使えなくなっちゃった……</JapaneseText>
      <EnglishText>It's been rendered useless...</EnglishText>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>3</Id>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset>272264</PointerOffset>
      <VoiceId>&lt;audio:VSM_100_010_004&gt;</VoiceId>
      <JapaneseText>必要なくなったからか？</JapaneseText>
      <EnglishText>Is it because we don't need it anymore?</EnglishText>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>4</Id>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset>272328</PointerOffset>
      <VoiceId>&lt;audio:VSM_100_010_005&gt;</VoiceId>
      <JapaneseText>なのかな……</JapaneseText>
      <EnglishText>I don't know...</EnglishText>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>5</Id>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset>272416</PointerOffset>
      <VoiceId>&lt;audio:VSM_100_010_006&gt;</VoiceId>
      <JapaneseText>とにかく、
&lt;Red&gt;ヴァルハラ&lt;White&gt;へ急ご！</JapaneseText>
      <EnglishText>Anyways we need to hurry to Valhalla!</EnglishText>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>6</Id>
      <Status>Proofreading</Status>
    </Entry>
