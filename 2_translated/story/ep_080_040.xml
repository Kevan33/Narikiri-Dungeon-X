      <VoiceId>&lt;audio:VSM_080_040_000&gt;</VoiceId>
      <JapaneseText>涸れちまったよ……</JapaneseText>
      <EnglishText>It dried up...</EnglishText>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>1</Id>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset>268316</PointerOffset>
      <VoiceId>&lt;audio:VSM_080_040_001&gt;</VoiceId>
      <JapaneseText>井戸を掘る
道具があればねぇ</JapaneseText>
      <EnglishText>How inhuman... It's our only means to get food.</EnglishText>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>2</Id>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset>268408</PointerOffset>
      <VoiceId>&lt;audio:VSM_080_040_002&gt;</VoiceId>
      <JapaneseText>無理だよ、
お金がないもの……</JapaneseText>
      <EnglishText>It's useless. There's no money...</EnglishText>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>3</Id>
