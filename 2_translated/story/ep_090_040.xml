      <PointerOffset>297584</PointerOffset>
      <VoiceId>&lt;audio:VSM_090_040_012&gt;</VoiceId>
      <JapaneseText>&lt;Rody&gt;待て、！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>9</Id>
      <Status>To Do</Status>
