    <Entry>
      <PointerOffset>298520</PointerOffset>
      <VoiceId>&lt;audio:VSM_090_040_024&gt;</VoiceId>
      <JapaneseText>いや……さて、ここでお別れだ君たちには君たちの
やらなければならないことが
あるだろう？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>18</Id>
      <BubbleId>2</BubbleId>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>298600</PointerOffset>
      <VoiceId>&lt;audio:VSM_090_040_025&gt;</VoiceId>
      <JapaneseText>&lt;Mel&gt;そうだな。
……帰ろう</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>21</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>298676</PointerOffset>
      <VoiceId>&lt;audio:VSM_090_040_026&gt;</VoiceId>
      <JapaneseText>うん。わたしたちの時代に</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>4</SpeakerId>
      <Id>22</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>298736</PointerOffset>
      <VoiceId>&lt;audio:VSM_090_040_027&gt;</VoiceId>
      <JapaneseText>じゃあな</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>23</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>298812</PointerOffset>
      <VoiceId>&lt;audio:VSM_090_040_028&gt;</VoiceId>
      <JapaneseText>うん。また、会えるかな？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>24</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>298904</PointerOffset>
      <VoiceId>&lt;audio:VSM_090_040_029&gt;</VoiceId>
      <JapaneseText>さぁ。だが……
機会があればたぶん、な</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>25</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>298992</PointerOffset>
      <VoiceId>&lt;audio:VSM_090_040_030&gt;</VoiceId>
      <JapaneseText>いろいろ、
ありがとうございました</JapaneseText>
      <EnglishText/>
      <Notes/>
