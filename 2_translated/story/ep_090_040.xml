    <Entry>
      <PointerOffset>297648</PointerOffset>
      <VoiceId>&lt;audio:VSM_090_040_013&gt;</VoiceId>
      <JapaneseText>くっ……！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>10</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>297812</PointerOffset>
      <VoiceId>&lt;audio:VSM_090_040_015&gt;</VoiceId>
      <JapaneseText>&lt;Claus&gt;ダオスって……
さんたちが
倒したんだろ？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>11</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>298008</PointerOffset>
      <VoiceId>&lt;audio:VSM_090_040_016&gt;</VoiceId>
      <JapaneseText></JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>12</Id>
      <BubbleId>0</BubbleId>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>298008</PointerOffset>
      <VoiceId>&lt;audio:VSM_090_040_017&gt;</VoiceId>
      <JapaneseText>ああ。だが彼女は
自分の手でダオスを
倒したいと思ってるダオスと戦うため……
彼女は再びダオスがいる
時間へと旅立ったのだろう</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>12</Id>
      <BubbleId>1</BubbleId>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>298080</PointerOffset>
      <VoiceId>&lt;audio:VSM_090_040_018&gt;</VoiceId>
      <JapaneseText>でも、どうして……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>14</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>298204</PointerOffset>
      <VoiceId>&lt;audio:VSM_090_040_019&gt;</VoiceId>
      <JapaneseText>&lt;Rody&gt;も、みんなと一緒で
世界を守るために
戦いたかったんじゃねーのか？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>15</Id>
      <Status>To Do</Status>
    </Entry>
