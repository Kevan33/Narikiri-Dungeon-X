      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>16</Id>
      <BubbleId>0</BubbleId>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>298344</PointerOffset>
      <VoiceId>&lt;audio:VSM_090_040_021&gt;</VoiceId>
      <JapaneseText>世界を守るか…………本当にこのアセリアを
守ったのは誰だったんだろうな</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>16</Id>
      <BubbleId>1</BubbleId>
      <Status>To Do</Status>
    </Entry>
