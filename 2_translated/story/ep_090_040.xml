    <Entry>
      <PointerOffset>296752</PointerOffset>
      <VoiceId>&lt;audio:VSM_090_040_001&gt;</VoiceId>
      <JapaneseText>うわっ……！
なに……！？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>1</Id>
      <OldPtr>278432</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>296856</PointerOffset>
      <VoiceId>&lt;audio:VSM_090_040_002&gt;</VoiceId>
      <JapaneseText>君たちのおかげで
いい感じにマナが
蓄積されたみたい</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>2</Id>
      <OldPtr>279860</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>296920</PointerOffset>
      <VoiceId>&lt;audio:VSM_090_040_003&gt;</VoiceId>
      <JapaneseText>マナ……！？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>3</Id>
      <OldPtr>280892</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>297120</PointerOffset>
      <VoiceId>&lt;audio:VSM_090_040_004&gt;</VoiceId>
      <JapaneseText>精霊さんからは大量に漏れ出る
余剰マナがあるんだ</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>4</Id>
      <BubbleId>0</BubbleId>
      <OldPtr>281304</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>297120</PointerOffset>
      <VoiceId>&lt;audio:VSM_090_040_005&gt;</VoiceId>
      <JapaneseText>そのマナがいっぱいになると
この指輪が力を発揮する</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>4</Id>
      <BubbleId>1</BubbleId>
      <OldPtr>281304</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>297120</PointerOffset>
      <VoiceId>&lt;audio:VSM_090_040_006&gt;</VoiceId>
      <JapaneseText>時間転移のね</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>4</Id>
      <BubbleId>2</BubbleId>
      <OldPtr>281304</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>297200</PointerOffset>
      <VoiceId>&lt;audio:VSM_090_040_007&gt;</VoiceId>
      <JapaneseText>待て！
どこへ行くつもりだ！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>7</Id>
      <OldPtr>281628</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>297268</PointerOffset>
      <VoiceId>&lt;audio:VSM_090_040_008&gt;</VoiceId>
      <JapaneseText>ダオスのところ</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>8</Id>
      <OldPtr>281864</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>297584</PointerOffset>
      <VoiceId>&lt;audio:VSM_090_040_012&gt;</VoiceId>
      <JapaneseText>待て、&lt;Rody&gt;！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>9</Id>
      <OldPtr>282700</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>297648</PointerOffset>
      <VoiceId>&lt;audio:VSM_090_040_013&gt;</VoiceId>
      <JapaneseText>くっ……！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>10</Id>
      <OldPtr>283300</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>297812</PointerOffset>
      <VoiceId>&lt;audio:VSM_090_040_015&gt;</VoiceId>
      <JapaneseText>ダオスって……
&lt;Claus&gt;さんたちが
倒したんだろ？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>11</Id>
      <OldPtr>283552</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>298008</PointerOffset>
      <VoiceId>&lt;audio:VSM_090_040_016&gt;</VoiceId>
      <JapaneseText>ああ。だが彼女は
自分の手でダオスを
倒したいと思ってる</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>12</Id>
      <BubbleId>0</BubbleId>
      <OldPtr>284132</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>298008</PointerOffset>
      <VoiceId>&lt;audio:VSM_090_040_017&gt;</VoiceId>
      <JapaneseText>ダオスと戦うため……
彼女は再びダオスがいる
時間へと旅立ったのだろう</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>12</Id>
      <BubbleId>1</BubbleId>
      <OldPtr>284132</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>298080</PointerOffset>
      <VoiceId>&lt;audio:VSM_090_040_018&gt;</VoiceId>
      <JapaneseText>でも、どうして……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>14</Id>
      <OldPtr>284380</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>298204</PointerOffset>
      <VoiceId>&lt;audio:VSM_090_040_019&gt;</VoiceId>
      <JapaneseText>&lt;Rody&gt;も、みんなと一緒で
世界を守るために
戦いたかったんじゃねーのか？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>15</Id>
      <OldPtr>284520</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>298344</PointerOffset>
      <VoiceId>&lt;audio:VSM_090_040_020&gt;</VoiceId>
      <JapaneseText>世界を守るか……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>16</Id>
      <BubbleId>0</BubbleId>
      <OldPtr>284660</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>298344</PointerOffset>
      <VoiceId>&lt;audio:VSM_090_040_021&gt;</VoiceId>
      <JapaneseText>……本当にこのアセリアを
守ったのは誰だったんだろうな</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>16</Id>
      <BubbleId>1</BubbleId>
      <OldPtr>284660</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>298520</PointerOffset>
      <VoiceId>&lt;audio:VSM_090_040_022&gt;</VoiceId>
      <JapaneseText>いや……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>18</Id>
      <BubbleId>0</BubbleId>
      <OldPtr>285024</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>298520</PointerOffset>
      <VoiceId>&lt;audio:VSM_090_040_023&gt;</VoiceId>
      <JapaneseText>さて、ここでお別れだ</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>18</Id>
      <BubbleId>1</BubbleId>
      <OldPtr>285024</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>298520</PointerOffset>
      <VoiceId>&lt;audio:VSM_090_040_024&gt;</VoiceId>
      <JapaneseText>君たちには君たちの
やらなければならないことが
あるだろう？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>18</Id>
      <BubbleId>2</BubbleId>
      <OldPtr>285024</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>298600</PointerOffset>
      <VoiceId>&lt;audio:VSM_090_040_025&gt;</VoiceId>
      <JapaneseText>そうだな。
&lt;Mel&gt;……帰ろう</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>21</Id>
      <OldPtr>285432</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>298676</PointerOffset>
      <VoiceId>&lt;audio:VSM_090_040_026&gt;</VoiceId>
      <JapaneseText>うん。わたしたちの時代に</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>4</SpeakerId>
      <Id>22</Id>
      <OldPtr>285840</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>298736</PointerOffset>
      <VoiceId>&lt;audio:VSM_090_040_027&gt;</VoiceId>
      <JapaneseText>じゃあな</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>23</Id>
      <OldPtr>286244</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>298812</PointerOffset>
      <VoiceId>&lt;audio:VSM_090_040_028&gt;</VoiceId>
      <JapaneseText>うん。また、会えるかな？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>24</Id>
      <OldPtr>286548</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>298904</PointerOffset>
      <VoiceId>&lt;audio:VSM_090_040_029&gt;</VoiceId>
      <JapaneseText>さぁ。だが……
機会があればたぶん、な</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>25</Id>
      <OldPtr>286688</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>298992</PointerOffset>
      <VoiceId>&lt;audio:VSM_090_040_030&gt;</VoiceId>
      <JapaneseText>いろいろ、
ありがとうございました</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>4</SpeakerId>
      <Id>26</Id>
      <OldPtr>287056</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>299048</PointerOffset>
      <VoiceId>&lt;audio:VSM_090_040_031&gt;</VoiceId>
      <JapaneseText>ああ</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>27</Id>
      <OldPtr>287252</OldPtr>
      <Status>To Do</Status>
    </Entry>
