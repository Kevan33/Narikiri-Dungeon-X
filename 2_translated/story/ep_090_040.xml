    <Entry>
      <PointerOffset>297120</PointerOffset>
      <VoiceId>&lt;audio:VSM_090_040_006&gt;</VoiceId>
      <JapaneseText>精霊さんからは大量に漏れ出る
余剰マナがあるんだそのマナがいっぱいになると
この指輪が力を発揮する時間転移のね</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>4</Id>
      <BubbleId>2</BubbleId>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>297200</PointerOffset>
      <VoiceId>&lt;audio:VSM_090_040_007&gt;</VoiceId>
      <JapaneseText>待て！
どこへ行くつもりだ！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>7</Id>
      <Status>To Do</Status>
