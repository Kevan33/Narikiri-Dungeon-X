      <JapaneseText>どっちでもいいってさ</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>21</Id>
      <OldPtr>269740</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>283504</PointerOffset>
      <JapaneseText>とにかく、
追いかけてみよ</JapaneseText>
