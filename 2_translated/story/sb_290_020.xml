    <Entry>
      <PointerOffset>282244</PointerOffset>
      <JapaneseText>さっき、何か落ちたの……
ここらへんか？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>1</Id>
      <OldPtr>259480</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>282300</PointerOffset>
      <JapaneseText>もう……早いよ、&lt;Dio&gt;</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>2</Id>
      <OldPtr>260160</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>282376</PointerOffset>
      <JapaneseText>……って……
ここ、なんか来たことない？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>3</Id>
      <OldPtr>261592</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>282444</PointerOffset>
      <JapaneseText>そう言われれば……
そうかも……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>4</Id>
      <OldPtr>261732</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>282512</PointerOffset>
      <JapaneseText>クルッ！　クルッ！
クルールッ！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>4</SpeakerId>
      <Id>5</Id>
      <OldPtr>262820</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>282568</PointerOffset>
      <JapaneseText>あれは……&lt;Couleur&gt;！？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>6</Id>
      <OldPtr>263464</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>282632</PointerOffset>
      <JapaneseText>でも&lt;Couleur&gt;は、
ここにいるぜ？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>7</Id>
      <OldPtr>263604</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>282700</PointerOffset>
      <JapaneseText>それじゃあ……
&lt;Couleur&gt;のお兄さん？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>8</Id>
      <OldPtr>264080</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>282768</PointerOffset>
      <JapaneseText>&lt;Couleur&gt;の姉ちゃんかも
しれねーぜ</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>9</Id>
      <OldPtr>264648</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>282844</PointerOffset>
      <JapaneseText>どっちでもいいよ！
でも、&lt;Couleur&gt;って……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>10</Id>
      <OldPtr>264944</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>282896</PointerOffset>
      <JapaneseText>クルール！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>5</SpeakerId>
      <Id>11</Id>
      <OldPtr>265860</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>282960</PointerOffset>
      <JapaneseText>あっ、&lt;Couleur&gt;が
行っちゃうよ！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>12</Id>
      <OldPtr>266176</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>283004</PointerOffset>
      <JapaneseText>クルール！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>4</SpeakerId>
      <Id>13</Id>
      <OldPtr>267376</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>283072</PointerOffset>
      <JapaneseText>なんだよ、おまえ、
行きたいのか？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>14</Id>
      <OldPtr>267640</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
