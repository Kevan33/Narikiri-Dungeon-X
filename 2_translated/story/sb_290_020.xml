      <Id>15</Id>
      <OldPtr>267936</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>283208</PointerOffset>
      <JapaneseText>姉ちゃんと再会できるかも
なんだもんな……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>16</Id>
      <BubbleId>0</BubbleId>
