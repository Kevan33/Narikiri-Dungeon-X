      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>283208</PointerOffset>
      <JapaneseText>……どうする？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>16</Id>
      <BubbleId>1</BubbleId>
      <OldPtr>268076</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>283292</PointerOffset>
      <JapaneseText>もちろん……&lt;Couleur&gt;が
お兄さんと会えるんなら……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>18</Id>
      <OldPtr>268484</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>283340</PointerOffset>
      <JapaneseText>姉ちゃんだろ？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>19</Id>
      <OldPtr>268624</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>283388</PointerOffset>
      <JapaneseText>クルール！！</JapaneseText>
