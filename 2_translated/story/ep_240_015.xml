    <Entry>
      <PointerOffset>309600</PointerOffset>
      <VoiceId>&lt;audio:VSM_240_010_039&gt;</VoiceId>
      <JapaneseText>エト、平気！？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>1</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>309704</PointerOffset>
      <VoiceId>&lt;audio:VSM_240_010_040&gt;</VoiceId>
      <JapaneseText>ぼく思い出したよ……
いろいろ思い出しちゃった……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>2</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>309804</PointerOffset>
      <VoiceId>&lt;audio:VSM_240_010_041&gt;</VoiceId>
      <JapaneseText>思い出したって……
自分が精霊だったこと……？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>3</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>309916</PointerOffset>
      <VoiceId>&lt;audio:VSM_240_010_042&gt;</VoiceId>
      <JapaneseText>うん……たくさん悪さした……
……精霊の力で街壊したり……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>4</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>310160</PointerOffset>
      <VoiceId>&lt;audio:VSM_240_010_044&gt;</VoiceId>
      <JapaneseText>みんなのことが嫌いだった。
ぼくの存在に気づかなくて
すごく悲しかった……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>5</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>310276</PointerOffset>
      <VoiceId>&lt;audio:VSM_240_010_045&gt;</VoiceId>
      <JapaneseText>ぼく、いけない子なんだ……
きみたちと一緒にいる
資格なんて……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>6</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>310352</PointerOffset>
      <VoiceId>&lt;audio:VSM_240_010_046&gt;</VoiceId>
      <JapaneseText>そんなことないよ、エト！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>7</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>310660</PointerOffset>
      <VoiceId>&lt;audio:VSM_240_010_049&gt;</VoiceId>
      <JapaneseText></JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>8</Id>
      <BubbleId>0</BubbleId>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>310660</PointerOffset>
      <VoiceId>&lt;audio:VSM_240_010_050&gt;</VoiceId>
      <JapaneseText>誰でも、悪いことをしちゃう
可能性がある大切なのはその後、
それとどう向き合うか
ってことなんじゃないかな</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>8</Id>
      <BubbleId>1</BubbleId>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>310732</PointerOffset>
      <VoiceId>&lt;audio:VSM_240_010_051&gt;</VoiceId>
      <JapaneseText>どう、向き合うか……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>10</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>310852</PointerOffset>
      <VoiceId>&lt;audio:VSM_240_010_052&gt;</VoiceId>
      <JapaneseText>ヤな思い出を受け入れるって
覚悟したから、エトの
記憶が戻ったんだろ？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>11</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>310936</PointerOffset>
      <VoiceId>&lt;audio:VSM_240_010_053&gt;</VoiceId>
      <JapaneseText>ぼくは……
ふたりのために……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>12</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>311144</PointerOffset>
      <VoiceId>&lt;audio:VSM_240_010_054&gt;</VoiceId>
      <JapaneseText></JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>13</Id>
      <BubbleId>0</BubbleId>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>311144</PointerOffset>
      <VoiceId>&lt;audio:VSM_240_010_055&gt;</VoiceId>
      <JapaneseText>&lt;Dio&gt;&lt;Mel&gt;そっか……ふたりがいたから、
ぼくはどんないやな思い出も
受け止められた……やっぱり……ぼくは……
との
『お母さん』なんだ……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>13</Id>
      <BubbleId>1</BubbleId>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>311332</PointerOffset>
      <VoiceId>&lt;audio:VSM_240_010_057&gt;</VoiceId>
      <JapaneseText>へん……エトなんて、
『お母さん』って感じ
と違うくせに……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>15</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>311560</PointerOffset>
      <VoiceId>&lt;audio:VSM_240_010_058&gt;</VoiceId>
      <JapaneseText></JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>16</Id>
      <BubbleId>0</BubbleId>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>311560</PointerOffset>
      <VoiceId>&lt;audio:VSM_240_010_059&gt;</VoiceId>
      <JapaneseText></JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>16</Id>
      <BubbleId>1</BubbleId>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>311560</PointerOffset>
      <VoiceId>&lt;audio:VSM_240_010_060&gt;</VoiceId>
      <JapaneseText>……かもね……でも……きみたちとの思い出が
ぼくをぼくでいさせてくれたよ……精霊のぼくじゃなくて、
きみたちと一緒に暮らしてきた
ぼくで……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>16</Id>
      <BubbleId>2</BubbleId>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>311672</PointerOffset>
      <VoiceId>&lt;audio:VSM_240_010_061&gt;</VoiceId>
      <JapaneseText>きみたちがいてくれてよかった……
きみたちの役に立てて……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>19</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>311736</PointerOffset>
      <VoiceId>&lt;audio:VSM_240_010_062&gt;</VoiceId>
      <JapaneseText>エト……！？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>20</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>311812</PointerOffset>
      <VoiceId>&lt;audio:VSM_240_010_063&gt;</VoiceId>
      <JapaneseText>……気を失ってるだけか</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>4</SpeakerId>
      <Id>21</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>311884</PointerOffset>
      <VoiceId>&lt;audio:VSM_240_010_064&gt;</VoiceId>
      <JapaneseText>はぁ……びっくりした</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>5</SpeakerId>
      <Id>22</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>311968</PointerOffset>
      <VoiceId>&lt;audio:VSM_240_010_065&gt;</VoiceId>
      <JapaneseText>ともかく、一旦、
家に戻って……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>6</SpeakerId>
      <Id>23</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>312036</PointerOffset>
      <VoiceId>&lt;audio:VSM_240_010_066&gt;</VoiceId>
      <JapaneseText>ダオス……！？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>7</SpeakerId>
      <Id>24</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>312100</PointerOffset>
      <VoiceId>&lt;audio:VSM_240_010_067&gt;</VoiceId>
      <JapaneseText>…………！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>8</SpeakerId>
      <Id>25</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>312172</PointerOffset>
      <VoiceId>&lt;audio:VSM_240_010_068&gt;</VoiceId>
      <JapaneseText>どうしてここに……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>7</SpeakerId>
      <Id>26</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>312256</PointerOffset>
      <VoiceId>&lt;audio:VSM_240_010_069&gt;</VoiceId>
      <JapaneseText>罪を犯した者を……
制裁するため</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>8</SpeakerId>
      <Id>27</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>312324</PointerOffset>
      <VoiceId>&lt;audio:VSM_240_010_070&gt;</VoiceId>
      <JapaneseText>罪を犯した……？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>7</SpeakerId>
      <Id>28</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>312404</PointerOffset>
      <VoiceId>&lt;audio:VSM_240_010_071&gt;</VoiceId>
      <JapaneseText>たぶんこの『虹輪』のことです</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>29</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>312608</PointerOffset>
      <VoiceId>&lt;audio:VSM_240_010_073&gt;</VoiceId>
      <JapaneseText>&lt;Rondoline&gt;どけ、。
死にたくないのであれば</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>8</SpeakerId>
      <Id>30</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>312676</PointerOffset>
      <VoiceId>&lt;audio:VSM_240_010_074&gt;</VoiceId>
      <JapaneseText>……どかないよ</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>7</SpeakerId>
      <Id>31</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>312784</PointerOffset>
      <VoiceId>&lt;audio:VSM_240_010_075&gt;</VoiceId>
      <JapaneseText>&lt;Rody&gt;さん……
ダオスとお知り合い、
なのですか……？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>9</SpeakerId>
      <Id>32</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>312852</PointerOffset>
      <VoiceId>&lt;audio:VSM_240_010_076&gt;</VoiceId>
      <JapaneseText>お知り合いだよ</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>7</SpeakerId>
      <Id>33</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>312944</PointerOffset>
      <VoiceId>&lt;audio:VSM_240_010_077&gt;</VoiceId>
      <JapaneseText>なんせ、私にこの指輪を
くれた人だもん</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>7</SpeakerId>
      <Id>34</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>313080</PointerOffset>
      <VoiceId>&lt;audio:VSM_240_010_078&gt;</VoiceId>
      <JapaneseText></JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>7</SpeakerId>
      <Id>35</Id>
      <BubbleId>0</BubbleId>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>313080</PointerOffset>
      <VoiceId>&lt;audio:VSM_240_010_079&gt;</VoiceId>
      <JapaneseText>退いて、ダオス……
私はあなたが手を汚すのを…………見たくない！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>7</SpeakerId>
      <Id>35</Id>
      <BubbleId>1</BubbleId>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>313180</PointerOffset>
      <VoiceId>&lt;audio:VSM_240_010_080&gt;</VoiceId>
      <JapaneseText>意思が沿わぬならば
奴らともども
おまえを消すまで</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>8</SpeakerId>
      <Id>37</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>313352</PointerOffset>
      <VoiceId>&lt;audio:VSM_240_010_081&gt;</VoiceId>
      <JapaneseText></JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>38</Id>
      <BubbleId>0</BubbleId>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>313352</PointerOffset>
      <VoiceId>&lt;audio:VSM_240_010_082&gt;</VoiceId>
      <JapaneseText>待てよ！　あんたは
オレらの罪がどうとか
言ってっけど、オレらは
まだそいつの後始末を
してねーんだって</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>38</Id>
      <BubbleId>1</BubbleId>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>313692</PointerOffset>
      <VoiceId>&lt;audio:VSM_240_010_084&gt;</VoiceId>
      <JapaneseText></JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>40</Id>
      <BubbleId>0</BubbleId>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>313692</PointerOffset>
      <VoiceId>&lt;audio:VSM_240_010_085&gt;</VoiceId>
      <JapaneseText></JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>40</Id>
      <BubbleId>1</BubbleId>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>313692</PointerOffset>
      <VoiceId>&lt;audio:VSM_240_010_086&gt;</VoiceId>
      <JapaneseText>まだ、どうしてこんなことが
起きたかわかんないままだもんちゃんとその罪と向き合って
何が悪かったのか、それをわたしたちが
どうすればいいのか、
ちゃんと答えを出したい</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>40</Id>
      <BubbleId>2</BubbleId>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>313956</PointerOffset>
      <VoiceId>&lt;audio:VSM_240_010_087&gt;</VoiceId>
      <JapaneseText>&lt;Mel&gt;</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>43</Id>
      <BubbleId>0</BubbleId>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>313956</PointerOffset>
      <VoiceId>&lt;audio:VSM_240_010_088&gt;</VoiceId>
      <JapaneseText></JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>43</Id>
      <BubbleId>1</BubbleId>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>313956</PointerOffset>
      <VoiceId>&lt;audio:VSM_240_010_089&gt;</VoiceId>
      <JapaneseText>もしの魔法の使い方が
悪かったんなら、
それを改めなきゃだしオレのフォローが
悪かったんなら、なんか
考えなきゃいけないだから、今、あんたに
『セイサイ』させられないんだ！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>43</Id>
      <BubbleId>2</BubbleId>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>314184</PointerOffset>
      <VoiceId>&lt;audio:VSM_240_010_090&gt;</VoiceId>
      <JapaneseText></JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>8</SpeakerId>
      <Id>46</Id>
      <BubbleId>0</BubbleId>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>314184</PointerOffset>
      <VoiceId>&lt;audio:VSM_240_010_091&gt;</VoiceId>
      <JapaneseText></JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>8</SpeakerId>
      <Id>46</Id>
      <BubbleId>1</BubbleId>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>314184</PointerOffset>
      <VoiceId>&lt;audio:VSM_240_010_092&gt;</VoiceId>
      <JapaneseText>おまえたちの罪は
私が知っているおまえたちが
それを知ったとて、
再び罪を繰り返すだけだから、ここで
おまえたちを消す。
向き合う必要はない</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>8</SpeakerId>
      <Id>46</Id>
      <BubbleId>2</BubbleId>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>314376</PointerOffset>
      <VoiceId>&lt;audio:VSM_240_010_094&gt;</VoiceId>
      <JapaneseText>でも……わたしたちも
ここでやられるわけには
いかないよ</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>49</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>314460</PointerOffset>
