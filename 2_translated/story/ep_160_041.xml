  <Strings>
    <Section>Main</Section>
    <Entry>
      <PointerOffset>301076</PointerOffset>
      <VoiceId>&lt;audio:VSM_160_040_035&gt;</VoiceId>
      <JapaneseText>ぐぅ</JapaneseText>
      <EnglishText>Guh...</EnglishText>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>1</Id>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset>301136</PointerOffset>
      <VoiceId>&lt;audio:VSM_160_040_036&gt;</VoiceId>
      <JapaneseText>今だ！</JapaneseText>
      <EnglishText>Quick!</EnglishText>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>2</Id>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset>301292</PointerOffset>
      <VoiceId>&lt;audio:VSM_160_040_038&gt;</VoiceId>
      <JapaneseText>バジルさん！
しっかりしてくれよ……！</JapaneseText>
      <EnglishText>Mister Basil! Hang in there!</EnglishText>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>3</Id>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset>301428</PointerOffset>
      <VoiceId>&lt;audio:VSM_160_040_039Z&gt;</VoiceId>
      <JapaneseText>夢はいつでも、
何者かに歪められる……</JapaneseText>
      <EnglishText>Dreams will always be distorted
by someone or something...</EnglishText>
      <Notes/>
      <SpeakerId>4</SpeakerId>
      <Id>4</Id>
      <BubbleId>0</BubbleId>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset>301428</PointerOffset>
      <VoiceId>&lt;audio:VSM_160_040_040Z&gt;</VoiceId>
      <JapaneseText>僕が
そうだったように……</JapaneseText>
      <EnglishText>That's...the one thing I learned...</EnglishText>
      <Notes/>
      <SpeakerId>4</SpeakerId>
      <Id>4</Id>
      <BubbleId>1</BubbleId>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset>301556</PointerOffset>
      <VoiceId>&lt;audio:VSM_160_040_041&gt;</VoiceId>
      <JapaneseText>ウソだ……ウソだよ……</JapaneseText>
      <EnglishText>No...that's a lie...</EnglishText>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>6</Id>
      <BubbleId>0</BubbleId>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset>301556</PointerOffset>
      <VoiceId>&lt;audio:VSM_160_040_042&gt;</VoiceId>
      <JapaneseText>オレに言ったのは、
何だったんだ！</JapaneseText>
      <EnglishText>Why did you tell me those things,
then? What are dreams good for!?</EnglishText>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>6</Id>
      <BubbleId>1</BubbleId>
      <Status>Problematic</Status>
    </Entry>
    <Entry>
      <PointerOffset>301792</PointerOffset>
      <VoiceId>&lt;audio:VSM_160_040_043Z&gt;</VoiceId>
      <JapaneseText>ハハハ……
１００年前の僕は
何も知らなかった</JapaneseText>
      <EnglishText>Hahahaha... &lt;Dio&gt;...100 years ago,
I really didn't know anything... </EnglishText>
      <Notes/>
      <SpeakerId>4</SpeakerId>
      <Id>8</Id>
      <BubbleId>0</BubbleId>
      <Status>Problematic</Status>
    </Entry>
    <Entry>
      <PointerOffset>301792</PointerOffset>
      <VoiceId>&lt;audio:VSM_160_040_044Z&gt;</VoiceId>
      <JapaneseText>無知だったのさ。
現実なんて夢は
夢のまま終わるだけだ</JapaneseText>
      <EnglishText>I was ignorant. Of course in reality a
dream can only end as a dream...</EnglishText>
      <Notes/>
      <SpeakerId>4</SpeakerId>
      <Id>8</Id>
      <BubbleId>1</BubbleId>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset>301792</PointerOffset>
      <VoiceId>&lt;audio:VSM_160_040_045Z&gt;</VoiceId>
      <JapaneseText>僕はもう何者にもなれない……
破滅するだけさ……</JapaneseText>
      <EnglishText>I'm worthless... I'm doomed...</EnglishText>
      <Notes/>
      <SpeakerId>4</SpeakerId>
      <Id>8</Id>
      <BubbleId>2</BubbleId>
      <Status>Problematic</Status>
    </Entry>
    <Entry>
      <PointerOffset>301956</PointerOffset>
      <VoiceId>&lt;audio:VSM_160_040_046&gt;</VoiceId>
      <JapaneseText>バジルさん！！</JapaneseText>
      <EnglishText>Mister Basil!</EnglishText>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>11</Id>
      <BubbleId>0</BubbleId>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset>301956</PointerOffset>
      <VoiceId>&lt;audio:VSM_160_040_047&gt;</VoiceId>
      <JapaneseText>そんなことないって
言ってくれよ！</JapaneseText>
      <EnglishText>Don't say things like that!</EnglishText>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>11</Id>
      <BubbleId>1</BubbleId>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset>301956</PointerOffset>
      <VoiceId>&lt;audio:VSM_160_040_048&gt;</VoiceId>
      <JapaneseText>そんなことないって……！</JapaneseText>
      <EnglishText>Don't...please...!</EnglishText>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>11</Id>
      <BubbleId>2</BubbleId>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset>302040</PointerOffset>
      <VoiceId>&lt;audio:VSM_160_040_049&gt;</VoiceId>
      <JapaneseText>&lt;Dio&gt;……
バジルさんはもう……</JapaneseText>
      <EnglishText>&lt;Dio&gt;...Basil has already...</EnglishText>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>14</Id>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset>302112</PointerOffset>
      <VoiceId>&lt;audio:VSM_160_040_050&gt;</VoiceId>
      <JapaneseText>歪め……られる……</JapaneseText>
      <EnglishText>Dreams...don't exist...</EnglishText>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>15</Id>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset>302176</PointerOffset>
      <VoiceId>&lt;audio:VSM_160_040_051&gt;</VoiceId>
      <JapaneseText>&lt;Dio&gt;……</JapaneseText>
      <EnglishText>&lt;Dio&gt;...</EnglishText>
      <Notes/>
      <SpeakerId>5</SpeakerId>
      <Id>16</Id>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset>302288</PointerOffset>
      <VoiceId>&lt;audio:VSM_160_040_052&gt;</VoiceId>
      <JapaneseText>オレ、家帰るよ……</JapaneseText>
      <EnglishText>I want to go home...</EnglishText>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>17</Id>
      <BubbleId>0</BubbleId>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset>302288</PointerOffset>
      <VoiceId>&lt;audio:VSM_160_040_053&gt;</VoiceId>
      <JapaneseText>もう……嫌だ……オレ</JapaneseText>
      <EnglishText>No more...please...</EnglishText>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>17</Id>
      <BubbleId>1</BubbleId>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset>302356</PointerOffset>
      <VoiceId>&lt;audio:VSM_160_040_054&gt;</VoiceId>
      <JapaneseText>あ、&lt;Dio&gt;……！</JapaneseText>
      <EnglishText>&lt;Dio&gt;! Don't run off on your own!</EnglishText>
      <Notes/>
      <SpeakerId>5</SpeakerId>
      <Id>19</Id>
      <Status>Proofreading</Status>
    </Entry>
  </Strings>
