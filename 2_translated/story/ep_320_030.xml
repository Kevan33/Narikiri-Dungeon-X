      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>271828</PointerOffset>
      <VoiceId>&lt;audio:VSM_320_030_004&gt;</VoiceId>
      <JapaneseText>……くそっ……
何やってんだよ……！そんな連中、
オレがいれば、
全滅させてやるのに……！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>3</Id>
      <BubbleId>1</BubbleId>
      <Status>To Do</Status>
    </Entry>
