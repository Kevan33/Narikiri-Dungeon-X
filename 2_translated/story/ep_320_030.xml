    <Entry>
      <PointerOffset>271996</PointerOffset>
      <VoiceId>&lt;audio:VSM_320_030_006&gt;</VoiceId>
      <JapaneseText>１３歳の時、
オレは軍人になろうと決めた両親の仇を討ちたかった。
オレにはその選択しかなかった</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>5</Id>
      <BubbleId>1</BubbleId>
      <Status>To Do</Status>
    </Entry>
