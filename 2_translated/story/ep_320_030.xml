    <Entry>
      <PointerOffset>272140</PointerOffset>
      <VoiceId>&lt;audio:VSM_320_030_008&gt;</VoiceId>
      <JapaneseText>だから、全部、
戦争のせいにすんだなデリス・カーラーンを
滅ぼしたのも全部</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>7</Id>
      <BubbleId>1</BubbleId>
      <Status>To Do</Status>
    </Entry>
