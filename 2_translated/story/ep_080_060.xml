    <Entry>
      <PointerOffset>278468</PointerOffset>
      <VoiceId>&lt;audio:VSM_080_060_001&gt;</VoiceId>
      <JapaneseText>夢か……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>1</Id>
      <OldPtr>260012</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>278548</PointerOffset>
      <VoiceId>&lt;audio:VSM_080_060_002&gt;</VoiceId>
      <JapaneseText>よーし……がんばっか……！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>2</Id>
      <OldPtr>260984</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>278644</PointerOffset>
      <VoiceId>&lt;audio:VSM_080_060_003&gt;</VoiceId>
      <JapaneseText>ずいぶん、はりきっちゃって
どうしたんだか</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>3</Id>
      <OldPtr>261248</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>278712</PointerOffset>
      <VoiceId>&lt;audio:VSM_080_060_004&gt;</VoiceId>
      <JapaneseText>なんでもねって</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>4</Id>
      <OldPtr>261612</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>278780</PointerOffset>
      <VoiceId>&lt;audio:VSM_080_060_005&gt;</VoiceId>
      <JapaneseText>……ねぇ、&lt;Dio&gt;</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>5</Id>
      <OldPtr>262048</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>278836</PointerOffset>
      <VoiceId>&lt;audio:VSM_080_060_006&gt;</VoiceId>
      <JapaneseText>ん？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>6</Id>
      <OldPtr>262348</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>278932</PointerOffset>
      <VoiceId>&lt;audio:VSM_080_060_007&gt;</VoiceId>
      <JapaneseText>本当にわたしたち、
何にでもなれると思う？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>7</Id>
      <OldPtr>262488</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>279000</PointerOffset>
      <VoiceId>&lt;audio:VSM_080_060_008&gt;</VoiceId>
      <JapaneseText>どーゆーこと？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>8</Id>
      <OldPtr>262684</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>279096</PointerOffset>
      <VoiceId>&lt;audio:VSM_080_060_009&gt;</VoiceId>
      <JapaneseText>あの人、わたしたちは
真っ白だって言ってた</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>9</Id>
      <OldPtr>262932</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>279192</PointerOffset>
      <VoiceId>&lt;audio:VSM_080_060_010&gt;</VoiceId>
      <JapaneseText>ああ。だから、
オレらはなんにでも
なれるって</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>10</Id>
      <OldPtr>263236</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>279296</PointerOffset>
      <VoiceId>&lt;audio:VSM_080_060_011&gt;</VoiceId>
      <JapaneseText>違うよ……
真っ白ってことは、
何もないってことだよ</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>11</Id>
      <OldPtr>263540</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>279360</PointerOffset>
      <VoiceId>&lt;audio:VSM_080_060_012&gt;</VoiceId>
      <JapaneseText>何もない？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>12</Id>
      <OldPtr>263680</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>279488</PointerOffset>
      <VoiceId>&lt;audio:VSM_080_060_013&gt;</VoiceId>
      <JapaneseText>わたしたち、子どもだよ。
困ってる人探してても
誰も頼りになんてしてくれない</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>13</Id>
      <OldPtr>263928</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>279920</PointerOffset>
      <VoiceId>&lt;audio:VSM_080_060_018&gt;</VoiceId>
      <JapaneseText>魔術使えば暴走させちゃう。
精霊と戦うのも精一杯だし……！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>14</Id>
      <OldPtr>264276</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>280008</PointerOffset>
      <VoiceId>&lt;audio:VSM_080_060_019&gt;</VoiceId>
      <JapaneseText>こんなんじゃ、
何もできないよ……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>15</Id>
      <OldPtr>264524</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>280296</PointerOffset>
      <VoiceId>&lt;audio:VSM_080_060_021&gt;</VoiceId>
      <JapaneseText>……&lt;Mel&gt;、
不安に思うことなんてないよ</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>16</Id>
      <BubbleId>0</BubbleId>
      <OldPtr>265508</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>280296</PointerOffset>
      <VoiceId>&lt;audio:VSM_080_060_022&gt;</VoiceId>
      <JapaneseText>もし、魔術の暴走が止められたら、
帰ろう、あの家に</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>16</Id>
      <BubbleId>1</BubbleId>
      <OldPtr>265508</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>280296</PointerOffset>
      <VoiceId>&lt;audio:VSM_080_060_023&gt;</VoiceId>
      <JapaneseText>今までどおりに
暮らせばいいんだシ。
でしょ？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>16</Id>
      <BubbleId>2</BubbleId>
      <OldPtr>265508</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>280392</PointerOffset>
      <VoiceId>&lt;audio:VSM_080_060_024&gt;</VoiceId>
      <JapaneseText>ゴメンなさい、エト。
つまんないこと言って</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>19</Id>
      <OldPtr>267232</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>280480</PointerOffset>
      <VoiceId>&lt;audio:VSM_080_060_025&gt;</VoiceId>
      <JapaneseText>&lt;Dio&gt;も。今の忘れて。
さぁ、行こう</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>20</Id>
      <OldPtr>267372</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>280568</PointerOffset>
      <VoiceId>&lt;audio:VSM_080_060_026&gt;</VoiceId>
      <JapaneseText>ずっと不安だったんだよ、
&lt;Mel&gt;は</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>21</Id>
      <OldPtr>268044</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>280912</PointerOffset>
      <VoiceId>&lt;audio:VSM_080_060_029&gt;</VoiceId>
      <JapaneseText>オレがやるよ、
魔術の暴走を止めるのだって、
『なりきり士』の仕事だって</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>22</Id>
      <BubbleId>0</BubbleId>
      <OldPtr>268864</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>280912</PointerOffset>
      <VoiceId>&lt;audio:VSM_080_060_030&gt;</VoiceId>
      <JapaneseText>無理して、
&lt;Mel&gt;も来ることない。
エトだって……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>22</Id>
      <BubbleId>1</BubbleId>
      <OldPtr>268864</OldPtr>
      <Status>To Do</Status>
    </Entry>
