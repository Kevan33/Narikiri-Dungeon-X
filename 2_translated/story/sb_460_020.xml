    <Entry>
      <PointerOffset>277984</PointerOffset>
      <JapaneseText>おやっ、見かけない顔だね。
あんたもこの村に住みたい
希望者かい？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>1</Id>
      <OldPtr>259044</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>278092</PointerOffset>
      <JapaneseText>おや、そちらにいるのは
&lt;Cless&gt;ちゃんじゃないの。
お知り合い？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>2</Id>
      <OldPtr>259212</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>278140</PointerOffset>
      <JapaneseText>あ、はい……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>3</Id>
      <OldPtr>259352</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>278244</PointerOffset>
      <JapaneseText>&lt;Mint&gt;さんがいるのにダメよ、
火遊びはほどほどにしないと</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>4</Id>
      <OldPtr>259492</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>278308</PointerOffset>
      <JapaneseText>あ、いえ、
そういうのでは……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>5</Id>
      <OldPtr>259724</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>278388</PointerOffset>
      <JapaneseText>ヒドイ！　&lt;Cless&gt;、
私のこと、遊びだったの？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>6</Id>
      <OldPtr>260024</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>278440</PointerOffset>
      <JapaneseText>&lt;Rody&gt;まで……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>7</Id>
      <OldPtr>260520</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>278508</PointerOffset>
      <JapaneseText>希望者って
わけじゃないけど……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>8</Id>
      <OldPtr>260668</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>278612</PointerOffset>
      <JapaneseText>この村は、
１年半前のあの惨劇から、
立ち直ろうとしているの</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>9</Id>
      <OldPtr>260808</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>278676</PointerOffset>
      <JapaneseText>ね？　&lt;Cless&gt;ちゃん</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>10</Id>
      <OldPtr>261316</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>278728</PointerOffset>
      <JapaneseText>あ、ええ、まあ……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>11</Id>
      <OldPtr>261456</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>278968</PointerOffset>
      <JapaneseText>避難して生き残った人と、
新しく移り住んできた人で
協力して村を再建したのよ</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>12</Id>
      <BubbleId>0</BubbleId>
      <OldPtr>261604</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>278968</PointerOffset>
      <JapaneseText>私はこの村長いけど、
新しい人は入ってくるななんて、
言うつもりは毛頭ないわ</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>12</Id>
      <BubbleId>1</BubbleId>
      <OldPtr>261604</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>278968</PointerOffset>
      <JapaneseText>ちゃんと村のルールを
守ってくれさえすればね</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>12</Id>
      <BubbleId>2</BubbleId>
      <OldPtr>261604</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>279040</PointerOffset>
      <JapaneseText>んじゃあ、
オレたちもここに住もっか</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>4</SpeakerId>
      <Id>15</Id>
      <OldPtr>261848</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>279120</PointerOffset>
      <JapaneseText>……きみ、そんなに
&lt;Red&gt;エトスハウス&lt;White&gt;がいや？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>5</SpeakerId>
      <Id>16</Id>
      <OldPtr>262476</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>279180</PointerOffset>
      <JapaneseText>そういうことと
違くって</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>4</SpeakerId>
      <Id>17</Id>
      <OldPtr>262672</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>279396</PointerOffset>
      <JapaneseText>やっぱり住むなら、
穏やかな環境よね</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>18</Id>
      <BubbleId>0</BubbleId>
      <OldPtr>262812</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>279396</PointerOffset>
      <JapaneseText>この村はあの惨劇を除けば、
ずっと平和そのものよね</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>18</Id>
      <BubbleId>1</BubbleId>
      <OldPtr>262812</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>279396</PointerOffset>
      <JapaneseText>この村であった事件って言えば、
２００年ほど前にあったらしい
誘拐事件くらいかしらね？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>18</Id>
      <BubbleId>2</BubbleId>
      <OldPtr>262812</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>279452</PointerOffset>
      <JapaneseText>２００年前の誘拐事件？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>21</Id>
      <OldPtr>263704</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>279620</PointerOffset>
      <JapaneseText>あら？　&lt;Cless&gt;ちゃん、
知らないの？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>22</Id>
      <OldPtr>263844</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>279672</PointerOffset>
      <JapaneseText>誘拐事件、ですか？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>6</SpeakerId>
      <Id>23</Id>
      <OldPtr>263992</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>279848</PointerOffset>
      <JapaneseText>怪しい連中が
ちっちゃい女の子連れて、
この村に来たの</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>24</Id>
      <BubbleId>0</BubbleId>
      <OldPtr>264132</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>279848</PointerOffset>
      <JapaneseText>３歳くらいの子だった
らしいんだけど</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>24</Id>
      <BubbleId>1</BubbleId>
      <OldPtr>264132</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>279848</PointerOffset>
      <JapaneseText>どうやら、どこかで
さらってきたらしくて</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>24</Id>
      <BubbleId>2</BubbleId>
      <OldPtr>264132</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>279892</PointerOffset>
      <JapaneseText>へぇ……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>4</SpeakerId>
      <Id>27</Id>
      <OldPtr>264272</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>279976</PointerOffset>
      <JapaneseText>確か、&lt;Rody&gt;って
名前の子だったわね</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>28</Id>
      <OldPtr>264412</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>280088</PointerOffset>
      <JapaneseText>え？　私……？
いやぁ、偶然だって</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>29</Id>
      <BubbleId>0</BubbleId>
      <OldPtr>265480</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>280088</PointerOffset>
      <JapaneseText>同じ呼び方の子なんて
いくらでもいるっしょ</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>29</Id>
      <BubbleId>1</BubbleId>
      <OldPtr>265480</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>280152</PointerOffset>
      <JapaneseText>そう、かなぁ……
そうかも……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>6</SpeakerId>
      <Id>31</Id>
      <OldPtr>265620</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>280224</PointerOffset>
      <JapaneseText>んで、その子どもは
どうなったんだ？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>4</SpeakerId>
      <Id>32</Id>
      <OldPtr>265864</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>280396</PointerOffset>
      <JapaneseText>ちゃんと救出されたわよ</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>33</Id>
      <BubbleId>0</BubbleId>
      <OldPtr>266544</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>280396</PointerOffset>
      <JapaneseText>でも、その前にその誘拐犯
ってのが、宿屋に立てこもって
大変だったんだって</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>33</Id>
      <BubbleId>1</BubbleId>
      <OldPtr>266544</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>280396</PointerOffset>
      <JapaneseText>村の連中は
誰も手を出せなくて</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>33</Id>
      <BubbleId>2</BubbleId>
      <OldPtr>266544</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>280456</PointerOffset>
      <JapaneseText>でも、助かったんですよね？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>6</SpeakerId>
      <Id>36</Id>
      <OldPtr>266684</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>280568</PointerOffset>
      <JapaneseText>そうなのよね。結局、
事件の顛末については
どこにも残ってないのよね</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>37</Id>
      <OldPtr>266824</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>280640</PointerOffset>
      <JapaneseText>この村で、そんなことが
あったんですね</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>38</Id>
      <OldPtr>266992</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>280840</PointerOffset>
      <JapaneseText>そうなのよ～</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>39</Id>
      <BubbleId>0</BubbleId>
      <OldPtr>267132</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>280840</PointerOffset>
      <JapaneseText>そんな誘拐事件が２００年後の
今に語り継がれちゃうくらい、
平和な村よ</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>39</Id>
      <BubbleId>1</BubbleId>
      <OldPtr>267132</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>280840</PointerOffset>
      <JapaneseText>そのうえ、今は&lt;Cless&gt;ちゃんが
ちゃんとこの村を守って
くれてるから安心よ？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>39</Id>
      <BubbleId>2</BubbleId>
      <OldPtr>267132</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>280928</PointerOffset>
      <JapaneseText>こんなのどかな村で、
昔、そんなことが
あったんですね</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>6</SpeakerId>
      <Id>42</Id>
      <OldPtr>267280</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>281124</PointerOffset>
      <JapaneseText>そうなのよ～</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>43</Id>
      <BubbleId>0</BubbleId>
      <OldPtr>267420</OldPtr>
