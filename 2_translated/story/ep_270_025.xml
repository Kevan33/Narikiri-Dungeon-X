    <Entry>
      <PointerOffset>278324</PointerOffset>
      <VoiceId>&lt;audio:VSM_270_025_001&gt;</VoiceId>
      <JapaneseText>……オレ、やっぱダオスが
優しい人とかって
ぴんと来ねんだよな</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>1</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>278388</PointerOffset>
      <VoiceId>&lt;audio:VSM_270_025_002&gt;</VoiceId>
      <JapaneseText>&lt;Dio&gt;……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>2</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>278560</PointerOffset>
      <VoiceId>&lt;audio:VSM_270_025_003&gt;</VoiceId>
      <JapaneseText></JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>3</Id>
      <BubbleId>0</BubbleId>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>278560</PointerOffset>
      <VoiceId>&lt;audio:VSM_270_025_004&gt;</VoiceId>
      <JapaneseText>だろうね、たくさんの人を
手にかけたんだもん私だってあいつに
初めて会った時、
やばそうなヤツって思った</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>3</Id>
      <BubbleId>1</BubbleId>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>278620</PointerOffset>
      <VoiceId>&lt;audio:VSM_270_025_005&gt;</VoiceId>
      <JapaneseText>だろ？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>5</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>278696</PointerOffset>
      <VoiceId>&lt;audio:VSM_270_025_006&gt;</VoiceId>
      <JapaneseText>で、あいつのこと
襲った</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>6</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>278768</PointerOffset>
      <VoiceId>&lt;audio:VSM_270_025_007&gt;</VoiceId>
      <JapaneseText>襲った？　どうして？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>7</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>278868</PointerOffset>
      <VoiceId>&lt;audio:VSM_270_025_008&gt;</VoiceId>
      <JapaneseText>私の父さんは、
ミッドガルズに
命を狙われてたんだ</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>8</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>278940</PointerOffset>
      <VoiceId>&lt;audio:VSM_270_025_009&gt;</VoiceId>
      <JapaneseText>ミッドガルズって？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>9</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>279060</PointerOffset>
      <VoiceId>&lt;audio:VSM_270_025_010&gt;</VoiceId>
      <JapaneseText>昔、ダオスに滅ぼされた
そういう名前の国が
あったって聞いたことある</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>10</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>279136</PointerOffset>
      <VoiceId>&lt;audio:VSM_270_025_011&gt;</VoiceId>
      <JapaneseText>そう、そのミッドガルズね</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>11</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>279220</PointerOffset>
      <VoiceId>&lt;audio:VSM_270_025_012&gt;</VoiceId>
      <JapaneseText>その日、私は森の中を
散歩してた</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>12</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>279784</PointerOffset>
      <VoiceId>&lt;audio:VSM_270_025_019&gt;</VoiceId>
      <JapaneseText>そん時にダオスと
会ったんだな</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>13</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>279900</PointerOffset>
      <VoiceId>&lt;audio:VSM_270_025_020&gt;</VoiceId>
      <JapaneseText>そう。で、あいつを
父の命を狙う刺客かと
勘違いして襲っちゃった</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>14</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>279988</PointerOffset>
      <VoiceId>&lt;audio:VSM_270_025_021&gt;</VoiceId>
      <JapaneseText>え！？
だいじょーぶだったのか！？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>15</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>280084</PointerOffset>
      <VoiceId>&lt;audio:VSM_270_025_022&gt;</VoiceId>
      <JapaneseText>全然。
ダオスの反撃食らって、
私、気を失って</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>16</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>280160</PointerOffset>
      <VoiceId>&lt;audio:VSM_270_025_023&gt;</VoiceId>
      <JapaneseText>やっぱりダオスって……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>17</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>280356</PointerOffset>
      <VoiceId>&lt;audio:VSM_270_025_025&gt;</VoiceId>
      <JapaneseText>気付いたら、ダオス、
私に法術っぽい癒しの術を
かけてくれてた</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>18</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>280428</PointerOffset>
      <VoiceId>&lt;audio:VSM_270_025_026&gt;</VoiceId>
      <JapaneseText>え？　ダオスが……？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>19</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>280552</PointerOffset>
      <VoiceId>&lt;audio:VSM_270_025_027&gt;</VoiceId>
      <JapaneseText>今思うと、突然襲いかかられて
手加減できなくて
ケガさせられたんだと思う</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>20</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>280640</PointerOffset>
      <VoiceId>&lt;audio:VSM_270_025_028&gt;</VoiceId>
      <JapaneseText>ゴメンなさい。
私、人違いしちゃった</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>21</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>280700</PointerOffset>
      <VoiceId>&lt;audio:VSM_270_025_029&gt;</VoiceId>
      <JapaneseText>いや……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>4</SpeakerId>
      <Id>22</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>280768</PointerOffset>
      <VoiceId>&lt;audio:VSM_270_025_030&gt;</VoiceId>
      <JapaneseText>どこから来た人？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>23</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>280812</PointerOffset>
      <JapaneseText>…………</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>4</SpeakerId>
      <Id>24</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>280908</PointerOffset>
      <VoiceId>&lt;audio:VSM_270_025_032&gt;</VoiceId>
      <JapaneseText>私はこの森に、
父さんと一緒に
住んでるんだ</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>25</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>281024</PointerOffset>
      <VoiceId>&lt;audio:VSM_270_025_033&gt;</VoiceId>
      <JapaneseText>ダオスは何も答えなかったけど、
私は一方的に自分のことを話した</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>26</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>281084</PointerOffset>
      <VoiceId>&lt;audio:VSM_270_025_034&gt;</VoiceId>
      <JapaneseText>それで？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>27</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>281196</PointerOffset>
      <VoiceId>&lt;audio:VSM_270_025_035&gt;</VoiceId>
      <JapaneseText>それだけ。
彼は私には何も話さないまま、
森の中へ消えてった</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>28</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>281260</PointerOffset>
      <VoiceId>&lt;audio:VSM_270_025_036&gt;</VoiceId>
      <JapaneseText>ふーん……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>29</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>281356</PointerOffset>
      <VoiceId>&lt;audio:VSM_270_025_037&gt;</VoiceId>
      <JapaneseText>……今のダオスと
なんかイメージ違うね……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>30</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>281500</PointerOffset>
      <VoiceId>&lt;audio:VSM_270_025_038&gt;</VoiceId>
      <JapaneseText></JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>31</Id>
      <BubbleId>0</BubbleId>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>281500</PointerOffset>
      <VoiceId>&lt;audio:VSM_270_025_039&gt;</VoiceId>
      <JapaneseText>そうかな……私には今のダオスも
あの時の延長（さき）に
いるように思えるよ</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>31</Id>
      <BubbleId>1</BubbleId>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>281724</PointerOffset>
      <VoiceId>&lt;audio:VSM_270_025_041&gt;</VoiceId>
      <JapaneseText>……人を……殺すことも
平気でやってたのに……？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>33</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>281856</PointerOffset>
      <VoiceId>&lt;audio:VSM_270_025_042&gt;</VoiceId>
      <JapaneseText>彼は正しいことだなんて
思ってなかったよ、きっと。
例え自分の故郷を救うためでも</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>34</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>282048</PointerOffset>
      <VoiceId>&lt;audio:VSM_270_025_044&gt;</VoiceId>
      <JapaneseText>じゃあ、どうして……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>35</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>282216</PointerOffset>
      <VoiceId>&lt;audio:VSM_270_025_045&gt;</VoiceId>
      <JapaneseText></JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>36</Id>
      <BubbleId>0</BubbleId>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>282216</PointerOffset>
      <VoiceId>&lt;audio:VSM_270_025_046&gt;</VoiceId>
      <JapaneseText></JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>36</Id>
      <BubbleId>1</BubbleId>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>282216</PointerOffset>
      <VoiceId>&lt;audio:VSM_270_025_047&gt;</VoiceId>
      <JapaneseText>それがわかんないんだ罪を背負ってまでして
彼が何を焦ってたのか……わかんないよ</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>36</Id>
      <BubbleId>2</BubbleId>
      <Status>To Do</Status>
    </Entry>
