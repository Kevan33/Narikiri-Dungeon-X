    <Entry>
      <PointerOffset>302680</PointerOffset>
      <VoiceId>&lt;audio:VSM_160_040_000&gt;</VoiceId>
      <JapaneseText>どうしてだよ！
バジルさん！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>1</Id>
      <BubbleId>0</BubbleId>
      <OldPtr>282504</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>302680</PointerOffset>
      <VoiceId>&lt;audio:VSM_160_040_001&gt;</VoiceId>
      <JapaneseText>魔法で世界の人、
救うんじゃなかったのか！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>1</Id>
      <BubbleId>1</BubbleId>
      <OldPtr>282504</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>302988</PointerOffset>
      <VoiceId>&lt;audio:VSM_160_040_002Z&gt;</VoiceId>
      <JapaneseText>救いたかったのは、
世界なんてものじゃない、
&lt;Red&gt;ヴァルハラ&lt;White&gt;の人たちだ！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>3</Id>
      <BubbleId>0</BubbleId>
      <OldPtr>282780</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>302988</PointerOffset>
      <VoiceId>&lt;audio:VSM_160_040_003Z&gt;</VoiceId>
      <JapaneseText>でも、アルヴァニスタは、
人工マナの材料である
『紅の月』の情報を流して</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>3</Id>
      <BubbleId>1</BubbleId>
      <OldPtr>282780</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>302988</PointerOffset>
      <VoiceId>&lt;audio:VSM_160_040_004Z&gt;</VoiceId>
      <JapaneseText>金目当ての採掘者どもをあおり、
結果、採掘者と住民との間の
衝突を看過した！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>3</Id>
      <BubbleId>2</BubbleId>
      <OldPtr>282780</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>303104</PointerOffset>
      <VoiceId>&lt;audio:VSM_160_040_005&gt;</VoiceId>
      <JapaneseText>で、&lt;Red&gt;ヴァルハラ&lt;White&gt;の連中は、
採掘者たちに
街を追い出された……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>6</Id>
      <OldPtr>283160</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>303276</PointerOffset>
      <VoiceId>&lt;audio:VSM_160_040_006Z&gt;</VoiceId>
      <JapaneseText>そうだ……
何人も寒さや飢えで
死んだ</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>7</Id>
      <BubbleId>0</BubbleId>
      <OldPtr>283356</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>303276</PointerOffset>
      <VoiceId>&lt;audio:VSM_160_040_007Z&gt;</VoiceId>
      <JapaneseText>アルヴァニスタは
何もしてくれなかった……
見殺しにしたのさ！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>7</Id>
      <BubbleId>1</BubbleId>
      <OldPtr>283356</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>303428</PointerOffset>
      <VoiceId>&lt;audio:VSM_160_040_008&gt;</VoiceId>
      <JapaneseText>だから、
無差別に人殺しする
連中の力借りんのか！？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>9</Id>
      <BubbleId>0</BubbleId>
      <OldPtr>283952</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>303428</PointerOffset>
      <VoiceId>&lt;audio:VSM_160_040_009&gt;</VoiceId>
      <JapaneseText>そんな
ヒドイ奴らの力を……！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>9</Id>
      <BubbleId>1</BubbleId>
      <OldPtr>283952</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>303596</PointerOffset>
      <VoiceId>&lt;audio:VSM_160_040_010Z&gt;</VoiceId>
      <JapaneseText>使えるヤツらなら、
それがどんなヤツだろうと
関係ない</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>11</Id>
      <BubbleId>0</BubbleId>
      <OldPtr>284156</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>303596</PointerOffset>
      <VoiceId>&lt;audio:VSM_160_040_011Z&gt;</VoiceId>
      <JapaneseText>魔科学と引き換えに
あの村を守れるんなら！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>11</Id>
      <BubbleId>1</BubbleId>
      <OldPtr>284156</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>303664</PointerOffset>
      <VoiceId>&lt;audio:VSM_160_040_012&gt;</VoiceId>
      <JapaneseText>魔科学を……！？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>4</SpeakerId>
      <Id>13</Id>
      <OldPtr>284296</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>303856</PointerOffset>
      <VoiceId>&lt;audio:VSM_160_040_013&gt;</VoiceId>
      <JapaneseText>なんだよ……そんなんで、
全部自分の夢、
台無しにしちまうのかよ……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>14</Id>
      <BubbleId>0</BubbleId>
      <OldPtr>284436</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>303856</PointerOffset>
      <VoiceId>&lt;audio:VSM_160_040_014&gt;</VoiceId>
      <JapaneseText>なぁっ！　夢は思い続けないと
叶わないって言ったよな！？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>14</Id>
      <BubbleId>1</BubbleId>
      <OldPtr>284436</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>304000</PointerOffset>
      <VoiceId>&lt;audio:VSM_160_040_015Z&gt;</VoiceId>
      <JapaneseText>その僕の夢がみんなを、
あの村をメチャクチャに
したんだ！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>16</Id>
      <BubbleId>0</BubbleId>
      <OldPtr>284668</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>304000</PointerOffset>
      <VoiceId>&lt;audio:VSM_160_040_016Z&gt;</VoiceId>
      <JapaneseText>もういい……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>16</Id>
      <BubbleId>1</BubbleId>
      <OldPtr>284668</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>304116</PointerOffset>
      <VoiceId>&lt;audio:VSM_160_040_017Z&gt;</VoiceId>
      <JapaneseText>夢なんて、思い続けてたって
叶いやしない……
叶うわけがない！！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>18</Id>
      <OldPtr>284808</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>304344</PointerOffset>
      <VoiceId>&lt;audio:VSM_160_040_019&gt;</VoiceId>
      <JapaneseText>ウソだよ……どうして、
そんなこと言うんだよ……
バジルさん……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>19</Id>
      <OldPtr>285184</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>304228</PointerOffset>
      <VoiceId>&lt;audio:VSM_160_040_018Z&gt;</VoiceId>
      <JapaneseText>僕が君に言った
なんにでもなれるなんて話は、
妄想なんだよ！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>20</Id>
      <OldPtr>285324</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>304576</PointerOffset>
      <VoiceId>&lt;audio:VSM_160_040_022Z&gt;</VoiceId>
      <JapaneseText>うわぁあっ！！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>21</Id>
      <OldPtr>289200</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>304644</PointerOffset>
      <VoiceId>&lt;audio:VSM_160_040_023&gt;</VoiceId>
      <JapaneseText>バジルさん！！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>22</Id>
      <OldPtr>290440</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>304716</PointerOffset>
      <VoiceId>&lt;audio:VSM_160_040_024&gt;</VoiceId>
      <JapaneseText>ご苦労さん</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>5</SpeakerId>
      <Id>23</Id>
      <OldPtr>290636</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>304848</PointerOffset>
      <VoiceId>&lt;audio:VSM_160_040_025&gt;</VoiceId>
      <JapaneseText>まったく、つまらん禁呪文で
オイラたちを操ろうなんて、
とんでもねぇ男だ</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>5</SpeakerId>
      <Id>24</Id>
      <OldPtr>290776</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>304936</PointerOffset>
      <VoiceId>&lt;audio:VSM_160_040_026&gt;</VoiceId>
      <JapaneseText>おまえは……
グレムリンレアー……！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>6</SpeakerId>
      <Id>25</Id>
      <OldPtr>291052</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>305068</PointerOffset>
      <VoiceId>&lt;audio:VSM_160_040_027&gt;</VoiceId>
      <JapaneseText>おや、誰かと思えば、
前にオイラ騙して、無理矢理
契約させた奴じゃないの</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>7</SpeakerId>
      <Id>26</Id>
      <OldPtr>291248</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>305172</PointerOffset>
      <VoiceId>&lt;audio:VSM_160_040_028Z&gt;</VoiceId>
      <JapaneseText>な、なぜだ……
なぜ僕の魔操術が……
効かない……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>27</Id>
      <OldPtr>291388</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>305360</PointerOffset>
      <VoiceId>&lt;audio:VSM_160_040_029&gt;</VoiceId>
      <JapaneseText>あんたのそれ通用すんの
下っ端の魔族だけだよ？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>7</SpeakerId>
      <Id>28</Id>
      <BubbleId>0</BubbleId>
      <OldPtr>291528</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>305360</PointerOffset>
      <VoiceId>&lt;audio:VSM_160_040_030&gt;</VoiceId>
      <JapaneseText>魔界の王プルート様も
感謝してるぜ。
魔界の門を開いてくれてさ</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>7</SpeakerId>
      <Id>28</Id>
      <BubbleId>1</BubbleId>
      <OldPtr>291528</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>305432</PointerOffset>
      <VoiceId>&lt;audio:VSM_160_040_031Z&gt;</VoiceId>
      <JapaneseText>うわぁああっ！！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>30</Id>
      <OldPtr>291920</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>305532</PointerOffset>
      <VoiceId>&lt;audio:VSM_160_040_032&gt;</VoiceId>
      <JapaneseText>バジルさんを……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>31</Id>
      <BubbleId>0</BubbleId>
      <OldPtr>292304</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>305532</PointerOffset>
      <VoiceId>&lt;audio:VSM_160_040_033&gt;</VoiceId>
      <JapaneseText>……はなせ！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>31</Id>
      <BubbleId>1</BubbleId>
      <OldPtr>292304</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>305652</PointerOffset>
      <VoiceId>&lt;audio:VSM_160_040_034&gt;</VoiceId>
      <JapaneseText>オイラとやるってかい？
いいよ、相手になろう
じゃないの！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>7</SpeakerId>
      <Id>33</Id>
      <OldPtr>292632</OldPtr>
      <Status>To Do</Status>
    </Entry>
