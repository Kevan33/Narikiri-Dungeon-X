    <Entry>
      <PointerOffset>300228</PointerOffset>
      <JapaneseText>ここが双子ちゃんたちの
育った家なんだね</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>1</Id>
      <OldPtr>278756</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>300288</PointerOffset>
      <JapaneseText>そう。ここがぼくたちのお家</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>2</Id>
      <OldPtr>279008</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>300356</PointerOffset>
      <JapaneseText>&lt;Red&gt;エトスハウス&lt;White&gt;って
呼んでるんだ</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>3</Id>
      <OldPtr>279204</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>300424</PointerOffset>
      <JapaneseText>ふたりはどんな
お子さんだったの？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>4</Id>
      <OldPtr>279520</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>300512</PointerOffset>
      <JapaneseText>&lt;Mel&gt;はとてもいい子だったよ。
今もいい子だけどね～</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>5</Id>
      <OldPtr>279760</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>300552</PointerOffset>
      <JapaneseText>親バカ</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>4</SpeakerId>
      <Id>6</Id>
      <OldPtr>280344</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>300604</PointerOffset>
      <JapaneseText>妬かない妬かない♪</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>7</Id>
      <OldPtr>280808</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>300660</PointerOffset>
      <JapaneseText>妬いてないって……！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>4</SpeakerId>
      <Id>8</Id>
      <OldPtr>281228</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>300728</PointerOffset>
      <JapaneseText>大丈夫、
&lt;Dio&gt;もいい子だから♪</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>9</Id>
      <OldPtr>281548</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>300800</PointerOffset>
      <JapaneseText>なんだよ、
そのつけたしみたいの……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>4</SpeakerId>
      <Id>10</Id>
      <OldPtr>282012</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>300916</PointerOffset>
      <JapaneseText>&lt;Mel&gt;は、よく家の
お手伝いしてくれたよね</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>11</Id>
      <BubbleId>0</BubbleId>
      <OldPtr>282256</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>300916</PointerOffset>
      <JapaneseText>掃除したりとか、
お料理してくれたりとか</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>11</Id>
      <BubbleId>1</BubbleId>
      <OldPtr>282256</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>300988</PointerOffset>
      <JapaneseText>オレもしたぜ。
壊れたもの直したりとか</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>4</SpeakerId>
      <Id>13</Id>
      <OldPtr>282516</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>301072</PointerOffset>
      <JapaneseText>それは、&lt;Dio&gt;くんが
自分で壊したもの、
でしょ？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>14</Id>
      <OldPtr>283104</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>301140</PointerOffset>
      <JapaneseText>オレじゃなくて、
&lt;Mel&gt;が、だよ</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>4</SpeakerId>
      <Id>15</Id>
      <OldPtr>283844</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>301188</PointerOffset>
      <JapaneseText>え、へへ……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>16</Id>
      <OldPtr>284456</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>301292</PointerOffset>
      <JapaneseText>それは&lt;Dio&gt;が、掃除の途中に
ブラシでちゃんばらゴッコ
始めるからでしょ</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>17</Id>
      <OldPtr>284720</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>301368</PointerOffset>
      <JapaneseText>え？　じゃあ、
どうして&lt;Mel&gt;ちゃんが？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>18</Id>
      <OldPtr>285284</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>301480</PointerOffset>
      <JapaneseText>だって、&lt;Dio&gt;が本気で
打ち掛かってくるから</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>19</Id>
      <BubbleId>0</BubbleId>
      <OldPtr>285848</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>301480</PointerOffset>
      <JapaneseText>相手しないわけには
いかなくて……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>19</Id>
      <BubbleId>1</BubbleId>
      <OldPtr>285848</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>301564</PointerOffset>
      <JapaneseText>やってるうちに、&lt;Mel&gt;の方が
白熱しちゃって、ね？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>21</Id>
      <OldPtr>286320</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>301664</PointerOffset>
      <JapaneseText>んで、&lt;Mel&gt;が壊したものは、
オレが直す役</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>4</SpeakerId>
      <Id>22</Id>
      <BubbleId>0</BubbleId>
      <OldPtr>286996</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>301664</PointerOffset>
      <JapaneseText>割が合わねって、まったく</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>4</SpeakerId>
      <Id>22</Id>
      <BubbleId>1</BubbleId>
      <OldPtr>286996</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>301740</PointerOffset>
      <JapaneseText>反省しない人は、
指さし棒でオシオキだよ</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>24</Id>
      <OldPtr>287544</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>301784</PointerOffset>
      <JapaneseText>いてっ……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>4</SpeakerId>
      <Id>25</Id>
      <OldPtr>288436</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>301908</PointerOffset>
      <JapaneseText>まったくもう……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>26</Id>
      <BubbleId>0</BubbleId>
      <OldPtr>289196</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>301908</PointerOffset>
      <JapaneseText>いつも、家のこと、
がんばってくれてる&lt;Mel&gt;には
この指さし棒をあげるね</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>26</Id>
      <BubbleId>1</BubbleId>
      <OldPtr>289196</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>301984</PointerOffset>
      <JapaneseText>え？　ほんと！　ありがと！
大切にするね</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>28</Id>
      <OldPtr>289724</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>302116</PointerOffset>
      <JapaneseText>……エトちゃんの
プレゼントのセンスも
わかんないけど</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>29</Id>
      <BubbleId>0</BubbleId>
      <OldPtr>290192</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>302116</PointerOffset>
      <JapaneseText>それで喜ぶ&lt;Mel&gt;ちゃんも
よくわかんない……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>29</Id>
      <BubbleId>1</BubbleId>
      <OldPtr>290192</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>302200</PointerOffset>
      <JapaneseText>あいつは、
エトからもらったものなら、
何でも喜ぶぞ</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>4</SpeakerId>
      <Id>31</Id>
      <OldPtr>290564</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>302256</PointerOffset>
      <JapaneseText>……いい子だね～ほんと</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>32</Id>
      <OldPtr>290984</OldPtr>
      <Status>To Do</Status>
    </Entry>
