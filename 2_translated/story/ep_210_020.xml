    <Section>Main</Section>
    <Entry>
      <PointerOffset>277228</PointerOffset>
      <VoiceId>&lt;audio:VSM_210_020_001&gt;</VoiceId>
      <JapaneseText>うわっ！　まっくら！</JapaneseText>
      <EnglishText>Whoa! Everything went pitch black!</EnglishText>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>1</Id>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset>277296</PointerOffset>
      <VoiceId>&lt;audio:VSM_210_020_002&gt;</VoiceId>
      <JapaneseText>何も見えない！</JapaneseText>
      <EnglishText>I can't see anything!</EnglishText>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>2</Id>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset>277360</PointerOffset>
      <VoiceId>&lt;audio:VSM_210_020_003&gt;</VoiceId>
      <JapaneseText>クルール！</JapaneseText>
      <EnglishText>Kuruuruu!</EnglishText>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>3</Id>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset>277440</PointerOffset>
      <VoiceId>&lt;audio:VSM_210_020_004&gt;</VoiceId>
      <JapaneseText>皆さん！　大丈夫ですか！？</JapaneseText>
      <EnglishText>Is everyone all right!?</EnglishText>
      <Notes/>
      <SpeakerId>4</SpeakerId>
      <Id>4</Id>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset>277504</PointerOffset>
      <VoiceId>&lt;audio:VSM_210_020_005&gt;</VoiceId>
      <JapaneseText>皆さん……？</JapaneseText>
      <EnglishText>Everyone...?</EnglishText>
      <Notes/>
      <SpeakerId>4</SpeakerId>
      <Id>5</Id>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset>277660</PointerOffset>
      <VoiceId>&lt;audio:VSM_210_020_006&gt;</VoiceId>
      <JapaneseText>あなたはこの子たちに
嫉妬しているのでしょう</JapaneseText>
      <EnglishText>You are jealous of those kids.</EnglishText>
      <Notes/>
      <SpeakerId>5</SpeakerId>
      <Id>6</Id>
      <BubbleId>0</BubbleId>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset>277660</PointerOffset>
      <VoiceId>&lt;audio:VSM_210_020_007&gt;</VoiceId>
      <JapaneseText>夢みたいなことを
言っているこの子たちに</JapaneseText>
      <EnglishText>Those kids are living lives
you'd only dream of.</EnglishText>
      <Notes/>
      <SpeakerId>5</SpeakerId>
      <Id>6</Id>
      <BubbleId>1</BubbleId>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset>277728</PointerOffset>
      <VoiceId>&lt;audio:VSM_210_020_008&gt;</VoiceId>
      <JapaneseText>誰ですか……？</JapaneseText>
      <EnglishText>...Who are you?</EnglishText>
      <Notes/>
      <SpeakerId>4</SpeakerId>
      <Id>8</Id>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset>277884</PointerOffset>
      <VoiceId>&lt;audio:VSM_210_020_010&gt;</VoiceId>
      <JapaneseText>でも、あなたは揺らいでいる</JapaneseText>
      <EnglishText>But...you are shaking...</EnglishText>
      <Notes/>
      <SpeakerId>5</SpeakerId>
      <Id>9</Id>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset>277944</PointerOffset>
      <VoiceId>&lt;audio:VSM_210_020_011&gt;</VoiceId>
      <JapaneseText>いえ……</JapaneseText>
      <EnglishText>No...</EnglishText>
      <Notes/>
      <SpeakerId>4</SpeakerId>
      <Id>10</Id>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset>278020</PointerOffset>
      <VoiceId>&lt;audio:VSM_210_020_012&gt;</VoiceId>
      <JapaneseText>今の自分に迷っている</JapaneseText>
      <EnglishText>You're losing grip of yourself.</EnglishText>
      <Notes/>
      <SpeakerId>5</SpeakerId>
      <Id>11</Id>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset>278088</PointerOffset>
      <VoiceId>&lt;audio:VSM_210_020_013&gt;</VoiceId>
      <JapaneseText>迷っていません</JapaneseText>
      <EnglishText>I will not lose myself.</EnglishText>
      <Notes/>
      <SpeakerId>4</SpeakerId>
      <Id>12</Id>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset>278268</PointerOffset>
      <VoiceId>&lt;audio:VSM_210_020_015&gt;</VoiceId>
      <JapaneseText>この現実が夢ならいいのに、
と思っている</JapaneseText>
      <EnglishText>But, if this reality was but a dream,
that'd be ok... Don't you agree?</EnglishText>
      <Notes/>
      <SpeakerId>5</SpeakerId>
      <Id>13</Id>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset>278328</PointerOffset>
      <VoiceId>&lt;audio:VSM_210_020_016&gt;</VoiceId>
      <JapaneseText>…………</JapaneseText>
      <EnglishText>...</EnglishText>
      <Notes/>
      <SpeakerId>4</SpeakerId>
      <Id>14</Id>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset>278468</PointerOffset>
      <VoiceId>&lt;audio:VSM_210_020_017&gt;</VoiceId>
      <JapaneseText>目覚めたら、
違う現実がそこにある</JapaneseText>
      <EnglishText>When you open your eyes,
you'll experience a new reality.
The reality in your mind.</EnglishText>
      <Notes/>
      <SpeakerId>5</SpeakerId>
      <Id>15</Id>
      <BubbleId>0</BubbleId>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset>278468</PointerOffset>
      <VoiceId>&lt;audio:VSM_210_020_018&gt;</VoiceId>
      <JapaneseText>さぁ……目覚めなさい。
朝ですよ</JapaneseText>
      <EnglishText>Now...Open your eyes...
It's morning already...</EnglishText>
      <Notes/>
      <SpeakerId>5</SpeakerId>
      <Id>15</Id>
      <BubbleId>1</BubbleId>
      <Status>Proofreading</Status>
    </Entry>
