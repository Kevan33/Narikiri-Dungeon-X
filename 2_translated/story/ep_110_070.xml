    <Entry>
      <PointerOffset>285224</PointerOffset>
      <VoiceId>&lt;audio:VSM_110_070_000&gt;</VoiceId>
      <JapaneseText>おかえり、兄ちゃん！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>1</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>285292</PointerOffset>
      <VoiceId>&lt;audio:VSM_110_070_001&gt;</VoiceId>
      <JapaneseText>腹へった～</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>2</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>285372</PointerOffset>
      <VoiceId>&lt;audio:VSM_110_070_002&gt;</VoiceId>
      <JapaneseText>この人たち、誰～？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>3</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>285452</PointerOffset>
      <VoiceId>&lt;audio:VSM_110_070_003&gt;</VoiceId>
      <JapaneseText>お客さんだ。静かにしてろよ？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>4</SpeakerId>
      <Id>4</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>285756</PointerOffset>
      <VoiceId>&lt;audio:VSM_110_070_007&gt;</VoiceId>
      <JapaneseText>この子たちは？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>5</SpeakerId>
      <Id>5</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>285868</PointerOffset>
      <VoiceId>&lt;audio:VSM_110_070_008&gt;</VoiceId>
      <JapaneseText>戦争で親を亡くした子どもたちだ。
オレが引き取って面倒みてる</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>4</SpeakerId>
      <Id>6</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>285964</PointerOffset>
      <VoiceId>&lt;audio:VSM_110_070_009&gt;</VoiceId>
      <JapaneseText>ミリー、お客さんが来たときは
どうするんだ？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>4</SpeakerId>
      <Id>7</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>286024</PointerOffset>
      <VoiceId>&lt;audio:VSM_110_070_010&gt;</VoiceId>
      <JapaneseText>お茶～！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>6</SpeakerId>
      <Id>8</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>286092</PointerOffset>
      <VoiceId>&lt;audio:VSM_110_070_011&gt;</VoiceId>
      <JapaneseText>腹へったよ～</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>9</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>286188</PointerOffset>
      <VoiceId>&lt;audio:VSM_110_070_012&gt;</VoiceId>
      <JapaneseText>グリッド、ジョンに
飯の支度を
してやってくれ</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>4</SpeakerId>
      <Id>10</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>286260</PointerOffset>
      <VoiceId>&lt;audio:VSM_110_070_013&gt;</VoiceId>
      <JapaneseText>火使ってもいいの？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>7</SpeakerId>
      <Id>11</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>286360</PointerOffset>
      <VoiceId>&lt;audio:VSM_110_070_014&gt;</VoiceId>
      <JapaneseText>ああ、オレもいるしな。
なにかあったら呼ぶんだぞ</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>4</SpeakerId>
      <Id>12</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>286472</PointerOffset>
      <VoiceId>&lt;audio:VSM_110_070_015&gt;</VoiceId>
      <JapaneseText>&lt;Cless&gt;&lt;Mint&gt;さてと。なんだっけ、と
に会いに来たんだったか</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>4</SpeakerId>
      <Id>13</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>286564</PointerOffset>
      <VoiceId>&lt;audio:VSM_110_070_016&gt;</VoiceId>
      <JapaneseText>うん、えっと……
何から話せばいいかな？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>8</SpeakerId>
      <Id>14</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>286724</PointerOffset>
      <VoiceId>&lt;audio:VSM_110_070_017&gt;</VoiceId>
      <JapaneseText>&lt;Red&gt;&lt;White&gt;</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>4</SpeakerId>
      <Id>15</Id>
      <BubbleId>0</BubbleId>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>286724</PointerOffset>
      <VoiceId>&lt;audio:VSM_110_070_018&gt;</VoiceId>
      <JapaneseText>なるほど……
マクスウェルってことは、
モーリア坑道だなよし、オレが一緒に
行ってやるよ</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>4</SpeakerId>
      <Id>15</Id>
      <BubbleId>1</BubbleId>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>286816</PointerOffset>
      <VoiceId>&lt;audio:VSM_110_070_019&gt;</VoiceId>
      <JapaneseText>&lt;Chester&gt;でもさんも
忙しいんじゃねーの？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>8</SpeakerId>
      <Id>17</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>287084</PointerOffset>
      <VoiceId>&lt;audio:VSM_110_070_021&gt;</VoiceId>
      <JapaneseText>&lt;Cless&gt;&lt;Mint&gt;</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>4</SpeakerId>
      <Id>18</Id>
      <BubbleId>0</BubbleId>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>287084</PointerOffset>
      <VoiceId>&lt;audio:VSM_110_070_022&gt;</VoiceId>
      <JapaneseText>……ああ、オレは
やとは
違うんだちょっと言い方がキツいせいで
周りから『コワいヤツ』って
思われてるみたいだしな</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>4</SpeakerId>
      <Id>18</Id>
      <BubbleId>1</BubbleId>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>287320</PointerOffset>
      <VoiceId>&lt;audio:VSM_110_070_025&gt;</VoiceId>
      <JapaneseText>でもさ、
あの子どもたちには
したわれてんだろ？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>8</SpeakerId>
      <Id>20</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>287428</PointerOffset>
      <VoiceId>&lt;audio:VSM_110_070_026&gt;</VoiceId>
      <JapaneseText></JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>4</SpeakerId>
      <Id>21</Id>
      <BubbleId>0</BubbleId>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>287428</PointerOffset>
      <VoiceId>&lt;audio:VSM_110_070_027&gt;</VoiceId>
      <JapaneseText>ま、子どもにはな……じゃ、行くかな</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>4</SpeakerId>
      <Id>21</Id>
      <BubbleId>1</BubbleId>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>287512</PointerOffset>
      <VoiceId>&lt;audio:VSM_110_070_028&gt;</VoiceId>
      <JapaneseText>兄ちゃん！　どこ行くんだ！？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>7</SpeakerId>
      <Id>23</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>287616</PointerOffset>
      <VoiceId>&lt;audio:VSM_110_070_029&gt;</VoiceId>
      <JapaneseText>ああ、ちょっとそこまでな。
おとなしく留守番してろよ</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>4</SpeakerId>
      <Id>24</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>287688</PointerOffset>
      <VoiceId>&lt;audio:VSM_110_070_030&gt;</VoiceId>
      <JapaneseText>置いてっちゃやだ～！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>6</SpeakerId>
      <Id>25</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>287752</PointerOffset>
      <VoiceId>&lt;audio:VSM_110_070_031&gt;</VoiceId>
      <JapaneseText>腹へった～！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>9</SpeakerId>
      <Id>26</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>287820</PointerOffset>
      <VoiceId>&lt;audio:VSM_110_070_032&gt;</VoiceId>
      <JapaneseText>すぐ帰ってくるよ</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>4</SpeakerId>
      <Id>27</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>287932</PointerOffset>
      <VoiceId>&lt;audio:VSM_110_070_033&gt;</VoiceId>
      <JapaneseText>ジョン、食いすぎて腹壊すなよ。
ミリー、寝る前には歯磨きだぞ</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>4</SpeakerId>
      <Id>28</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>288016</PointerOffset>
      <VoiceId>&lt;audio:VSM_110_070_034&gt;</VoiceId>
      <JapaneseText>グリッド、
ふたりのこと頼んだぞ</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>4</SpeakerId>
      <Id>29</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>288084</PointerOffset>
      <VoiceId>&lt;audio:VSM_110_070_035&gt;</VoiceId>
      <JapaneseText>う、うん……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>7</SpeakerId>
      <Id>30</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>288148</PointerOffset>
      <VoiceId>&lt;audio:VSM_110_070_036&gt;</VoiceId>
      <JapaneseText>さ、行くぞ</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>4</SpeakerId>
      <Id>31</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>288232</PointerOffset>
      <VoiceId>&lt;audio:VSM_110_070_037&gt;</VoiceId>
      <JapaneseText>&lt;Chester&gt;い、いいんですか、
さん</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>5</SpeakerId>
      <Id>32</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>288384</PointerOffset>
      <VoiceId>&lt;audio:VSM_110_070_038&gt;</VoiceId>
      <JapaneseText></JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>4</SpeakerId>
      <Id>33</Id>
      <BubbleId>0</BubbleId>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>288384</PointerOffset>
      <VoiceId>&lt;audio:VSM_110_070_039&gt;</VoiceId>
      <JapaneseText>ああ、道場の連中も親切で、
面倒見てくれてるからなそれから、
『さん』はいらないぜ</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>4</SpeakerId>
      <Id>33</Id>
      <BubbleId>1</BubbleId>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>288452</PointerOffset>
      <VoiceId>&lt;audio:VSM_110_070_040&gt;</VoiceId>
      <JapaneseText>え？　マジか？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>8</SpeakerId>
      <Id>35</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>288516</PointerOffset>
      <VoiceId>&lt;audio:VSM_110_070_041&gt;</VoiceId>
      <JapaneseText>もちろんだ</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>4</SpeakerId>
      <Id>36</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>288600</PointerOffset>
      <VoiceId>&lt;audio:VSM_110_070_042&gt;</VoiceId>
      <JapaneseText>&lt;Chester&gt;わかった！　よろしくな、
</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>8</SpeakerId>
      <Id>37</Id>
      <Status>To Do</Status>
    </Entry>
