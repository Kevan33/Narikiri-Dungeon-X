      <PointerOffset>294316</PointerOffset>
      <VoiceId>&lt;audio:VSM_300_020_003&gt;</VoiceId>
      <JapaneseText>魔科学兵器は
デリス・カーラーン全体の
マナを吸い取ったけどここは直撃を受けた場所だから、
特にひどいんだ</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>2</Id>
      <BubbleId>1</BubbleId>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>294408</PointerOffset>
      <VoiceId>&lt;audio:VSM_300_020_004&gt;</VoiceId>
      <JapaneseText>どうして、
きみがそんなこと
知ってるの？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>4</Id>
      <Status>To Do</Status>
