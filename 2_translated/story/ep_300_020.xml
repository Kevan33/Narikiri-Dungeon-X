    <Entry>
      <PointerOffset>294552</PointerOffset>
      <VoiceId>&lt;audio:VSM_300_020_006&gt;</VoiceId>
      <JapaneseText>え……なんでかな……なんかぼんやりと
いろんなことが
頭に流れ込んでて……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>5</Id>
