      <PointerOffset>331520</PointerOffset>
      <VoiceId>&lt;audio:VSM_240_010_096&gt;</VoiceId>
      <JapaneseText>ダオス……本当にあなたは
変わってしまったんだね……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>1</Id>
      <Status>To Do</Status>
