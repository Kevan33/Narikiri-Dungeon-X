    <Entry>
      <PointerOffset>331520</PointerOffset>
      <VoiceId>&lt;audio:VSM_240_010_096&gt;</VoiceId>
      <JapaneseText>ダオス……本当にあなたは
変わってしまったんだね……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>1</Id>
      <OldPtr>280240</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>331816</PointerOffset>
      <VoiceId>&lt;audio:VSM_240_010_099&gt;</VoiceId>
      <JapaneseText>おまえは、私のことなど
何も知っていない</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>2</Id>
      <BubbleId>0</BubbleId>
      <OldPtr>281932</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>331816</PointerOffset>
      <VoiceId>&lt;audio:VSM_240_010_100&gt;</VoiceId>
      <JapaneseText>私にあるのは後悔と復讐、
それのみだ</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>2</Id>
      <BubbleId>1</BubbleId>
      <OldPtr>281932</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>331940</PointerOffset>
      <VoiceId>&lt;audio:VSM_240_010_101&gt;</VoiceId>
      <JapaneseText>ダオス、どうして……！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>4</Id>
      <BubbleId>0</BubbleId>
      <OldPtr>283436</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>331940</PointerOffset>
      <VoiceId>&lt;audio:VSM_240_010_102&gt;</VoiceId>
      <JapaneseText>後悔……復讐……
何のための……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>4</Id>
      <BubbleId>1</BubbleId>
      <OldPtr>283436</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>332060</PointerOffset>
      <VoiceId>&lt;audio:VSM_240_010_103&gt;</VoiceId>
      <JapaneseText>……ここにいたダオスは
別の時空から飛んできた
ダオスだったのか……？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>6</Id>
      <OldPtr>283696</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>332140</PointerOffset>
      <VoiceId>&lt;audio:VSM_240_010_104&gt;</VoiceId>
      <JapaneseText>&lt;Rody&gt;……
気がすんだか？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>4</SpeakerId>
      <Id>7</Id>
      <OldPtr>283996</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>332244</PointerOffset>
      <VoiceId>&lt;audio:VSM_240_010_105&gt;</VoiceId>
      <JapaneseText>ごめん……
みんなにはいろいろ、
迷惑かけちゃったね</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>8</Id>
      <OldPtr>286072</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>332508</PointerOffset>
      <VoiceId>&lt;audio:VSM_240_010_106&gt;</VoiceId>
      <JapaneseText>私は幼い時、ダオスと、
世界樹の前で出会った</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>9</Id>
      <BubbleId>0</BubbleId>
      <OldPtr>286876</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>332508</PointerOffset>
      <VoiceId>&lt;audio:VSM_240_010_107&gt;</VoiceId>
      <JapaneseText>デリス・カーラーン……
自分の故郷に『大いなる実り』を
持ち帰るためにそこへ来てた</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>9</Id>
      <BubbleId>1</BubbleId>
      <OldPtr>286876</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>332508</PointerOffset>
      <VoiceId>&lt;audio:VSM_240_010_108&gt;</VoiceId>
      <JapaneseText>あの頃、優しくて、
思慮深いヤツだったよ、
あいつは</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>9</Id>
      <BubbleId>2</BubbleId>
      <OldPtr>286876</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>332576</PointerOffset>
      <VoiceId>&lt;audio:VSM_240_010_109&gt;</VoiceId>
      <JapaneseText>ダオスが……？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>12</Id>
      <OldPtr>287144</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>332932</PointerOffset>
      <VoiceId>&lt;audio:VSM_240_010_110&gt;</VoiceId>
      <JapaneseText>そう。だから、そんな彼が、
人類に戦争を仕掛けた張本人
だなんてとても思えなかった</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>13</Id>
      <BubbleId>0</BubbleId>
      <OldPtr>287284</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>332932</PointerOffset>
      <VoiceId>&lt;audio:VSM_240_010_111&gt;</VoiceId>
      <JapaneseText>だから、確かめたかった。
ダオスがあのダオスなのか</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>13</Id>
      <BubbleId>1</BubbleId>
      <OldPtr>287284</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>332932</PointerOffset>
      <VoiceId>&lt;audio:VSM_240_010_112&gt;</VoiceId>
      <JapaneseText>そうだとしたら、
止めなきゃって……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>13</Id>
      <BubbleId>2</BubbleId>
      <OldPtr>287284</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>332932</PointerOffset>
      <VoiceId>&lt;audio:VSM_240_010_113&gt;</VoiceId>
      <JapaneseText>でも、怖くて聞けなかった……
何も、ちゃんと……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>13</Id>
      <BubbleId>3</BubbleId>
      <OldPtr>287284</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>332932</PointerOffset>
      <VoiceId>&lt;audio:VSM_240_010_114&gt;</VoiceId>
      <JapaneseText>私ってダメなヤツ</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>13</Id>
      <BubbleId>4</BubbleId>
      <OldPtr>287284</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>333028</PointerOffset>
      <VoiceId>&lt;audio:VSM_240_010_115&gt;</VoiceId>
      <JapaneseText>そっか……
&lt;Rody&gt;さん、
ダオスのこと……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>5</SpeakerId>
      <Id>18</Id>
      <OldPtr>287748</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>333116</PointerOffset>
      <VoiceId>&lt;audio:VSM_240_010_116&gt;</VoiceId>
      <JapaneseText>ん……あれ……
何があった、の……？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>6</SpeakerId>
      <Id>19</Id>
      <OldPtr>288720</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>333184</PointerOffset>
      <VoiceId>&lt;audio:VSM_240_010_117&gt;</VoiceId>
      <JapaneseText>気がついたか？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>7</SpeakerId>
      <Id>20</Id>
      <OldPtr>290312</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>333268</PointerOffset>
      <VoiceId>&lt;audio:VSM_240_010_118&gt;</VoiceId>
      <JapaneseText>…………？
ねぇ、これ、
何かな？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>8</SpeakerId>
      <Id>21</Id>
      <OldPtr>291440</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>333360</PointerOffset>
      <VoiceId>&lt;audio:VSM_240_010_119&gt;</VoiceId>
      <JapaneseText>これは……！
魔科学兵器のかけらだ……！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>22</Id>
      <OldPtr>293476</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>333424</PointerOffset>
      <VoiceId>&lt;audio:VSM_240_010_120&gt;</VoiceId>
      <JapaneseText>なんだって？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>9</SpeakerId>
      <Id>23</Id>
      <OldPtr>294640</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>333608</PointerOffset>
      <VoiceId>&lt;audio:VSM_240_010_121&gt;</VoiceId>
      <JapaneseText>&lt;Red&gt;ヴァルハラ&lt;White&gt;で『シグルド』が
使ってたものじゃないかな</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>24</Id>
      <BubbleId>0</BubbleId>
      <OldPtr>294780</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>333608</PointerOffset>
      <VoiceId>&lt;audio:VSM_240_010_122&gt;</VoiceId>
      <JapaneseText>爆発すると自動的に
詠唱を続けて、
魔法を継続させる兵器だよ</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>24</Id>
      <BubbleId>1</BubbleId>
      <OldPtr>294780</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>333688</PointerOffset>
      <VoiceId>&lt;audio:VSM_240_010_123&gt;</VoiceId>
      <JapaneseText>これだよ！
『虹輪』の原因！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>6</SpeakerId>
      <Id>26</Id>
      <OldPtr>295080</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>333784</PointerOffset>
      <VoiceId>&lt;audio:VSM_240_010_124&gt;</VoiceId>
      <JapaneseText>わたしが魔術を使ったはずみに
爆発して……？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>5</SpeakerId>
      <Id>27</Id>
      <OldPtr>296000</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>333884</PointerOffset>
      <VoiceId>&lt;audio:VSM_240_010_125&gt;</VoiceId>
      <JapaneseText>なんだ……&lt;Mel&gt;の
せいじゃねーよな、
これって</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>7</SpeakerId>
      <Id>28</Id>
      <OldPtr>296764</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>334124</PointerOffset>
      <VoiceId>&lt;audio:VSM_240_010_126&gt;</VoiceId>
      <JapaneseText>せいじゃないってことはないよ。
爆発させた原因はわたしだもん</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>5</SpeakerId>
      <Id>29</Id>
      <BubbleId>0</BubbleId>
      <OldPtr>297184</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>334124</PointerOffset>
      <VoiceId>&lt;audio:VSM_240_010_127&gt;</VoiceId>
      <JapaneseText>……でも、よかった……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>5</SpeakerId>
      <Id>29</Id>
      <BubbleId>1</BubbleId>
      <OldPtr>297184</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>334124</PointerOffset>
      <VoiceId>&lt;audio:VSM_240_010_128&gt;</VoiceId>
      <JapaneseText>わたし、魔術使うたび怖かった。
また暴走させちゃうんじゃ
ないかって</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>5</SpeakerId>
      <Id>29</Id>
      <BubbleId>2</BubbleId>
      <OldPtr>297184</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>334208</PointerOffset>
      <VoiceId>&lt;audio:VSM_240_010_129&gt;</VoiceId>
      <JapaneseText>うん……よかったよ、
本当に……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>6</SpeakerId>
      <Id>32</Id>
      <OldPtr>297744</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>334296</PointerOffset>
      <VoiceId>&lt;audio:VSM_240_010_130&gt;</VoiceId>
      <JapaneseText>……ま、これで
一件落着ってことかな</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>8</SpeakerId>
      <Id>33</Id>
      <OldPtr>298368</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>334404</PointerOffset>
      <VoiceId>&lt;audio:VSM_240_010_131&gt;</VoiceId>
      <JapaneseText>ふたりのことも見届けられたし、
自分たちの時代に戻ろうか</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>34</Id>
      <OldPtr>299200</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>334540</PointerOffset>
      <VoiceId>&lt;audio:VSM_240_010_132&gt;</VoiceId>
      <JapaneseText>指輪も
いい感じになってるし</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>35</Id>
      <BubbleId>0</BubbleId>
      <OldPtr>300516</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>334540</PointerOffset>
      <VoiceId>&lt;audio:VSM_240_010_133&gt;</VoiceId>
      <JapaneseText>私がみんなを元の時代に
送ったげるよ</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>35</Id>
      <BubbleId>1</BubbleId>
      <OldPtr>300516</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>334632</PointerOffset>
      <VoiceId>&lt;audio:VSM_240_010_134&gt;</VoiceId>
      <JapaneseText>&lt;Rody&gt;はどうすんだ。
またダオスを……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>7</SpeakerId>
      <Id>37</Id>
      <OldPtr>301948</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>334820</PointerOffset>
      <VoiceId>&lt;audio:VSM_240_010_135&gt;</VoiceId>
      <JapaneseText>できればそうしたいけど、
どこ行ったかわかんないし</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>38</Id>
      <BubbleId>0</BubbleId>
      <OldPtr>302372</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>334820</PointerOffset>
      <VoiceId>&lt;audio:VSM_240_010_136&gt;</VoiceId>
      <JapaneseText>この指輪の気まぐれに
付き合ってみてもいいかなって。
風の向くままにさ</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>38</Id>
      <BubbleId>1</BubbleId>
      <OldPtr>302372</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>334904</PointerOffset>
      <VoiceId>&lt;audio:VSM_240_010_137&gt;</VoiceId>
      <JapaneseText>あっ……来た……
ほら、みんな</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>40</Id>
      <OldPtr>302896</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>334996</PointerOffset>
      <VoiceId>&lt;audio:VSM_240_010_138&gt;</VoiceId>
      <JapaneseText>それじゃあ、
&lt;Dio&gt;、&lt;Mel&gt;、がんばって</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>41</Id>
      <OldPtr>304860</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>335088</PointerOffset>
      <VoiceId>&lt;audio:VSM_240_010_139&gt;</VoiceId>
      <JapaneseText>&lt;Arche&gt;、元気でな。
寂しくて、泣くなよ</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>4</SpeakerId>
      <Id>42</Id>
      <OldPtr>305200</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>335180</PointerOffset>
      <VoiceId>&lt;audio:VSM_240_010_140&gt;</VoiceId>
      <JapaneseText>泣くかっ！
このスカポンタン！
空気読め！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>8</SpeakerId>
      <Id>43</Id>
      <OldPtr>305452</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>335328</PointerOffset>
      <VoiceId>&lt;audio:VSM_240_010_141&gt;</VoiceId>
      <JapaneseText>おふたりに会えて、
友達ができたみたいで
楽しかったです</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>10</SpeakerId>
      <Id>44</Id>
      <BubbleId>0</BubbleId>
      <OldPtr>305904</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>335328</PointerOffset>
      <VoiceId>&lt;audio:VSM_240_010_142&gt;</VoiceId>
      <JapaneseText>ありがとうございます</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>10</SpeakerId>
      <Id>44</Id>
      <BubbleId>1</BubbleId>
      <OldPtr>305904</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>335400</PointerOffset>
      <VoiceId>&lt;audio:VSM_240_010_143&gt;</VoiceId>
      <JapaneseText>みたい、と違うだろ</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>7</SpeakerId>
      <Id>46</Id>
      <OldPtr>306108</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>335480</PointerOffset>
      <VoiceId>&lt;audio:VSM_240_010_144&gt;</VoiceId>
      <JapaneseText>友達だもんね、
わたしたち</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>5</SpeakerId>
      <Id>47</Id>
      <OldPtr>306504</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>335544</PointerOffset>
      <VoiceId>&lt;audio:VSM_240_010_145&gt;</VoiceId>
      <JapaneseText>……はい！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>10</SpeakerId>
      <Id>48</Id>
      <OldPtr>306700</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>335608</PointerOffset>
      <VoiceId>&lt;audio:VSM_240_010_146&gt;</VoiceId>
      <JapaneseText>終わったね</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>5</SpeakerId>
      <Id>49</Id>
      <OldPtr>308948</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>335728</PointerOffset>
      <VoiceId>&lt;audio:VSM_240_010_147&gt;</VoiceId>
      <JapaneseText>ああ、終わった……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>7</SpeakerId>
      <Id>50</Id>
      <BubbleId>0</BubbleId>
      <OldPtr>309192</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>335728</PointerOffset>
      <VoiceId>&lt;audio:VSM_240_010_148&gt;</VoiceId>
      <JapaneseText>……ってまだ
終わってねーだろ</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>7</SpeakerId>
      <Id>50</Id>
      <BubbleId>1</BubbleId>
      <OldPtr>309192</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>335788</PointerOffset>
      <VoiceId>&lt;audio:VSM_240_010_149&gt;</VoiceId>
      <JapaneseText>え……？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>5</SpeakerId>
      <Id>52</Id>
      <OldPtr>309996</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>335912</PointerOffset>
      <VoiceId>&lt;audio:VSM_240_010_150&gt;</VoiceId>
      <JapaneseText>だってノルンに言われた
『なりきり士』の仕事
オレら、なんもしてねーぞ？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>7</SpeakerId>
      <Id>53</Id>
      <OldPtr>310136</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>335996</PointerOffset>
      <VoiceId>&lt;audio:VSM_240_010_151&gt;</VoiceId>
      <JapaneseText>あ……そうだっけ……
そうだね</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>5</SpeakerId>
      <Id>54</Id>
      <OldPtr>310332</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>336104</PointerOffset>
      <VoiceId>&lt;audio:VSM_240_010_152&gt;</VoiceId>
      <JapaneseText>自分たちで事件起こして
自分たちで解決しただけだもんね</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>6</SpeakerId>
      <Id>55</Id>
      <OldPtr>310648</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>336172</PointerOffset>
      <VoiceId>&lt;audio:VSM_240_010_153&gt;</VoiceId>
      <JapaneseText>よし！　行くぜ！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>7</SpeakerId>
      <Id>56</Id>
      <OldPtr>310948</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>336272</PointerOffset>
      <VoiceId>&lt;audio:VSM_240_010_154&gt;</VoiceId>
      <JapaneseText>どーせ、またどこ行くか、
わかってないんでしょ</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>6</SpeakerId>
      <Id>57</Id>
      <OldPtr>311208</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>336400</PointerOffset>
      <VoiceId>&lt;audio:VSM_240_010_155&gt;</VoiceId>
      <JapaneseText>わかんねーよ</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>7</SpeakerId>
      <Id>58</Id>
      <BubbleId>0</BubbleId>
      <OldPtr>311508</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>336400</PointerOffset>
      <VoiceId>&lt;audio:VSM_240_010_156&gt;</VoiceId>
      <JapaneseText>でも……
わかんねーから
おもしれーんじゃん！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>7</SpeakerId>
      <Id>58</Id>
      <BubbleId>1</BubbleId>
      <OldPtr>311508</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>336484</PointerOffset>
      <VoiceId>&lt;audio:VSM_240_010_157&gt;</VoiceId>
      <JapaneseText>あ、&lt;Dio&gt;……
まったく、もう！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>6</SpeakerId>
      <Id>60</Id>
      <OldPtr>312104</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>336596</PointerOffset>
      <VoiceId>&lt;audio:VSM_240_010_158&gt;</VoiceId>
      <JapaneseText>おもしろい、かな……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>5</SpeakerId>
      <Id>61</Id>
      <BubbleId>0</BubbleId>
      <OldPtr>312732</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>336596</PointerOffset>
      <VoiceId>&lt;audio:VSM_240_010_159&gt;</VoiceId>
      <JapaneseText>……うん、そうかも！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>5</SpeakerId>
      <Id>61</Id>
      <BubbleId>1</BubbleId>
      <OldPtr>312732</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>336740</PointerOffset>
      <VoiceId>&lt;audio:VSM_240_010_160&gt;</VoiceId>
      <JapaneseText>あ、&lt;Mel&gt;まで……！！
まったく……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>6</SpeakerId>
      <Id>63</Id>
      <BubbleId>0</BubbleId>
      <OldPtr>313748</OldPtr>
