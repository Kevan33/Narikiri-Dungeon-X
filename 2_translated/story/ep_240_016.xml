      <Id>2</Id>
      <BubbleId>0</BubbleId>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>331816</PointerOffset>
      <VoiceId>&lt;audio:VSM_240_010_100&gt;</VoiceId>
      <JapaneseText>おまえは、私のことなど
何も知っていない私にあるのは後悔と復讐、
それのみだ</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>2</Id>
      <BubbleId>1</BubbleId>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>331940</PointerOffset>
      <VoiceId>&lt;audio:VSM_240_010_101&gt;</VoiceId>
      <JapaneseText></JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>4</Id>
      <BubbleId>0</BubbleId>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>331940</PointerOffset>
      <VoiceId>&lt;audio:VSM_240_010_102&gt;</VoiceId>
      <JapaneseText>ダオス、どうして……！後悔……復讐……
何のための……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>4</Id>
      <BubbleId>1</BubbleId>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>332060</PointerOffset>
      <VoiceId>&lt;audio:VSM_240_010_103&gt;</VoiceId>
      <JapaneseText>……ここにいたダオスは
別の時空から飛んできた
ダオスだったのか……？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>6</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>332140</PointerOffset>
      <VoiceId>&lt;audio:VSM_240_010_104&gt;</VoiceId>
      <JapaneseText>&lt;Rody&gt;……
気がすんだか？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>4</SpeakerId>
      <Id>7</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>332244</PointerOffset>
      <VoiceId>&lt;audio:VSM_240_010_105&gt;</VoiceId>
      <JapaneseText>ごめん……
みんなにはいろいろ、
迷惑かけちゃったね</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>8</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>332508</PointerOffset>
      <VoiceId>&lt;audio:VSM_240_010_106&gt;</VoiceId>
      <JapaneseText></JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>9</Id>
      <BubbleId>0</BubbleId>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>332508</PointerOffset>
      <VoiceId>&lt;audio:VSM_240_010_107&gt;</VoiceId>
      <JapaneseText></JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>9</Id>
      <BubbleId>1</BubbleId>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>332508</PointerOffset>
      <VoiceId>&lt;audio:VSM_240_010_108&gt;</VoiceId>
      <JapaneseText>私は幼い時、ダオスと、
世界樹の前で出会ったデリス・カーラーン……
自分の故郷に『大いなる実り』を
持ち帰るためにそこへ来てたあの頃、優しくて、
思慮深いヤツだったよ、
あいつは</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>9</Id>
      <BubbleId>2</BubbleId>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>332576</PointerOffset>
      <VoiceId>&lt;audio:VSM_240_010_109&gt;</VoiceId>
      <JapaneseText>ダオスが……？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>12</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>332932</PointerOffset>
      <VoiceId>&lt;audio:VSM_240_010_110&gt;</VoiceId>
      <JapaneseText></JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>13</Id>
      <BubbleId>0</BubbleId>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>332932</PointerOffset>
      <VoiceId>&lt;audio:VSM_240_010_111&gt;</VoiceId>
      <JapaneseText></JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>13</Id>
      <BubbleId>1</BubbleId>
      <Status>To Do</Status>
    </Entry>
    <Entry>
