    <Entry>
      <PointerOffset>336596</PointerOffset>
      <VoiceId>&lt;audio:VSM_240_010_159&gt;</VoiceId>
      <JapaneseText>おもしろい、かな…………うん、そうかも！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>5</SpeakerId>
      <Id>61</Id>
      <BubbleId>1</BubbleId>
