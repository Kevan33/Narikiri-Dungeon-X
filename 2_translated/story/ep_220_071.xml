    <Entry>
      <PointerOffset>310028</PointerOffset>
      <VoiceId>&lt;audio:VSM_220_070_014&gt;</VoiceId>
      <JapaneseText>おまえたちの力、
しかと心に刻んだ</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>1</Id>
      <BubbleId>0</BubbleId>
      <OldPtr>278808</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>310028</PointerOffset>
      <VoiceId>&lt;audio:VSM_220_070_015&gt;</VoiceId>
      <JapaneseText>我が力、
おまえたちに預けよう</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>1</Id>
      <BubbleId>1</BubbleId>
      <OldPtr>278808</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>310092</PointerOffset>
      <VoiceId>&lt;audio:VSM_220_070_016&gt;</VoiceId>
      <JapaneseText>こいつだよな</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>3</Id>
      <OldPtr>279336</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>310204</PointerOffset>
      <VoiceId>&lt;audio:VSM_220_070_017&gt;</VoiceId>
      <JapaneseText>よーし、そいつで一気に
世界全部の瘴気、
浄化しちまおうぜ！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>4</Id>
      <OldPtr>282220</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>310400</PointerOffset>
      <VoiceId>&lt;audio:VSM_220_070_018&gt;</VoiceId>
      <JapaneseText>残念ながら、もはや
我ひとりの力で、世界全体の
瘴気を浄化することは叶わぬ</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>5</Id>
      <BubbleId>0</BubbleId>
      <OldPtr>283716</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>310400</PointerOffset>
      <VoiceId>&lt;audio:VSM_220_070_019&gt;</VoiceId>
      <JapaneseText>プルートは
地下世界で力をつけた。
奴を討たねば……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>5</Id>
      <BubbleId>1</BubbleId>
      <OldPtr>283716</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>310500</PointerOffset>
      <VoiceId>&lt;audio:VSM_220_070_020&gt;</VoiceId>
      <JapaneseText>プルートを倒せば
いんだな……。っし、わかった</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>7</Id>
      <OldPtr>285248</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>310568</PointerOffset>
      <VoiceId>&lt;audio:VSM_220_070_021&gt;</VoiceId>
      <JapaneseText>行きましょう！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>4</SpeakerId>
      <Id>8</Id>
      <OldPtr>286356</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>310628</PointerOffset>
      <VoiceId>&lt;audio:VSM_220_070_022&gt;</VoiceId>
      <JapaneseText>待て</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>9</Id>
      <OldPtr>287624</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>310704</PointerOffset>
      <VoiceId>&lt;audio:VSM_220_070_023&gt;</VoiceId>
      <JapaneseText>小さき者よ、おまえだ</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>10</Id>
      <OldPtr>289448</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>310768</PointerOffset>
      <VoiceId>&lt;audio:VSM_220_070_024&gt;</VoiceId>
      <JapaneseText>ぼく……！？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>5</SpeakerId>
      <Id>11</Id>
      <OldPtr>289644</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>310872</PointerOffset>
      <VoiceId>&lt;audio:VSM_220_070_025&gt;</VoiceId>
      <JapaneseText>そうだ、おまえの
知りたがっていた
真実を教えよう</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>12</Id>
      <OldPtr>290060</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>310952</PointerOffset>
      <VoiceId>&lt;audio:VSM_220_070_026&gt;</VoiceId>
      <JapaneseText>ぼくのって……
まさか……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>5</SpeakerId>
      <Id>13</Id>
      <OldPtr>290256</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>311068</PointerOffset>
      <VoiceId>&lt;audio:VSM_220_070_027&gt;</VoiceId>
      <JapaneseText>おまえは音を司る者</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>14</Id>
      <BubbleId>0</BubbleId>
      <OldPtr>290396</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>311068</PointerOffset>
      <VoiceId>&lt;audio:VSM_220_070_028&gt;</VoiceId>
      <JapaneseText>音の精霊グラムロックだ</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>14</Id>
      <BubbleId>1</BubbleId>
      <OldPtr>290396</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>311292</PointerOffset>
      <VoiceId>&lt;audio:VSM_220_070_031&gt;</VoiceId>
      <JapaneseText>……ぼくが……
音の精霊……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>5</SpeakerId>
      <Id>16</Id>
      <OldPtr>291664</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>311432</PointerOffset>
      <VoiceId>&lt;audio:VSM_220_070_033&gt;</VoiceId>
      <JapaneseText>受け入れよ、
これが真実だ</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>17</Id>
      <OldPtr>291804</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>311624</PointerOffset>
      <VoiceId>&lt;audio:VSM_220_070_035&gt;</VoiceId>
      <JapaneseText>だって、そんなこと
突然言われても、
ぼく、思い出せないシ……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>5</SpeakerId>
      <Id>18</Id>
      <OldPtr>292000</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>311724</PointerOffset>
      <VoiceId>&lt;audio:VSM_220_070_036&gt;</VoiceId>
      <JapaneseText>どうして、
エトはそのことを
忘れてたんですか？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>6</SpeakerId>
      <Id>19</Id>
      <OldPtr>292240</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>311828</PointerOffset>
      <VoiceId>&lt;audio:VSM_220_070_037&gt;</VoiceId>
      <JapaneseText>多くの過ちがゆえ……
我がおまえから記憶を奪った</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>20</Id>
      <OldPtr>292436</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>311892</PointerOffset>
      <VoiceId>&lt;audio:VSM_220_070_038&gt;</VoiceId>
      <JapaneseText>あなたが……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>6</SpeakerId>
      <Id>21</Id>
      <OldPtr>292576</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>311960</PointerOffset>
      <VoiceId>&lt;audio:VSM_220_070_039&gt;</VoiceId>
      <JapaneseText>おまえは……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>22</Id>
      <OldPtr>292716</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>312036</PointerOffset>
      <VoiceId>&lt;audio:VSM_220_070_040&gt;</VoiceId>
      <JapaneseText>それ以上、言わないでッ！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>5</SpeakerId>
      <Id>23</Id>
      <OldPtr>293088</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>312152</PointerOffset>
      <VoiceId>&lt;audio:VSM_220_070_041&gt;</VoiceId>
      <JapaneseText>ぼくは思い出したくない……！
そんなこと……
そんなことしたラ……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>5</SpeakerId>
      <Id>24</Id>
      <OldPtr>293496</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>312224</PointerOffset>
      <VoiceId>&lt;audio:VSM_220_070_042&gt;</VoiceId>
      <JapaneseText>何言ってんだよ！？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>25</Id>
      <OldPtr>293636</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>312368</PointerOffset>
      <VoiceId>&lt;audio:VSM_220_070_043&gt;</VoiceId>
      <JapaneseText>……だって、
ぼく、今と違う自分に
なっちゃうよ……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>5</SpeakerId>
      <Id>26</Id>
      <BubbleId>0</BubbleId>
      <OldPtr>294156</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>312368</PointerOffset>
      <VoiceId>&lt;audio:VSM_220_070_044&gt;</VoiceId>
      <JapaneseText>それがこわいんだ……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>5</SpeakerId>
      <Id>26</Id>
      <BubbleId>1</BubbleId>
      <OldPtr>294156</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>312588</PointerOffset>
      <VoiceId>&lt;audio:VSM_220_070_047&gt;</VoiceId>
      <JapaneseText>…………</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>6</SpeakerId>
      <Id>28</Id>
      <OldPtr>294560</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>312776</PointerOffset>
      <VoiceId>&lt;audio:VSM_220_070_048&gt;</VoiceId>
      <JapaneseText>何、弱っちぃこと
言ってんだよ</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>29</Id>
      <BubbleId>0</BubbleId>
      <OldPtr>294700</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>312776</PointerOffset>
      <VoiceId>&lt;audio:VSM_220_070_049&gt;</VoiceId>
      <JapaneseText>……エトが今と違う
エトになっても</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>29</Id>
      <BubbleId>1</BubbleId>
      <OldPtr>294700</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>312776</PointerOffset>
      <VoiceId>&lt;audio:VSM_220_070_050&gt;</VoiceId>
      <JapaneseText>これまでがなくなる
わけじゃねーし</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>29</Id>
      <BubbleId>2</BubbleId>
      <OldPtr>294700</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>312848</PointerOffset>
      <VoiceId>&lt;audio:VSM_220_070_051&gt;</VoiceId>
      <JapaneseText>そうだよ、エト……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>6</SpeakerId>
      <Id>32</Id>
      <OldPtr>295184</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>312908</PointerOffset>
      <VoiceId>&lt;audio:VSM_220_070_052&gt;</VoiceId>
      <JapaneseText>…………</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>5</SpeakerId>
      <Id>33</Id>
      <OldPtr>295324</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>313084</PointerOffset>
      <VoiceId>&lt;audio:VSM_220_070_053&gt;</VoiceId>
      <JapaneseText>……よかろう。
受け入れるもよし、
拒むのもまたよし</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>34</Id>
      <BubbleId>0</BubbleId>
      <OldPtr>295564</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>313084</PointerOffset>
      <VoiceId>&lt;audio:VSM_220_070_054&gt;</VoiceId>
      <JapaneseText>すべてはおまえが、
正しいと断じた方向へ
進むがよい</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>34</Id>
      <BubbleId>1</BubbleId>
      <OldPtr>295564</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>313148</PointerOffset>
      <VoiceId>&lt;audio:VSM_220_070_055&gt;</VoiceId>
      <JapaneseText>……わかった</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>5</SpeakerId>
      <Id>36</Id>
      <OldPtr>296372</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>313264</PointerOffset>
      <VoiceId>&lt;audio:VSM_220_070_056&gt;</VoiceId>
      <JapaneseText>……では、改めて……
&lt;Red&gt;ネルヴィの洞窟&lt;White&gt;……
プルートのところへ！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>4</SpeakerId>
      <Id>37</Id>
      <OldPtr>296856</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>313348</PointerOffset>
      <VoiceId>&lt;audio:VSM_220_070_057&gt;</VoiceId>
      <JapaneseText>……ぼくが音の精霊？
そんな……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>5</SpeakerId>
      <Id>38</Id>
      <OldPtr>299692</OldPtr>
      <Status>To Do</Status>
    </Entry>
