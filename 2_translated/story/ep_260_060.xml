    <Section>Main</Section>
    <Entry>
      <PointerOffset>271192</PointerOffset>
      <VoiceId>&lt;audio:VSM_260_060_001&gt;</VoiceId>
      <JapaneseText>お母さーん……</JapaneseText>
      <EnglishText>Mooommmy...</EnglishText>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>1</Id>
      <BubbleId>0</BubbleId>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset>271192</PointerOffset>
      <VoiceId>&lt;audio:VSM_260_060_002&gt;</VoiceId>
      <JapaneseText>お母さーん……寒いよぉ……</JapaneseText>
      <EnglishText>Mommy...It's cold...</EnglishText>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>1</Id>
      <BubbleId>1</BubbleId>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset>271404</PointerOffset>
      <VoiceId>&lt;audio:VSM_260_060_003&gt;</VoiceId>
      <JapaneseText>おお、そう怖がるな</JapaneseText>
      <EnglishText>Hey little one, don't be scared.</EnglishText>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>3</Id>
      <BubbleId>0</BubbleId>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset>271404</PointerOffset>
      <VoiceId>&lt;audio:VSM_260_060_004&gt;</VoiceId>
      <JapaneseText>……と言っても無理かな。
このおヒゲは怖いもんな</JapaneseText>
      <EnglishText>I understand, this beard of mine makes
me look a little scary, doesn't it?</EnglishText>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>3</Id>
      <BubbleId>1</BubbleId>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset>271404</PointerOffset>
      <VoiceId>&lt;audio:VSM_260_060_005&gt;</VoiceId>
      <JapaneseText>でも剃るのは勘弁してくれ。
このおヒゲはお気に入りでな</JapaneseText>
      <EnglishText>But you'll have to bear with it.
You see, I can't bring myself to
shave my precious beard.</EnglishText>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>3</Id>
      <BubbleId>2</BubbleId>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset>271472</PointerOffset>
      <VoiceId>&lt;audio:VSM_260_060_006&gt;</VoiceId>
      <JapaneseText>…………</JapaneseText>
      <EnglishText>...</EnglishText>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>6</Id>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset>271572</PointerOffset>
      <VoiceId>&lt;audio:VSM_260_060_007&gt;</VoiceId>
      <JapaneseText>触ってみるか？
このおヒゲを。
かまわんぞ、ほら</JapaneseText>
      <EnglishText>Want to touch it? I don't mind at all. Here.</EnglishText>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>7</Id>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset>271636</PointerOffset>
      <VoiceId>&lt;audio:VSM_260_060_008&gt;</VoiceId>
      <JapaneseText>迷子か？</JapaneseText>
      <EnglishText>Are you lost?</EnglishText>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>8</Id>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset>271732</PointerOffset>
      <VoiceId>&lt;audio:VSM_260_060_009&gt;</VoiceId>
      <JapaneseText>うん……お母さんと
はぐれたの……</JapaneseText>
      <EnglishText>Yup... I got separated from mommy...</EnglishText>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>9</Id>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset>271856</PointerOffset>
      <VoiceId>&lt;audio:VSM_260_060_010&gt;</VoiceId>
      <JapaneseText>そうか。
おじさんと一緒に探そうな</JapaneseText>
      <EnglishText>I see... Then let's try to
find mommy together.</EnglishText>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>10</Id>
      <BubbleId>0</BubbleId>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset>271856</PointerOffset>
      <VoiceId>&lt;audio:VSM_260_060_011&gt;</VoiceId>
      <JapaneseText>君の名前は……？</JapaneseText>
      <EnglishText>And your name is...?</EnglishText>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>10</Id>
      <BubbleId>1</BubbleId>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset>271928</PointerOffset>
      <VoiceId>&lt;audio:VSM_260_060_012&gt;</VoiceId>
      <JapaneseText>メルティア</JapaneseText>
      <EnglishText>Meltia...</EnglishText>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>12</Id>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset>272024</PointerOffset>
      <VoiceId>&lt;audio:VSM_260_060_013&gt;</VoiceId>
      <JapaneseText>メルティアか……
よし、それじゃあ、行こう</JapaneseText>
      <EnglishText>Meltia... Well, little girl, let's go.</EnglishText>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>13</Id>
      <Status>Proofreading</Status>
    </Entry>
