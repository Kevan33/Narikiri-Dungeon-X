    <Entry>
      <PointerOffset>298924</PointerOffset>
      <VoiceId>&lt;audio:VSM_120_060_029&gt;</VoiceId>
      <JapaneseText>くっ……うわっ……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>1</Id>
      <OldPtr>279880</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>299004</PointerOffset>
      <VoiceId>&lt;audio:VSM_120_060_030&gt;</VoiceId>
      <JapaneseText>バラバラに……
なりそう……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>2</Id>
      <OldPtr>280324</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>299112</PointerOffset>
      <VoiceId>&lt;audio:VSM_120_060_031&gt;</VoiceId>
      <JapaneseText>普段は体の耐久度に応じて
抑制されとる力じゃからの</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>3</Id>
      <OldPtr>280464</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>299184</PointerOffset>
      <VoiceId>&lt;audio:VSM_120_060_032&gt;</VoiceId>
      <JapaneseText>&lt;Dio&gt;！　&lt;Mel&gt;！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>4</SpeakerId>
      <Id>4</Id>
      <OldPtr>280660</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>299272</PointerOffset>
      <VoiceId>&lt;audio:VSM_120_060_033&gt;</VoiceId>
      <JapaneseText>おい！　じいさん！
大丈夫なのかよ！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>5</SpeakerId>
      <Id>5</Id>
      <OldPtr>280856</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>299376</PointerOffset>
      <VoiceId>&lt;audio:VSM_120_060_034&gt;</VoiceId>
      <JapaneseText>さぁのう。
じゃが、初めに
警告したはずじゃぞ</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>6</Id>
      <OldPtr>280996</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>299448</PointerOffset>
      <VoiceId>&lt;audio:VSM_120_060_035&gt;</VoiceId>
      <JapaneseText>くっ、苦しいよ……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>7</Id>
      <OldPtr>281136</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>299528</PointerOffset>
      <VoiceId>&lt;audio:VSM_120_060_036&gt;</VoiceId>
      <JapaneseText>うっ……うわぁあああっ！！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>8</Id>
      <OldPtr>281660</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>299688</PointerOffset>
      <VoiceId>&lt;audio:VSM_120_060_037&gt;</VoiceId>
      <JapaneseText>アミィと変わらない歳の子が
こんなに苦しんでるのに……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>5</SpeakerId>
      <Id>9</Id>
      <BubbleId>0</BubbleId>
      <OldPtr>281800</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>299688</PointerOffset>
      <VoiceId>&lt;audio:VSM_120_060_038&gt;</VoiceId>
      <JapaneseText>オレは……
何もできないのか……！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>5</SpeakerId>
      <Id>9</Id>
      <BubbleId>1</BubbleId>
      <OldPtr>281800</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>299776</PointerOffset>
      <VoiceId>&lt;audio:VSM_120_060_039&gt;</VoiceId>
      <JapaneseText>きゃあああっ！
うわぁあっ！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>6</SpeakerId>
      <Id>11</Id>
      <OldPtr>282672</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>299908</PointerOffset>
      <VoiceId>&lt;audio:VSM_120_060_041&gt;</VoiceId>
      <JapaneseText>ハァ、ハァ……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>12</Id>
      <OldPtr>283912</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>299988</PointerOffset>
      <VoiceId>&lt;audio:VSM_120_060_042&gt;</VoiceId>
      <JapaneseText>し、死ぬかと……
思った……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>13</Id>
      <OldPtr>284052</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>300060</PointerOffset>
      <VoiceId>&lt;audio:VSM_120_060_043&gt;</VoiceId>
      <JapaneseText>だ、大丈夫なのか……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>5</SpeakerId>
      <Id>14</Id>
      <OldPtr>284248</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>300156</PointerOffset>
      <VoiceId>&lt;audio:VSM_120_060_044&gt;</VoiceId>
      <JapaneseText>よく耐えたの。
さて、もう一戦やるかの</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>15</Id>
      <OldPtr>284388</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>300244</PointerOffset>
      <VoiceId>&lt;audio:VSM_120_060_045&gt;</VoiceId>
      <JapaneseText>おい！　何考えてんだ、
じいさん！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>5</SpeakerId>
      <Id>16</Id>
      <OldPtr>284872</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>300316</PointerOffset>
      <VoiceId>&lt;audio:VSM_120_060_046&gt;</VoiceId>
      <JapaneseText>もう、やめさせて！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>4</SpeakerId>
      <Id>17</Id>
      <OldPtr>285012</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>300432</PointerOffset>
      <VoiceId>&lt;audio:VSM_120_060_047&gt;</VoiceId>
      <JapaneseText>なに、後はちょいと
この力を制御する方法を
教えるだけじゃて</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>18</Id>
      <OldPtr>285152</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>300512</PointerOffset>
      <VoiceId>&lt;audio:VSM_120_060_048&gt;</VoiceId>
      <JapaneseText>平気、です、
&lt;Chester&gt;さん……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>19</Id>
      <OldPtr>285628</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>300592</PointerOffset>
      <VoiceId>&lt;audio:VSM_120_060_049&gt;</VoiceId>
      <JapaneseText>覚悟しやがれ……
じじぃ……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>20</Id>
      <OldPtr>285880</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>300668</PointerOffset>
      <VoiceId>&lt;audio:VSM_120_060_050&gt;</VoiceId>
      <JapaneseText>では……行くぞ？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>21</Id>
      <OldPtr>286452</OldPtr>
      <Status>To Do</Status>
    </Entry>
