    <Section>Main</Section>
    <Entry>
      <PointerOffset>298508</PointerOffset>
      <VoiceId>&lt;audio:VSM_060_030_018&gt;</VoiceId>
      <JapaneseText>よかった……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>1</Id>
      <OldPtr>279232</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>298648</PointerOffset>
      <VoiceId>&lt;audio:VSM_060_030_020&gt;</VoiceId>
      <JapaneseText>か、軽ぃ軽ぃ……！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>2</Id>
      <OldPtr>279476</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>298836</PointerOffset>
      <VoiceId>&lt;audio:VSM_060_030_022&gt;</VoiceId>
      <JapaneseText>……いいでしょう。
あなたたちに我が精霊晶核を
お分けしましょう</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>3</Id>
      <OldPtr>279896</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>298900</PointerOffset>
      <VoiceId>&lt;audio:VSM_060_030_023&gt;</VoiceId>
      <JapaneseText>それでは……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>4</Id>
      <OldPtr>281916</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>298972</PointerOffset>
      <VoiceId>&lt;audio:VSM_060_030_024&gt;</VoiceId>
      <JapaneseText>……まだ足りない……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>4</SpeakerId>
      <Id>5</Id>
      <OldPtr>283408</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>299040</PointerOffset>
      <VoiceId>&lt;audio:VSM_060_030_025&gt;</VoiceId>
      <JapaneseText>足りないって？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>6</Id>
      <OldPtr>283780</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>299144</PointerOffset>
      <VoiceId>&lt;audio:VSM_060_030_026&gt;</VoiceId>
      <JapaneseText>乙女のヒミツを覗くなんて、
&lt;Dio&gt;くん、だいた～ん！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>4</SpeakerId>
      <Id>7</Id>
      <OldPtr>284228</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>299228</PointerOffset>
      <VoiceId>&lt;audio:VSM_060_030_027&gt;</VoiceId>
      <JapaneseText>いや、そんなんと
違くて……！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>8</Id>
      <OldPtr>284424</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>299316</PointerOffset>
      <VoiceId>&lt;audio:VSM_060_030_028&gt;</VoiceId>
      <JapaneseText>ちょっと、&lt;Dio&gt;、
何やってるの？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>9</Id>
      <OldPtr>285036</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>299416</PointerOffset>
      <VoiceId>&lt;audio:VSM_060_030_029&gt;</VoiceId>
      <JapaneseText>ほら、他の精霊さんとこ、
行ったりするんでしょ？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>4</SpeakerId>
      <Id>10</Id>
      <OldPtr>285596</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>299512</PointerOffset>
      <VoiceId>&lt;audio:VSM_060_030_030&gt;</VoiceId>
      <JapaneseText>そ、そうそう、それそれ！
次はどこ行くんだ？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>11</Id>
      <OldPtr>285792</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>299628</PointerOffset>
      <VoiceId>&lt;audio:VSM_060_030_031&gt;</VoiceId>
      <JapaneseText>ここからだと
この大陸を南に下がった
&lt;Red&gt;精霊の洞窟&lt;White&gt;が一番近いな</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>5</SpeakerId>
      <Id>12</Id>
      <OldPtr>285988</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>299732</PointerOffset>
      <VoiceId>&lt;audio:VSM_060_030_032&gt;</VoiceId>
      <JapaneseText>&lt;Red&gt;精霊の洞窟&lt;White&gt;ってことは、
ノームがいるところだね</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>4</SpeakerId>
      <Id>13</Id>
      <OldPtr>286912</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>299804</PointerOffset>
      <VoiceId>&lt;audio:VSM_060_030_033&gt;</VoiceId>
      <JapaneseText>んじゃ、行ってみよう</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>4</SpeakerId>
      <Id>14</Id>
      <OldPtr>287716</OldPtr>
      <Status>To Do</Status>
    </Entry>
