    <Entry>
      <PointerOffset>274960</PointerOffset>
      <JapaneseText>み、見つかっただす……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>1</Id>
      <OldPtr>258936</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>275036</PointerOffset>
      <JapaneseText>見つかったって、
一応、ここ店なんだろ？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>2</Id>
      <OldPtr>259132</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>275128</PointerOffset>
      <JapaneseText>み、店だすが……、
う、売り物はないだす……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>3</Id>
      <OldPtr>259272</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>275204</PointerOffset>
      <JapaneseText>売り物がないから、
こんなところにいたの？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>4</Id>
      <OldPtr>259468</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>275332</PointerOffset>
      <JapaneseText>す、すまんこっただす……
お、おいどんが扱ってるのは……
お、音だけなんだすよ……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>5</Id>
      <OldPtr>259712</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>275404</PointerOffset>
      <JapaneseText>音ってことは、
聞けるってことですか？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>4</SpeakerId>
      <Id>6</Id>
      <OldPtr>259852</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>275520</PointerOffset>
      <JapaneseText>ひ、ひーーー！
な、何も売ってなくて……
わ、悪いと思ってるだす……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>7</Id>
      <OldPtr>260096</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>275628</PointerOffset>
      <JapaneseText>おめぇよ、
さっきから、喋りがうざいだよ。
言いたい事サッサと伝えるだ</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>5</SpeakerId>
      <Id>8</Id>
      <OldPtr>260292</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>275700</PointerOffset>
      <JapaneseText>おまえが言うのか、
この書き割り野郎が</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>9</Id>
      <OldPtr>260952</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>275780</PointerOffset>
      <JapaneseText>あんだとー！
この毛無しのハゲぼうずが！！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>5</SpeakerId>
      <Id>10</Id>
      <OldPtr>261252</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>275912</PointerOffset>
      <JapaneseText>す、すまんこっただす……
お、おいどんのせいだす……
こ、これで許してほしいだす……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>11</Id>
      <OldPtr>261392</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>276008</PointerOffset>
      <JapaneseText>売り物が無くて、
音があるってのは、
こういう事だったんですね</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>4</SpeakerId>
      <Id>12</Id>
      <OldPtr>263280</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>276112</PointerOffset>
      <JapaneseText>ひ、ひーーーー！！！
や、やっぱり怒ってるだすか……？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>13</Id>
      <OldPtr>263580</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>276176</PointerOffset>
      <JapaneseText>いやいや、
誰も怒ってないかラ</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>14</Id>
      <OldPtr>263776</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>276276</PointerOffset>
      <JapaneseText>ほ、ほんとだすか……
そ、それなら良かっただす……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>15</Id>
      <OldPtr>264076</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>276348</PointerOffset>
      <JapaneseText>これって、
また聞かしてくれんだろ？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>16</Id>
      <OldPtr>264216</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>276440</PointerOffset>
      <JapaneseText>は、はい～～～！
い、いつでもＯＫだす……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>17</Id>
      <OldPtr>264356</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>276528</PointerOffset>
      <JapaneseText>それじゃ、
また聞きに来ますね。
ありがとうございます</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>4</SpeakerId>
      <Id>18</Id>
      <OldPtr>264496</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>276676</PointerOffset>
      <JapaneseText>さっき、エト助が、
誰も怒ってねぇつったが、
おらだけは別だかんな</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>5</SpeakerId>
      <Id>19</Id>
      <BubbleId>0</BubbleId>
      <OldPtr>265356</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>276676</PointerOffset>
      <JapaneseText>おらは、おめぇみたいなやつ
いらいらしてくるだ</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>5</SpeakerId>
      <Id>19</Id>
      <BubbleId>1</BubbleId>
      <OldPtr>265356</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>276812</PointerOffset>
      <JapaneseText>んだども、
おめぇのその音への気持ち
おらは好きだど</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>5</SpeakerId>
      <Id>21</Id>
      <BubbleId>0</BubbleId>
      <OldPtr>265552</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>276812</PointerOffset>
      <JapaneseText>これからも、精進せぇ。
んだば、また来るだーよ</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>5</SpeakerId>
      <Id>21</Id>
      <BubbleId>1</BubbleId>
      <OldPtr>265552</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>276912</PointerOffset>
      <JapaneseText>あ、ありがとうだす……
や、安っぽいタンスの人……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>23</Id>
      <OldPtr>265888</OldPtr>
      <Status>To Do</Status>
    </Entry>
