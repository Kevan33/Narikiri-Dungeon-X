    <Entry>
      <PointerOffset>281988</PointerOffset>
      <VoiceId>&lt;audio:VSM_210_050_001&gt;</VoiceId>
      <JapaneseText>&lt;Suzu&gt;ちゃん……！
どうしたんだ！？</JapaneseText>
      <EnglishText>Hey, &lt;Suzu&gt;, are you okay!?</EnglishText>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>1</Id>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset>282052</PointerOffset>
      <VoiceId>&lt;audio:VSM_210_050_002&gt;</VoiceId>
      <JapaneseText>出てきなさい</JapaneseText>
      <EnglishText>Show yourself.</EnglishText>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>2</Id>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset>282128</PointerOffset>
      <VoiceId>&lt;audio:VSM_210_050_003&gt;</VoiceId>
      <JapaneseText>我々の幻を破るとはな</JapaneseText>
      <EnglishText>You really tore down our little illusion.</EnglishText>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>3</Id>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset>282220</PointerOffset>
      <VoiceId>&lt;audio:VSM_210_050_004&gt;</VoiceId>
      <JapaneseText>私たちの仲間を
倒したのはあなた方ですね</JapaneseText>
      <EnglishText>You were the ones that killed my scouts.</EnglishText>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>4</Id>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset>282300</PointerOffset>
      <VoiceId>&lt;audio:VSM_210_050_005&gt;</VoiceId>
      <JapaneseText>手ごたえのない連中だった</JapaneseText>
      <EnglishText>Quite a resistant bunch, honestly.</EnglishText>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>5</Id>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset>282412</PointerOffset>
      <VoiceId>&lt;audio:VSM_210_050_006&gt;</VoiceId>
      <JapaneseText>またおまえら……！
どーゆーつもりだ、
&lt;Suzu&gt;ちゃんにまで！</JapaneseText>
      <EnglishText>It's you bastards again...! And now
you're even messing with &lt;Suzu&gt;!</EnglishText>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>6</Id>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset>282484</PointerOffset>
      <VoiceId>&lt;audio:VSM_210_050_007&gt;</VoiceId>
      <JapaneseText>知り合いなのですか？</JapaneseText>
      <EnglishText>An acquaintance of yours?</EnglishText>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>7</Id>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset>282624</PointerOffset>
      <VoiceId>&lt;audio:VSM_210_050_008&gt;</VoiceId>
      <JapaneseText>そんなんと違うよ</JapaneseText>
      <EnglishText>Hell no!</EnglishText>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>8</Id>
      <BubbleId>0</BubbleId>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset>282624</PointerOffset>
      <VoiceId>&lt;audio:VSM_210_050_009&gt;</VoiceId>
      <JapaneseText>なんかずっとオレら、
嫌がらせされてんだ、
こいつらに</JapaneseText>
      <EnglishText>Every time something has
gone to hell, these masked
freaks were behind it.</EnglishText>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>8</Id>
      <BubbleId>1</BubbleId>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset>282720</PointerOffset>
      <VoiceId>&lt;audio:VSM_210_050_010&gt;</VoiceId>
      <JapaneseText>それでは、
プルートの手の者では
ないのですね</JapaneseText>
      <EnglishText>In that case they cannot
be allied with Pluto.</EnglishText>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>10</Id>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset>282808</PointerOffset>
      <VoiceId>&lt;audio:VSM_210_050_011&gt;</VoiceId>
      <JapaneseText>一体、&lt;Suzu&gt;ちゃんに
何をしたの！？</JapaneseText>
      <EnglishText>What have you done to &lt;Suzu&gt;!?</EnglishText>
      <Notes/>
      <SpeakerId>4</SpeakerId>
      <Id>11</Id>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset>282888</PointerOffset>
      <VoiceId>&lt;audio:VSM_210_050_012&gt;</VoiceId>
      <JapaneseText>ちょっとからかってみただけ</JapaneseText>
      <EnglishText>We were just playing a little game.</EnglishText>
      <Notes/>
      <SpeakerId>5</SpeakerId>
      <Id>12</Id>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset>282984</PointerOffset>
      <VoiceId>&lt;audio:VSM_210_050_013&gt;</VoiceId>
      <JapaneseText>だが、そう簡単には、
たぶらかせなかったか</JapaneseText>
      <EnglishText>But, she didn't really want to
play along. Shame, really.</EnglishText>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>13</Id>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset>283204</PointerOffset>
      <VoiceId>&lt;audio:VSM_210_050_016&gt;</VoiceId>
      <JapaneseText>あいつら……！</JapaneseText>
      <EnglishText>Those rotten...!</EnglishText>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>14</Id>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset>283264</PointerOffset>
      <VoiceId>&lt;audio:VSM_210_050_017&gt;</VoiceId>
      <JapaneseText>平気！？</JapaneseText>
      <EnglishText>Is everyone okay!?</EnglishText>
      <Notes/>
      <SpeakerId>4</SpeakerId>
      <Id>15</Id>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset>283432</PointerOffset>
      <VoiceId>&lt;audio:VSM_210_050_018&gt;</VoiceId>
      <JapaneseText>ええ……</JapaneseText>
      <EnglishText>Yes...</EnglishText>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>16</Id>
      <BubbleId>0</BubbleId>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset>283432</PointerOffset>
      <VoiceId>&lt;audio:VSM_210_050_019&gt;</VoiceId>
      <JapaneseText>掟に忠実で、自分の生き方に疑問を
持たなかった、以前の私なら
こんな失態はなかったでしょう</JapaneseText>
      <EnglishText>I fell into their illusion knowing it was a trap...
tempted by the questions lurking in my mind
since I met you two. I've acted disgracefully.</EnglishText>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>16</Id>
      <BubbleId>1</BubbleId>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset>283540</PointerOffset>
      <VoiceId>&lt;audio:VSM_210_050_020&gt;</VoiceId>
      <JapaneseText>それって、
&lt;Suzu&gt;ちゃんは前と
何か変わったってことか？</JapaneseText>
      <EnglishText>So...you've had these doubts
for a long time?</EnglishText>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>18</Id>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset>283640</PointerOffset>
      <VoiceId>&lt;audio:VSM_210_050_021&gt;</VoiceId>
      <JapaneseText>ええ……&lt;Cless&gt;さんとの出会いが
私を変えたのです</JapaneseText>
      <EnglishText>Correct... Ever since I met with
&lt;Cless&gt; I have had my doubts.</EnglishText>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>19</Id>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset>283820</PointerOffset>
      <VoiceId>&lt;audio:VSM_210_050_022&gt;</VoiceId>
      <JapaneseText>今は、こんな迷いのある
自分もちゃんと受け入れたい、
そう思うんです</JapaneseText>
      <EnglishText>I think just now...I wanted to be
tricked and accepted the temptation.</EnglishText>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>20</Id>
      <BubbleId>0</BubbleId>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset>283820</PointerOffset>
      <VoiceId>&lt;audio:VSM_210_050_023&gt;</VoiceId>
      <JapaneseText>どんな不安があっても
それと向き合いたい、と</JapaneseText>
      <EnglishText>If there exists any anxiety,
our own judgment will be
clouded by our feelings.</EnglishText>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>20</Id>
      <BubbleId>1</BubbleId>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset>283892</PointerOffset>
      <VoiceId>&lt;audio:VSM_210_050_024&gt;</VoiceId>
      <JapaneseText>&lt;Suzu&gt;ちゃんも……</JapaneseText>
      <EnglishText>&lt;Suzu&gt;...You're...</EnglishText>
      <Notes/>
      <SpeakerId>4</SpeakerId>
      <Id>22</Id>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset>283972</PointerOffset>
      <VoiceId>&lt;audio:VSM_210_050_025&gt;</VoiceId>
      <JapaneseText>……オレらと
同じなんだな</JapaneseText>
      <EnglishText>No different from us...</EnglishText>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>23</Id>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset>284056</PointerOffset>
      <VoiceId>&lt;audio:VSM_210_050_026&gt;</VoiceId>
      <JapaneseText>そっか……
強いんだね、みんな</JapaneseText>
      <EnglishText>Everyone...is so strong...</EnglishText>
      <Notes/>
      <SpeakerId>6</SpeakerId>
      <Id>24</Id>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset>284120</PointerOffset>
      <VoiceId>&lt;audio:VSM_210_050_027&gt;</VoiceId>
      <JapaneseText>強い……？</JapaneseText>
      <EnglishText>Strong?</EnglishText>
      <Notes/>
      <SpeakerId>4</SpeakerId>
      <Id>25</Id>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset>285556</PointerOffset>
      <VoiceId>&lt;audio:VSM_210_050_044&gt;</VoiceId>
      <JapaneseText>ファあ……！</JapaneseText>
      <EnglishText>Haah!</EnglishText>
      <Notes/>
      <SpeakerId>7</SpeakerId>
      <Id>26</Id>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset>285628</PointerOffset>
      <VoiceId>&lt;audio:VSM_210_050_045&gt;</VoiceId>
      <JapaneseText>今のエトの声……？</JapaneseText>
      <EnglishText>Was that Eto's voice just now!?</EnglishText>
      <Notes/>
      <SpeakerId>4</SpeakerId>
      <Id>27</Id>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset>285692</PointerOffset>
      <VoiceId>&lt;audio:VSM_210_050_046&gt;</VoiceId>
      <JapaneseText>行こうぜ！</JapaneseText>
      <EnglishText>Let's go!</EnglishText>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>28</Id>
      <Status>Proofreading</Status>
    </Entry>
