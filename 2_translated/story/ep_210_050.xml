    <Entry>
      <PointerOffset>281988</PointerOffset>
      <VoiceId>&lt;audio:VSM_210_050_001&gt;</VoiceId>
      <JapaneseText>&lt;Suzu&gt;ちゃん……！
どうしたんだ！？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>1</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>282052</PointerOffset>
      <VoiceId>&lt;audio:VSM_210_050_002&gt;</VoiceId>
      <JapaneseText>出てきなさい</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>2</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>282128</PointerOffset>
      <VoiceId>&lt;audio:VSM_210_050_003&gt;</VoiceId>
      <JapaneseText>我々の幻を破るとはな</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>3</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>282220</PointerOffset>
      <VoiceId>&lt;audio:VSM_210_050_004&gt;</VoiceId>
      <JapaneseText>私たちの仲間を
倒したのはあなた方ですね</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>4</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>282300</PointerOffset>
      <VoiceId>&lt;audio:VSM_210_050_005&gt;</VoiceId>
      <JapaneseText>手ごたえのない連中だった</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>5</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>282412</PointerOffset>
      <VoiceId>&lt;audio:VSM_210_050_006&gt;</VoiceId>
      <JapaneseText>&lt;Suzu&gt;またおまえら……！
どーゆーつもりだ、
ちゃんにまで！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>6</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>282484</PointerOffset>
      <VoiceId>&lt;audio:VSM_210_050_007&gt;</VoiceId>
      <JapaneseText>知り合いなのですか？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>7</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>282624</PointerOffset>
      <VoiceId>&lt;audio:VSM_210_050_008&gt;</VoiceId>
      <JapaneseText></JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>8</Id>
      <BubbleId>0</BubbleId>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>282624</PointerOffset>
      <VoiceId>&lt;audio:VSM_210_050_009&gt;</VoiceId>
      <JapaneseText>そんなんと違うよなんかずっとオレら、
嫌がらせされてんだ、
こいつらに</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>8</Id>
      <BubbleId>1</BubbleId>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>282720</PointerOffset>
      <VoiceId>&lt;audio:VSM_210_050_010&gt;</VoiceId>
      <JapaneseText>それでは、
プルートの手の者では
ないのですね</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>10</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>282808</PointerOffset>
      <VoiceId>&lt;audio:VSM_210_050_011&gt;</VoiceId>
      <JapaneseText>&lt;Suzu&gt;一体、ちゃんに
何をしたの！？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>4</SpeakerId>
      <Id>11</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>282888</PointerOffset>
      <VoiceId>&lt;audio:VSM_210_050_012&gt;</VoiceId>
      <JapaneseText>ちょっとからかってみただけ</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>5</SpeakerId>
      <Id>12</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>282984</PointerOffset>
      <VoiceId>&lt;audio:VSM_210_050_013&gt;</VoiceId>
      <JapaneseText>だが、そう簡単には、
たぶらかせなかったか</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>13</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>283204</PointerOffset>
      <VoiceId>&lt;audio:VSM_210_050_016&gt;</VoiceId>
      <JapaneseText>あいつら……！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>14</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>283264</PointerOffset>
      <VoiceId>&lt;audio:VSM_210_050_017&gt;</VoiceId>
      <JapaneseText>平気！？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>4</SpeakerId>
      <Id>15</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>283432</PointerOffset>
      <VoiceId>&lt;audio:VSM_210_050_018&gt;</VoiceId>
      <JapaneseText></JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>16</Id>
      <BubbleId>0</BubbleId>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>283432</PointerOffset>
      <VoiceId>&lt;audio:VSM_210_050_019&gt;</VoiceId>
      <JapaneseText>ええ……掟に忠実で、自分の生き方に疑問を
持たなかった、以前の私なら
こんな失態はなかったでしょう</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>16</Id>
      <BubbleId>1</BubbleId>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>283540</PointerOffset>
      <VoiceId>&lt;audio:VSM_210_050_020&gt;</VoiceId>
      <JapaneseText>&lt;Suzu&gt;それって、
ちゃんは前と
何か変わったってことか？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>18</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>283640</PointerOffset>
      <VoiceId>&lt;audio:VSM_210_050_021&gt;</VoiceId>
      <JapaneseText>&lt;Cless&gt;ええ……さんとの出会いが
私を変えたのです</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>19</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>283820</PointerOffset>
      <VoiceId>&lt;audio:VSM_210_050_022&gt;</VoiceId>
      <JapaneseText></JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>20</Id>
      <BubbleId>0</BubbleId>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>283820</PointerOffset>
      <VoiceId>&lt;audio:VSM_210_050_023&gt;</VoiceId>
      <JapaneseText>今は、こんな迷いのある
自分もちゃんと受け入れたい、
そう思うんですどんな不安があっても
それと向き合いたい、と</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>20</Id>
      <BubbleId>1</BubbleId>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>283892</PointerOffset>
      <VoiceId>&lt;audio:VSM_210_050_024&gt;</VoiceId>
      <JapaneseText>&lt;Suzu&gt;ちゃんも……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>4</SpeakerId>
      <Id>22</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>283972</PointerOffset>
      <VoiceId>&lt;audio:VSM_210_050_025&gt;</VoiceId>
      <JapaneseText>……オレらと
同じなんだな</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>23</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>284056</PointerOffset>
      <VoiceId>&lt;audio:VSM_210_050_026&gt;</VoiceId>
      <JapaneseText>そっか……
強いんだね、みんな</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>6</SpeakerId>
      <Id>24</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>284120</PointerOffset>
      <VoiceId>&lt;audio:VSM_210_050_027&gt;</VoiceId>
      <JapaneseText>強い……？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>4</SpeakerId>
      <Id>25</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>285556</PointerOffset>
      <VoiceId>&lt;audio:VSM_210_050_044&gt;</VoiceId>
      <JapaneseText>ファあ……！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>7</SpeakerId>
      <Id>26</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>285628</PointerOffset>
      <VoiceId>&lt;audio:VSM_210_050_045&gt;</VoiceId>
      <JapaneseText>今のエトの声……？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>4</SpeakerId>
      <Id>27</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>285692</PointerOffset>
      <VoiceId>&lt;audio:VSM_210_050_046&gt;</VoiceId>
      <JapaneseText>行こうぜ！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>28</Id>
      <Status>To Do</Status>
    </Entry>
