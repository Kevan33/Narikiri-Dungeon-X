    <Section>Main</Section>
    <Entry>
      <PointerOffset>278060</PointerOffset>
      <VoiceId>&lt;audio:VSM_210_060_001&gt;</VoiceId>
      <JapaneseText>エト！</JapaneseText>
      <EnglishText>Eto!</EnglishText>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>1</Id>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset>278128</PointerOffset>
      <VoiceId>&lt;audio:VSM_210_060_002&gt;</VoiceId>
      <JapaneseText>どこにいんだ！</JapaneseText>
      <EnglishText>Where are you!?</EnglishText>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>2</Id>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset>278204</PointerOffset>
      <VoiceId>&lt;audio:VSM_210_060_003&gt;</VoiceId>
      <JapaneseText>&lt;Dio&gt;！？　&lt;Mel&gt;！？</JapaneseText>
      <EnglishText>&lt;Dio&gt;!? &lt;Mel&gt;!?</EnglishText>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>3</Id>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset>278272</PointerOffset>
      <VoiceId>&lt;audio:VSM_210_060_004&gt;</VoiceId>
      <JapaneseText>エト、どこ！？</JapaneseText>
      <EnglishText>Eto, where are you!?</EnglishText>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>4</Id>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset>278336</PointerOffset>
      <VoiceId>&lt;audio:VSM_210_060_005&gt;</VoiceId>
      <JapaneseText>ここだよ～！</JapaneseText>
      <EnglishText>I'm right here!</EnglishText>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>5</Id>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset>278620</PointerOffset>
      <VoiceId>&lt;audio:VSM_210_060_008&gt;</VoiceId>
      <JapaneseText>待ってください、
これもあの仮面の者たちの
幻なのでは……？</JapaneseText>
      <EnglishText>Wait a moment. Could this
not be another illusion of
those masked people?</EnglishText>
      <Notes/>
      <SpeakerId>4</SpeakerId>
      <Id>6</Id>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset>278728</PointerOffset>
      <VoiceId>&lt;audio:VSM_210_060_009&gt;</VoiceId>
      <JapaneseText>ううん、そんなことない、
これはエトの声に間違いないよ！</JapaneseText>
      <EnglishText>No, I'm sure of this.
I could recognize Eto's
voice anywhere.</EnglishText>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>7</Id>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset>278820</PointerOffset>
      <VoiceId>&lt;audio:VSM_210_060_010&gt;</VoiceId>
      <JapaneseText>オレらがエトの声、
聞き違うはずねーもん</JapaneseText>
      <EnglishText>You can count on me,
that's Eto's voice.</EnglishText>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>8</Id>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset>278888</PointerOffset>
      <VoiceId>&lt;audio:VSM_210_060_011&gt;</VoiceId>
      <JapaneseText>そうなんですか？</JapaneseText>
      <EnglishText>How can you be so certain?</EnglishText>
      <Notes/>
      <SpeakerId>4</SpeakerId>
      <Id>9</Id>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset>278992</PointerOffset>
      <VoiceId>&lt;audio:VSM_210_060_012&gt;</VoiceId>
      <JapaneseText>ふたりにとって、エトちゃんは
母親みたいなものだしね</JapaneseText>
      <EnglishText>Miss Eto is none other than
their foster mother. I trust
the twins on this one.</EnglishText>
      <Notes/>
      <SpeakerId>5</SpeakerId>
      <Id>10</Id>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset>279092</PointerOffset>
      <VoiceId>&lt;audio:VSM_210_060_013&gt;</VoiceId>
      <JapaneseText>お母さん……</JapaneseText>
      <EnglishText>Mother...</EnglishText>
      <Notes/>
      <SpeakerId>4</SpeakerId>
      <Id>11</Id>
      <BubbleId>0</BubbleId>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset>279092</PointerOffset>
      <VoiceId>&lt;audio:VSM_210_060_014&gt;</VoiceId>
      <JapaneseText>そうですか……</JapaneseText>
      <EnglishText>I see...</EnglishText>
      <Notes/>
      <SpeakerId>4</SpeakerId>
      <Id>11</Id>
      <BubbleId>1</BubbleId>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset>279180</PointerOffset>
      <VoiceId>&lt;audio:VSM_210_060_015&gt;</VoiceId>
      <JapaneseText>&lt;Dio&gt;ー！　&lt;Mel&gt;ー！！
どこ～！？</JapaneseText>
      <EnglishText>&lt;Dio&gt;! &lt;Mel&gt;!! Where are you!?</EnglishText>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>13</Id>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset>279392</PointerOffset>
      <VoiceId>&lt;audio:VSM_210_060_017&gt;</VoiceId>
      <JapaneseText>……くんくん……</JapaneseText>
      <EnglishText>...*sniff sniff*...</EnglishText>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>14</Id>
      <BubbleId>0</BubbleId>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset>279392</PointerOffset>
      <VoiceId>&lt;audio:VSM_210_060_018&gt;</VoiceId>
      <JapaneseText>こっち……！
エトの匂いがする……！</JapaneseText>
      <EnglishText>This way...! Eto's smell is
coming from here...!</EnglishText>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>14</Id>
      <BubbleId>1</BubbleId>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset>279456</PointerOffset>
      <VoiceId>&lt;audio:VSM_210_060_019&gt;</VoiceId>
      <JapaneseText>匂い……？</JapaneseText>
      <EnglishText>Her smell...?</EnglishText>
      <Notes/>
      <SpeakerId>4</SpeakerId>
      <Id>16</Id>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset>279596</PointerOffset>
      <VoiceId>&lt;audio:VSM_210_060_021&gt;</VoiceId>
      <JapaneseText>……エト！
そこを動かないで！</JapaneseText>
      <EnglishText>...Eto! Please don't move
while we go for you!</EnglishText>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>17</Id>
      <Status>Proofreading</Status>
    </Entry>
