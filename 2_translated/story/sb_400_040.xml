    <Entry>
      <PointerOffset>294212</PointerOffset>
      <JapaneseText>私と再び戦うと
言うのですか？しかし、私には
あなた方と戦う理由が……そうですか、
自らに対する試練と
いうわけですね……いいでしょう、
お相手しましょう！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>2</Id>
      <BubbleId>3</BubbleId>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>294284</PointerOffset>
      <JapaneseText>私の負けです……
またいらしてください</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>6</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>294432</PointerOffset>
      <JapaneseText>シルフ！
オレらに力を貸してくれ！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>7</Id>
      <Status>To Do</Status>
