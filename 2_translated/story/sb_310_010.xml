    <Entry>
      <PointerOffset>274420</PointerOffset>
      <JapaneseText>&lt;Suzu&gt;ねぇねぇ、ちゃんとこの温泉、
久しぶりに、みんなで入ろうよ。
ちょっと癒されたいじゃない？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>1</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>274472</PointerOffset>
      <JapaneseText>ゲッ！
お、温泉!?</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>2</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>274540</PointerOffset>
      <JapaneseText>どうした？
温泉入るのイヤなのか？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>3</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>274604</PointerOffset>
      <JapaneseText>&lt;Dio&gt;は、お風呂嫌いなんです</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>4</SpeakerId>
      <Id>4</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>274720</PointerOffset>
      <JapaneseText>&lt;Dio&gt;くんお風呂嫌いなんだぁ。
じゃ、お姉さんと一緒に入る？
体、洗ってあげるよ∀</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>5</SpeakerId>
      <Id>5</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>274804</PointerOffset>
      <JapaneseText>な、な！
自分で洗えるって！
先に入ってっから！！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>6</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>274880</PointerOffset>
      <JapaneseText>&lt;Dio&gt;もう、を
からかわないでください！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>4</SpeakerId>
      <Id>7</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>274984</PointerOffset>
      <JapaneseText>いいじゃない。
結果はどうあれ、自ら進んで
お風呂に入ったんだから、ね？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>5</SpeakerId>
      <Id>8</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>275072</PointerOffset>
      <JapaneseText>よーし！
ゆーっくり、お風呂入って
旅の疲れを癒そうね</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>9</Id>
      <Status>To Do</Status>
    </Entry>
