  <Strings>
    <Section>Main</Section>
    <Entry>
      <PointerOffset>270828</PointerOffset>
      <VoiceId>&lt;audio:VSM_270_050_001&gt;</VoiceId>
      <JapaneseText>……………………</JapaneseText>
      <EnglishText>...</EnglishText>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>1</Id>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset>270904</PointerOffset>
      <VoiceId>&lt;audio:VSM_270_050_002&gt;</VoiceId>
      <JapaneseText>どうした？　ひとりか？</JapaneseText>
      <EnglishText>What's the matter? Are you on your own?</EnglishText>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>2</Id>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset>270984</PointerOffset>
      <VoiceId>&lt;audio:VSM_270_050_003&gt;</VoiceId>
      <JapaneseText>何だよ、おじさん？</JapaneseText>
      <EnglishText>What do you need, sir?</EnglishText>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>3</Id>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset>271076</PointerOffset>
      <VoiceId>&lt;audio:VSM_270_050_004&gt;</VoiceId>
      <JapaneseText>私はバンディ。
パレスグドラの将軍だ</JapaneseText>
      <EnglishText>I'm Bandi. I'm a general of Palace Gudora.</EnglishText>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>4</Id>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset>271160</PointerOffset>
      <VoiceId>&lt;audio:VSM_270_050_005&gt;</VoiceId>
      <JapaneseText>その将軍が
何の用だよ</JapaneseText>
      <EnglishText>What does a general want with me?</EnglishText>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>5</Id>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset>271256</PointerOffset>
      <VoiceId>&lt;audio:VSM_270_050_006&gt;</VoiceId>
      <JapaneseText>いや……おまえの
父と母はどうした？</JapaneseText>
      <EnglishText>No matter... Where are your parents, boy?</EnglishText>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>6</Id>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset>271380</PointerOffset>
      <VoiceId>&lt;audio:VSM_270_050_007&gt;</VoiceId>
      <JapaneseText>ふたりとも
パレスセダムの兵隊に……</JapaneseText>
      <EnglishText>Palace Sedamyu's soldiers
attacked them, and...</EnglishText>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>7</Id>
      <BubbleId>0</BubbleId>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset>271380</PointerOffset>
      <VoiceId>&lt;audio:VSM_270_050_008&gt;</VoiceId>
      <JapaneseText>くっ……！</JapaneseText>
      <EnglishText>Ungh...!</EnglishText>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>7</Id>
      <BubbleId>1</BubbleId>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset>271456</PointerOffset>
      <VoiceId>&lt;audio:VSM_270_050_009&gt;</VoiceId>
      <JapaneseText>殺された……か……</JapaneseText>
      <EnglishText>They killed them...didn't they?</EnglishText>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>9</Id>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset>271656</PointerOffset>
      <VoiceId>&lt;audio:VSM_270_050_010&gt;</VoiceId>
      <JapaneseText>くそっ……！
パレスセダムの奴ら……</JapaneseText>
      <EnglishText>Damn it...! It's all the fault of
those Palace Sedamyu assholes...</EnglishText>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>10</Id>
      <BubbleId>0</BubbleId>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset>271656</PointerOffset>
      <VoiceId>&lt;audio:VSM_270_050_011&gt;</VoiceId>
      <JapaneseText>滅ぼしてやりたい！
あいつら……！</JapaneseText>
      <EnglishText>I want to kill them! Every
single one of them...!</EnglishText>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>10</Id>
      <BubbleId>1</BubbleId>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset>271656</PointerOffset>
      <VoiceId>&lt;audio:VSM_270_050_012&gt;</VoiceId>
      <JapaneseText>父ちゃんと母ちゃんの
仇を……！</JapaneseText>
      <EnglishText>I'll avenge my mommy and daddy!</EnglishText>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>10</Id>
      <BubbleId>2</BubbleId>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset>271724</PointerOffset>
      <VoiceId>&lt;audio:VSM_270_050_013&gt;</VoiceId>
      <JapaneseText>…………</JapaneseText>
      <EnglishText>...</EnglishText>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>13</Id>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset>271888</PointerOffset>
      <VoiceId>&lt;audio:VSM_270_050_014&gt;</VoiceId>
      <JapaneseText>なぁ、あんた、
将軍なんだろ！
なんとかしてくれよ！</JapaneseText>
      <EnglishText>Hey, you said you're a general, right?!
Can't you do something...!?</EnglishText>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>14</Id>
      <BubbleId>0</BubbleId>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset>271888</PointerOffset>
      <VoiceId>&lt;audio:VSM_270_050_015&gt;</VoiceId>
      <JapaneseText>パレスセダムを
滅ぼしてくれよ！！</JapaneseText>
      <EnglishText>Destroy Palace Sedamyu!</EnglishText>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>14</Id>
      <BubbleId>1</BubbleId>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset>271964</PointerOffset>
      <VoiceId>&lt;audio:VSM_270_050_016&gt;</VoiceId>
      <JapaneseText>おまえ……名前は？</JapaneseText>
      <EnglishText>You...what's your name?</EnglishText>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>16</Id>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset>272060</PointerOffset>
      <VoiceId>&lt;audio:VSM_270_050_017&gt;</VoiceId>
      <JapaneseText>オレの名前……？
ディオスだけど……</JapaneseText>
      <EnglishText>My...name...? I'm Dios, but...</EnglishText>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>17</Id>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset>272148</PointerOffset>
      <VoiceId>&lt;audio:VSM_270_050_018&gt;</VoiceId>
      <JapaneseText>仇なら自分の手で
打つがいい</JapaneseText>
      <EnglishText>If you want my help, I'll need
you to give me a hand.</EnglishText>
      <Notes>Tl check</Notes>
      <SpeakerId>3</SpeakerId>
      <Id>18</Id>
      <Status>Problematic</Status>
    </Entry>
    <Entry>
      <PointerOffset>272220</PointerOffset>
      <VoiceId>&lt;audio:VSM_270_050_019&gt;</VoiceId>
      <JapaneseText>オレの手で……？</JapaneseText>
      <EnglishText>A...hand?</EnglishText>
      <Notes/>
      <SpeakerId>4</SpeakerId>
      <Id>19</Id>
      <Status>Problematic</Status>
    </Entry>
    <Entry>
      <PointerOffset>272292</PointerOffset>
      <VoiceId>&lt;audio:VSM_270_050_020&gt;</VoiceId>
      <JapaneseText>そうだ。来い！</JapaneseText>
      <EnglishText>That's right... Now come!</EnglishText>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>20</Id>
      <Status>Proofreading</Status>
    </Entry>
  </Strings>
