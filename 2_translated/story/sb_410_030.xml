    <Entry>
      <PointerOffset>267412</PointerOffset>
      <JapaneseText>おおっ！　順調のようじゃな！
こっちもおかげで会員が
さらに増えよったわい！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>1</Id>
      <BubbleId>0</BubbleId>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>267412</PointerOffset>
      <JapaneseText>これは報酬じゃ！
とっといてくれい</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>1</Id>
      <BubbleId>1</BubbleId>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>267560</PointerOffset>
      <JapaneseText>『ねっと』とかいう海を
これでさーふぃんするのじゃ！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>3</Id>
      <BubbleId>0</BubbleId>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>267560</PointerOffset>
      <JapaneseText>これからも我がギルドのために
がんばっておくれぃ！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>3</Id>
      <BubbleId>1</BubbleId>
      <Status>To Do</Status>
    </Entry>
