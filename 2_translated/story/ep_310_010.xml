    <Section>Main</Section>
    <Entry>
      <PointerOffset>270380</PointerOffset>
      <VoiceId>&lt;audio:VSM_310_010_001&gt;</VoiceId>
      <JapaneseText>ここがダオスの城……？
ダオス戦役んとき、
時空の狭間にあったって</JapaneseText>
      <EnglishText>This is Dhaos's Castle...? During
the war against him, it was
inside a pocket dimension.</EnglishText>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>1</Id>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset>270476</PointerOffset>
      <VoiceId>&lt;audio:VSM_310_010_002&gt;</VoiceId>
      <JapaneseText>そう、&lt;Cless&gt;たちが
最後にダオスと戦った場所</JapaneseText>
      <EnglishText>Right. This is where the decisive fight
of &lt;Cless&gt; and the others took place.</EnglishText>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>2</Id>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset>270568</PointerOffset>
      <VoiceId>&lt;audio:VSM_310_010_003&gt;</VoiceId>
      <JapaneseText>……オレらも、
そこに乗り込もー
ってか</JapaneseText>
      <EnglishText>...And we're marching inside now.</EnglishText>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>3</Id>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset>270704</PointerOffset>
      <VoiceId>&lt;audio:VSM_310_010_004&gt;</VoiceId>
      <JapaneseText>&lt;Dio&gt;……</JapaneseText>
      <EnglishText>&lt;Dio&gt;...</EnglishText>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>4</Id>
      <BubbleId>0</BubbleId>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset>270704</PointerOffset>
      <VoiceId>&lt;audio:VSM_310_010_005&gt;</VoiceId>
      <JapaneseText>……確かめたいことが
あるって言ってたよね？
……なに？</JapaneseText>
      <EnglishText>You said there was something you two
had to be sure of... What did you mean?</EnglishText>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>4</Id>
      <BubbleId>1</BubbleId>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset>270768</PointerOffset>
      <VoiceId>&lt;audio:VSM_310_010_006&gt;</VoiceId>
      <JapaneseText>オレらは……</JapaneseText>
      <EnglishText>We...</EnglishText>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>6</Id>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset>271568</PointerOffset>
      <VoiceId>&lt;audio:VSM_310_010_016&gt;</VoiceId>
      <JapaneseText>さ、行こうよ</JapaneseText>
      <EnglishText>Heh, let's go.</EnglishText>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>7</Id>
      <Status>Proofreading</Status>
    </Entry>
