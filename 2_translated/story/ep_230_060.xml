    <Entry>
      <PointerOffset>314848</PointerOffset>
      <VoiceId>&lt;audio:VSM_230_060_001&gt;</VoiceId>
      <JapaneseText>くそっ……
一体どうすれば……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>1</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>314912</PointerOffset>
      <VoiceId>&lt;audio:VSM_230_060_002&gt;</VoiceId>
      <JapaneseText>これは……？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>2</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>314980</PointerOffset>
      <VoiceId>&lt;audio:VSM_230_060_003&gt;</VoiceId>
      <JapaneseText>我に従え……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>3</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>315056</PointerOffset>
      <VoiceId>&lt;audio:VSM_230_060_004&gt;</VoiceId>
      <JapaneseText>なに……これは……？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>4</SpeakerId>
      <Id>4</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>315140</PointerOffset>
      <VoiceId>&lt;audio:VSM_230_060_005&gt;</VoiceId>
      <JapaneseText>中にこんなん入れたの、
誰だよ？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>5</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>315416</PointerOffset>
      <VoiceId>&lt;audio:VSM_230_060_008&gt;</VoiceId>
      <JapaneseText></JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>6</Id>
      <BubbleId>0</BubbleId>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>315416</PointerOffset>
      <VoiceId>&lt;audio:VSM_230_060_009&gt;</VoiceId>
      <JapaneseText>まさか……そのポットはもともと、
バジル博士のものだった</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>6</Id>
      <BubbleId>1</BubbleId>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>315484</PointerOffset>
      <VoiceId>&lt;audio:VSM_230_060_010&gt;</VoiceId>
      <JapaneseText>バジルの……？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>5</SpeakerId>
      <Id>8</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>315556</PointerOffset>
      <VoiceId>&lt;audio:VSM_230_060_011&gt;</VoiceId>
      <JapaneseText>我に従え……！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>9</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>315620</PointerOffset>
      <VoiceId>&lt;audio:VSM_230_060_012&gt;</VoiceId>
      <JapaneseText>ぐぅっ……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>4</SpeakerId>
      <Id>10</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>315720</PointerOffset>
      <VoiceId>&lt;audio:VSM_230_060_013&gt;</VoiceId>
      <JapaneseText>今すぐ、瘴気を消して、
この世界から去りなさい！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>6</SpeakerId>
      <Id>11</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>315884</PointerOffset>
      <VoiceId>&lt;audio:VSM_230_060_014&gt;</VoiceId>
      <JapaneseText></JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>4</SpeakerId>
      <Id>12</Id>
      <BubbleId>0</BubbleId>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>315884</PointerOffset>
      <VoiceId>&lt;audio:VSM_230_060_015&gt;</VoiceId>
      <JapaneseText>我ら……魔界人（まかいびと）の
悲願が……我は……
再び、この地上へ戻ってくる……
絶対に……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>4</SpeakerId>
      <Id>12</Id>
      <BubbleId>1</BubbleId>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>315960</PointerOffset>
      <VoiceId>&lt;audio:VSM_230_060_016&gt;</VoiceId>
      <JapaneseText>ファぁあ……助かった……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>7</SpeakerId>
      <Id>14</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>316068</PointerOffset>
      <VoiceId>&lt;audio:VSM_230_060_017&gt;</VoiceId>
      <JapaneseText>まさか、バジルのやつ、
魔操術を
完成させていたとは……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>5</SpeakerId>
      <Id>15</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>316176</PointerOffset>
      <VoiceId>&lt;audio:VSM_230_060_018&gt;</VoiceId>
      <JapaneseText>魔操術……？
そう言えば、バジル博士が
そんなことを……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>8</SpeakerId>
      <Id>16</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>316412</PointerOffset>
      <VoiceId>&lt;audio:VSM_230_060_019&gt;</VoiceId>
      <JapaneseText></JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>5</SpeakerId>
      <Id>17</Id>
      <BubbleId>0</BubbleId>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>316412</PointerOffset>
      <VoiceId>&lt;audio:VSM_230_060_020&gt;</VoiceId>
      <JapaneseText></JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>5</SpeakerId>
      <Id>17</Id>
      <BubbleId>1</BubbleId>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>316412</PointerOffset>
      <VoiceId>&lt;audio:VSM_230_060_021&gt;</VoiceId>
      <JapaneseText>プルートはその強い魔力で
魔界の者たちを統率しているその魔力、
カリスマ性の根源こそ、
『魔魂』だそれを人工的に作り出し、
魔界の者を操るのが魔操術だ</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>5</SpeakerId>
      <Id>17</Id>
      <BubbleId>2</BubbleId>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>316524</PointerOffset>
      <VoiceId>&lt;audio:VSM_230_060_022&gt;</VoiceId>
      <JapaneseText>つまり、今のは
プルート対偽プルートの
戦いだったってことか？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>9</SpeakerId>
      <Id>20</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>316684</PointerOffset>
      <VoiceId>&lt;audio:VSM_230_060_023&gt;</VoiceId>
      <JapaneseText></JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>5</SpeakerId>
      <Id>21</Id>
      <BubbleId>0</BubbleId>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>316684</PointerOffset>
      <VoiceId>&lt;audio:VSM_230_060_024&gt;</VoiceId>
      <JapaneseText>まあ、そういうことになるなおそらく、普段のプルートならば
通用しなかったかもしれないが……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>5</SpeakerId>
      <Id>21</Id>
      <BubbleId>1</BubbleId>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>316776</PointerOffset>
      <VoiceId>&lt;audio:VSM_230_060_025&gt;</VoiceId>
      <JapaneseText>わたしたちとの戦いで、
弱ってたから……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>10</SpeakerId>
      <Id>23</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>316836</PointerOffset>
      <VoiceId>&lt;audio:VSM_230_060_026&gt;</VoiceId>
      <JapaneseText>だろうな</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>5</SpeakerId>
      <Id>24</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>316936</PointerOffset>
      <VoiceId>&lt;audio:VSM_230_060_027&gt;</VoiceId>
      <JapaneseText>バジルさんが……
最後にオレらを救ってくれた……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>25</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>317000</PointerOffset>
      <VoiceId>&lt;audio:VSM_230_060_028&gt;</VoiceId>
      <JapaneseText>そうだね……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>10</SpeakerId>
      <Id>26</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>317060</PointerOffset>
      <VoiceId>&lt;audio:VSM_230_060_029&gt;</VoiceId>
      <JapaneseText>…………</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>5</SpeakerId>
      <Id>27</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>317164</PointerOffset>
      <VoiceId>&lt;audio:VSM_230_060_030&gt;</VoiceId>
      <JapaneseText>さてと……
君たちはいつまで
ここにいるつもりだい？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>28</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>317252</PointerOffset>
      <VoiceId>&lt;audio:VSM_230_060_031&gt;</VoiceId>
      <JapaneseText>そうだ！
虹輪を消しにいかなくちゃ！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>7</SpeakerId>
      <Id>29</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>317352</PointerOffset>
      <VoiceId>&lt;audio:VSM_230_060_032&gt;</VoiceId>
      <JapaneseText>ちゃんと覚えてるって！
戻ろうぜ、元の時代に！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>30</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>317416</PointerOffset>
      <VoiceId>&lt;audio:VSM_230_060_033&gt;</VoiceId>
      <JapaneseText>クルール！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>11</SpeakerId>
      <Id>31</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>317492</PointerOffset>
      <VoiceId>&lt;audio:VSM_230_060_034&gt;</VoiceId>
      <JapaneseText>&lt;Red&gt;&lt;White&gt;うん、トールだよね</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>10</SpeakerId>
      <Id>32</Id>
      <Status>To Do</Status>
    </Entry>
