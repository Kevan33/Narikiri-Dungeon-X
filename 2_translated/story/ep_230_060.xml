    <Entry>
      <PointerOffset>314848</PointerOffset>
      <VoiceId>&lt;audio:VSM_230_060_001&gt;</VoiceId>
      <JapaneseText>くそっ……
一体どうすれば……</JapaneseText>
      <EnglishText>Dammit...! What can we do now...!?</EnglishText>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>1</Id>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset>314912</PointerOffset>
      <VoiceId>&lt;audio:VSM_230_060_002&gt;</VoiceId>
      <JapaneseText>これは……？</JapaneseText>
      <EnglishText>Huh?</EnglishText>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>2</Id>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset>314980</PointerOffset>
      <VoiceId>&lt;audio:VSM_230_060_003&gt;</VoiceId>
      <JapaneseText>我に従え……</JapaneseText>
      <EnglishText>Obey me...</EnglishText>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>3</Id>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset>315056</PointerOffset>
      <VoiceId>&lt;audio:VSM_230_060_004&gt;</VoiceId>
      <JapaneseText>なに……これは……？</JapaneseText>
      <EnglishText>What...is the meaning of this?</EnglishText>
      <Notes/>
      <SpeakerId>4</SpeakerId>
      <Id>4</Id>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset>315140</PointerOffset>
      <VoiceId>&lt;audio:VSM_230_060_005&gt;</VoiceId>
      <JapaneseText>中にこんなん入れたの、
誰だよ？</JapaneseText>
      <EnglishText>I don't understand! Who's
inside the Elements' Pot?</EnglishText>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>5</Id>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset>315416</PointerOffset>
      <VoiceId>&lt;audio:VSM_230_060_008&gt;</VoiceId>
      <JapaneseText>まさか……</JapaneseText>
      <EnglishText>No way...</EnglishText>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>6</Id>
      <BubbleId>0</BubbleId>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset>315416</PointerOffset>
      <VoiceId>&lt;audio:VSM_230_060_009&gt;</VoiceId>
      <JapaneseText>そのポットはもともと、
バジル博士のものだった</JapaneseText>
      <EnglishText>That Pot was originally
property of Professor Basil!</EnglishText>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>6</Id>
      <BubbleId>1</BubbleId>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset>315484</PointerOffset>
      <VoiceId>&lt;audio:VSM_230_060_010&gt;</VoiceId>
      <JapaneseText>バジルの……？</JapaneseText>
      <EnglishText>Basil...?</EnglishText>
      <Notes/>
      <SpeakerId>5</SpeakerId>
      <Id>8</Id>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset>315556</PointerOffset>
      <VoiceId>&lt;audio:VSM_230_060_011&gt;</VoiceId>
      <JapaneseText>我に従え……！</JapaneseText>
      <EnglishText>Obey me...!</EnglishText>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>9</Id>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset>315620</PointerOffset>
      <VoiceId>&lt;audio:VSM_230_060_012&gt;</VoiceId>
      <JapaneseText>ぐぅっ……</JapaneseText>
      <EnglishText>Hngh...!</EnglishText>
      <Notes/>
      <SpeakerId>4</SpeakerId>
      <Id>10</Id>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset>315720</PointerOffset>
      <VoiceId>&lt;audio:VSM_230_060_013&gt;</VoiceId>
      <JapaneseText>今すぐ、瘴気を消して、
この世界から去りなさい！</JapaneseText>
      <EnglishText>If the Miasma is not cleansed
immediately, the world as we 
know it will be forever lost!</EnglishText>
      <Notes/>
      <SpeakerId>6</SpeakerId>
      <Id>11</Id>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset>315884</PointerOffset>
      <VoiceId>&lt;audio:VSM_230_060_014&gt;</VoiceId>
      <JapaneseText>我ら……魔界人（まかいびと）の
悲願が……</JapaneseText>
      <EnglishText>I...need to grant...my
people's one wish...</EnglishText>
      <Notes/>
      <SpeakerId>4</SpeakerId>
      <Id>12</Id>
      <BubbleId>0</BubbleId>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset>315884</PointerOffset>
      <VoiceId>&lt;audio:VSM_230_060_015&gt;</VoiceId>
      <JapaneseText>我は……
再び、この地上へ戻ってくる……
絶対に……</JapaneseText>
      <EnglishText>I must rule...the surface once
more... It must be done!</EnglishText>
      <Notes/>
      <SpeakerId>4</SpeakerId>
      <Id>12</Id>
      <BubbleId>1</BubbleId>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset>315960</PointerOffset>
      <VoiceId>&lt;audio:VSM_230_060_016&gt;</VoiceId>
      <JapaneseText>ファぁあ……助かった……</JapaneseText>
      <EnglishText>Phew! We've been saved!</EnglishText>
      <Notes/>
      <SpeakerId>7</SpeakerId>
      <Id>14</Id>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset>316068</PointerOffset>
      <VoiceId>&lt;audio:VSM_230_060_017&gt;</VoiceId>
      <JapaneseText>まさか、バジルのやつ、
魔操術を
完成させていたとは……</JapaneseText>
      <EnglishText>Is it possible...that Basil wanted
to perfect forbidden Demonic
Manipulation arts for this purpose?</EnglishText>
      <Notes/>
      <SpeakerId>5</SpeakerId>
      <Id>15</Id>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset>316176</PointerOffset>
      <VoiceId>&lt;audio:VSM_230_060_018&gt;</VoiceId>
      <JapaneseText>魔操術……？
そう言えば、バジル博士が
そんなことを……</JapaneseText>
      <EnglishText>Demonic Manipulation? Now that
you mention it...Professor Basil had
mentioned something like that...</EnglishText>
      <Notes/>
      <SpeakerId>8</SpeakerId>
      <Id>16</Id>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset>316412</PointerOffset>
      <VoiceId>&lt;audio:VSM_230_060_019&gt;</VoiceId>
      <JapaneseText>プルートはその強い魔力で
魔界の者たちを統率している</JapaneseText>
      <EnglishText>With Pluto's vast magical power
he is capable of controlling a
legion of monsters.</EnglishText>
      <Notes/>
      <SpeakerId>5</SpeakerId>
      <Id>17</Id>
      <BubbleId>0</BubbleId>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset>316412</PointerOffset>
      <VoiceId>&lt;audio:VSM_230_060_020&gt;</VoiceId>
      <JapaneseText>その魔力、
カリスマ性の根源こそ、
『魔魂』だ</JapaneseText>
      <EnglishText>That charisma is the root of his power.
His "Demonic Essence", essentially.</EnglishText>
      <Notes/>
      <SpeakerId>5</SpeakerId>
      <Id>17</Id>
      <BubbleId>1</BubbleId>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset>316412</PointerOffset>
      <VoiceId>&lt;audio:VSM_230_060_021&gt;</VoiceId>
      <JapaneseText>それを人工的に作り出し、
魔界の者を操るのが魔操術だ</JapaneseText>
      <EnglishText>To artificially be able to replicate
such effect on Demons...that's
what Demonic Manipulation is.</EnglishText>
      <Notes/>
      <SpeakerId>5</SpeakerId>
      <Id>17</Id>
      <BubbleId>2</BubbleId>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset>316524</PointerOffset>
      <VoiceId>&lt;audio:VSM_230_060_022&gt;</VoiceId>
      <JapaneseText>つまり、今のは
プルート対偽プルートの
戦いだったってことか？</JapaneseText>
      <EnglishText>In short, he created the artificial
Pluto to fight the real thing for
control of his people, right?</EnglishText>
      <Notes/>
      <SpeakerId>9</SpeakerId>
      <Id>20</Id>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset>316684</PointerOffset>
      <VoiceId>&lt;audio:VSM_230_060_023&gt;</VoiceId>
      <JapaneseText>まあ、そういうことになるな</JapaneseText>
      <EnglishText>Yeah, well, that's just my hypothesis.</EnglishText>
      <Notes/>
      <SpeakerId>5</SpeakerId>
      <Id>21</Id>
      <BubbleId>0</BubbleId>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset>316684</PointerOffset>
      <VoiceId>&lt;audio:VSM_230_060_024&gt;</VoiceId>
      <JapaneseText>おそらく、普段のプルートならば
通用しなかったかもしれないが……</JapaneseText>
      <EnglishText>Perhaps that was his second
best option, as he couldn't 
obtain the real Pluto.</EnglishText>
      <Notes/>
      <SpeakerId>5</SpeakerId>
      <Id>21</Id>
      <BubbleId>1</BubbleId>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset>316776</PointerOffset>
      <VoiceId>&lt;audio:VSM_230_060_025&gt;</VoiceId>
      <JapaneseText>わたしたちとの戦いで、
弱ってたから……</JapaneseText>
      <EnglishText>...Then he waited for someone
to weaken Pluto from a fight,
like we just did?</EnglishText>
      <Notes/>
      <SpeakerId>10</SpeakerId>
      <Id>23</Id>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset>316836</PointerOffset>
      <VoiceId>&lt;audio:VSM_230_060_026&gt;</VoiceId>
      <JapaneseText>だろうな</JapaneseText>
      <EnglishText>I think so.</EnglishText>
      <Notes/>
      <SpeakerId>5</SpeakerId>
      <Id>24</Id>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset>316936</PointerOffset>
      <VoiceId>&lt;audio:VSM_230_060_027&gt;</VoiceId>
      <JapaneseText>バジルさんが……
最後にオレらを救ってくれた……</JapaneseText>
      <EnglishText>In the end...Mister Basil saved us all...</EnglishText>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>25</Id>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset>317000</PointerOffset>
      <VoiceId>&lt;audio:VSM_230_060_028&gt;</VoiceId>
      <JapaneseText>そうだね……</JapaneseText>
      <EnglishText>That he did...</EnglishText>
      <Notes/>
      <SpeakerId>10</SpeakerId>
      <Id>26</Id>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset>317060</PointerOffset>
      <VoiceId>&lt;audio:VSM_230_060_029&gt;</VoiceId>
      <JapaneseText>…………</JapaneseText>
      <EnglishText>...</EnglishText>
      <Notes/>
      <SpeakerId>5</SpeakerId>
      <Id>27</Id>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset>317164</PointerOffset>
      <VoiceId>&lt;audio:VSM_230_060_030&gt;</VoiceId>
      <JapaneseText>さてと……
君たちはいつまで
ここにいるつもりだい？</JapaneseText>
      <EnglishText>Now that that's settled, how long do
you guys plan to stay in this era?</EnglishText>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>28</Id>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset>317252</PointerOffset>
      <VoiceId>&lt;audio:VSM_230_060_031&gt;</VoiceId>
      <JapaneseText>そうだ！
虹輪を消しにいかなくちゃ！</JapaneseText>
      <EnglishText>That's right! We need to dissolve
the Prism Ring from our time!</EnglishText>
      <Notes/>
      <SpeakerId>7</SpeakerId>
      <Id>29</Id>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset>317352</PointerOffset>
      <VoiceId>&lt;audio:VSM_230_060_032&gt;</VoiceId>
      <JapaneseText>ちゃんと覚えてるって！
戻ろうぜ、元の時代に！</JapaneseText>
      <EnglishText>I wouldn't forget THAT! Now,
let's go back to our time!</EnglishText>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>30</Id>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset>317416</PointerOffset>
      <VoiceId>&lt;audio:VSM_230_060_033&gt;</VoiceId>
      <JapaneseText>クルール！</JapaneseText>
      <EnglishText>Kuru~ru!</EnglishText>
      <Notes/>
      <SpeakerId>11</SpeakerId>
      <Id>31</Id>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset>317492</PointerOffset>
      <VoiceId>&lt;audio:VSM_230_060_034&gt;</VoiceId>
      <JapaneseText>うん、&lt;Red&gt;トール&lt;White&gt;だよね</JapaneseText>
      <EnglishText>All right! To &lt;Red&gt;Thor&lt;White&gt;, then!</EnglishText>
      <Notes/>
      <SpeakerId>10</SpeakerId>
      <Id>32</Id>
      <Status>Proofreading</Status>
    </Entry>
