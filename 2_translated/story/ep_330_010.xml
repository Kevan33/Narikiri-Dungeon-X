    <Entry>
      <PointerOffset>315364</PointerOffset>
      <VoiceId>&lt;audio:VSM_330_010_002&gt;</VoiceId>
      <JapaneseText>ノルン！
どこにいんだよ！？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>1</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>315440</PointerOffset>
      <VoiceId>&lt;audio:VSM_330_010_003&gt;</VoiceId>
      <JapaneseText>&lt;Couleur&gt;？
どこ行くんだ？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>2</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>315540</PointerOffset>
      <VoiceId>&lt;audio:VSM_330_010_004&gt;</VoiceId>
      <JapaneseText>よくぞ、
あなたは自分たちの罪を
受け入れました</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>3</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>315604</PointerOffset>
      <VoiceId>&lt;audio:VSM_330_010_005&gt;</VoiceId>
      <JapaneseText>&lt;Couleur&gt;……？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>4</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>315692</PointerOffset>
      <VoiceId>&lt;audio:VSM_330_010_006&gt;</VoiceId>
      <JapaneseText>&lt;Couleur&gt;まさか……
がノルンさん……？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>5</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>315788</PointerOffset>
      <VoiceId>&lt;audio:VSM_330_010_007&gt;</VoiceId>
      <JapaneseText>ずっとあなた方を
そばで見させてもらいました</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>4</SpeakerId>
      <Id>6</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>315984</PointerOffset>
      <VoiceId>&lt;audio:VSM_330_010_008&gt;</VoiceId>
      <JapaneseText></JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>5</SpeakerId>
      <Id>7</Id>
      <BubbleId>0</BubbleId>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>315984</PointerOffset>
      <VoiceId>&lt;audio:VSM_330_010_009&gt;</VoiceId>
      <JapaneseText>ノルン！　ぼくに
この子たちを育てさせたのは、
全部今日のため？ふたりに、
自分たちの手で、罪を
償わせるためだったんですか！？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>5</SpeakerId>
      <Id>7</Id>
      <BubbleId>1</BubbleId>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>316140</PointerOffset>
      <VoiceId>&lt;audio:VSM_330_010_010&gt;</VoiceId>
      <JapaneseText></JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>4</SpeakerId>
      <Id>9</Id>
      <BubbleId>0</BubbleId>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>316140</PointerOffset>
      <VoiceId>&lt;audio:VSM_330_010_011&gt;</VoiceId>
      <JapaneseText>そうです。
ここまでの旅もすべて……その罪に向き合う覚悟を
育てるために私が与えた試練</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>4</SpeakerId>
      <Id>9</Id>
      <BubbleId>1</BubbleId>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>316216</PointerOffset>
      <VoiceId>&lt;audio:VSM_330_010_012&gt;</VoiceId>
      <JapaneseText>どうして……そんな……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>5</SpeakerId>
      <Id>11</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>316288</PointerOffset>
      <VoiceId>&lt;audio:VSM_330_010_013&gt;</VoiceId>
      <JapaneseText>ひどいと思いますか？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>4</SpeakerId>
      <Id>12</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>316372</PointerOffset>
      <VoiceId>&lt;audio:VSM_330_010_014&gt;</VoiceId>
      <JapaneseText>ひどいよ……
ひどすぎます……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>5</SpeakerId>
      <Id>13</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>316484</PointerOffset>
      <VoiceId>&lt;audio:VSM_330_010_015&gt;</VoiceId>
      <JapaneseText>ならば、あなたが
彼らの因果の糸をつなぐ
結び目になりますか？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>4</SpeakerId>
      <Id>14</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>316584</PointerOffset>
      <VoiceId>&lt;audio:VSM_330_010_016&gt;</VoiceId>
      <JapaneseText>精霊であるあなた。
その魂を使えば
ふたりは助かる</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>4</SpeakerId>
      <Id>15</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>316660</PointerOffset>
      <VoiceId>&lt;audio:VSM_330_010_017&gt;</VoiceId>
      <JapaneseText>代わりにあなたが消える</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>4</SpeakerId>
      <Id>16</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>316720</PointerOffset>
      <VoiceId>&lt;audio:VSM_330_010_018&gt;</VoiceId>
      <JapaneseText>エト！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>17</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>316868</PointerOffset>
      <VoiceId>&lt;audio:VSM_330_010_019&gt;</VoiceId>
      <JapaneseText></JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>5</SpeakerId>
      <Id>18</Id>
      <BubbleId>0</BubbleId>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>316868</PointerOffset>
      <VoiceId>&lt;audio:VSM_330_010_020&gt;</VoiceId>
      <JapaneseText>……ふたりが消えたくない
って言うなラ……ぼく、喜んで、
この身を捧げます！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>5</SpeakerId>
      <Id>18</Id>
      <BubbleId>1</BubbleId>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>316928</PointerOffset>
      <VoiceId>&lt;audio:VSM_330_010_021&gt;</VoiceId>
      <JapaneseText>エト！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>20</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>316988</PointerOffset>
      <VoiceId>&lt;audio:VSM_330_010_022&gt;</VoiceId>
      <JapaneseText>やめて！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>21</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>317212</PointerOffset>
      <VoiceId>&lt;audio:VSM_330_010_023&gt;</VoiceId>
      <JapaneseText></JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>5</SpeakerId>
      <Id>22</Id>
      <BubbleId>0</BubbleId>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>317212</PointerOffset>
      <VoiceId>&lt;audio:VSM_330_010_024&gt;</VoiceId>
      <JapaneseText></JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>5</SpeakerId>
      <Id>22</Id>
      <BubbleId>1</BubbleId>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>317212</PointerOffset>
      <VoiceId>&lt;audio:VSM_330_010_025&gt;</VoiceId>
      <JapaneseText></JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>5</SpeakerId>
      <Id>22</Id>
      <BubbleId>2</BubbleId>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>317212</PointerOffset>
      <VoiceId>&lt;audio:VSM_330_010_026&gt;</VoiceId>
      <JapaneseText>でも……これが
ふたりの決断なら……
ぼくはその覚悟を受け止めるつらいよ……きみたちを
失いたくはないよ……でも……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>5</SpeakerId>
      <Id>22</Id>
      <BubbleId>3</BubbleId>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>317304</PointerOffset>
      <VoiceId>&lt;audio:VSM_330_010_027&gt;</VoiceId>
      <JapaneseText>子どもたちを救うのは
親ではないのですか</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>4</SpeakerId>
      <Id>26</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>317400</PointerOffset>
      <VoiceId>&lt;audio:VSM_330_010_028&gt;</VoiceId>
      <JapaneseText>子どもたちのした決意を
尊重するのも親です</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>5</SpeakerId>
      <Id>27</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>317476</PointerOffset>
      <VoiceId>&lt;audio:VSM_330_010_029&gt;</VoiceId>
      <JapaneseText>それが間違った決意でも？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>4</SpeakerId>
      <Id>28</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>317640</PointerOffset>
      <VoiceId>&lt;audio:VSM_330_010_030&gt;</VoiceId>
      <JapaneseText></JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>5</SpeakerId>
      <Id>29</Id>
      <BubbleId>0</BubbleId>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>317640</PointerOffset>
      <VoiceId>&lt;audio:VSM_330_010_031&gt;</VoiceId>
      <JapaneseText>もうふたりが間違ってるか
どうか、判断するのは
ぼくじゃないんだふたりはもう
それができる……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>5</SpeakerId>
      <Id>29</Id>
      <BubbleId>1</BubbleId>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>317736</PointerOffset>
      <VoiceId>&lt;audio:VSM_330_010_032&gt;</VoiceId>
      <JapaneseText>わたしたちは、
覚悟を決めました。
だから……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>31</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>317824</PointerOffset>
      <VoiceId>&lt;audio:VSM_330_010_033&gt;</VoiceId>
      <JapaneseText>もう、エトは関係ない！
エトを離せ！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>32</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>317984</PointerOffset>
      <VoiceId>&lt;audio:VSM_330_010_034&gt;</VoiceId>
      <JapaneseText></JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>4</SpeakerId>
      <Id>33</Id>
      <BubbleId>0</BubbleId>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>317984</PointerOffset>
      <VoiceId>&lt;audio:VSM_330_010_035&gt;</VoiceId>
      <JapaneseText>エトス、
本当にそれで
よいのですか？ふたりの存在は、
彼らの未来はここで
失われるのです</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>4</SpeakerId>
      <Id>33</Id>
      <BubbleId>1</BubbleId>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>318064</PointerOffset>
      <VoiceId>&lt;audio:VSM_330_010_036&gt;</VoiceId>
      <JapaneseText>&lt;Dio&gt;&lt;Mel&gt;との、
未来……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>5</SpeakerId>
      <Id>35</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>318164</PointerOffset>
      <VoiceId>&lt;audio:VSM_330_010_037&gt;</VoiceId>
      <JapaneseText>『なりきり士』として、
ふたりが見ていた未来です</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>4</SpeakerId>
      <Id>36</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>318228</PointerOffset>
      <VoiceId>&lt;audio:VSM_330_010_038&gt;</VoiceId>
      <JapaneseText>もうやめて！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>37</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>318292</PointerOffset>
      <VoiceId>&lt;audio:VSM_330_010_039&gt;</VoiceId>
      <JapaneseText>エトを……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>38</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>318364</PointerOffset>
      <VoiceId>&lt;audio:VSM_330_010_040&gt;</VoiceId>
      <JapaneseText>イジめるなぁあっ！！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>39</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>318444</PointerOffset>
      <VoiceId>&lt;audio:VSM_330_010_041&gt;</VoiceId>
      <JapaneseText>&lt;Mel&gt;、
エトを取り戻すぞ</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>40</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>318508</PointerOffset>
      <VoiceId>&lt;audio:VSM_330_010_042&gt;</VoiceId>
      <JapaneseText>うん……！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>41</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>318676</PointerOffset>
      <VoiceId>&lt;audio:VSM_330_010_043&gt;</VoiceId>
      <JapaneseText></JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>4</SpeakerId>
      <Id>42</Id>
      <BubbleId>0</BubbleId>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>318676</PointerOffset>
      <VoiceId>&lt;audio:VSM_330_010_044&gt;</VoiceId>
      <JapaneseText>ご覧なさい。彼らは
あなたを取り返すために、
私に立ち向かおうとしています愚かだと思いませんか？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>4</SpeakerId>
      <Id>42</Id>
      <BubbleId>1</BubbleId>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>318764</PointerOffset>
      <VoiceId>&lt;audio:VSM_330_010_045&gt;</VoiceId>
      <JapaneseText>&lt;Dio&gt;&lt;Mel&gt;……とを
バカにするな！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>5</SpeakerId>
      <Id>44</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>318852</PointerOffset>
      <VoiceId>&lt;audio:VSM_330_010_046&gt;</VoiceId>
      <JapaneseText>うぉおおおっ！
やぁああっ！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>6</SpeakerId>
      <Id>45</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>319008</PointerOffset>
      <VoiceId>&lt;audio:VSM_330_010_048&gt;</VoiceId>
      <JapaneseText>戦うと言うのならば、
受けて立ちましょう</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>4</SpeakerId>
      <Id>46</Id>
      <Status>To Do</Status>
    </Entry>
