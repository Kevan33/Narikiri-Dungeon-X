    <Entry>
      <PointerOffset>298820</PointerOffset>
      <VoiceId>&lt;audio:VSM_300_010_001&gt;</VoiceId>
      <JapaneseText>ひどい……何もかもが
石灰化したみたいな……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>1</Id>
      <OldPtr>278760</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>298892</PointerOffset>
      <VoiceId>&lt;audio:VSM_300_010_002&gt;</VoiceId>
      <JapaneseText>これ、戦争の痕だよ</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>2</Id>
      <OldPtr>279024</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>298972</PointerOffset>
      <VoiceId>&lt;audio:VSM_300_010_003&gt;</VoiceId>
      <JapaneseText>魔科学兵器が
使われたんだ</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>3</Id>
      <OldPtr>279552</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>299076</PointerOffset>
      <VoiceId>&lt;audio:VSM_300_010_004&gt;</VoiceId>
      <JapaneseText>どういうこと……？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>4</Id>
      <BubbleId>0</BubbleId>
      <OldPtr>279908</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>299076</PointerOffset>
      <VoiceId>&lt;audio:VSM_300_010_005&gt;</VoiceId>
      <JapaneseText>戦争って何の？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>4</Id>
      <BubbleId>1</BubbleId>
      <OldPtr>279908</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>299184</PointerOffset>
      <VoiceId>&lt;audio:VSM_300_010_006&gt;</VoiceId>
      <JapaneseText>あの日、『青い光』が輝き、
この地のすべてを焼き尽くした</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>4</SpeakerId>
      <Id>6</Id>
      <OldPtr>282152</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>299312</PointerOffset>
      <VoiceId>&lt;audio:VSM_300_010_007&gt;</VoiceId>
      <JapaneseText>ダオス……！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>7</Id>
      <BubbleId>0</BubbleId>
      <OldPtr>282784</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>299312</PointerOffset>
      <VoiceId>&lt;audio:VSM_300_010_008&gt;</VoiceId>
      <JapaneseText>……まさか、ここは
デリス・カーラーン……！？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>7</Id>
      <BubbleId>1</BubbleId>
      <OldPtr>282784</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>299440</PointerOffset>
      <VoiceId>&lt;audio:VSM_300_010_009&gt;</VoiceId>
      <JapaneseText>大地を焼いた光は、
星のマナをすべて吸いつくし、
終焉の淵へと追い込んだのだ</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>4</SpeakerId>
      <Id>9</Id>
      <OldPtr>283120</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>299500</PointerOffset>
      <VoiceId>&lt;audio:VSM_300_010_010&gt;</VoiceId>
      <JapaneseText>待って！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>10</Id>
      <OldPtr>283632</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>299648</PointerOffset>
      <VoiceId>&lt;audio:VSM_300_010_011&gt;</VoiceId>
      <JapaneseText>どうしてふたりが
こんなところに来る
必要があるの？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>5</SpeakerId>
      <Id>11</Id>
      <BubbleId>0</BubbleId>
      <OldPtr>285336</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>299648</PointerOffset>
      <VoiceId>&lt;audio:VSM_300_010_012&gt;</VoiceId>
      <JapaneseText>ねぇ、&lt;Dio&gt;！　&lt;Mel&gt;！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>5</SpeakerId>
      <Id>11</Id>
      <BubbleId>1</BubbleId>
      <OldPtr>285336</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>299840</PointerOffset>
      <VoiceId>&lt;audio:VSM_300_010_013&gt;</VoiceId>
      <JapaneseText>オレらは大切なこと、
忘れてるんだ</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>13</Id>
      <BubbleId>0</BubbleId>
      <OldPtr>286336</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>299840</PointerOffset>
      <VoiceId>&lt;audio:VSM_300_010_014&gt;</VoiceId>
      <JapaneseText>ダオスが仮面のヤツらの居場所を
オレらに教えたのは、それを
思い出させるためなんだ。きっと</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>13</Id>
      <BubbleId>1</BubbleId>
      <OldPtr>286336</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>299916</PointerOffset>
      <VoiceId>&lt;audio:VSM_300_010_015&gt;</VoiceId>
      <JapaneseText>どうしてダオスが……？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>15</Id>
      <OldPtr>286844</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>300056</PointerOffset>
      <VoiceId>&lt;audio:VSM_300_010_016&gt;</VoiceId>
      <JapaneseText>それは
確かにわたしの胸を
ざわざわさせてる</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>16</Id>
      <BubbleId>0</BubbleId>
      <OldPtr>286984</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>300056</PointerOffset>
      <VoiceId>&lt;audio:VSM_300_010_017&gt;</VoiceId>
      <JapaneseText>すごく逃げたい、
でも……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>16</Id>
      <BubbleId>1</BubbleId>
      <OldPtr>286984</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>300188</PointerOffset>
      <VoiceId>&lt;audio:VSM_300_010_018&gt;</VoiceId>
      <JapaneseText>逃げたいなら、
逃げればいいじゃない</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>5</SpeakerId>
      <Id>18</Id>
      <BubbleId>0</BubbleId>
      <OldPtr>287584</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>300188</PointerOffset>
      <VoiceId>&lt;audio:VSM_300_010_019&gt;</VoiceId>
      <JapaneseText>やめよう、
もう帰ろうよ</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>5</SpeakerId>
      <Id>18</Id>
      <BubbleId>1</BubbleId>
      <OldPtr>287584</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>300252</PointerOffset>
      <VoiceId>&lt;audio:VSM_300_010_020&gt;</VoiceId>
      <JapaneseText>エトちゃん</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>20</Id>
      <OldPtr>288040</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>300384</PointerOffset>
      <VoiceId>&lt;audio:VSM_300_010_021&gt;</VoiceId>
      <JapaneseText>ちゃんと見たいんだ。
その不安の正体</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>21</Id>
      <BubbleId>0</BubbleId>
      <OldPtr>288572</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>300384</PointerOffset>
      <VoiceId>&lt;audio:VSM_300_010_022&gt;</VoiceId>
      <JapaneseText>ちゃんと決着つけなきゃだ</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>21</Id>
      <BubbleId>1</BubbleId>
      <OldPtr>288572</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>300484</PointerOffset>
      <VoiceId>&lt;audio:VSM_300_010_023&gt;</VoiceId>
      <JapaneseText>…………</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>5</SpeakerId>
      <Id>23</Id>
      <BubbleId>0</BubbleId>
      <OldPtr>289404</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>300484</PointerOffset>
      <VoiceId>&lt;audio:VSM_300_010_024&gt;</VoiceId>
      <JapaneseText>……わかった、
行こう</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>5</SpeakerId>
      <Id>23</Id>
      <BubbleId>1</BubbleId>
      <OldPtr>289404</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>300564</PointerOffset>
      <VoiceId>&lt;audio:VSM_300_010_025&gt;</VoiceId>
      <JapaneseText>ありがとう、
ゴメンね、エト</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>25</Id>
      <OldPtr>289724</OldPtr>
      <Status>To Do</Status>
    </Entry>
