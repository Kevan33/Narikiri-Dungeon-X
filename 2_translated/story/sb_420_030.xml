  <Strings>
    <Section>Main</Section>
    <Entry>
      <PointerOffset>271536</PointerOffset>
      <JapaneseText>あら、&lt;Mel&gt;ちゃん、どうしたの？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>1</Id>
      <OldPtr>258304</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>272572</PointerOffset>
      <JapaneseText>あら……あなたは……
もしかして&lt;Mel&gt;ちゃん、かしら？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>2</Id>
      <OldPtr>258452</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>272640</PointerOffset>
      <JapaneseText>わたしのことを知ってるんですか？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>3</Id>
      <OldPtr>258648</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>272824</PointerOffset>
      <JapaneseText>うちのご先祖様が
お世話になったとか何とか……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>4</Id>
      <BubbleId>0</BubbleId>
      <OldPtr>258788</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>272824</PointerOffset>
      <JapaneseText>その似顔絵にそっくりなのよね～
でもそんな長生きなわけないから
あなたもその&lt;Mel&gt;ちゃんの子孫？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>4</Id>
      <BubbleId>1</BubbleId>
      <OldPtr>258788</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>272912</PointerOffset>
      <JapaneseText>あ、あはははは……
わ、わたしも&lt;Mel&gt;っていうんですよ</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>6</Id>
      <OldPtr>258984</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>273004</PointerOffset>
      <JapaneseText>そうなの？
何だかあたしたち、
すごい縁なのかもね</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>7</Id>
      <OldPtr>259180</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>271576</PointerOffset>
      <JapaneseText>あっ！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>8</Id>
      <OldPtr>259376</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>271632</PointerOffset>
      <JapaneseText>な、なに？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>9</Id>
      <OldPtr>259572</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>271708</PointerOffset>
      <JapaneseText>ねぇ&lt;Dio&gt;、タルロウさんの
ダンスの件……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>10</Id>
      <OldPtr>259872</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>271812</PointerOffset>
      <JapaneseText>ああ！　ここなら
お客もいっぱい来そうだし、
相談してみるといいかも！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>11</Id>
      <OldPtr>260172</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>271856</PointerOffset>
      <JapaneseText>じつは……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>12</Id>
      <OldPtr>260628</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>272020</PointerOffset>
      <JapaneseText>ふむふむ、なるほど……
ダンスの先生か</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>13</Id>
      <BubbleId>0</BubbleId>
      <OldPtr>261120</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>272020</PointerOffset>
      <JapaneseText>それなら、あたしの友達の
母親のいとこの息子の同級生の
先生の親戚がそうだったかも！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>13</Id>
      <BubbleId>1</BubbleId>
      <OldPtr>261120</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>272084</PointerOffset>
      <JapaneseText>さ、さすがに遠くないか……？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>15</Id>
      <OldPtr>261436</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>272180</PointerOffset>
      <JapaneseText>さっそく現地に
行ってもらえるように
頼んでみるよ！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>16</Id>
      <OldPtr>261576</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>272252</PointerOffset>
      <JapaneseText>本当ですか！？
ありがとうございます！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>17</Id>
      <OldPtr>261772</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>272344</PointerOffset>
      <JapaneseText>なーに、他ならぬ
&lt;Mel&gt;ちゃんの頼みとあらば！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>18</Id>
      <OldPtr>261912</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>272388</PointerOffset>
      <JapaneseText>やったな！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>19</Id>
      <OldPtr>262152</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>272472</PointerOffset>
      <JapaneseText>うん！　さっそく
タルロウさんのところに行こう！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>20</Id>
      <OldPtr>262460</OldPtr>
      <Status>To Do</Status>
    </Entry>
