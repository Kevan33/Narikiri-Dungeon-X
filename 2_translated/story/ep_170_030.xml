    <Entry>
      <PointerOffset>291384</PointerOffset>
      <VoiceId>&lt;audio:VSM_170_030_001&gt;</VoiceId>
      <JapaneseText>全部勝手に想像して、
勝手に期待してたよ、
オレ……もっと、外は楽しいって
思ってた、でも……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>1</Id>
      <BubbleId>1</BubbleId>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>291468</PointerOffset>
      <VoiceId>&lt;audio:VSM_170_030_002&gt;</VoiceId>
      <JapaneseText>いやなことは、
たくさんある</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>3</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>291572</PointerOffset>
      <VoiceId>&lt;audio:VSM_170_030_003&gt;</VoiceId>
      <JapaneseText>でも、そういうものに
わざわざ向き合う
必要はないわ</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>4</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>291636</PointerOffset>
      <VoiceId>&lt;audio:VSM_170_030_004&gt;</VoiceId>
      <JapaneseText>誰だ……！？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>5</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>291840</PointerOffset>
      <VoiceId>&lt;audio:VSM_170_030_005&gt;</VoiceId>
      <JapaneseText></JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>6</Id>
      <BubbleId>0</BubbleId>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>291840</PointerOffset>
      <VoiceId>&lt;audio:VSM_170_030_006&gt;</VoiceId>
      <JapaneseText>外に出て傷つくくらいなら、
ここでずっと好きなことを
していればいいんだわ彼女は……きっと
そんなあなたをずっと
見守ってくれる……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>6</Id>
      <BubbleId>1</BubbleId>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>291928</PointerOffset>
      <VoiceId>&lt;audio:VSM_170_030_007&gt;</VoiceId>
      <JapaneseText>……そうなんかな……
本当に……？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>8</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>291992</PointerOffset>
      <VoiceId>&lt;audio:VSM_170_030_008&gt;</VoiceId>
      <JapaneseText>きゃあっ！！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>9</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>292088</PointerOffset>
      <VoiceId>&lt;audio:VSM_170_030_009&gt;</VoiceId>
      <JapaneseText>外へ戻るの？
あなたを傷つける外の世界に</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>10</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>292168</PointerOffset>
      <VoiceId>&lt;audio:VSM_170_030_010&gt;</VoiceId>
      <JapaneseText>&lt;Mel&gt;をほっとけねーよっ！！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>11</Id>
      <Status>To Do</Status>
    </Entry>
