    <Section>Main</Section>
    <Entry>
      <PointerOffset>293208</PointerOffset>
      <VoiceId>&lt;audio:VSM_150_020_016&gt;</VoiceId>
      <JapaneseText>くっ……っちぃ……
少しは手加減しろよな！</JapaneseText>
      <EnglishText>Ow...ie... You coulda gone
easy on me, you know!</EnglishText>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>1</Id>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset>293284</PointerOffset>
      <VoiceId>&lt;audio:VSM_150_020_017&gt;</VoiceId>
      <JapaneseText>なんか変くないか……？</JapaneseText>
      <EnglishText>Hey, hey... That voice just
now was kinda weird...</EnglishText>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>2</Id>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset>293376</PointerOffset>
      <VoiceId>&lt;audio:VSM_150_020_018&gt;</VoiceId>
      <JapaneseText>アルテミス。
おやめなさい</JapaneseText>
      <EnglishText>Artemis. Cease this at once.</EnglishText>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>3</Id>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset>293488</PointerOffset>
      <VoiceId>&lt;audio:VSM_150_020_019&gt;</VoiceId>
      <JapaneseText>だって、こいつらまた、
ルナお姉ちゃんを
連れてこうとしてんだよ</JapaneseText>
      <EnglishText>But if I do that, these people will
take you away again, Miss Luna.</EnglishText>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>4</Id>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset>293752</PointerOffset>
      <VoiceId>&lt;audio:VSM_150_020_022&gt;</VoiceId>
      <JapaneseText>もう、あなたを置いて、
どこかへ行ったりは
しませんよ</JapaneseText>
      <EnglishText>Please. I won't leave you alone ever again.</EnglishText>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>5</Id>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset>293928</PointerOffset>
      <VoiceId>&lt;audio:VSM_150_020_024&gt;</VoiceId>
      <JapaneseText>約束します。
だから、その方たちを
お通ししなさい</JapaneseText>
      <EnglishText>It's a promise, then. But please
leave these people be.</EnglishText>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>6</Id>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset>294028</PointerOffset>
      <VoiceId>&lt;audio:VSM_150_020_025&gt;</VoiceId>
      <JapaneseText>うん……わかった</JapaneseText>
      <EnglishText>Hrmph... Understood.</EnglishText>
      <Notes/>
      <SpeakerId>4</SpeakerId>
      <Id>7</Id>
      <BubbleId>0</BubbleId>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset>294028</PointerOffset>
      <VoiceId>&lt;audio:VSM_150_020_026&gt;</VoiceId>
      <JapaneseText>通れよ</JapaneseText>
      <EnglishText>Move along!</EnglishText>
      <Notes/>
      <SpeakerId>4</SpeakerId>
      <Id>7</Id>
      <BubbleId>1</BubbleId>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset>294100</PointerOffset>
      <VoiceId>&lt;audio:VSM_150_020_027&gt;</VoiceId>
      <JapaneseText>ありがとうございます</JapaneseText>
      <EnglishText>Thank you very much!</EnglishText>
      <Notes/>
      <SpeakerId>5</SpeakerId>
      <Id>9</Id>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset>294164</PointerOffset>
      <VoiceId>&lt;audio:VSM_150_020_028&gt;</VoiceId>
      <JapaneseText>ありがとうね</JapaneseText>
      <EnglishText>Yeah, thank you!</EnglishText>
      <Notes/>
      <SpeakerId>6</SpeakerId>
      <Id>10</Id>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset>294232</PointerOffset>
      <VoiceId>&lt;audio:VSM_150_020_029&gt;</VoiceId>
      <JapaneseText>ふんだ……</JapaneseText>
      <EnglishText>Sure, whatever.</EnglishText>
      <Notes/>
      <SpeakerId>4</SpeakerId>
      <Id>11</Id>
      <Status>Proofreading</Status>
    </Entry>
