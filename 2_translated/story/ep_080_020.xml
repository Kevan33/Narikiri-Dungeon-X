  <Strings>
    <Section>Main</Section>
    <Entry>
      <PointerOffset>267964</PointerOffset>
      <VoiceId>&lt;audio:VSM_080_020_001&gt;</VoiceId>
      <JapaneseText>ほらよ！
こいつ、おまえが食え！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>1</Id>
      <OldPtr>258452</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>268088</PointerOffset>
      <VoiceId>&lt;audio:VSM_080_020_002&gt;</VoiceId>
      <JapaneseText>何バカ言ってんだい！
そいつは今日の最後の食糧だ！
あんたが食いな！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>2</Id>
      <OldPtr>258592</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>268196</PointerOffset>
      <VoiceId>&lt;audio:VSM_080_020_003&gt;</VoiceId>
      <JapaneseText>てめぇこそ、もう三日も
何も食ってねーだろ！
食え！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>3</Id>
      <OldPtr>258732</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>268324</PointerOffset>
      <VoiceId>&lt;audio:VSM_080_020_004&gt;</VoiceId>
      <JapaneseText>このろくでなし亭主が！
そんな腹へり状態で、
働きに出るつもりかい！？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>4</Id>
      <OldPtr>258872</OldPtr>
      <Status>To Do</Status>
    </Entry>
