  <Strings>
    <Section>Main</Section>
    <Entry>
      <PointerOffset>293736</PointerOffset>
      <VoiceId>&lt;audio:VSM_170_050_001&gt;</VoiceId>
      <JapaneseText>そ、そんな……</JapaneseText>
      <EnglishText>Wh-What have you done...!?</EnglishText>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>1</Id>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset>293832</PointerOffset>
      <VoiceId>&lt;audio:VSM_170_050_002&gt;</VoiceId>
      <JapaneseText>これであなたたちは
元の時代には戻れない</JapaneseText>
      <EnglishText>With this, now you'll never return
to your original timeline.</EnglishText>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>2</Id>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset>293896</PointerOffset>
      <VoiceId>&lt;audio:VSM_170_050_003&gt;</VoiceId>
      <JapaneseText>ふん……</JapaneseText>
      <EnglishText>Hmph...</EnglishText>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>3</Id>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset>293988</PointerOffset>
      <VoiceId>&lt;audio:VSM_170_050_004&gt;</VoiceId>
      <JapaneseText>待て！</JapaneseText>
      <EnglishText>Hey, wait!</EnglishText>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>4</Id>
      <BubbleId>0</BubbleId>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset>293988</PointerOffset>
      <VoiceId>&lt;audio:VSM_170_050_005&gt;</VoiceId>
      <JapaneseText>……くそっ！</JapaneseText>
      <EnglishText>...Crap!</EnglishText>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>4</Id>
      <BubbleId>1</BubbleId>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset>294084</PointerOffset>
      <VoiceId>&lt;audio:VSM_170_050_006&gt;</VoiceId>
      <JapaneseText>帰れなくなっちゃった……
どうしよ、エト……</JapaneseText>
      <EnglishText>If we can't return, we can't stop the
Prism Ring...! What should we do, Eto!?</EnglishText>
      <Notes/>
      <SpeakerId>4</SpeakerId>
      <Id>6</Id>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset>294200</PointerOffset>
      <VoiceId>&lt;audio:VSM_170_050_007&gt;</VoiceId>
      <JapaneseText>……どうしようっても、
なんか元の時間に戻る
方法を考えないと……</JapaneseText>
      <EnglishText>Well, uhm... If we can't return with the paintings,
there might be some other way to travel
through time. But nothing comes to mind...</EnglishText>
      <Notes/>
      <SpeakerId>5</SpeakerId>
      <Id>7</Id>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset>294312</PointerOffset>
      <VoiceId>&lt;audio:VSM_170_050_008&gt;</VoiceId>
      <JapaneseText>なんだよ、
あんなえらそーなこと
言った後にいきなり弱気だな</JapaneseText>
      <EnglishText>Right after that big speech about
fear and stuff, now you act all
weak? C'mon, &lt;Mel&gt;!</EnglishText>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>8</Id>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset>294372</PointerOffset>
      <VoiceId>&lt;audio:VSM_170_050_009&gt;</VoiceId>
      <JapaneseText>だって</JapaneseText>
      <EnglishText>But, what can we do...?</EnglishText>
      <Notes/>
      <SpeakerId>4</SpeakerId>
      <Id>9</Id>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset>294568</PointerOffset>
      <VoiceId>&lt;audio:VSM_170_050_010&gt;</VoiceId>
      <JapaneseText>&lt;Cless&gt;さんたちなら、
いい方法を教えてくれっかも</JapaneseText>
      <EnglishText>I'm pretty sure Mister &lt;Cless&gt; knows of
another way to travel through time.</EnglishText>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>10</Id>
      <BubbleId>0</BubbleId>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset>294568</PointerOffset>
      <VoiceId>&lt;audio:VSM_170_050_011&gt;</VoiceId>
      <JapaneseText>だって、時空戦士なんだぜ</JapaneseText>
      <EnglishText>They aren't called the Heroes
of Time for nothing!</EnglishText>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>10</Id>
      <BubbleId>1</BubbleId>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset>294568</PointerOffset>
      <VoiceId>&lt;audio:VSM_170_050_012&gt;</VoiceId>
      <JapaneseText>時間転移の方法くらい
知ってるって</JapaneseText>
      <EnglishText>If anyone knows how to
travel through time is them!</EnglishText>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>10</Id>
      <BubbleId>2</BubbleId>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset>294852</PointerOffset>
      <VoiceId>&lt;audio:VSM_170_050_015&gt;</VoiceId>
      <JapaneseText>で、それ聞いたらもっぺん、
マクスウェルんとこ行こーぜ</JapaneseText>
      <EnglishText>Once we get that done, we
should go pay Maxwell a visit.</EnglishText>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>13</Id>
      <BubbleId>0</BubbleId>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset>294852</PointerOffset>
      <VoiceId>&lt;audio:VSM_170_050_016&gt;</VoiceId>
      <JapaneseText>で、いいだろ？</JapaneseText>
      <EnglishText>Sounds good to me. Any objections?</EnglishText>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>13</Id>
      <BubbleId>1</BubbleId>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset>294920</PointerOffset>
      <VoiceId>&lt;audio:VSM_170_050_017&gt;</VoiceId>
      <JapaneseText>え？　あ、うん</JapaneseText>
      <EnglishText>What? Well, I guess...</EnglishText>
      <Notes/>
      <SpeakerId>5</SpeakerId>
      <Id>15</Id>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset>295032</PointerOffset>
      <VoiceId>&lt;audio:VSM_170_050_018&gt;</VoiceId>
      <JapaneseText>あと……その、ゴメン……
オレ、いじけて……
メーワクかけて</JapaneseText>
      <EnglishText>And...uh...well... I'm sorry for
being all depressed back there.</EnglishText>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>16</Id>
      <Status>Proofreading</Status>
    </Entry>
