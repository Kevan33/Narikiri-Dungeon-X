    <Entry>
      <PointerOffset>293988</PointerOffset>
      <VoiceId>&lt;audio:VSM_170_050_005&gt;</VoiceId>
      <JapaneseText>待て！……くそっ！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>4</Id>
      <BubbleId>1</BubbleId>
      <Status>To Do</Status>
