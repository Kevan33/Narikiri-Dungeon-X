  <Strings>
    <Section>Main</Section>
    <Entry>
      <PointerOffset>269692</PointerOffset>
      <JapaneseText>えええええー！？
ば、バイトじゃなかったの……？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>1</Id>
      <BubbleId>0</BubbleId>
      <OldPtr>258220</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>269692</PointerOffset>
      <JapaneseText>ごめんなさい。
あたし、はやとちりで……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>1</Id>
      <BubbleId>1</BubbleId>
      <OldPtr>258220</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>269808</PointerOffset>
      <JapaneseText>いいですよ。
結構面白かったし、充実感もあったし
今日のバイト代まで頂いちゃったし</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>3</Id>
      <OldPtr>258592</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>269900</PointerOffset>
      <JapaneseText>そ、そお？
えへへ、そう言ってくれると助かるな</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>4</Id>
      <OldPtr>258788</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>270048</PointerOffset>
      <JapaneseText>普段気にしてなかった、
ウェイトレスさんの大変さも
とっても勉強になりました</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>5</Id>
      <BubbleId>0</BubbleId>
      <OldPtr>259048</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>270048</PointerOffset>
      <JapaneseText>もしなんでしたら
お手伝いに来ますよ？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>5</Id>
      <BubbleId>1</BubbleId>
      <OldPtr>259048</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>270156</PointerOffset>
      <JapaneseText>ええええええ！
ホントに！？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>7</Id>
      <BubbleId>0</BubbleId>
      <OldPtr>259308</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>270156</PointerOffset>
      <JapaneseText>ううっ、&lt;Mel&gt;ちゃん、
いい子だよ～</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>7</Id>
      <BubbleId>1</BubbleId>
      <OldPtr>259308</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>270228</PointerOffset>
      <JapaneseText>いいのか？　&lt;Mel&gt;。
んなコト言って</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>9</Id>
      <OldPtr>259668</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>270304</PointerOffset>
      <JapaneseText>うん。これもなりきり士の
お仕事だし、ね</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>10</Id>
      <OldPtr>260032</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>270440</PointerOffset>
      <JapaneseText>ありがとう！
じゃあ気が向いたら
また声かけてね</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>11</Id>
      <BubbleId>0</BubbleId>
      <OldPtr>260328</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>270440</PointerOffset>
      <JapaneseText>あっ！　本当に
都合のいいときでいいから、ね♪</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>11</Id>
      <BubbleId>1</BubbleId>
      <OldPtr>260328</OldPtr>
      <Status>To Do</Status>
    </Entry>
