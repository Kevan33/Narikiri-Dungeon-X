    <Entry>
      <PointerOffset>267968</PointerOffset>
      <JapaneseText>これは……スキル書か</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>1</Id>
      <OldPtr>257888</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>268012</PointerOffset>
      <JapaneseText>スキル書？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>2</Id>
      <OldPtr>258188</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>268160</PointerOffset>
      <JapaneseText>ああ。
戦い方のコツを書いた書物だ。
先人のまとめた貴重なものだぞ</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>3</Id>
      <BubbleId>0</BubbleId>
      <OldPtr>258400</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>268160</PointerOffset>
      <JapaneseText>これを熟読すれば、
戦いを有利に進められるだろう</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>3</Id>
      <BubbleId>1</BubbleId>
      <OldPtr>258400</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>268240</PointerOffset>
      <JapaneseText>それってすげーな！
オレでも覚えられっかな？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>5</Id>
      <OldPtr>258612</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>268360</PointerOffset>
      <JapaneseText>誰にでも分かるように丁寧に書かれている。
焦らずゆっくり読めば、必ず習得できるはずだ</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>6</Id>
      <OldPtr>258752</OldPtr>
      <Status>To Do</Status>
    </Entry>
