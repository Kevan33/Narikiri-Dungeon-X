    <Entry>
      <PointerOffset>301148</PointerOffset>
      <VoiceId>&lt;audio:VSS_039_030_001&gt;</VoiceId>
      <JapaneseText>うぅっ……寒っ……！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>1</Id>
      <OldPtr>278284</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>301228</PointerOffset>
      <VoiceId>&lt;audio:VSS_039_030_002&gt;</VoiceId>
      <JapaneseText>どこかで
あったまろうよ……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>2</Id>
      <OldPtr>278728</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>301292</PointerOffset>
      <VoiceId>&lt;audio:VSS_039_030_003&gt;</VoiceId>
      <JapaneseText>きゃっ！！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>3</Id>
      <OldPtr>279428</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>301384</PointerOffset>
      <VoiceId>&lt;audio:VSS_039_030_004&gt;</VoiceId>
      <JapaneseText>私を呼んでくれて、
サンキュー！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>4</Id>
      <OldPtr>280004</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>301456</PointerOffset>
      <VoiceId>&lt;audio:VSS_039_030_005&gt;</VoiceId>
      <JapaneseText>呼んでねーっての……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>5</Id>
      <OldPtr>280312</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>301548</PointerOffset>
      <VoiceId>&lt;audio:VSS_039_030_006&gt;</VoiceId>
      <JapaneseText>ワンダーシェフ！
ここに参上！！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>6</Id>
      <OldPtr>280576</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>301632</PointerOffset>
      <VoiceId>&lt;audio:VSS_039_030_007&gt;</VoiceId>
      <JapaneseText>……何しに
出てきたんだよ……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>7</Id>
      <OldPtr>280716</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>301876</PointerOffset>
      <VoiceId>&lt;audio:VSS_039_030_008&gt;</VoiceId>
      <JapaneseText>寒く冷たいあなたの心に、
このスープをあげるわ</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>8</Id>
      <BubbleId>0</BubbleId>
      <OldPtr>280912</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>301876</PointerOffset>
      <VoiceId>&lt;audio:VSS_039_030_009&gt;</VoiceId>
      <JapaneseText>じっくりコトコト
煮込んだ末に、
できたこのスープ</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>8</Id>
      <BubbleId>1</BubbleId>
      <OldPtr>280912</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>301876</PointerOffset>
      <VoiceId>&lt;audio:VSS_039_030_010&gt;</VoiceId>
      <JapaneseText>食卓のお供に、毎朝、
笑顔で朝食を
食べられる代物よ</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>8</Id>
      <BubbleId>2</BubbleId>
      <OldPtr>280912</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>301972</PointerOffset>
      <VoiceId>&lt;audio:VSS_039_030_011&gt;</VoiceId>
      <JapaneseText>んじゃあ、
いただきまーす！
んぐんぐっ……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>11</Id>
      <OldPtr>281816</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>302136</PointerOffset>
      <VoiceId>&lt;audio:VSS_039_030_012&gt;</VoiceId>
      <JapaneseText>か、かれぇ～！！！
……でも……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>12</Id>
      <BubbleId>0</BubbleId>
      <OldPtr>282068</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>302136</PointerOffset>
      <VoiceId>&lt;audio:VSS_039_030_013&gt;</VoiceId>
      <JapaneseText>美味い！
そして……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>12</Id>
      <BubbleId>1</BubbleId>
      <OldPtr>282068</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>302136</PointerOffset>
      <VoiceId>&lt;audio:VSS_039_030_014&gt;</VoiceId>
      <JapaneseText>体が
ポッカポッカする！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>12</Id>
      <BubbleId>2</BubbleId>
      <OldPtr>282068</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>302204</PointerOffset>
      <VoiceId>&lt;audio:VSS_039_030_015&gt;</VoiceId>
      <JapaneseText>ポッカポッカ？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>15</Id>
      <OldPtr>282776</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>302272</PointerOffset>
      <VoiceId>&lt;audio:VSS_039_030_016&gt;</VoiceId>
      <JapaneseText>そ、ポッカポッカ</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>16</Id>
      <OldPtr>282972</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>302356</PointerOffset>
      <VoiceId>&lt;audio:VSS_039_030_017&gt;</VoiceId>
      <JapaneseText>なんかカレーの匂いが
するね？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>17</Id>
      <OldPtr>283348</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>302460</PointerOffset>
      <VoiceId>&lt;audio:VSS_039_030_018&gt;</VoiceId>
      <JapaneseText>いや、でも
中華っぽくもあるぜ？
……これ、なんだ？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>18</Id>
      <OldPtr>283612</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>302584</PointerOffset>
      <VoiceId>&lt;audio:VSS_039_030_019&gt;</VoiceId>
      <JapaneseText>それはカレーとマーボー豆腐の
辛さの饗宴、
マーボーカレースープ！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>19</Id>
      <OldPtr>284032</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>302660</PointerOffset>
      <VoiceId>&lt;audio:VSS_039_030_020&gt;</VoiceId>
      <JapaneseText>マーボーカレースープ？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>20</Id>
      <OldPtr>284284</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>302904</PointerOffset>
      <VoiceId>&lt;audio:VSS_039_030_022&gt;</VoiceId>
      <JapaneseText>辛いものを体内に
取り込むと、発汗作用が
促進されて体が温かくなるの</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>21</Id>
      <BubbleId>0</BubbleId>
      <OldPtr>284480</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>302904</PointerOffset>
      <VoiceId>&lt;audio:VSS_039_030_023&gt;</VoiceId>
      <JapaneseText>だから、
寒い時には最適</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>21</Id>
      <BubbleId>1</BubbleId>
      <OldPtr>284480</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>302980</PointerOffset>
      <VoiceId>&lt;audio:VSS_039_030_024&gt;</VoiceId>
      <JapaneseText>おまえも
食ってみろよ</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>23</Id>
      <OldPtr>284724</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>303124</PointerOffset>
      <VoiceId>&lt;audio:VSS_039_030_025&gt;</VoiceId>
      <JapaneseText>いただきます。
んぐんぐんぐ……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>24</Id>
      <BubbleId>0</BubbleId>
      <OldPtr>285264</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>303124</PointerOffset>
      <VoiceId>&lt;audio:VSS_039_030_026&gt;</VoiceId>
      <JapaneseText>辛くて、汗が
たくさん出るけど、
美味しいね</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>24</Id>
      <BubbleId>1</BubbleId>
      <OldPtr>285264</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>303220</PointerOffset>
      <VoiceId>&lt;audio:VSS_039_030_027&gt;</VoiceId>
      <JapaneseText>そんだけ汗かいたら、
その分、少しは痩せるぜ</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>26</Id>
      <OldPtr>285924</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>303292</PointerOffset>
      <VoiceId>&lt;audio:VSS_039_030_028&gt;</VoiceId>
      <JapaneseText>いっ……てぇ……！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>27</Id>
      <OldPtr>288212</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>303412</PointerOffset>
      <VoiceId>&lt;audio:VSS_039_030_029&gt;</VoiceId>
      <JapaneseText>わたし、太ってないもん</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>28</Id>
      <BubbleId>0</BubbleId>
      <OldPtr>289508</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>303412</PointerOffset>
      <VoiceId>&lt;audio:VSS_039_030_030&gt;</VoiceId>
      <JapaneseText>んぐんぐ……
おいしい……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>28</Id>
      <BubbleId>1</BubbleId>
      <OldPtr>289508</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>303544</PointerOffset>
      <VoiceId>&lt;audio:VSS_039_030_031&gt;</VoiceId>
      <JapaneseText>ポッカポッカというより、
ボッカボッカかしら。
あら、私うまいこと言った</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>30</Id>
      <OldPtr>290512</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>303604</PointerOffset>
      <VoiceId>&lt;audio:VSS_039_030_032&gt;</VoiceId>
      <JapaneseText>どこが</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>31</Id>
      <OldPtr>290764</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>303740</PointerOffset>
      <VoiceId>&lt;audio:VSS_039_030_033&gt;</VoiceId>
      <JapaneseText>…………</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>32</Id>
      <BubbleId>0</BubbleId>
      <OldPtr>290960</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>303740</PointerOffset>
      <VoiceId>&lt;audio:VSS_039_030_034&gt;</VoiceId>
      <JapaneseText>ポッカポッカというより、
ボッカボッカね、えへ∀</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>32</Id>
      <BubbleId>1</BubbleId>
      <OldPtr>290960</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>303840</PointerOffset>
      <VoiceId>&lt;audio:VSS_039_030_035&gt;</VoiceId>
      <JapaneseText>２回言うな！
そして言いっぱなしにして
逃げるな！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>34</Id>
      <OldPtr>291504</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>303952</PointerOffset>
      <VoiceId>&lt;audio:VSS_039_030_036&gt;</VoiceId>
      <JapaneseText>でも、あの人、
レシピとスープの材料
置いていってくれたよ？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>35</Id>
      <OldPtr>291912</OldPtr>
      <Status>To Do</Status>
    </Entry>
