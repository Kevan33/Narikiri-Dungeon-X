    <Section>Main</Section>
    <Entry>
      <PointerOffset>292972</PointerOffset>
      <VoiceId>&lt;audio:VSM_240_010_001&gt;</VoiceId>
      <JapaneseText>精霊よ……！
オレらに力を貸してくれ！</JapaneseText>
      <EnglishText>Summon Spirits...show us your strength!</EnglishText>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>1</Id>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset>293060</PointerOffset>
      <VoiceId>&lt;audio:VSM_240_010_002&gt;</VoiceId>
      <JapaneseText>あなたたちから
溢れ出る力を感じます</JapaneseText>
      <EnglishText>I can sense overflowing power
emanating from you.</EnglishText>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>2</Id>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset>293160</PointerOffset>
      <VoiceId>&lt;audio:VSM_240_010_003&gt;</VoiceId>
      <JapaneseText>貴様らの力を礎とし、
『虹輪』を抑え込まん</JapaneseText>
      <EnglishText>With your power as a foundation,
we shall be able to dissipate this
Prism Ring.</EnglishText>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>3</Id>
      <Status>Proofreading</Status>
    </Entry>
  </Strings>
