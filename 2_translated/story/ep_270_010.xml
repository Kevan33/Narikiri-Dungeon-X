    <Entry>
      <PointerOffset>299156</PointerOffset>
      <VoiceId>&lt;audio:VSM_270_010_001&gt;</VoiceId>
      <JapaneseText>ここが&lt;Red&gt;氷狼王の礎&lt;White&gt;なんだね</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>1</Id>
      <OldPtr>279188</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>299232</PointerOffset>
      <VoiceId>&lt;audio:VSM_270_010_002&gt;</VoiceId>
      <JapaneseText>入り口が解かされてる……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>2</Id>
      <OldPtr>279432</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>299320</PointerOffset>
      <VoiceId>&lt;audio:VSM_270_010_003&gt;</VoiceId>
      <JapaneseText>『不燃の古木』
使ったんじゃねーか</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>3</Id>
      <OldPtr>279676</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>299424</PointerOffset>
      <VoiceId>&lt;audio:VSM_270_010_004&gt;</VoiceId>
      <JapaneseText>あの暑い塔にあった
宝物だもんね、
それくらい簡単かも</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>4</Id>
      <OldPtr>279984</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>299488</PointerOffset>
      <VoiceId>&lt;audio:VSM_270_010_005&gt;</VoiceId>
      <JapaneseText>クルール！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>4</SpeakerId>
      <Id>5</Id>
      <OldPtr>280724</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>299580</PointerOffset>
      <VoiceId>&lt;audio:VSM_270_010_006&gt;</VoiceId>
      <JapaneseText>&lt;Rody&gt;さん？
どうしてこんなところに？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>6</Id>
      <OldPtr>284188</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>299736</PointerOffset>
      <VoiceId>&lt;audio:VSM_270_010_007&gt;</VoiceId>
      <JapaneseText>なんかへもへも歩いてたら、
迷いこんじゃった、てへへ</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>5</SpeakerId>
      <Id>7</Id>
      <BubbleId>0</BubbleId>
      <OldPtr>284384</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>299736</PointerOffset>
      <VoiceId>&lt;audio:VSM_270_010_008&gt;</VoiceId>
      <JapaneseText>君たち、ここ、
どこだか知ってる？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>5</SpeakerId>
      <Id>7</Id>
      <BubbleId>1</BubbleId>
      <OldPtr>284384</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>299824</PointerOffset>
      <VoiceId>&lt;audio:VSM_270_010_009&gt;</VoiceId>
      <JapaneseText>暗黒時空だって……
ダオスが言ってた</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>9</Id>
      <OldPtr>284712</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>299888</PointerOffset>
      <VoiceId>&lt;audio:VSM_270_010_010&gt;</VoiceId>
      <JapaneseText>ダオス……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>5</SpeakerId>
      <Id>10</Id>
      <OldPtr>284908</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>299988</PointerOffset>
      <VoiceId>&lt;audio:VSM_270_010_011&gt;</VoiceId>
      <JapaneseText>もしかして、&lt;Rody&gt;さん、
まだダオスを……？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>11</Id>
      <OldPtr>285048</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>300232</PointerOffset>
      <VoiceId>&lt;audio:VSM_270_010_013&gt;</VoiceId>
      <JapaneseText>そうだよ、
ダオスを追ってきた</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>5</SpeakerId>
      <Id>12</Id>
      <BubbleId>0</BubbleId>
      <OldPtr>285364</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>300232</PointerOffset>
      <VoiceId>&lt;audio:VSM_270_010_014&gt;</VoiceId>
      <JapaneseText>君たち見て、
このままじゃいけない
って思ったからさ</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>5</SpeakerId>
      <Id>12</Id>
      <BubbleId>1</BubbleId>
      <OldPtr>285364</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>300296</PointerOffset>
      <VoiceId>&lt;audio:VSM_270_010_015&gt;</VoiceId>
      <JapaneseText>オレらを？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>14</Id>
      <OldPtr>286568</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>300396</PointerOffset>
      <VoiceId>&lt;audio:VSM_270_010_016&gt;</VoiceId>
      <JapaneseText>そう。自分の中の
不安とちゃんと
向き合おうって</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>5</SpeakerId>
      <Id>15</Id>
      <OldPtr>286708</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>301004</PointerOffset>
      <VoiceId>&lt;audio:VSM_270_010_023&gt;</VoiceId>
      <JapaneseText>ダオス……
あいつ、またオレらの前に
出てきたんだ</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>16</Id>
      <OldPtr>286952</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>301088</PointerOffset>
      <VoiceId>&lt;audio:VSM_270_010_024&gt;</VoiceId>
      <JapaneseText>まだ君たちを
狙ってんの……？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>5</SpeakerId>
      <Id>17</Id>
      <OldPtr>287260</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>301180</PointerOffset>
      <VoiceId>&lt;audio:VSM_270_010_025&gt;</VoiceId>
      <JapaneseText>ううん、
なんかちょっと
違うみたいで……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>18</Id>
      <OldPtr>287456</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>301372</PointerOffset>
      <VoiceId>&lt;audio:VSM_270_010_027&gt;</VoiceId>
      <JapaneseText>今、オレら、
別のもん追ってんだ</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>19</Id>
      <BubbleId>0</BubbleId>
      <OldPtr>287776</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>301372</PointerOffset>
      <VoiceId>&lt;audio:VSM_270_010_028&gt;</VoiceId>
      <JapaneseText>見なかったか？
仮面かぶったヤツ</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>19</Id>
      <BubbleId>1</BubbleId>
      <OldPtr>287776</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>301484</PointerOffset>
      <VoiceId>&lt;audio:VSM_270_010_029&gt;</VoiceId>
      <JapaneseText>仮面？　前に
シャドウのとこで会った
連中のこと？　さあ……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>5</SpeakerId>
      <Id>21</Id>
      <OldPtr>287916</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>301568</PointerOffset>
      <VoiceId>&lt;audio:VSM_270_010_030&gt;</VoiceId>
      <JapaneseText>やっぱ、
この洞窟にいんのかな</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>22</Id>
      <OldPtr>288360</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>301644</PointerOffset>
      <VoiceId>&lt;audio:VSM_270_010_031&gt;</VoiceId>
      <JapaneseText>んじゃ、私も一緒に行くよ</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>5</SpeakerId>
      <Id>23</Id>
      <OldPtr>288676</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>302096</PointerOffset>
      <VoiceId>&lt;audio:VSM_270_010_037&gt;</VoiceId>
      <JapaneseText>でも、ダオスが来るとは
限らないですよ</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>24</Id>
      <OldPtr>289184</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>302240</PointerOffset>
      <VoiceId>&lt;audio:VSM_270_010_038&gt;</VoiceId>
      <JapaneseText>もし、そうでも
君たちと行くよ</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>5</SpeakerId>
      <Id>25</Id>
      <BubbleId>0</BubbleId>
      <OldPtr>289380</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>302240</PointerOffset>
      <VoiceId>&lt;audio:VSM_270_010_039&gt;</VoiceId>
      <JapaneseText>だって、君たちと旅するの、
嫌いじゃないしね</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>5</SpeakerId>
      <Id>25</Id>
      <BubbleId>1</BubbleId>
      <OldPtr>289380</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>302332</PointerOffset>
      <VoiceId>&lt;audio:VSM_270_010_040&gt;</VoiceId>
      <JapaneseText>じゃあ、改めてよろしく、
&lt;Rody&gt;さん</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>27</Id>
      <OldPtr>289640</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>302396</PointerOffset>
      <VoiceId>&lt;audio:VSM_270_010_041&gt;</VoiceId>
      <JapaneseText>よろしくな</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>28</Id>
      <OldPtr>289780</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>302492</PointerOffset>
      <VoiceId>&lt;audio:VSM_270_010_042&gt;</VoiceId>
      <JapaneseText>うん、よろしくね、
エトちゃんも、
&lt;Couleur&gt;も</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>5</SpeakerId>
      <Id>29</Id>
      <OldPtr>289976</OldPtr>
      <Status>To Do</Status>
    </Entry>
