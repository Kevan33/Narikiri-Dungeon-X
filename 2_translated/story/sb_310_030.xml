    <Entry>
      <PointerOffset>271772</PointerOffset>
      <JapaneseText>魔物と戦っていたせいか
だいぶ汚れてしまったな</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>1</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>271860</PointerOffset>
      <JapaneseText>&lt;Dio&gt;ほんとですね。
なんて
顔にヒゲが生えてるみたい</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>2</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>271956</PointerOffset>
      <JapaneseText>な、なに言ってんだよ！
んなもん、こすっときゃ
消えるってーの</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>3</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>272068</PointerOffset>
      <JapaneseText>&lt;Dio&gt;もう、くんたら
ちゃんと拭かなきゃだめだよ～。
ほら、やってあげるって∀</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>4</SpeakerId>
      <Id>4</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>272128</PointerOffset>
      <JapaneseText>オ、オレ、風呂入ってくる！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>5</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>272184</PointerOffset>
      <JapaneseText>はいは～い、また後でね</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>4</SpeakerId>
      <Id>6</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>272244</PointerOffset>
      <JapaneseText>&lt;Rody&gt;さん！
またー。</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>7</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>272348</PointerOffset>
      <JapaneseText>いいじゃん、いいじゃん。
また、進んでお風呂入って
くれたんだからさ∀</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>4</SpeakerId>
      <Id>8</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>272420</PointerOffset>
      <JapaneseText>それでは、
我々も便乗するとしようか</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>9</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>272496</PointerOffset>
      <JapaneseText>わかりました。
すぐにご用意いたしますね</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>5</SpeakerId>
      <Id>10</Id>
      <Status>To Do</Status>
    </Entry>
