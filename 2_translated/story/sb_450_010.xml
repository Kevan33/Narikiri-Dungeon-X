    <Entry>
      <PointerOffset>304736</PointerOffset>
      <JapaneseText>あっ！　忘れ物！
アイテム袋忘れた！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>1</Id>
      <OldPtr>278696</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>304832</PointerOffset>
      <JapaneseText>もう、&lt;Dio&gt;ったら……
あっ……わたしも……
日記帳忘れた……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>2</Id>
      <OldPtr>279244</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>304900</PointerOffset>
      <JapaneseText>なんだよ、
人のこと言えねーだろ</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>3</Id>
      <OldPtr>280252</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>304968</PointerOffset>
      <JapaneseText>やれやれ……
……ぼくも見てくるね</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>4</Id>
      <OldPtr>280728</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>305028</PointerOffset>
      <JapaneseText>うん、
行ってらっしゃい</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>4</SpeakerId>
      <Id>5</Id>
      <OldPtr>281272</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>305112</PointerOffset>
      <JapaneseText>ダオス……！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>4</SpeakerId>
      <Id>6</Id>
      <BubbleId>0</BubbleId>
      <OldPtr>283320</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>305112</PointerOffset>
      <JapaneseText>まさか、
また双子ちゃんを狙って……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>4</SpeakerId>
      <Id>6</Id>
      <BubbleId>1</BubbleId>
      <OldPtr>283320</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>305184</PointerOffset>
      <JapaneseText>彼らは自身の手で、
決着をつけるだろう</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>5</SpeakerId>
      <Id>8</Id>
      <OldPtr>283580</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>305236</PointerOffset>
      <JapaneseText>……だったら……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>4</SpeakerId>
      <Id>9</Id>
      <OldPtr>283720</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>305304</PointerOffset>
      <JapaneseText>おまえに
言い忘れたことがあった</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>5</SpeakerId>
      <Id>10</Id>
      <OldPtr>283860</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>305348</PointerOffset>
      <JapaneseText>なに……？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>4</SpeakerId>
      <Id>11</Id>
      <OldPtr>284000</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>305416</PointerOffset>
      <JapaneseText>私はダオスという男の
亡想にすぎぬ</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>5</SpeakerId>
      <Id>12</Id>
      <OldPtr>284140</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>305476</PointerOffset>
      <JapaneseText>うん……残存思念だね……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>4</SpeakerId>
      <Id>13</Id>
      <OldPtr>284336</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>305720</PointerOffset>
      <JapaneseText>だが、我が肉体は、
大樹カーラーンに救われ、
『大いなる実り』となった</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>5</SpeakerId>
      <Id>14</Id>
      <BubbleId>0</BubbleId>
      <OldPtr>284600</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>305720</PointerOffset>
      <JapaneseText>そして故郷
デリス・カーラーンへの
帰路についた</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>5</SpeakerId>
      <Id>14</Id>
      <BubbleId>1</BubbleId>
      <OldPtr>284600</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>305720</PointerOffset>
      <JapaneseText>これは、誰も……私と
大樹カーラーン以外が
知ることのない事実……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>5</SpeakerId>
      <Id>14</Id>
      <BubbleId>2</BubbleId>
      <OldPtr>284600</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>305720</PointerOffset>
      <JapaneseText>伝えたかったのは、
それだけだ</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>5</SpeakerId>
      <Id>14</Id>
      <BubbleId>3</BubbleId>
      <OldPtr>284600</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>305776</PointerOffset>
      <JapaneseText>……それだけ、ね……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>4</SpeakerId>
      <Id>18</Id>
      <OldPtr>285100</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>306016</PointerOffset>
      <JapaneseText>最後にひとつ、聞かせて</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>4</SpeakerId>
      <Id>19</Id>
      <BubbleId>0</BubbleId>
      <OldPtr>285360</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>306016</PointerOffset>
      <JapaneseText>『大いなる実り』は……
ダオスは、故郷に戻れたの？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>4</SpeakerId>
      <Id>19</Id>
      <BubbleId>1</BubbleId>
      <OldPtr>285360</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>306016</PointerOffset>
      <JapaneseText>デリス・カーラーンは
どうなったの……？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>4</SpeakerId>
      <Id>19</Id>
      <BubbleId>2</BubbleId>
      <OldPtr>285360</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>306076</PointerOffset>
      <JapaneseText>デリス・カーラーンは……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>5</SpeakerId>
      <Id>22</Id>
      <OldPtr>285684</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>306132</PointerOffset>
      <JapaneseText>待たせてごめんなさい</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>23</Id>
      <OldPtr>287920</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>306196</PointerOffset>
      <JapaneseText>いいのいいの。
さ、行こうよ</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>4</SpeakerId>
      <Id>24</Id>
      <OldPtr>288340</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>306240</PointerOffset>
      <JapaneseText>ああ……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>25</Id>
      <OldPtr>288480</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>306308</PointerOffset>
      <JapaneseText>&lt;Dio&gt;くん、
&lt;Mel&gt;ちゃん……！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>4</SpeakerId>
      <Id>26</Id>
      <OldPtr>289504</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>306408</PointerOffset>
      <JapaneseText>………………</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>4</SpeakerId>
      <Id>27</Id>
      <BubbleId>0</BubbleId>
      <OldPtr>290392</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>306408</PointerOffset>
      <JapaneseText>……ううん、
やっぱりなんでもないよ、
さ、行こっか</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>4</SpeakerId>
      <Id>27</Id>
      <BubbleId>1</BubbleId>
      <OldPtr>290392</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>306460</PointerOffset>
      <JapaneseText>……そ、っか……？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>29</Id>
      <OldPtr>291000</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>306524</PointerOffset>
      <JapaneseText>&lt;Rody&gt;、
どうしたんだ……？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>30</Id>
      <OldPtr>292200</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>306580</PointerOffset>
      <JapaneseText>……わかんない、でも</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>31</Id>
      <OldPtr>292440</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>306668</PointerOffset>
      <JapaneseText>……わたしたちがいない間に
なにかあったのかな……？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>32</Id>
      <OldPtr>292948</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>306740</PointerOffset>
      <JapaneseText>オレら、
聞かねーほうがいいことかも</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>33</Id>
      <OldPtr>293188</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>306796</PointerOffset>
      <JapaneseText>……かな……
かもね</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>34</Id>
      <OldPtr>293656</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>306844</PointerOffset>
      <JapaneseText>どういうこと？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>35</Id>
      <OldPtr>293852</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>306896</PointerOffset>
      <JapaneseText>そういうことだって</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>36</Id>
      <OldPtr>294260</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>306964</PointerOffset>
      <JapaneseText>あ、&lt;Rody&gt;、
置いてかないで！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>37</Id>
      <OldPtr>294672</OldPtr>
      <Status>To Do</Status>
    </Entry>
