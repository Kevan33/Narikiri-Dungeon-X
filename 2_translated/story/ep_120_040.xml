      <PointerOffset>271864</PointerOffset>
      <VoiceId>&lt;audio:VSM_120_040_001&gt;</VoiceId>
      <JapaneseText>ここは……？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
