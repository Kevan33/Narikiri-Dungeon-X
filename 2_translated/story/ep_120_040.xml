    <Entry>
      <PointerOffset>272516</PointerOffset>
      <VoiceId>&lt;audio:VSM_120_040_010&gt;</VoiceId>
      <JapaneseText>なんで……いや、とにかく。
何て書いてあるんだ？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>9</Id>
      <BubbleId>1</BubbleId>
