    <Entry>
      <PointerOffset>271936</PointerOffset>
      <VoiceId>&lt;audio:VSM_120_040_002&gt;</VoiceId>
      <JapaneseText>なにか書いてあるよ？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>2</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>272012</PointerOffset>
      <VoiceId>&lt;audio:VSM_120_040_003&gt;</VoiceId>
      <JapaneseText>なんだこれ。何語なんだ？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>3</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>272084</PointerOffset>
      <VoiceId>&lt;audio:VSM_120_040_004&gt;</VoiceId>
      <JapaneseText>ちょっと読めないな</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>4</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>272148</PointerOffset>
      <VoiceId>&lt;audio:VSM_120_040_005&gt;</VoiceId>
      <JapaneseText>クルールゥ～</JapaneseText>
      <EnglishText/>
      <Notes/>
