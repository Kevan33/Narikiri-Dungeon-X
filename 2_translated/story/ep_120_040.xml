      <Id>5</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>272248</PointerOffset>
      <VoiceId>&lt;audio:VSM_120_040_006&gt;</VoiceId>
      <JapaneseText>死を暗示する方位には、
破壊を司る者を招くがよい</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>5</SpeakerId>
      <Id>6</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>272312</PointerOffset>
      <VoiceId>&lt;audio:VSM_120_040_007&gt;</VoiceId>
      <JapaneseText>読めるのか？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>7</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>272396</PointerOffset>
      <VoiceId>&lt;audio:VSM_120_040_008&gt;</VoiceId>
      <JapaneseText>う、うん……
読める、みたい……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>5</SpeakerId>
      <Id>8</Id>
      <Status>To Do</Status>
    </Entry>
