      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>274092</PointerOffset>
      <JapaneseText>練習しとかないと、
あいつに置いてかれるからな</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>7</Id>
      <OldPtr>260412</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>274164</PointerOffset>
      <JapaneseText>……あいつって、
&lt;Cless&gt;さんのこと？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>8</Id>
      <OldPtr>260608</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>274280</PointerOffset>
      <JapaneseText>ああ、あれ以上、
あいつに特訓とかされたら、
オレが追いつけない</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>9</Id>
      <BubbleId>0</BubbleId>
      <OldPtr>260748</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>274280</PointerOffset>
      <JapaneseText>でも、やるんだよな</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>9</Id>
      <BubbleId>1</BubbleId>
      <OldPtr>260748</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>274384</PointerOffset>
      <JapaneseText>なんでこそこそすんだよ。
