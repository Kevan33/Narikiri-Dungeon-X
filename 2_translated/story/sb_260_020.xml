    <Entry>
      <PointerOffset>273928</PointerOffset>
      <JapaneseText>おわっ！……っと、
びっくりした……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>4</Id>
      <BubbleId>1</BubbleId>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>274012</PointerOffset>
      <JapaneseText>&lt;Cless&gt;なんだよ、さんには
休憩しとけって言ってさ</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>6</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>274092</PointerOffset>
      <JapaneseText>練習しとかないと、
あいつに置いてかれるからな</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>7</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>274164</PointerOffset>
      <JapaneseText>&lt;Cless&gt;……あいつって、
さんのこと？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>8</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
