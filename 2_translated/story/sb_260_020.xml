    </Entry>
    <Entry>
      <PointerOffset>275160</PointerOffset>
      <JapaneseText>よし、いい返事だ！でも、この技は気合だけでは
できねーぜ？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>26</Id>
      <BubbleId>1</BubbleId>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>275208</PointerOffset>
      <JapaneseText>覚悟はしてるぜ</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>28</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>275256</PointerOffset>
      <JapaneseText>よし、行くぞ！</JapaneseText>
