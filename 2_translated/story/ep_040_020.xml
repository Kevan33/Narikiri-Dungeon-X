    <Entry>
      <PointerOffset>280728</PointerOffset>
      <VoiceId>&lt;audio:VSM_040_020_001&gt;</VoiceId>
      <JapaneseText>ここ、かな……？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>1</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>280800</PointerOffset>
      <VoiceId>&lt;audio:VSM_040_020_002&gt;</VoiceId>
      <JapaneseText>ごめんくださーい！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>2</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>280864</PointerOffset>
      <VoiceId>&lt;audio:VSM_040_020_003&gt;</VoiceId>
      <JapaneseText>留守か？？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>3</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>280932</PointerOffset>
      <VoiceId>&lt;audio:VSM_040_020_004&gt;</VoiceId>
      <JapaneseText>んん～？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>4</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>281076</PointerOffset>
      <VoiceId>&lt;audio:VSM_040_020_005&gt;</VoiceId>
      <JapaneseText></JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>5</Id>
      <BubbleId>0</BubbleId>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>281076</PointerOffset>
      <VoiceId>&lt;audio:VSM_040_020_006&gt;</VoiceId>
      <JapaneseText>なんで帰ってきたんだ、
おまえは……！……なんだ……
違うのか……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>5</Id>
      <BubbleId>1</BubbleId>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>281160</PointerOffset>
      <VoiceId>&lt;audio:VSM_040_020_007&gt;</VoiceId>
      <JapaneseText>&lt;Claus&gt;あなたが
さん、ですか？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>7</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>281284</PointerOffset>
      <VoiceId>&lt;audio:VSM_040_020_008&gt;</VoiceId>
      <JapaneseText></JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>4</SpeakerId>
      <Id>8</Id>
      <BubbleId>0</BubbleId>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>281284</PointerOffset>
      <VoiceId>&lt;audio:VSM_040_020_009&gt;</VoiceId>
      <JapaneseText>ん？　そうだが……なんだ、子どもが
私に何の用だ？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>4</SpeakerId>
      <Id>8</Id>
      <BubbleId>1</BubbleId>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>281396</PointerOffset>
      <VoiceId>&lt;audio:VSM_040_020_010&gt;</VoiceId>
      <JapaneseText>&lt;Claus&gt;実は魔術の暴走を止めるために
さんに
会いに来たんです</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>10</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>281504</PointerOffset>
      <VoiceId>&lt;audio:VSM_040_020_011&gt;</VoiceId>
      <JapaneseText>どこで私のことを
聞いたかは知らんが、
他をあたってくれ</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>5</SpeakerId>
      <Id>11</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>281604</PointerOffset>
      <VoiceId>&lt;audio:VSM_040_020_012&gt;</VoiceId>
      <JapaneseText>他って言っても、
わたしたち、他にあてなんて……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>12</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>281696</PointerOffset>
      <VoiceId>&lt;audio:VSM_040_020_013&gt;</VoiceId>
      <JapaneseText>もうやめたんだよ、
魔法とかそういうの</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>5</SpeakerId>
      <Id>13</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>281812</PointerOffset>
      <VoiceId>&lt;audio:VSM_040_020_014&gt;</VoiceId>
      <JapaneseText>ダオス倒した英雄が
こんなダメなおっさん？
昼間から酒飲んで……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>14</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>282064</PointerOffset>
      <VoiceId>&lt;audio:VSM_040_020_017&gt;</VoiceId>
      <JapaneseText>&lt;Claus&gt;残念だったな、
・Ｆ・レスターが、
こんな人間で</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>5</SpeakerId>
      <Id>15</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>282164</PointerOffset>
      <VoiceId>&lt;audio:VSM_040_020_018&gt;</VoiceId>
      <JapaneseText>わたしたち、どうしても、
精霊の力が必要なんです</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>16</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>282228</PointerOffset>
      <VoiceId>&lt;audio:VSM_040_020_019&gt;</VoiceId>
      <JapaneseText>精霊……？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>5</SpeakerId>
      <Id>17</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>282336</PointerOffset>
      <VoiceId>&lt;audio:VSM_040_020_020&gt;</VoiceId>
      <JapaneseText>はい、
精霊について聞きたいんです。
力を貸してください</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>18</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>282600</PointerOffset>
      <VoiceId>&lt;audio:VSM_040_020_021&gt;</VoiceId>
      <JapaneseText></JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>5</SpeakerId>
      <Id>19</Id>
      <BubbleId>0</BubbleId>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>282600</PointerOffset>
      <VoiceId>&lt;audio:VSM_040_020_022&gt;</VoiceId>
      <JapaneseText>&lt;Red&gt;&lt;White&gt;</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>5</SpeakerId>
      <Id>19</Id>
      <BubbleId>1</BubbleId>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>282600</PointerOffset>
      <VoiceId>&lt;audio:VSM_040_020_023&gt;</VoiceId>
      <JapaneseText>……よし。
だったら、条件があるここから東、フレイランドの
熱砂の洞窟に四大精霊の一体、
イフリートがいるヤツをここへ連れてこられたら、
言うことを聞いて
やらないこともない</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>5</SpeakerId>
      <Id>19</Id>
      <BubbleId>2</BubbleId>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>282676</PointerOffset>
      <VoiceId>&lt;audio:VSM_040_020_024&gt;</VoiceId>
      <JapaneseText>イフリート、ですか……？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>22</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>282764</PointerOffset>
      <VoiceId>&lt;audio:VSM_040_020_025&gt;</VoiceId>
      <JapaneseText>よーし、わかった。
連れてきてやる！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>23</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>282968</PointerOffset>
      <VoiceId>&lt;audio:VSM_040_020_026&gt;</VoiceId>
      <JapaneseText></JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>5</SpeakerId>
      <Id>24</Id>
      <BubbleId>0</BubbleId>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>282968</PointerOffset>
      <VoiceId>&lt;audio:VSM_040_020_027&gt;</VoiceId>
      <JapaneseText>ふん、気をつけろよ。
精霊って奴は人間の命なんて
露ほどにも思ってない中でもイフリートは、
粗暴な性格で有名だ。
丸焦げにされんようにな</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>5</SpeakerId>
      <Id>24</Id>
      <BubbleId>1</BubbleId>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>283060</PointerOffset>
      <VoiceId>&lt;audio:VSM_040_020_028&gt;</VoiceId>
      <JapaneseText>丸焦げって……
おっさん、それって……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>26</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>283160</PointerOffset>
      <VoiceId>&lt;audio:VSM_040_020_029&gt;</VoiceId>
      <JapaneseText>怖いなら、やめておけ。
そのほうが君たちのためだ</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>5</SpeakerId>
      <Id>27</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>283224</PointerOffset>
      <VoiceId>&lt;audio:VSM_040_020_030&gt;</VoiceId>
      <JapaneseText>&lt;Dio&gt;行こ、</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>28</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>283356</PointerOffset>
      <VoiceId>&lt;audio:VSM_040_020_031&gt;</VoiceId>
      <JapaneseText>&lt;Mel&gt;</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>29</Id>
      <BubbleId>0</BubbleId>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>283356</PointerOffset>
      <VoiceId>&lt;audio:VSM_040_020_032&gt;</VoiceId>
      <JapaneseText>え？　ちょっ、？絶対、連れてくっから！
そん時は頼むぜ！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>29</Id>
      <BubbleId>1</BubbleId>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>283416</PointerOffset>
      <VoiceId>&lt;audio:VSM_040_020_033&gt;</VoiceId>
      <JapaneseText>ふん……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>5</SpeakerId>
      <Id>31</Id>
      <Status>To Do</Status>
    </Entry>
