    <Entry>
      <PointerOffset>275632</PointerOffset>
      <VoiceId>&lt;audio:VSM_020_030_001&gt;</VoiceId>
      <JapaneseText>……見つからないね</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>1</Id>
      <OldPtr>258984</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>275720</PointerOffset>
      <VoiceId>&lt;audio:VSM_020_030_002&gt;</VoiceId>
      <JapaneseText>そんないないんだな、
困ってる人って</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>2</Id>
      <OldPtr>259196</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>275820</PointerOffset>
      <VoiceId>&lt;audio:VSM_020_030_003&gt;</VoiceId>
      <JapaneseText>でも、それって、
みんな幸せって
ことじゃないの？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>3</Id>
      <OldPtr>259392</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>275916</PointerOffset>
      <VoiceId>&lt;audio:VSM_020_030_004&gt;</VoiceId>
      <JapaneseText>そう簡単なことじゃあ、
ないと思うけド……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>4</Id>
      <OldPtr>259652</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>275984</PointerOffset>
      <VoiceId>&lt;audio:VSM_020_030_005&gt;</VoiceId>
      <JapaneseText>どういうこと？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>5</Id>
      <OldPtr>260116</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>276104</PointerOffset>
      <VoiceId>&lt;audio:VSM_020_030_006&gt;</VoiceId>
      <JapaneseText>きみたちみたいな子どもに、
いきなり困ってること
聞かれて話すと思う？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>6</Id>
      <OldPtr>260256</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>276168</PointerOffset>
      <VoiceId>&lt;audio:VSM_020_030_007&gt;</VoiceId>
      <JapaneseText>……そうだね</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>7</Id>
      <OldPtr>260516</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>276268</PointerOffset>
      <VoiceId>&lt;audio:VSM_020_030_008&gt;</VoiceId>
      <JapaneseText>んじゃあ、
オレら、何しに来たか、
わかんなくね？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>8</Id>
      <OldPtr>260656</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>276364</PointerOffset>
      <VoiceId>&lt;audio:VSM_020_030_009&gt;</VoiceId>
      <JapaneseText>きゃあっ！！　逃げて！
魔物よ！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>4</SpeakerId>
      <Id>9</Id>
      <OldPtr>261940</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>276428</PointerOffset>
      <VoiceId>&lt;audio:VSM_020_030_010&gt;</VoiceId>
      <JapaneseText>魔物……！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>10</Id>
      <OldPtr>264060</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>276496</PointerOffset>
      <VoiceId>&lt;audio:VSM_020_030_011&gt;</VoiceId>
      <JapaneseText>逃げないと……！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>11</Id>
      <OldPtr>264360</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>276560</PointerOffset>
      <VoiceId>&lt;audio:VSM_020_030_012&gt;</VoiceId>
      <JapaneseText>あ、&lt;Dio&gt;！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>12</Id>
      <OldPtr>264884</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>276628</PointerOffset>
      <VoiceId>&lt;audio:VSM_020_030_013&gt;</VoiceId>
      <JapaneseText>&lt;Mel&gt;も……！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>13</Id>
      <OldPtr>265444</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>276716</PointerOffset>
      <VoiceId>&lt;audio:VSM_020_030_014&gt;</VoiceId>
      <JapaneseText>&lt;Dio&gt;を止めなきゃ。
エトは逃げて！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>14</Id>
      <OldPtr>265688</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>276784</PointerOffset>
      <VoiceId>&lt;audio:VSM_020_030_015&gt;</VoiceId>
      <JapaneseText>……あ、もう……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>15</Id>
      <OldPtr>266036</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>276872</PointerOffset>
      <VoiceId>&lt;audio:VSM_020_030_016&gt;</VoiceId>
      <JapaneseText>でも、魔物が
どうして街の中に……？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>16</Id>
      <OldPtr>266456</OldPtr>
      <Status>To Do</Status>
    </Entry>
