    <Section>Main</Section>
    <Entry>
      <PointerOffset>292352</PointerOffset>
      <VoiceId>&lt;audio:VSM_220_070_001&gt;</VoiceId>
      <JapaneseText>オリジン！</JapaneseText>
      <EnglishText>Origin!</EnglishText>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>1</Id>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset>292492</PointerOffset>
      <VoiceId>&lt;audio:VSM_220_070_002&gt;</VoiceId>
      <JapaneseText>よくぞ来た</JapaneseText>
      <EnglishText>I expected your arrival.</EnglishText>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>2</Id>
      <BubbleId>0</BubbleId>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset>292492</PointerOffset>
      <VoiceId>&lt;audio:VSM_220_070_003&gt;</VoiceId>
      <JapaneseText>おまえたちがここへ来ることは
ある者から聞いて知っていた</JapaneseText>
      <EnglishText>It has informed me you would come
here to ask something of me.</EnglishText>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>2</Id>
      <BubbleId>1</BubbleId>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset>292552</PointerOffset>
      <VoiceId>&lt;audio:VSM_220_070_004&gt;</VoiceId>
      <JapaneseText>ある者？</JapaneseText>
      <EnglishText>..."It"?</EnglishText>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>4</Id>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset>292624</PointerOffset>
      <VoiceId>&lt;audio:VSM_220_070_005&gt;</VoiceId>
      <JapaneseText>だとすれば、話が早い</JapaneseText>
      <EnglishText>If that's the case, we'll be brief.</EnglishText>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>5</Id>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset>292772</PointerOffset>
      <VoiceId>&lt;audio:VSM_220_070_006&gt;</VoiceId>
      <JapaneseText>我が力を欲するならば、
おまえたち自身の力を示せ</JapaneseText>
      <EnglishText>If it is my power you seek, you
will have to prove your worth.</EnglishText>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>6</Id>
      <BubbleId>0</BubbleId>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset>292772</PointerOffset>
      <VoiceId>&lt;audio:VSM_220_070_007&gt;</VoiceId>
      <JapaneseText>それが汝らに
与えられた試練</JapaneseText>
      <EnglishText>You can think of it as my trial. </EnglishText>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>6</Id>
      <BubbleId>1</BubbleId>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset>292844</PointerOffset>
      <VoiceId>&lt;audio:VSM_220_070_008&gt;</VoiceId>
      <JapaneseText>やっぱ戦うんだな……</JapaneseText>
      <EnglishText>I knew it, another fight...</EnglishText>
      <Notes/>
      <SpeakerId>4</SpeakerId>
      <Id>8</Id>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset>292908</PointerOffset>
      <VoiceId>&lt;audio:VSM_220_070_009&gt;</VoiceId>
      <JapaneseText>怖いか？</JapaneseText>
      <EnglishText>Is that a reaction of fear?</EnglishText>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>9</Id>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset>293000</PointerOffset>
      <VoiceId>&lt;audio:VSM_220_070_010&gt;</VoiceId>
      <JapaneseText>ううん……
ここまでたくさん戦ってきた</JapaneseText>
      <EnglishText>No, that's not it...We've fought too hard
to come this far and back down.</EnglishText>
      <Notes/>
      <SpeakerId>5</SpeakerId>
      <Id>10</Id>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset>293080</PointerOffset>
      <VoiceId>&lt;audio:VSM_220_070_011&gt;</VoiceId>
      <JapaneseText>だな。コワくなんてねーよな</JapaneseText>
      <EnglishText>Right. I'm not scared anymore.</EnglishText>
      <Notes/>
      <SpeakerId>4</SpeakerId>
      <Id>11</Id>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset>293144</PointerOffset>
      <VoiceId>&lt;audio:VSM_220_070_012&gt;</VoiceId>
      <JapaneseText>クルール！</JapaneseText>
      <EnglishText>Kuruuruu!</EnglishText>
      <Notes/>
      <SpeakerId>6</SpeakerId>
      <Id>12</Id>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset>293212</PointerOffset>
      <VoiceId>&lt;audio:VSM_220_070_013&gt;</VoiceId>
      <JapaneseText>ならば、来い</JapaneseText>
      <EnglishText>In that case...Come!</EnglishText>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>13</Id>
      <Status>Proofreading</Status>
    </Entry>
