    <Entry>
      <PointerOffset>280940</PointerOffset>
      <VoiceId>&lt;audio:VSM_110_050_000&gt;</VoiceId>
      <JapaneseText>&lt;Cless&gt;さんが帰ってくるまで
待ってみるか……？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>1</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>281040</PointerOffset>
      <VoiceId>&lt;audio:VSM_110_050_001&gt;</VoiceId>
      <JapaneseText>……いや、あの教会の列に
並んだ方がいいかな……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>2</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>281140</PointerOffset>
      <VoiceId>&lt;audio:VSM_110_050_002&gt;</VoiceId>
      <JapaneseText>ねぇ……
マクスウェルの話、
先になんとかしない？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>3</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>281204</PointerOffset>
      <VoiceId>&lt;audio:VSM_110_050_003&gt;</VoiceId>
      <JapaneseText>う～ん……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>4</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>281268</PointerOffset>
      <VoiceId>&lt;audio:VSM_110_050_004&gt;</VoiceId>
      <JapaneseText>……え……？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>5</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>281332</PointerOffset>
      <VoiceId>&lt;audio:VSM_110_050_005&gt;</VoiceId>
      <JapaneseText>いいよ、もう</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>6</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>281408</PointerOffset>
      <VoiceId>&lt;audio:VSM_110_050_006&gt;</VoiceId>
      <JapaneseText>なんだよ、言えよ……！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>7</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>281588</PointerOffset>
      <VoiceId>&lt;audio:VSM_110_050_007&gt;</VoiceId>
      <JapaneseText></JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>8</Id>
      <BubbleId>0</BubbleId>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>281588</PointerOffset>
      <VoiceId>&lt;audio:VSM_110_050_008&gt;</VoiceId>
      <JapaneseText>時空戦士に会うのなんて、
後でもいいでしょ？わたしたちが優先しなきゃ
いけないのは、
マクスウェルの方なんだよ？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>8</Id>
      <BubbleId>1</BubbleId>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>281724</PointerOffset>
      <VoiceId>&lt;audio:VSM_110_050_009&gt;</VoiceId>
      <JapaneseText></JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>10</Id>
      <BubbleId>0</BubbleId>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>281724</PointerOffset>
      <VoiceId>&lt;audio:VSM_110_050_010&gt;</VoiceId>
      <JapaneseText>どっちが優先とかあんのかよ！？オレら、
ダオスに命狙われたのに！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>10</Id>
      <BubbleId>1</BubbleId>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>281816</PointerOffset>
      <VoiceId>&lt;audio:VSM_110_050_011&gt;</VoiceId>
      <JapaneseText>それだって、
魔術の暴走が
原因なんだよ？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>12</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>281900</PointerOffset>
      <VoiceId>&lt;audio:VSM_110_050_012&gt;</VoiceId>
      <JapaneseText>なんで、そんな
断言できんだよ！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>13</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>282000</PointerOffset>
      <VoiceId>&lt;audio:VSM_110_050_013&gt;</VoiceId>
      <JapaneseText>コラコラ、
ケンカするなよ、
こんなところで</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>14</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>282072</PointerOffset>
      <VoiceId>&lt;audio:VSM_110_050_014&gt;</VoiceId>
      <JapaneseText>な、なんだよ、あんた</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>15</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>282180</PointerOffset>
      <VoiceId>&lt;audio:VSM_110_050_015&gt;</VoiceId>
      <JapaneseText>おまえたち子どもだけか？
親父さんとおふくろさんは？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>16</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>282252</PointerOffset>
      <VoiceId>&lt;audio:VSM_110_050_016&gt;</VoiceId>
      <JapaneseText>それは……えっと……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>17</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>282332</PointerOffset>
      <VoiceId>&lt;audio:VSM_110_050_017&gt;</VoiceId>
      <JapaneseText>おお！　なんだ、コイツ？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>18</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>282432</PointerOffset>
      <VoiceId>&lt;audio:VSM_110_050_018&gt;</VoiceId>
      <JapaneseText>ぼくは妖精のエトス。
この子たちの親代わりなんだ</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>4</SpeakerId>
      <Id>19</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>282508</PointerOffset>
      <VoiceId>&lt;audio:VSM_110_050_019&gt;</VoiceId>
      <JapaneseText>ふぅーん？　妖精？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>20</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>282692</PointerOffset>
      <VoiceId>&lt;audio:VSM_110_050_020&gt;</VoiceId>
      <JapaneseText></JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>21</Id>
      <BubbleId>0</BubbleId>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>282692</PointerOffset>
      <VoiceId>&lt;audio:VSM_110_050_021&gt;</VoiceId>
      <JapaneseText></JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>21</Id>
      <BubbleId>1</BubbleId>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>282692</PointerOffset>
      <VoiceId>&lt;audio:VSM_110_050_022&gt;</VoiceId>
      <JapaneseText>……っていうか、
親代わりだって！？へぇ……
なんかすげぇな……で？　何を
もめてたんだ？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>21</Id>
      <BubbleId>2</BubbleId>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>282780</PointerOffset>
      <VoiceId>&lt;audio:VSM_110_050_023&gt;</VoiceId>
      <JapaneseText>&lt;Cless&gt;オレら、さんに
会いに来たんだ</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>24</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>282908</PointerOffset>
      <VoiceId>&lt;audio:VSM_110_050_024&gt;</VoiceId>
      <JapaneseText>&lt;Cless&gt;&lt;Red&gt;&lt;White&gt;に？　そうか、悪いな。
あいつ、今、
ヴァルハラに行ってて……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>25</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>283052</PointerOffset>
      <VoiceId>&lt;audio:VSM_110_050_025&gt;</VoiceId>
      <JapaneseText></JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>26</Id>
      <BubbleId>0</BubbleId>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>283052</PointerOffset>
      <VoiceId>&lt;audio:VSM_110_050_026&gt;</VoiceId>
      <JapaneseText>はい、それは聞きましたそれでこれから
どうしようかで
意見が合わなくて……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>26</Id>
      <BubbleId>1</BubbleId>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>283132</PointerOffset>
      <VoiceId>&lt;audio:VSM_110_050_027&gt;</VoiceId>
      <JapaneseText>ケンカしてたってわけか</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>28</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>283236</PointerOffset>
      <VoiceId>&lt;audio:VSM_110_050_028&gt;</VoiceId>
      <JapaneseText></JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>29</Id>
      <BubbleId>0</BubbleId>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>283236</PointerOffset>
      <VoiceId>&lt;audio:VSM_110_050_029&gt;</VoiceId>
      <JapaneseText>&lt;Mint&gt;うん……さんにも
会えないし</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>29</Id>
      <BubbleId>1</BubbleId>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>283388</PointerOffset>
      <VoiceId>&lt;audio:VSM_110_050_030&gt;</VoiceId>
      <JapaneseText>&lt;Mint&gt;</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>31</Id>
      <BubbleId>0</BubbleId>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>283388</PointerOffset>
      <VoiceId>&lt;audio:VSM_110_050_031&gt;</VoiceId>
      <JapaneseText>ああ、も忙しいしなぁしょうがねえな。
オレでよければ、
話聞いてやるぜ</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>31</Id>
      <BubbleId>1</BubbleId>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>283456</PointerOffset>
      <VoiceId>&lt;audio:VSM_110_050_032&gt;</VoiceId>
      <JapaneseText>え？　でも……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>33</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>283568</PointerOffset>
      <VoiceId>&lt;audio:VSM_110_050_033&gt;</VoiceId>
      <JapaneseText>まあ、立ち話もなんだから、
うちに来いよ。この近くなんだ</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>34</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>283736</PointerOffset>
      <VoiceId>&lt;audio:VSM_110_050_035&gt;</VoiceId>
      <JapaneseText>ついてっても、
だいじょぶかな？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>35</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>283808</PointerOffset>
      <VoiceId>&lt;audio:VSM_110_050_036&gt;</VoiceId>
      <JapaneseText>危ない人とかじゃ……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>4</SpeakerId>
      <Id>36</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>283904</PointerOffset>
      <VoiceId>&lt;audio:VSM_110_050_037&gt;</VoiceId>
      <JapaneseText>……うーん、
悪い人じゃない感じは
するけど</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>37</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>284068</PointerOffset>
      <VoiceId>&lt;audio:VSM_110_050_038&gt;</VoiceId>
      <JapaneseText></JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>38</Id>
      <BubbleId>0</BubbleId>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>284068</PointerOffset>
      <VoiceId>&lt;audio:VSM_110_050_039&gt;</VoiceId>
      <JapaneseText></JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>38</Id>
      <BubbleId>1</BubbleId>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>284068</PointerOffset>
      <VoiceId>&lt;audio:VSM_110_050_040&gt;</VoiceId>
      <JapaneseText>聞こえてるぜ初対面で信用しろ
ってのもなんだしなま、好きにすればいいさ</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>38</Id>
      <BubbleId>2</BubbleId>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>284132</PointerOffset>
      <VoiceId>&lt;audio:VSM_110_050_041&gt;</VoiceId>
      <JapaneseText>どうする？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>41</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>284212</PointerOffset>
      <VoiceId>&lt;audio:VSM_110_050_042&gt;</VoiceId>
      <JapaneseText>行こう。
いいよね、エト？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>42</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>284292</PointerOffset>
      <VoiceId>&lt;audio:VSM_110_050_043&gt;</VoiceId>
      <JapaneseText>いいけど……
気をつけてよ</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>4</SpeakerId>
      <Id>43</Id>
      <Status>To Do</Status>
    </Entry>
