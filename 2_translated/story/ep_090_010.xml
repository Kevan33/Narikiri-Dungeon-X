    <Entry>
      <PointerOffset>282780</PointerOffset>
      <VoiceId>&lt;audio:VSM_090_010_008&gt;</VoiceId>
      <JapaneseText>そういうもん、なの？</JapaneseText>
      <EnglishText/>
