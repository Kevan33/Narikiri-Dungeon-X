    <Entry>
      <PointerOffset>275012</PointerOffset>
      <VoiceId>&lt;audio:VSM_180_010_001&gt;</VoiceId>
      <JapaneseText>すげー、かっこよすぎ……！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>1</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>275320</PointerOffset>
      <VoiceId>&lt;audio:VSM_180_010_004&gt;</VoiceId>
      <JapaneseText>&lt;Red&gt;&lt;White&gt;</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>2</Id>
      <BubbleId>0</BubbleId>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>275320</PointerOffset>
      <VoiceId>&lt;audio:VSM_180_010_005&gt;</VoiceId>
      <JapaneseText>超古代都市トールだこの街の
マザーコンピューターシステムに
時間転移の機能があるんだ</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>2</Id>
      <BubbleId>1</BubbleId>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>275392</PointerOffset>
      <VoiceId>&lt;audio:VSM_180_010_006&gt;</VoiceId>
      <JapaneseText>ルー……クルール？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>4</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>275484</PointerOffset>
      <VoiceId>&lt;audio:VSM_180_010_007&gt;</VoiceId>
      <JapaneseText>ま、百聞は一見にしかず、だ。
行こうぜ</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>4</SpeakerId>
      <Id>5</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>275584</PointerOffset>
      <VoiceId>&lt;audio:VSM_180_010_008&gt;</VoiceId>
      <JapaneseText>ねぇ、エト。このまま、
戻っちゃってもいいの？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>5</SpeakerId>
      <Id>6</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>275760</PointerOffset>
      <VoiceId>&lt;audio:VSM_180_010_010&gt;</VoiceId>
      <JapaneseText>本当はまだ自分が何者か、
ひっかかってるんじゃない？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>5</SpeakerId>
      <Id>7</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>276196</PointerOffset>
      <VoiceId>&lt;audio:VSM_180_010_015&gt;</VoiceId>
      <JapaneseText>&lt;Dio&gt;</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>6</SpeakerId>
      <Id>8</Id>
      <BubbleId>0</BubbleId>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>276196</PointerOffset>
      <VoiceId>&lt;audio:VSM_180_010_016&gt;</VoiceId>
      <JapaneseText>前にが
言ってたでしょ別にぼくが妖精でも何でも、
何も変わらないって</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>6</SpeakerId>
      <Id>8</Id>
      <BubbleId>1</BubbleId>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>276276</PointerOffset>
      <VoiceId>&lt;audio:VSM_180_010_017&gt;</VoiceId>
      <JapaneseText>そんなことオレ、
言ったか？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>10</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>276340</PointerOffset>
      <VoiceId>&lt;audio:VSM_180_010_018&gt;</VoiceId>
      <JapaneseText>言ったよ？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>6</SpeakerId>
      <Id>11</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>276592</PointerOffset>
      <VoiceId>&lt;audio:VSM_180_010_021&gt;</VoiceId>
      <JapaneseText>&lt;Red&gt;&lt;White&gt;ヴァルハラ町のことが
決着ついたら、エトのこと
調べる、わたし</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>5</SpeakerId>
      <Id>12</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>276692</PointerOffset>
      <VoiceId>&lt;audio:VSM_180_010_022&gt;</VoiceId>
      <JapaneseText>え……あ、いや、
別にそんなの……
……ほんとに？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>6</SpeakerId>
      <Id>13</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>276784</PointerOffset>
      <VoiceId>&lt;audio:VSM_180_010_023&gt;</VoiceId>
      <JapaneseText>エトには、
いつも明るくいて
ほしいから</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>5</SpeakerId>
      <Id>14</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>276856</PointerOffset>
      <VoiceId>&lt;audio:VSM_180_010_024&gt;</VoiceId>
      <JapaneseText>&lt;Mel&gt;ありがとう、</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>6</SpeakerId>
      <Id>15</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>276964</PointerOffset>
      <VoiceId>&lt;audio:VSM_180_010_025&gt;</VoiceId>
      <JapaneseText>っし！　早くこっちのカタつけて、
戻ろうぜ、元の時代に</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>16</Id>
      <Status>To Do</Status>
    </Entry>
