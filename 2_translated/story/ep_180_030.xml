    <Entry>
      <PointerOffset>272680</PointerOffset>
      <VoiceId>&lt;audio:VSM_180_030_001&gt;</VoiceId>
      <JapaneseText>わっ、んだよ……巨像？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>1</Id>
      <OldPtr>259504</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>272756</PointerOffset>
      <VoiceId>&lt;audio:VSM_180_030_002&gt;</VoiceId>
      <JapaneseText>気をつけて。あれは魔物だ</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>2</Id>
      <OldPtr>261196</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>272824</PointerOffset>
      <VoiceId>&lt;audio:VSM_180_030_003&gt;</VoiceId>
      <JapaneseText>そーなのか……？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>3</Id>
      <OldPtr>261632</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>272908</PointerOffset>
      <VoiceId>&lt;audio:VSM_180_030_004&gt;</VoiceId>
      <JapaneseText>ちょ、ちょっと
&lt;Rody&gt;……！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>4</Id>
      <OldPtr>262044</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>273004</PointerOffset>
      <VoiceId>&lt;audio:VSM_180_030_005&gt;</VoiceId>
      <JapaneseText>君はそこで
お姉さんの妙技に
見惚れてなさい</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>5</Id>
      <OldPtr>262368</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>273092</PointerOffset>
      <VoiceId>&lt;audio:VSM_180_030_006&gt;</VoiceId>
      <JapaneseText>っと……待てよ、
オレもやるって！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>6</Id>
      <OldPtr>263048</OldPtr>
      <Status>To Do</Status>
