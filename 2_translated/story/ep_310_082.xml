    <Entry>
      <PointerOffset>301880</PointerOffset>
      <VoiceId>&lt;audio:VSM_310_080_020&gt;</VoiceId>
      <JapaneseText>ディオスは……
いや……オレらはずっと
思ってたんだダオスがもっと、
しっかりしていれば、
戦争は起きなかったって</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>2</Id>
      <BubbleId>2</BubbleId>
      <Status>To Do</Status>
    </Entry>
