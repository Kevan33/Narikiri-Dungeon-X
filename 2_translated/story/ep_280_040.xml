    <Entry>
      <PointerOffset>276092</PointerOffset>
      <VoiceId>&lt;audio:VSM_280_040_001&gt;</VoiceId>
      <JapaneseText>将軍！　停戦の手続きを！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>1</Id>
      <OldPtr>258252</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>276160</PointerOffset>
      <VoiceId>&lt;audio:VSM_280_040_002&gt;</VoiceId>
      <JapaneseText>停戦はない</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>2</Id>
      <OldPtr>258448</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>276228</PointerOffset>
      <VoiceId>&lt;audio:VSM_280_040_003&gt;</VoiceId>
      <JapaneseText>しかし……！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>3</Id>
      <OldPtr>258588</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>276388</PointerOffset>
      <VoiceId>&lt;audio:VSM_280_040_004&gt;</VoiceId>
      <JapaneseText>そんなことをすれば、
我が領土は奴らに蹂躙される</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>4</Id>
      <BubbleId>0</BubbleId>
      <OldPtr>258920</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>276388</PointerOffset>
      <VoiceId>&lt;audio:VSM_280_040_005&gt;</VoiceId>
      <JapaneseText>そんなことは
わかっているはずだろう</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>4</Id>
      <BubbleId>1</BubbleId>
      <OldPtr>258920</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>276572</PointerOffset>
      <VoiceId>&lt;audio:VSM_280_040_006&gt;</VoiceId>
      <JapaneseText>しかし、近隣の国々にも
戦禍が飛び火しています</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>6</Id>
      <BubbleId>0</BubbleId>
      <OldPtr>259100</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>276572</PointerOffset>
      <VoiceId>&lt;audio:VSM_280_040_007&gt;</VoiceId>
      <JapaneseText>エリュシオンのダオスからも、
直ちに停戦せよとの要請が
ありました</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>6</Id>
      <BubbleId>1</BubbleId>
      <OldPtr>259100</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>276640</PointerOffset>
      <VoiceId>&lt;audio:VSM_280_040_008&gt;</VoiceId>
      <JapaneseText>あれを使え</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>8</Id>
      <OldPtr>259388</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>276712</PointerOffset>
      <VoiceId>&lt;audio:VSM_280_040_009&gt;</VoiceId>
      <JapaneseText>……あれとはまさか</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>9</Id>
      <OldPtr>259656</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>276776</PointerOffset>
      <VoiceId>&lt;audio:VSM_280_040_010&gt;</VoiceId>
      <JapaneseText>そうだ</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>10</Id>
      <OldPtr>259796</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>276860</PointerOffset>
      <VoiceId>&lt;audio:VSM_280_040_011&gt;</VoiceId>
      <JapaneseText>待ってください！
あれは……！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>11</Id>
      <OldPtr>260140</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>276956</PointerOffset>
      <VoiceId>&lt;audio:VSM_280_040_012&gt;</VoiceId>
      <JapaneseText>そんな悠長なことを
言っている場合か？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>12</Id>
      <OldPtr>260336</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>277088</PointerOffset>
      <VoiceId>&lt;audio:VSM_280_040_013&gt;</VoiceId>
      <JapaneseText>しかし、閣下のおっしゃっていた
デリス・カーラーンの
平和はどうなるのですか？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>13</Id>
      <OldPtr>260732</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>277216</PointerOffset>
      <VoiceId>&lt;audio:VSM_280_040_014&gt;</VoiceId>
      <JapaneseText>ここで降伏すれば、
我々にはその平和を享受する
権利すら与えられない！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>14</Id>
      <OldPtr>261068</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>277284</PointerOffset>
      <VoiceId>&lt;audio:VSM_280_040_015&gt;</VoiceId>
      <JapaneseText>ですが……！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>15</Id>
      <OldPtr>261356</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>277548</PointerOffset>
      <VoiceId>&lt;audio:VSM_280_040_016&gt;</VoiceId>
      <JapaneseText>口答えできる立場か！
私は身寄りのない
おまえたちを育ててやった！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>16</Id>
      <BubbleId>0</BubbleId>
      <OldPtr>261552</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>277548</PointerOffset>
      <VoiceId>&lt;audio:VSM_280_040_017&gt;</VoiceId>
      <JapaneseText>今こそ、
その恩に報いる時では
ないのか！？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>16</Id>
      <BubbleId>1</BubbleId>
      <OldPtr>261552</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>277548</PointerOffset>
      <VoiceId>&lt;audio:VSM_280_040_018&gt;</VoiceId>
      <JapaneseText>今すぐ行け。
&lt;Red&gt;ロキ魔科学研究窟&lt;White&gt;へ。
メルティアがそこにいる</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>16</Id>
      <BubbleId>2</BubbleId>
      <OldPtr>261552</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>277620</PointerOffset>
      <VoiceId>&lt;audio:VSM_280_040_019&gt;</VoiceId>
      <JapaneseText>ぐわあっ！！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>19</Id>
      <OldPtr>264268</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>277708</PointerOffset>
      <VoiceId>&lt;audio:VSM_280_040_020&gt;</VoiceId>
      <JapaneseText>閣下、大丈夫ですか！？
閣下……！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>20</Id>
      <OldPtr>265332</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>277872</PointerOffset>
      <VoiceId>&lt;audio:VSM_280_040_021&gt;</VoiceId>
      <JapaneseText>閣下……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>21</Id>
      <BubbleId>0</BubbleId>
      <OldPtr>265716</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>277872</PointerOffset>
      <VoiceId>&lt;audio:VSM_280_040_022&gt;</VoiceId>
      <JapaneseText>……父上！？
返事をしてください！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>21</Id>
      <BubbleId>1</BubbleId>
      <OldPtr>265716</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>277872</PointerOffset>
      <VoiceId>&lt;audio:VSM_280_040_023&gt;</VoiceId>
      <JapaneseText>どこにいるんですか！？
父上！！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>21</Id>
      <BubbleId>2</BubbleId>
      <OldPtr>265716</OldPtr>
      <Status>To Do</Status>
    </Entry>
