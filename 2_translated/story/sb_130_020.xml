    <Entry>
      <PointerOffset>276296</PointerOffset>
      <JapaneseText>お待たせです！
え……と、黒い人ー！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>1</Id>
      <OldPtr>258592</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>276388</PointerOffset>
      <JapaneseText>おおっ！　待っていたよ！
で、どうかね？いけそうかね？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>2</Id>
      <OldPtr>258732</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>276448</PointerOffset>
      <JapaneseText>ちょっと待っててください</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>3</Id>
      <OldPtr>258976</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>276496</PointerOffset>
      <JapaneseText>よしっ……と</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>4</Id>
      <OldPtr>259116</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>276572</PointerOffset>
      <JapaneseText>うおっ！
……君、本当に転移できるんだね</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>5</Id>
      <OldPtr>260156</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>276656</PointerOffset>
      <JapaneseText>うわっ！　狭い！
……そちらも本当に、
真っ黒ですね</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>6</Id>
      <OldPtr>260296</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>276760</PointerOffset>
      <JapaneseText>そ、そうかね？
と、ところで狭いので、
早くしてもらえると助かるのだが</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>7</Id>
      <OldPtr>260436</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>276932</PointerOffset>
      <JapaneseText>そうですね。
しかし、別の世界なんて
うまくいくのかな？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>8</Id>
      <BubbleId>0</BubbleId>
      <OldPtr>260576</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>276932</PointerOffset>
      <JapaneseText>まあ、とりあえず……
すみません、あなたの世界を
イメージして、これを握ってください</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>8</Id>
      <BubbleId>1</BubbleId>
      <OldPtr>260576</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>276980</PointerOffset>
      <JapaneseText>こう、かね？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>10</Id>
      <OldPtr>260716</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>277056</PointerOffset>
      <JapaneseText>……！
そ、そこじゃないです。
この剣です</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>11</Id>
      <OldPtr>260856</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>277152</PointerOffset>
      <JapaneseText>い、いや、すまない。
わたしとしたことが。
では、こう、かね？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>12</Id>
      <OldPtr>260996</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>277212</PointerOffset>
      <JapaneseText>……行きますよ。
むんっ！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>13</Id>
      <OldPtr>261136</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>277264</PointerOffset>
      <JapaneseText>……………………</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>4</SpeakerId>
      <Id>14</Id>
      <OldPtr>261472</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>277316</PointerOffset>
      <JapaneseText>……………………</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>15</Id>
      <OldPtr>261648</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>277360</PointerOffset>
      <JapaneseText>ただいま</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>16</Id>
      <OldPtr>262540</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>277412</PointerOffset>
      <JapaneseText>び、びっくりした！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>4</SpeakerId>
      <Id>17</Id>
      <OldPtr>263100</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>277516</PointerOffset>
      <JapaneseText>もうっ！　後ろに現れるなら
そうと言ってください</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>18</Id>
      <BubbleId>0</BubbleId>
      <OldPtr>263240</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>277516</PointerOffset>
      <JapaneseText>……で、どうでした？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>18</Id>
      <BubbleId>1</BubbleId>
      <OldPtr>263240</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>277644</PointerOffset>
      <JapaneseText>うん、何とかうまく行ったよ。
別の世界がイメージできないから、
普段じゃムリなんだろうけど、ね</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>20</Id>
      <OldPtr>263380</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>277696</PointerOffset>
      <JapaneseText>そうか、よかった～</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>4</SpeakerId>
      <Id>21</Id>
      <OldPtr>263576</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>277780</PointerOffset>
      <JapaneseText>すみません。&lt;Cless&gt;さん。
手伝ってもらっちゃって</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>22</Id>
      <OldPtr>263772</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>277868</PointerOffset>
      <JapaneseText>ああ、そうそう。
社長さんから、
&lt;Mel&gt;ちゃんにお礼だよ</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>23</Id>
      <OldPtr>263912</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>278048</PointerOffset>
      <JapaneseText>社長さん？　私に？
ああ、あの人どこかの
社長さんだったんですか</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>24</Id>
      <BubbleId>0</BubbleId>
      <OldPtr>264052</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>278048</PointerOffset>
      <JapaneseText>でも、お礼だなんて。
わたし今回何もしてないのに。
それなら&lt;Cless&gt;さんのほうが……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>24</Id>
      <BubbleId>1</BubbleId>
      <OldPtr>264052</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>278164</PointerOffset>
      <JapaneseText>あ、ああ、いや。ぼ、僕のほうは
いいんだ。それに、女の子用の
ステージ衣装みたいだし</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>26</Id>
      <OldPtr>264248</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>278228</PointerOffset>
      <JapaneseText>すみません。
じゃあ、遠慮なく</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>27</Id>
      <OldPtr>264388</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>278316</PointerOffset>
      <JapaneseText>ステージ衣装って、
あの人、何の社長さんだったんだ？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>4</SpeakerId>
      <Id>28</Id>
      <OldPtr>264528</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>278436</PointerOffset>
      <JapaneseText>それはパーフェクトに
ワンダリングなミッシングだから
勝手に触んな、このハゲぼうず！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>5</SpeakerId>
      <Id>29</Id>
      <OldPtr>265492</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>278636</PointerOffset>
      <JapaneseText>しっかし、パンスト野郎よぉ、
おめぇ、もしやお礼にとか言って
ライブに行って来ただな？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>5</SpeakerId>
      <Id>30</Id>
      <BubbleId>0</BubbleId>
      <OldPtr>265792</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>278636</PointerOffset>
      <JapaneseText>まんず、チケットが取れねぇ
プレミアーンなライブによ？
あ？　あ？　そうだべ？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>5</SpeakerId>
      <Id>30</Id>
      <BubbleId>1</BubbleId>
      <OldPtr>265792</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>278740</PointerOffset>
      <JapaneseText>え！？
いや……そ、そんな？　そもそも、
すぐに帰ってきたじゃないか！？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>32</Id>
      <OldPtr>266232</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>278960</PointerOffset>
      <JapaneseText>ふん！　時空転移使っただ！
んなもん幾らでもごまかせるべ！
おめぇなら、やりかねんだーよ！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>5</SpeakerId>
      <Id>33</Id>
      <BubbleId>0</BubbleId>
      <OldPtr>266372</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>278960</PointerOffset>
      <JapaneseText>あーあ、自分だけずるいんだ～！
おらも、おらも行きたかったな！
ふたごちゃんを応援したいだ！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>5</SpeakerId>
      <Id>33</Id>
      <BubbleId>1</BubbleId>
      <OldPtr>266372</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>279056</PointerOffset>
      <JapaneseText>そうなのかい？
ぼくはどっちかっていうと
あずささんのほうが……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>35</Id>
      <OldPtr>266512</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>279108</PointerOffset>
      <JapaneseText>何の話？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>6</SpeakerId>
      <Id>36</Id>
      <OldPtr>266764</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>279168</PointerOffset>
      <JapaneseText>なんでもない！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>7</SpeakerId>
      <Id>37</Id>
      <OldPtr>267224</OldPtr>
      <Status>To Do</Status>
    </Entry>
