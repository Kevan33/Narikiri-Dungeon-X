    <Section>Main</Section>
    <Entry>
      <PointerOffset>275272</PointerOffset>
      <VoiceId>&lt;audio:VSM_160_020_001&gt;</VoiceId>
      <JapaneseText>止まれ！　ブレイナー！</JapaneseText>
      <EnglishText>Hold it! Brainer!</EnglishText>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>1</Id>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset>275360</PointerOffset>
      <VoiceId>&lt;audio:VSM_160_020_002&gt;</VoiceId>
      <JapaneseText>バジルさん！
バジルさんなのか！？</JapaneseText>
      <EnglishText>Mister Basil! Mister Basil, is that you!?</EnglishText>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>2</Id>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset>275528</PointerOffset>
      <VoiceId>&lt;audio:VSM_160_020_003Z&gt;</VoiceId>
      <JapaneseText>ばれたら、仕方がない。
久しぶりだな</JapaneseText>
      <EnglishText>No use hiding it anymore.
Long time no see, &lt;Dio&gt;.</EnglishText>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>3</Id>
      <BubbleId>0</BubbleId>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset>275528</PointerOffset>
      <VoiceId>&lt;audio:VSM_160_020_004Z&gt;</VoiceId>
      <JapaneseText>しかし君たち、
全く歳をとらないな。
エルフでもないのに……</JapaneseText>
      <EnglishText>But, you guys look the same after all
this time. You aren't elves either...</EnglishText>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>3</Id>
      <BubbleId>1</BubbleId>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset>275632</PointerOffset>
      <VoiceId>&lt;audio:VSM_160_020_005&gt;</VoiceId>
      <JapaneseText>……どうして……！
なんでこんなこと
してるんだよ！？</JapaneseText>
      <EnglishText>...Why are you doing this!?
What could possibly drive
you to do this!?</EnglishText>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>5</Id>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset>275728</PointerOffset>
      <VoiceId>&lt;audio:VSM_160_020_006Z&gt;</VoiceId>
      <JapaneseText>どうしてだって？
アハハ、僕にもわからないよ</JapaneseText>
      <EnglishText>Why you ask? Hahaha! Not
even I know for sure, myself.</EnglishText>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>6</Id>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset>275792</PointerOffset>
      <VoiceId>&lt;audio:VSM_160_020_007&gt;</VoiceId>
      <JapaneseText>ふざけるな！</JapaneseText>
      <EnglishText>Don't mess with us!</EnglishText>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>7</Id>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset>275872</PointerOffset>
      <VoiceId>&lt;audio:VSM_160_020_008Z&gt;</VoiceId>
      <JapaneseText>ふざけてるのは
どっちだ！</JapaneseText>
      <EnglishText>YOU should cut the crap!</EnglishText>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>8</Id>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset>275980</PointerOffset>
      <VoiceId>&lt;audio:VSM_160_020_009Z&gt;</VoiceId>
      <JapaneseText>僕の大切なものを
すべて踏みにじったのは
おまえたちだ！</JapaneseText>
      <EnglishText>You're the ones who destroyed
everything I hold dear!</EnglishText>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>9</Id>
      <Status>Proofreading</Status>
    </Entry>
  </Strings>
