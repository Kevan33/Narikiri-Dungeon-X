    <Entry>
      <PointerOffset>275272</PointerOffset>
      <VoiceId>&lt;audio:VSM_160_020_001&gt;</VoiceId>
      <JapaneseText>止まれ！　ブレイナー！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>1</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>275360</PointerOffset>
      <VoiceId>&lt;audio:VSM_160_020_002&gt;</VoiceId>
      <JapaneseText>バジルさん！
バジルさんなのか！？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>2</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>275528</PointerOffset>
      <VoiceId>&lt;audio:VSM_160_020_003Z&gt;</VoiceId>
      <JapaneseText></JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>3</Id>
      <BubbleId>0</BubbleId>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>275528</PointerOffset>
      <VoiceId>&lt;audio:VSM_160_020_004Z&gt;</VoiceId>
      <JapaneseText>ばれたら、仕方がない。
久しぶりだなしかし君たち、
全く歳をとらないな。
エルフでもないのに……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>3</Id>
      <BubbleId>1</BubbleId>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>275632</PointerOffset>
      <VoiceId>&lt;audio:VSM_160_020_005&gt;</VoiceId>
      <JapaneseText>……どうして……！
なんでこんなこと
してるんだよ！？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>5</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>275728</PointerOffset>
      <VoiceId>&lt;audio:VSM_160_020_006Z&gt;</VoiceId>
      <JapaneseText>どうしてだって？
アハハ、僕にもわからないよ</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>6</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>275792</PointerOffset>
      <VoiceId>&lt;audio:VSM_160_020_007&gt;</VoiceId>
      <JapaneseText>ふざけるな！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>7</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>275872</PointerOffset>
      <VoiceId>&lt;audio:VSM_160_020_008Z&gt;</VoiceId>
      <JapaneseText>ふざけてるのは
どっちだ！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>8</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>275980</PointerOffset>
      <VoiceId>&lt;audio:VSM_160_020_009Z&gt;</VoiceId>
      <JapaneseText>僕の大切なものを
すべて踏みにじったのは
おまえたちだ！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>9</Id>
      <Status>To Do</Status>
    </Entry>
