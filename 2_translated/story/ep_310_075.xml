    <Entry>
      <PointerOffset>298500</PointerOffset>
      <VoiceId>&lt;audio:VSM_310_075_001&gt;</VoiceId>
      <JapaneseText>&lt;Rody&gt;、どうしたの？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>1</Id>
      <OldPtr>279160</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>298580</PointerOffset>
      <VoiceId>&lt;audio:VSM_310_075_002&gt;</VoiceId>
      <JapaneseText>ん？　いや……
なんでもない</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>2</Id>
      <OldPtr>279356</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>298740</PointerOffset>
      <VoiceId>&lt;audio:VSM_310_075_004&gt;</VoiceId>
      <JapaneseText>ほら、
ダオスのいるところまで
あともう少しだよ</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>3</Id>
      <OldPtr>279552</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>298804</PointerOffset>
      <VoiceId>&lt;audio:VSM_310_075_005&gt;</VoiceId>
      <JapaneseText>あ、あぁ……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>4</Id>
      <OldPtr>279748</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>298880</PointerOffset>
      <VoiceId>&lt;audio:VSM_310_075_006&gt;</VoiceId>
      <JapaneseText>そこにいるんでしょ……？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>5</Id>
      <OldPtr>280712</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>298940</PointerOffset>
      <VoiceId>&lt;audio:VSM_310_075_007&gt;</VoiceId>
      <JapaneseText>…………</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>4</SpeakerId>
      <Id>6</Id>
      <OldPtr>281188</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>299028</PointerOffset>
      <VoiceId>&lt;audio:VSM_310_075_008&gt;</VoiceId>
      <JapaneseText>また……
私を他の時間に
飛ばす気？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>7</Id>
      <OldPtr>281972</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>299112</PointerOffset>
      <VoiceId>&lt;audio:VSM_310_075_009&gt;</VoiceId>
      <JapaneseText>指輪だけ、
時間転移しちゃったね</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>8</Id>
      <OldPtr>284644</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>299172</PointerOffset>
      <VoiceId>&lt;audio:VSM_310_075_010&gt;</VoiceId>
      <JapaneseText>…………</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>4</SpeakerId>
      <Id>9</Id>
      <OldPtr>284908</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>299276</PointerOffset>
      <VoiceId>&lt;audio:VSM_310_075_011&gt;</VoiceId>
      <JapaneseText>ゴメンね。あの指輪、
大事にするって言ったのに……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>10</Id>
      <OldPtr>285104</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>299380</PointerOffset>
      <VoiceId>&lt;audio:VSM_310_075_012&gt;</VoiceId>
      <JapaneseText>今すぐ去れ……
あの双子ともども
消されたくなければ</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>4</SpeakerId>
      <Id>11</Id>
      <OldPtr>285244</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>299532</PointerOffset>
      <VoiceId>&lt;audio:VSM_310_075_013&gt;</VoiceId>
      <JapaneseText>あの双子ちゃんを消すのは、
デリス・カーラーンを
滅ぼしたから？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>12</Id>
      <BubbleId>0</BubbleId>
      <OldPtr>285440</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>299532</PointerOffset>
      <VoiceId>&lt;audio:VSM_310_075_014&gt;</VoiceId>
      <JapaneseText>それは復讐なの？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>12</Id>
      <BubbleId>1</BubbleId>
      <OldPtr>285440</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>299724</PointerOffset>
      <VoiceId>&lt;audio:VSM_310_075_015&gt;</VoiceId>
      <JapaneseText>違う……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>4</SpeakerId>
      <Id>14</Id>
      <BubbleId>0</BubbleId>
      <OldPtr>285768</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>299724</PointerOffset>
      <VoiceId>&lt;audio:VSM_310_075_016&gt;</VoiceId>
      <JapaneseText>この星と大樹カーラーンを
守るため……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>4</SpeakerId>
      <Id>14</Id>
      <BubbleId>1</BubbleId>
      <OldPtr>285768</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>299724</PointerOffset>
      <VoiceId>&lt;audio:VSM_310_075_017&gt;</VoiceId>
      <JapaneseText>再び同じ蛮行を繰り返す可能性の
芽を潰さなければならない</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>4</SpeakerId>
      <Id>14</Id>
      <BubbleId>2</BubbleId>
      <OldPtr>285768</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>300184</PointerOffset>
      <VoiceId>&lt;audio:VSM_310_075_018&gt;</VoiceId>
      <JapaneseText>……ダオス、もう帰ろう</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>17</Id>
      <BubbleId>0</BubbleId>
      <OldPtr>286468</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>300184</PointerOffset>
      <VoiceId>&lt;audio:VSM_310_075_019&gt;</VoiceId>
      <JapaneseText>『大いなる実り』がなる
あの森にさ</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>17</Id>
      <BubbleId>1</BubbleId>
      <OldPtr>286468</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>300184</PointerOffset>
      <VoiceId>&lt;audio:VSM_310_075_020&gt;</VoiceId>
      <JapaneseText>私、たくさんのこと、
覚えてる</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>17</Id>
      <BubbleId>2</BubbleId>
      <OldPtr>286468</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>300184</PointerOffset>
      <VoiceId>&lt;audio:VSM_310_075_021&gt;</VoiceId>
      <JapaneseText>ご飯作って
持っていった時のこととか</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>17</Id>
      <BubbleId>3</BubbleId>
      <OldPtr>286468</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>300184</PointerOffset>
      <VoiceId>&lt;audio:VSM_310_075_022&gt;</VoiceId>
      <JapaneseText>おいしいともマズイとも
言わないんだもん、本当、
作りがいないよ、アレ</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>17</Id>
      <BubbleId>4</BubbleId>
      <OldPtr>286468</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>300184</PointerOffset>
      <VoiceId>&lt;audio:VSM_310_075_023&gt;</VoiceId>
      <JapaneseText>星を見てる時も、
ずっとあなたは故郷のことを
思い出してたんでしょ？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>17</Id>
      <BubbleId>5</BubbleId>
      <OldPtr>286468</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>300184</PointerOffset>
      <VoiceId>&lt;audio:VSM_310_075_024&gt;</VoiceId>
      <JapaneseText>隣にあんな純情可憐な乙女が
いたってのにさ</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>17</Id>
      <BubbleId>6</BubbleId>
      <OldPtr>286468</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>300244</PointerOffset>
      <VoiceId>&lt;audio:VSM_310_075_025&gt;</VoiceId>
      <JapaneseText>…………</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>4</SpeakerId>
      <Id>24</Id>
      <OldPtr>287104</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>300376</PointerOffset>
      <VoiceId>&lt;audio:VSM_310_075_026&gt;</VoiceId>
      <JapaneseText>ねぇ、ダオス……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>25</Id>
      <BubbleId>0</BubbleId>
      <OldPtr>287244</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>300376</PointerOffset>
      <VoiceId>&lt;audio:VSM_310_075_027&gt;</VoiceId>
      <JapaneseText>あなたを救うために
今の私に……何ができる？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>25</Id>
      <BubbleId>1</BubbleId>
      <OldPtr>287244</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>300468</PointerOffset>
      <VoiceId>&lt;audio:VSM_310_075_028&gt;</VoiceId>
      <JapaneseText>残存思念となった我に
もはや救いなどない</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>4</SpeakerId>
      <Id>27</Id>
      <OldPtr>287636</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>300628</PointerOffset>
      <VoiceId>&lt;audio:VSM_310_075_030&gt;</VoiceId>
      <JapaneseText>あの双子とともに
来るのならば、来い、
&lt;Rondoline&gt;</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>4</SpeakerId>
      <Id>28</Id>
      <OldPtr>288136</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>300532</PointerOffset>
      <VoiceId>&lt;audio:VSM_310_075_029&gt;</VoiceId>
      <JapaneseText>待ってよ！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>29</Id>
      <OldPtr>288808</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>300820</PointerOffset>
      <VoiceId>&lt;audio:VSM_310_075_032&gt;</VoiceId>
      <JapaneseText>私はあなたと
戦いたくない……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>30</Id>
      <BubbleId>0</BubbleId>
      <OldPtr>289304</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>300820</PointerOffset>
      <VoiceId>&lt;audio:VSM_310_075_033&gt;</VoiceId>
      <JapaneseText>でも……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>30</Id>
      <BubbleId>1</BubbleId>
      <OldPtr>289304</OldPtr>
      <Status>To Do</Status>
    </Entry>
