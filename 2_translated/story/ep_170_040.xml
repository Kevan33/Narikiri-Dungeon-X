    <Entry>
      <PointerOffset>301472</PointerOffset>
      <VoiceId>&lt;audio:VSM_170_040_001&gt;</VoiceId>
      <JapaneseText>これであの弱虫も、
勝手に外へ出るなどの
わがままはしなくなる</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>1</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>301568</PointerOffset>
      <VoiceId>&lt;audio:VSM_170_040_002&gt;</VoiceId>
      <JapaneseText>&lt;Dio&gt;は
弱虫なんかじゃない！
きっと……！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>2</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>301756</PointerOffset>
      <VoiceId>&lt;audio:VSM_170_040_003&gt;</VoiceId>
      <JapaneseText></JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>3</Id>
      <BubbleId>0</BubbleId>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>301756</PointerOffset>
      <VoiceId>&lt;audio:VSM_170_040_004&gt;</VoiceId>
      <JapaneseText>知らなくてもいいことを知り、
歪むくらいなら
何も知らない方が幸せだおまえとて、外の世界に
出るのは不安だったのだろう</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>3</Id>
      <BubbleId>1</BubbleId>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>301880</PointerOffset>
      <VoiceId>&lt;audio:VSM_170_040_005&gt;</VoiceId>
      <JapaneseText>……たしかに、すごく不安だけど
それを乗り越えるのが
楽しいっていうか……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>5</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>302008</PointerOffset>
      <VoiceId>&lt;audio:VSM_170_040_006&gt;</VoiceId>
      <JapaneseText>……よくわからないけど、
だからこそ、そこに新しいもの
を見つけられる気がして</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>6</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>302072</PointerOffset>
      <VoiceId>&lt;audio:VSM_170_040_007&gt;</VoiceId>
      <JapaneseText>違う、かな？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>7</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>302148</PointerOffset>
      <VoiceId>&lt;audio:VSM_170_040_008&gt;</VoiceId>
      <JapaneseText>……うん、そう、だと思う</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>8</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>302212</PointerOffset>
      <VoiceId>&lt;audio:VSM_170_040_009&gt;</VoiceId>
      <JapaneseText>……ふん</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>9</Id>
      <Status>To Do</Status>
