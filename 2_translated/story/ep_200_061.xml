    <Entry>
      <PointerOffset>297152</PointerOffset>
      <VoiceId>&lt;audio:VSM_200_060_010&gt;</VoiceId>
      <JapaneseText>ヴォルト！
オレらに“電気”の
力を分けてくれ！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>2</Id>
      <OldPtr>278208</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>297216</PointerOffset>
      <VoiceId>&lt;audio:VSM_200_060_011&gt;</VoiceId>
      <JapaneseText>※★☆●～</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>3</Id>
      <OldPtr>278348</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>297276</PointerOffset>
      <VoiceId>&lt;audio:VSM_200_060_012&gt;</VoiceId>
      <JapaneseText>あっ……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>4</Id>
      <OldPtr>278808</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>297352</PointerOffset>
      <VoiceId>&lt;audio:VSM_200_060_013&gt;</VoiceId>
      <JapaneseText>◎×※※★□▼＄☆……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>5</Id>
      <OldPtr>280688</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>297444</PointerOffset>
      <VoiceId>&lt;audio:VSM_200_060_014&gt;</VoiceId>
      <JapaneseText>え……南の……方の
精霊が騒がしい……？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>6</Id>
      <OldPtr>281352</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>297516</PointerOffset>
      <VoiceId>&lt;audio:VSM_200_060_015&gt;</VoiceId>
      <JapaneseText>ん？　どういうこと？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>4</SpeakerId>
      <Id>7</Id>
      <OldPtr>281908</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>297636</PointerOffset>
      <VoiceId>&lt;audio:VSM_200_060_016&gt;</VoiceId>
      <JapaneseText>さあ、それは……。
でも、ヴォルトの言ってる言葉が
わかるみたいで……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>8</Id>
      <OldPtr>282160</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>297728</PointerOffset>
      <VoiceId>&lt;audio:VSM_200_060_017&gt;</VoiceId>
      <JapaneseText>精霊晶核もらったことと
関係あんのか？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>9</Id>
      <OldPtr>283032</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>297800</PointerOffset>
      <VoiceId>&lt;audio:VSM_200_060_018&gt;</VoiceId>
      <JapaneseText>☆☆☆◎★★※▲</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>10</Id>
      <OldPtr>283424</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>297912</PointerOffset>
      <VoiceId>&lt;audio:VSM_200_060_019&gt;</VoiceId>
      <JapaneseText>えっと……その騒ぎのせいで、
わたしたちを襲った……って……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>11</Id>
      <OldPtr>283676</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>297984</PointerOffset>
      <VoiceId>&lt;audio:VSM_200_060_020&gt;</VoiceId>
      <JapaneseText>精霊が、騒がしい……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>12</Id>
      <OldPtr>283932</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>298084</PointerOffset>
      <VoiceId>&lt;audio:VSM_200_060_021&gt;</VoiceId>
      <JapaneseText>もしかして、
そこにエトちゃんがいる、
とか！？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>4</SpeakerId>
      <Id>13</Id>
      <OldPtr>284336</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>298164</PointerOffset>
      <VoiceId>&lt;audio:VSM_200_060_022&gt;</VoiceId>
      <JapaneseText>そう言えば
ノームの時も……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>14</Id>
      <OldPtr>284700</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>298256</PointerOffset>
      <VoiceId>&lt;audio:VSM_200_060_023&gt;</VoiceId>
      <JapaneseText>それだよ……！
きっとそこにエトがいる！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>15</Id>
      <OldPtr>285172</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>298348</PointerOffset>
      <VoiceId>&lt;audio:VSM_200_060_024&gt;</VoiceId>
      <JapaneseText>ここから
南の大陸と言えば
アーリィですね</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>5</SpeakerId>
      <Id>16</Id>
      <OldPtr>286008</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>298456</PointerOffset>
      <VoiceId>&lt;audio:VSM_200_060_025&gt;</VoiceId>
      <JapaneseText>行ってみよーぜ！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>17</Id>
      <BubbleId>0</BubbleId>
      <OldPtr>286564</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>298456</PointerOffset>
      <VoiceId>&lt;audio:VSM_200_060_026&gt;</VoiceId>
      <JapaneseText>サンキュ、ヴォルト</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>17</Id>
      <BubbleId>1</BubbleId>
      <OldPtr>286564</OldPtr>
