    <Entry>
      <PointerOffset>284540</PointerOffset>
      <VoiceId>&lt;audio:VSM_320_060_012&gt;</VoiceId>
      <JapaneseText>くっ……オレたちを倒すことが……
どういうことか……
わかっていないようだな……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>1</Id>
      <OldPtr>259860</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>284644</PointerOffset>
      <VoiceId>&lt;audio:VSM_320_060_013&gt;</VoiceId>
      <JapaneseText>わかってるっての。
だから“決着”つける
って言ったろ</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>2</Id>
      <OldPtr>260056</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>284744</PointerOffset>
      <VoiceId>&lt;audio:VSM_320_060_014&gt;</VoiceId>
      <JapaneseText>まったく……馬鹿野郎だよ、
おまえたち、は……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>3</Id>
      <OldPtr>260540</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>284856</PointerOffset>
      <VoiceId>&lt;audio:VSM_320_060_015&gt;</VoiceId>
      <JapaneseText>後悔し恐れるといいわ……
報いを受けるその瞬間まで……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>4</Id>
      <OldPtr>260680</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>284944</PointerOffset>
      <VoiceId>&lt;audio:VSM_320_060_016&gt;</VoiceId>
      <JapaneseText>……え？　え？
どういう、こと……？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>4</SpeakerId>
      <Id>5</Id>
      <OldPtr>265672</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>285028</PointerOffset>
      <VoiceId>&lt;audio:VSM_320_060_017&gt;</VoiceId>
      <JapaneseText>あいつら消せば、
オレらも消える</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>6</Id>
      <OldPtr>266316</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>285116</PointerOffset>
      <VoiceId>&lt;audio:VSM_320_060_018&gt;</VoiceId>
      <JapaneseText>消えるって……？
え……？
まさか……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>4</SpeakerId>
      <Id>7</Id>
      <OldPtr>266456</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>285296</PointerOffset>
      <VoiceId>&lt;audio:VSM_320_060_019&gt;</VoiceId>
      <JapaneseText>……あのふたりは
&lt;Dio&gt;くんと&lt;Mel&gt;ちゃんだった</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>5</SpeakerId>
      <Id>8</Id>
      <BubbleId>0</BubbleId>
      <OldPtr>266736</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>285296</PointerOffset>
      <VoiceId>&lt;audio:VSM_320_060_020&gt;</VoiceId>
      <JapaneseText>だから、あのふたりを
倒すってことは、
自分自身を倒すこと……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>5</SpeakerId>
      <Id>8</Id>
      <BubbleId>1</BubbleId>
      <OldPtr>266736</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>285392</PointerOffset>
      <VoiceId>&lt;audio:VSM_320_060_021&gt;</VoiceId>
      <JapaneseText>そういうことだよ。
黙っててゴメンね、エト</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>6</SpeakerId>
      <Id>10</Id>
      <OldPtr>267400</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>285456</PointerOffset>
      <VoiceId>&lt;audio:VSM_320_060_022&gt;</VoiceId>
      <JapaneseText>そ、んな……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>4</SpeakerId>
      <Id>11</Id>
      <OldPtr>268876</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>285552</PointerOffset>
      <VoiceId>&lt;audio:VSM_320_060_023&gt;</VoiceId>
      <JapaneseText>これが……ノルンが望んだ
オレらの決着なんだ</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>12</Id>
      <OldPtr>269108</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>285676</PointerOffset>
      <VoiceId>&lt;audio:VSM_320_060_024&gt;</VoiceId>
      <JapaneseText>でも、試練受けさせて、
それできみたちの善悪を
判断するって、ノルンは……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>4</SpeakerId>
      <Id>13</Id>
      <OldPtr>269340</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>285800</PointerOffset>
      <VoiceId>&lt;audio:VSM_320_060_025&gt;</VoiceId>
      <JapaneseText>自分自身で罪に向き合い、
自分の手で罪を償う、
それがノルンの意思だった</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>6</SpeakerId>
      <Id>14</Id>
      <OldPtr>269480</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>286004</PointerOffset>
      <VoiceId>&lt;audio:VSM_320_060_026&gt;</VoiceId>
      <JapaneseText>ノルンの言ったことは
嘘だったの！？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>4</SpeakerId>
      <Id>15</Id>
      <BubbleId>0</BubbleId>
      <OldPtr>269620</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>286004</PointerOffset>
      <VoiceId>&lt;audio:VSM_320_060_027&gt;</VoiceId>
      <JapaneseText>自分の手で
自分を殺すことが
ノルンの望んだことなんて……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>4</SpeakerId>
      <Id>15</Id>
      <BubbleId>1</BubbleId>
      <OldPtr>269620</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>286004</PointerOffset>
      <VoiceId>&lt;audio:VSM_320_060_028&gt;</VoiceId>
      <JapaneseText>ひどいよ……ひどい！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>4</SpeakerId>
      <Id>15</Id>
      <BubbleId>2</BubbleId>
      <OldPtr>269620</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>286104</PointerOffset>
      <VoiceId>&lt;audio:VSM_320_060_029&gt;</VoiceId>
      <JapaneseText>ノルンが望んだんじゃない。
オレらが選んだんだ</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>18</Id>
      <OldPtr>270276</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>286244</PointerOffset>
      <VoiceId>&lt;audio:VSM_320_060_030&gt;</VoiceId>
      <JapaneseText>他に何ができるか、
考えたよ</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>6</SpeakerId>
      <Id>19</Id>
      <BubbleId>0</BubbleId>
      <OldPtr>270576</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>286244</PointerOffset>
      <VoiceId>&lt;audio:VSM_320_060_031&gt;</VoiceId>
      <JapaneseText>でも、背負った罪の
大きさは重過ぎる……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>6</SpeakerId>
      <Id>19</Id>
      <BubbleId>1</BubbleId>
      <OldPtr>270576</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>286444</PointerOffset>
      <VoiceId>&lt;audio:VSM_320_060_032&gt;</VoiceId>
      <JapaneseText>デリス・カーラーンの
１０億の民……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>21</Id>
      <BubbleId>0</BubbleId>
      <OldPtr>270808</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>286444</PointerOffset>
      <VoiceId>&lt;audio:VSM_320_060_033&gt;</VoiceId>
      <JapaneseText>ダオスの想いと
その犠牲になった人……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>21</Id>
      <BubbleId>1</BubbleId>
      <OldPtr>270808</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>286444</PointerOffset>
      <VoiceId>&lt;audio:VSM_320_060_034&gt;</VoiceId>
      <JapaneseText>それに値する償いは
これしかなかった</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>21</Id>
      <BubbleId>2</BubbleId>
      <OldPtr>270808</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>286504</PointerOffset>
      <VoiceId>&lt;audio:VSM_320_060_035&gt;</VoiceId>
      <JapaneseText>…………</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>4</SpeakerId>
      <Id>24</Id>
      <OldPtr>270948</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>286568</PointerOffset>
      <VoiceId>&lt;audio:VSM_320_060_036&gt;</VoiceId>
      <JapaneseText>クルール！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>7</SpeakerId>
      <Id>25</Id>
      <OldPtr>271144</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>286636</PointerOffset>
      <VoiceId>&lt;audio:VSM_320_060_037&gt;</VoiceId>
      <JapaneseText>あ、&lt;Couleur&gt;……！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>4</SpeakerId>
      <Id>26</Id>
      <OldPtr>271980</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>286732</PointerOffset>
      <VoiceId>&lt;audio:VSM_320_060_038&gt;</VoiceId>
      <JapaneseText>さぁ……
私のところへ来なさい。
この奥です</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>8</SpeakerId>
      <Id>27</Id>
      <OldPtr>272160</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>286836</PointerOffset>
      <VoiceId>&lt;audio:VSM_320_060_039&gt;</VoiceId>
      <JapaneseText>……きみの
かわいい双子ちゃんの決意、
見届けようぜ</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>5</SpeakerId>
      <Id>28</Id>
      <OldPtr>273484</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>286976</PointerOffset>
      <VoiceId>&lt;audio:VSM_320_060_040&gt;</VoiceId>
      <JapaneseText>ふたりの、決意……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>4</SpeakerId>
      <Id>29</Id>
      <BubbleId>0</BubbleId>
      <OldPtr>273624</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>286976</PointerOffset>
      <VoiceId>&lt;audio:VSM_320_060_041&gt;</VoiceId>
      <JapaneseText>……でもだからって
こんなの……
あんまりだよ……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>4</SpeakerId>
      <Id>29</Id>
      <BubbleId>1</BubbleId>
      <OldPtr>273624</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>287072</PointerOffset>
      <VoiceId>&lt;audio:VSM_320_060_042&gt;</VoiceId>
      <JapaneseText>……そうだね。
だからこそ……
見届けるんだよ</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>5</SpeakerId>
      <Id>31</Id>
      <OldPtr>274432</OldPtr>
      <Status>To Do</Status>
    </Entry>
