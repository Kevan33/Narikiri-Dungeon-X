    <Entry>
      <PointerOffset>274016</PointerOffset>
      <VoiceId>&lt;audio:VSM_130_030_001&gt;</VoiceId>
      <JapaneseText>君は……
さっき、来てた子だね</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>1</Id>
      <OldPtr>258344</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>274116</PointerOffset>
      <VoiceId>&lt;audio:VSM_130_030_002&gt;</VoiceId>
      <JapaneseText>&lt;Cless&gt;さん！
&lt;Mint&gt;さんに会いに
行ってやれよ！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>2</Id>
      <OldPtr>258660</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>274216</PointerOffset>
      <VoiceId>&lt;audio:VSM_130_030_003&gt;</VoiceId>
      <JapaneseText>&lt;Dio&gt;……！
もう少し言い方ってもんが
あるでしょ</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>3</Id>
      <OldPtr>258956</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>274288</PointerOffset>
      <VoiceId>&lt;audio:VSM_130_030_004&gt;</VoiceId>
      <JapaneseText>なんだい、藪から棒に</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>4</Id>
      <OldPtr>259260</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>274376</PointerOffset>
      <VoiceId>&lt;audio:VSM_130_030_005&gt;</VoiceId>
      <JapaneseText>&lt;Mint&gt;さんが
会いたがってるんだ！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>5</Id>
      <OldPtr>259668</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>274444</PointerOffset>
      <VoiceId>&lt;audio:VSM_130_030_006&gt;</VoiceId>
      <JapaneseText>&lt;Mint&gt;が……？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>6</Id>
      <OldPtr>259920</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>274540</PointerOffset>
      <VoiceId>&lt;audio:VSM_130_030_007&gt;</VoiceId>
      <JapaneseText>……今はダメだよ。
後で時間があったら……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>7</Id>
      <OldPtr>260856</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>274624</PointerOffset>
      <VoiceId>&lt;audio:VSM_130_030_008&gt;</VoiceId>
      <JapaneseText>そんなこと
言ってる場合かよ！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>8</Id>
      <OldPtr>261276</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>274744</PointerOffset>
      <VoiceId>&lt;audio:VSM_130_030_009&gt;</VoiceId>
      <JapaneseText>そこをどいて</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>9</Id>
      <BubbleId>0</BubbleId>
      <OldPtr>261472</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>274744</PointerOffset>
      <VoiceId>&lt;audio:VSM_130_030_010&gt;</VoiceId>
      <JapaneseText>荷物を馬車に
乗せなきゃいけないんだ</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>9</Id>
      <BubbleId>1</BubbleId>
      <OldPtr>261472</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>274832</PointerOffset>
      <VoiceId>&lt;audio:VSM_130_030_011&gt;</VoiceId>
      <JapaneseText>そんなの、オレが、
やってやるよ！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>11</Id>
      <OldPtr>261612</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>274908</PointerOffset>
      <VoiceId>&lt;audio:VSM_130_030_012&gt;</VoiceId>
      <JapaneseText>兵士たちの稽古もあるし</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>12</Id>
      <OldPtr>261808</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>274992</PointerOffset>
      <VoiceId>&lt;audio:VSM_130_030_013&gt;</VoiceId>
      <JapaneseText>それもオレが
やってやるって！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>13</Id>
      <OldPtr>261948</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>275096</PointerOffset>
      <VoiceId>&lt;audio:VSM_130_030_014&gt;</VoiceId>
      <JapaneseText>いや……君みたいな子どもに
そんなこと任せられないよ</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>14</Id>
      <OldPtr>262088</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>275192</PointerOffset>
      <VoiceId>&lt;audio:VSM_130_030_015&gt;</VoiceId>
      <JapaneseText>任せらんねーかどうか、
勝負すりゃわかるよ！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>15</Id>
      <OldPtr>262340</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>275280</PointerOffset>
      <VoiceId>&lt;audio:VSM_130_030_016&gt;</VoiceId>
      <JapaneseText>……そんなことを
してる暇はないんだ</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>16</Id>
      <OldPtr>262768</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>275352</PointerOffset>
      <VoiceId>&lt;audio:VSM_130_030_017&gt;</VoiceId>
      <JapaneseText>負けんのが怖いのか？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>17</Id>
      <OldPtr>263076</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>275484</PointerOffset>
      <VoiceId>&lt;audio:VSM_130_030_018&gt;</VoiceId>
      <JapaneseText>……わかったよ。
少しだけ</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>18</Id>
      <BubbleId>0</BubbleId>
      <OldPtr>263328</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>275484</PointerOffset>
      <VoiceId>&lt;audio:VSM_130_030_019&gt;</VoiceId>
      <JapaneseText>街の中じゃ迷惑だから、
外へ出よう</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>18</Id>
      <BubbleId>1</BubbleId>
      <OldPtr>263328</OldPtr>
      <Status>To Do</Status>
    </Entry>
