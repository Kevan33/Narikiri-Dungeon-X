    <Entry>
      <PointerOffset>276496</PointerOffset>
      <VoiceId>&lt;audio:VSM_250_020_001&gt;</VoiceId>
      <JapaneseText>わたしたちは
『なりきり士』のお仕事を
始めました</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>2</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>276684</PointerOffset>
      <VoiceId>&lt;audio:VSM_250_020_003&gt;</VoiceId>
      <JapaneseText>子どもの面倒みたりとか、
犬のお散歩、とか</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>3</Id>
      <Status>To Do</Status>
    </Entry>
