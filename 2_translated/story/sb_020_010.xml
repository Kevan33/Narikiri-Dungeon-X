  <Strings>
    <Section>Main</Section>
    <Entry>
      <PointerOffset>272692</PointerOffset>
      <JapaneseText>なぁ、エトってさ、
オレたちに会う前って
ずっと仲間探してたのか？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>1</Id>
      <OldPtr>258548</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>272768</PointerOffset>
      <JapaneseText>うん、世界中を旅してた。
ずっと長い間……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>2</Id>
      <OldPtr>258688</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>272824</PointerOffset>
      <JapaneseText>たった……ひとりで？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>3</Id>
      <OldPtr>258828</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>272920</PointerOffset>
      <JapaneseText>大体、ね。でも時々、
友達もできたよ。
鳥とか、魚とか、虫とか</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>4</Id>
      <OldPtr>259072</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>272976</PointerOffset>
      <JapaneseText>鳥とか、魚とかって……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>5</Id>
      <OldPtr>259212</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>273056</PointerOffset>
      <JapaneseText>みんな、一緒になって、
仲間を探してくれたんだ</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>6</Id>
      <OldPtr>259408</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>273128</PointerOffset>
      <JapaneseText>それでも、仲間は
見つからなかったの？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>7</Id>
      <OldPtr>259548</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>273268</PointerOffset>
      <JapaneseText>……だね</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>8</Id>
      <BubbleId>0</BubbleId>
      <OldPtr>259688</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>273268</PointerOffset>
      <JapaneseText>あの子たち、基本的に
自由で気ままだからさ</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>8</Id>
      <BubbleId>1</BubbleId>
      <OldPtr>259688</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>273268</PointerOffset>
      <JapaneseText>すぐ、
他のことに気をとられて
どこかへ行っちゃうんだ</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>8</Id>
      <BubbleId>2</BubbleId>
      <OldPtr>259688</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>273316</PointerOffset>
      <JapaneseText>そうなんだ……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>11</Id>
      <OldPtr>259920</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>273404</PointerOffset>
      <JapaneseText>でも、妖精じゃないんだもん。
見つからないはずだよね</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>12</Id>
      <OldPtr>260060</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>273492</PointerOffset>
      <JapaneseText>でも……妖精じゃないとしても、
仲間はいるはずでしょ</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>13</Id>
      <OldPtr>260200</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>273540</PointerOffset>
      <JapaneseText>……かも、ね</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>14</Id>
      <OldPtr>260340</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>273644</PointerOffset>
      <JapaneseText>大体、エトって
どこで生まれたんだ？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>15</Id>
      <BubbleId>0</BubbleId>
      <OldPtr>260480</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>273644</PointerOffset>
      <JapaneseText>そこに仲間とか
いなかったのか？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>15</Id>
      <BubbleId>1</BubbleId>
      <OldPtr>260480</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>273848</PointerOffset>
      <JapaneseText>……生まれた場所も
覚えてない……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>17</Id>
      <BubbleId>0</BubbleId>
      <OldPtr>260816</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>273848</PointerOffset>
      <JapaneseText>昔のことって、新しいことに
どんどん押し出されて、
忘れてっちゃうみたい……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>17</Id>
      <BubbleId>1</BubbleId>
      <OldPtr>260816</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>273848</PointerOffset>
      <JapaneseText>でも……どこか暗くて
もやもやしたところ……
のような気がする</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>17</Id>
      <BubbleId>2</BubbleId>
      <OldPtr>260816</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>273932</PointerOffset>
      <JapaneseText>暗くて、もやもや……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>20</Id>
      <BubbleId>0</BubbleId>
      <OldPtr>260956</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>273932</PointerOffset>
      <JapaneseText>わかった！
霧のかかった洞窟！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>20</Id>
      <BubbleId>1</BubbleId>
      <OldPtr>260956</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>274064</PointerOffset>
      <JapaneseText>そのまんま……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>22</Id>
      <BubbleId>0</BubbleId>
      <OldPtr>261492</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>274064</PointerOffset>
      <JapaneseText>じゃあ、エトは誰が
お父さんかお母さんか
なんてわかんないんだ</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>22</Id>
      <BubbleId>1</BubbleId>
      <OldPtr>261492</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>274064</PointerOffset>
      <JapaneseText>わたしたちと一緒だね</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>22</Id>
      <BubbleId>2</BubbleId>
      <OldPtr>261492</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>274144</PointerOffset>
      <JapaneseText>何言ってんの。
ふたりのお母さんは
ぼくでしょ？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>25</Id>
      <OldPtr>261912</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>274192</PointerOffset>
      <JapaneseText>またそれかよ</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>26</Id>
      <OldPtr>262276</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>274240</PointerOffset>
      <JapaneseText>うん、だよね</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>27</Id>
      <OldPtr>262520</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>274288</PointerOffset>
      <JapaneseText>だけどさぁ……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>28</Id>
      <OldPtr>262660</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>274380</PointerOffset>
      <JapaneseText>……いつか、
きみたちのことも……
忘れちゃうの、かな……？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>29</Id>
      <OldPtr>263592</OldPtr>
      <Status>To Do</Status>
    </Entry>
