    <Entry>
      <PointerOffset>302404</PointerOffset>
      <VoiceId>&lt;audio:VSM_070_030_009&gt;</VoiceId>
      <JapaneseText>まだやるか！？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>1</Id>
      <OldPtr>282232</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>302464</PointerOffset>
      <VoiceId>&lt;audio:VSM_070_030_010&gt;</VoiceId>
      <JapaneseText>むぎゅ～</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>2</Id>
      <OldPtr>282372</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>302536</PointerOffset>
      <VoiceId>&lt;audio:VSM_070_030_011&gt;</VoiceId>
      <JapaneseText>エト……大丈夫！？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>3</Id>
      <OldPtr>283532</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>302600</PointerOffset>
      <VoiceId>&lt;audio:VSM_070_030_012&gt;</VoiceId>
      <JapaneseText>ふみゃ……？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>4</SpeakerId>
      <Id>4</Id>
      <OldPtr>283672</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>302684</PointerOffset>
      <VoiceId>&lt;audio:VSM_070_030_013&gt;</VoiceId>
      <JapaneseText>よかった……
よかったよぉ……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>5</Id>
      <OldPtr>284244</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>302764</PointerOffset>
      <VoiceId>&lt;audio:VSM_070_030_014&gt;</VoiceId>
      <JapaneseText>気ぃつけろよな、
マジで……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>6</Id>
      <OldPtr>284440</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>302868</PointerOffset>
      <VoiceId>&lt;audio:VSM_070_030_015&gt;</VoiceId>
      <JapaneseText>どぉ？
お姉さんの華麗なパンチ、
よく効くでしょお？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>5</SpeakerId>
      <Id>7</Id>
      <OldPtr>284724</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>302940</PointerOffset>
      <VoiceId>&lt;audio:VSM_070_030_016&gt;</VoiceId>
      <JapaneseText>うぇ～ん。痛いのら～</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>8</Id>
      <OldPtr>284920</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>303048</PointerOffset>
      <VoiceId>&lt;audio:VSM_070_030_017&gt;</VoiceId>
      <JapaneseText>やれやれ。精霊が縄張りに
ここまで過敏反応を示すとはな</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>6</SpeakerId>
      <Id>9</Id>
      <OldPtr>285060</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>303144</PointerOffset>
      <VoiceId>&lt;audio:VSM_070_030_018&gt;</VoiceId>
      <JapaneseText>妖精も精霊と同じ超自然的な
存在だからか……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>6</SpeakerId>
      <Id>10</Id>
      <OldPtr>285308</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>303308</PointerOffset>
      <VoiceId>&lt;audio:VSM_070_030_020&gt;</VoiceId>
      <JapaneseText>おい！　ノーム！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>11</Id>
      <OldPtr>285976</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>303396</PointerOffset>
      <VoiceId>&lt;audio:VSM_070_030_021&gt;</VoiceId>
      <JapaneseText>まいったのら～
もうやらないのら～</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>12</Id>
      <OldPtr>286956</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>303480</PointerOffset>
      <VoiceId>&lt;audio:VSM_070_030_022&gt;</VoiceId>
      <JapaneseText>&lt;Dio&gt;……
きみ、ちょっと……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>4</SpeakerId>
      <Id>13</Id>
      <OldPtr>287264</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>303576</PointerOffset>
      <VoiceId>&lt;audio:VSM_070_030_023&gt;</VoiceId>
      <JapaneseText>精霊晶核をもらうぞ！
戦って勝ったんだからな</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>14</Id>
      <OldPtr>287844</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>303644</PointerOffset>
      <VoiceId>&lt;audio:VSM_070_030_024&gt;</VoiceId>
      <JapaneseText>わかったのら～</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>15</Id>
      <OldPtr>287984</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>303728</PointerOffset>
      <VoiceId>&lt;audio:VSM_070_030_025&gt;</VoiceId>
      <JapaneseText>もう帰るのら～
バイバイなのら～</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>16</Id>
      <OldPtr>289348</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>303828</PointerOffset>
      <VoiceId>&lt;audio:VSM_070_030_026&gt;</VoiceId>
      <JapaneseText>&lt;Dio&gt;……&lt;Mel&gt;……
ごめんね……
心配かけて……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>4</SpeakerId>
      <Id>17</Id>
      <OldPtr>290408</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>303932</PointerOffset>
      <VoiceId>&lt;audio:VSM_070_030_027&gt;</VoiceId>
      <JapaneseText>ううん。
こっちこそ、ごめんね、
すぐに助けられなくて</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>18</Id>
      <OldPtr>290948</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>304020</PointerOffset>
      <VoiceId>&lt;audio:VSM_070_030_028&gt;</VoiceId>
      <JapaneseText>なんでもいいよ、
無事だったんだし</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>19</Id>
      <OldPtr>291316</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>304088</PointerOffset>
      <VoiceId>&lt;audio:VSM_070_030_029&gt;</VoiceId>
      <JapaneseText>……もう少し……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>5</SpeakerId>
      <Id>20</Id>
      <OldPtr>292236</OldPtr>
      <Status>To Do</Status>
    </Entry>
