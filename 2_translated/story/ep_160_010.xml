    <Entry>
      <PointerOffset>313820</PointerOffset>
      <VoiceId>&lt;audio:VSM_160_010_001&gt;</VoiceId>
      <JapaneseText>どうしたの……！？</JapaneseText>
      <EnglishText>What happened...!?</EnglishText>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>1</Id>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset>313888</PointerOffset>
      <VoiceId>&lt;audio:VSM_160_010_002&gt;</VoiceId>
      <JapaneseText>う、動けねぇ……</JapaneseText>
      <EnglishText>I-I can't move a muscle...</EnglishText>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>2</Id>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset>313956</PointerOffset>
      <VoiceId>&lt;audio:VSM_160_010_003&gt;</VoiceId>
      <JapaneseText>クルールゥ……</JapaneseText>
      <EnglishText>Kururuu... </EnglishText>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>3</Id>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset>314016</PointerOffset>
      <VoiceId>&lt;audio:VSM_160_010_004&gt;</VoiceId>
      <JapaneseText>え……</JapaneseText>
      <EnglishText>No...</EnglishText>
      <Notes/>
      <SpeakerId>4</SpeakerId>
      <Id>4</Id>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset>314080</PointerOffset>
      <VoiceId>&lt;audio:VSM_160_010_005&gt;</VoiceId>
      <JapaneseText>これは……！</JapaneseText>
      <EnglishText>What's that!?</EnglishText>
      <Notes/>
      <SpeakerId>4</SpeakerId>
      <Id>5</Id>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset>314228</PointerOffset>
      <VoiceId>&lt;audio:VSM_160_010_006&gt;</VoiceId>
      <JapaneseText>かかったな、人間ども</JapaneseText>
      <EnglishText>You've come, stupid humans!</EnglishText>
      <Notes/>
      <SpeakerId>5</SpeakerId>
      <Id>6</Id>
      <BubbleId>0</BubbleId>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset>314228</PointerOffset>
      <VoiceId>&lt;audio:VSM_160_010_007&gt;</VoiceId>
      <JapaneseText>主命により、
我々の邪魔をする者は
ここで消す！</JapaneseText>
      <EnglishText>By our Lord's orders, we'll
erase you from existence!</EnglishText>
      <Notes/>
      <SpeakerId>5</SpeakerId>
      <Id>6</Id>
      <BubbleId>1</BubbleId>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset>314324</PointerOffset>
      <VoiceId>&lt;audio:VSM_160_010_008&gt;</VoiceId>
      <JapaneseText>こ、こいつら……！
ブレイナーの操る魔族か！</JapaneseText>
      <EnglishText>Th-These are Brainer's monsters!</EnglishText>
      <Notes/>
      <SpeakerId>4</SpeakerId>
      <Id>8</Id>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset>314392</PointerOffset>
      <VoiceId>&lt;audio:VSM_160_010_009&gt;</VoiceId>
      <JapaneseText>死ね！</JapaneseText>
      <EnglishText>DIE!</EnglishText>
      <Notes/>
      <SpeakerId>5</SpeakerId>
      <Id>9</Id>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset>314544</PointerOffset>
      <VoiceId>&lt;audio:VSM_160_010_011&gt;</VoiceId>
      <JapaneseText>ぐわぁあっ！！</JapaneseText>
      <EnglishText>Guaaaaah!</EnglishText>
      <Notes/>
      <SpeakerId>5</SpeakerId>
      <Id>10</Id>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset>314604</PointerOffset>
      <VoiceId>&lt;audio:VSM_160_010_012&gt;</VoiceId>
      <JapaneseText>危ない！</JapaneseText>
      <EnglishText>Careful!</EnglishText>
      <Notes/>
      <SpeakerId>4</SpeakerId>
      <Id>11</Id>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset>314668</PointerOffset>
      <VoiceId>&lt;audio:VSM_160_010_013&gt;</VoiceId>
      <JapaneseText>大丈夫かい？</JapaneseText>
      <EnglishText>Are you hurt?</EnglishText>
      <Notes/>
      <SpeakerId>4</SpeakerId>
      <Id>12</Id>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset>314760</PointerOffset>
      <VoiceId>&lt;audio:VSM_160_010_014&gt;</VoiceId>
      <JapaneseText>はい。
ありがとうございます、
&lt;Cless&gt;さん</JapaneseText>
      <EnglishText>No, I'm fine. Thanks for
the help, Mister &lt;Cless&gt;.</EnglishText>
      <Notes/>
      <SpeakerId>6</SpeakerId>
      <Id>13</Id>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset>314824</PointerOffset>
      <VoiceId>&lt;audio:VSM_160_010_015&gt;</VoiceId>
      <JapaneseText>……&lt;Dio&gt;も</JapaneseText>
      <EnglishText>What about you, &lt;Dio&gt;?</EnglishText>
      <Notes/>
      <SpeakerId>4</SpeakerId>
      <Id>14</Id>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset>314896</PointerOffset>
      <VoiceId>&lt;audio:VSM_160_010_016&gt;</VoiceId>
      <JapaneseText>あ……う、うん……</JapaneseText>
      <EnglishText>I-I'm...fine...</EnglishText>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>15</Id>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset>314960</PointerOffset>
      <VoiceId>&lt;audio:VSM_160_010_017&gt;</VoiceId>
      <JapaneseText>&lt;Chester&gt;さん！</JapaneseText>
      <EnglishText>&lt;Chester&gt;!</EnglishText>
      <Notes/>
      <SpeakerId>7</SpeakerId>
      <Id>16</Id>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset>315036</PointerOffset>
      <VoiceId>&lt;audio:VSM_160_010_018&gt;</VoiceId>
      <JapaneseText>最後の切り札参上ってな</JapaneseText>
      <EnglishText>When danger approaches, there's only
one hope ... Enter, the amazing &lt;Chester&gt;!</EnglishText>
      <Notes>Tl check. For sure localized </Notes>
      <SpeakerId>8</SpeakerId>
      <Id>17</Id>
      <Status>Problematic</Status>
    </Entry>
    <Entry>
      <PointerOffset>315104</PointerOffset>
      <VoiceId>&lt;audio:VSM_160_010_019&gt;</VoiceId>
      <JapaneseText>やっぱりおまえか</JapaneseText>
      <EnglishText>So it was you back there! I knew it!</EnglishText>
      <Notes/>
      <SpeakerId>4</SpeakerId>
      <Id>18</Id>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset>315264</PointerOffset>
      <VoiceId>&lt;audio:VSM_160_010_020&gt;</VoiceId>
      <JapaneseText>帰ってきた連中に聞いて
飛んできたぜ</JapaneseText>
      <EnglishText>If any friend is in trouble, I'll back them up.</EnglishText>
      <Notes>Tl check</Notes>
      <SpeakerId>8</SpeakerId>
      <Id>19</Id>
      <BubbleId>0</BubbleId>
      <Status>Problematic</Status>
    </Entry>
    <Entry>
      <PointerOffset>315264</PointerOffset>
      <VoiceId>&lt;audio:VSM_160_010_021&gt;</VoiceId>
      <JapaneseText>街の方の魔物もぱぱっと
片付けてやったし、
もう大丈夫だ</JapaneseText>
      <EnglishText>Most monsters in town have been
taken down, so it should be okay
to relax now.</EnglishText>
      <Notes>TL check</Notes>
      <SpeakerId>8</SpeakerId>
      <Id>19</Id>
      <BubbleId>1</BubbleId>
      <Status>Problematic</Status>
    </Entry>
    <Entry>
      <PointerOffset>315376</PointerOffset>
      <VoiceId>&lt;audio:VSM_160_010_022&gt;</VoiceId>
      <JapaneseText>ありがとう、&lt;Chester&gt;。
あの魔物たちは
この森の奥から来てるんだ</JapaneseText>
      <EnglishText>Thank you &lt;Chester&gt;. The monsters
are coming from this very forest.</EnglishText>
      <Notes/>
      <SpeakerId>4</SpeakerId>
      <Id>21</Id>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset>315480</PointerOffset>
      <VoiceId>&lt;audio:VSM_160_010_023&gt;</VoiceId>
      <JapaneseText>ああ……聞いた。
こっちもぱぱっと
片付けちまおうぜ</JapaneseText>
      <EnglishText>Yeah, I heard... C'mon, let's
hurry and wrap this up!</EnglishText>
      <Notes/>
      <SpeakerId>8</SpeakerId>
      <Id>22</Id>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset>315560</PointerOffset>
      <VoiceId>&lt;audio:VSM_160_010_024&gt;</VoiceId>
      <JapaneseText>おまえたちも
来てたんだな</JapaneseText>
      <EnglishText>I see you kids came here, too.</EnglishText>
      <Notes/>
      <SpeakerId>8</SpeakerId>
      <Id>23</Id>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset>315632</PointerOffset>
      <VoiceId>&lt;audio:VSM_160_010_025&gt;</VoiceId>
      <JapaneseText>あ、ああ……うん……</JapaneseText>
      <EnglishText>Y-Yeah...We did...</EnglishText>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>24</Id>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset>315728</PointerOffset>
      <VoiceId>&lt;audio:VSM_160_010_026&gt;</VoiceId>
      <JapaneseText>オレ、やっぱ
ここで待ってて……
いいかな？</JapaneseText>
      <EnglishText>Is it okay if I just
wait around here?</EnglishText>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>25</Id>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset>315800</PointerOffset>
      <VoiceId>&lt;audio:VSM_160_010_027&gt;</VoiceId>
      <JapaneseText>どうしたんだ、突然？</JapaneseText>
      <EnglishText>What's with the sudden change of heart?</EnglishText>
      <Notes/>
      <SpeakerId>4</SpeakerId>
      <Id>26</Id>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset>315904</PointerOffset>
      <VoiceId>&lt;audio:VSM_160_010_028&gt;</VoiceId>
      <JapaneseText>&lt;Dio&gt;……なんか変だよ。
&lt;Red&gt;ヴァルハラ&lt;White&gt;の時かラ……</JapaneseText>
      <EnglishText>&lt;Dio&gt;...You've been acting very weird
since the assault on &lt;Red&gt;Valhalla&lt;White&gt;...</EnglishText>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>27</Id>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset>315980</PointerOffset>
      <VoiceId>&lt;audio:VSM_160_010_029&gt;</VoiceId>
      <JapaneseText>……変じゃねーって、別に</JapaneseText>
      <EnglishText>I'm not acting weird at all!</EnglishText>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>28</Id>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset>316060</PointerOffset>
      <VoiceId>&lt;audio:VSM_160_010_030&gt;</VoiceId>
      <JapaneseText>何見たの？　&lt;Red&gt;ヴァルハラ&lt;White&gt;で</JapaneseText>
      <EnglishText>Is it something you saw in &lt;Red&gt;Valhalla&lt;White&gt;?</EnglishText>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>29</Id>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset>316120</PointerOffset>
      <VoiceId>&lt;audio:VSM_160_010_031&gt;</VoiceId>
      <JapaneseText>何も……</JapaneseText>
      <EnglishText>It's noth—</EnglishText>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>30</Id>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset>316204</PointerOffset>
      <VoiceId>&lt;audio:VSM_160_010_032&gt;</VoiceId>
      <JapaneseText>わたしの
見間違いじゃなければ</JapaneseText>
      <EnglishText>Maybe I just imagined things...but...</EnglishText>
      <Notes/>
      <SpeakerId>6</SpeakerId>
      <Id>31</Id>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset>316296</PointerOffset>
      <VoiceId>&lt;audio:VSM_160_010_033&gt;</VoiceId>
      <JapaneseText>ブレイナーって人、
バジルさんだったよね</JapaneseText>
      <EnglishText>I'm pretty sure that Brainer is Mister Basil...</EnglishText>
      <Notes/>
      <SpeakerId>6</SpeakerId>
      <Id>32</Id>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset>316360</PointerOffset>
      <VoiceId>&lt;audio:VSM_160_010_034&gt;</VoiceId>
      <JapaneseText>バジル……</JapaneseText>
      <EnglishText>Who's Basil...?</EnglishText>
      <Notes/>
      <SpeakerId>4</SpeakerId>
      <Id>33</Id>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset>316452</PointerOffset>
      <VoiceId>&lt;audio:VSM_160_010_035&gt;</VoiceId>
      <JapaneseText>バジルって……
&lt;Klarth&gt;さんの友達の……</JapaneseText>
      <EnglishText>You mean the same Basil
that's &lt;Klarth&gt;'s friend?</EnglishText>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>34</Id>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset>316516</PointerOffset>
      <VoiceId>&lt;audio:VSM_160_010_036&gt;</VoiceId>
      <JapaneseText>違う……！</JapaneseText>
      <EnglishText>You're wrong!</EnglishText>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>35</Id>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset>316616</PointerOffset>
      <VoiceId>&lt;audio:VSM_160_010_037&gt;</VoiceId>
      <JapaneseText>だから、&lt;Dio&gt;、
なんか様子が
変だったんでしょ？</JapaneseText>
      <EnglishText>Then &lt;Dio&gt;, tell me. Why else would
you been acting so strange?</EnglishText>
      <Notes/>
      <SpeakerId>6</SpeakerId>
      <Id>36</Id>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset>316808</PointerOffset>
      <VoiceId>&lt;audio:VSM_160_010_038&gt;</VoiceId>
      <JapaneseText>まだ、そうって
決まってない！</JapaneseText>
      <EnglishText>There's no way to know for sure!</EnglishText>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>37</Id>
      <BubbleId>0</BubbleId>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset>316808</PointerOffset>
      <VoiceId>&lt;audio:VSM_160_010_039&gt;</VoiceId>
      <JapaneseText>行こうぜ、&lt;Cless&gt;さん</JapaneseText>
      <EnglishText>Let's go, Mister &lt;Cless&gt;!</EnglishText>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>37</Id>
      <BubbleId>1</BubbleId>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset>316808</PointerOffset>
      <VoiceId>&lt;audio:VSM_160_010_040&gt;</VoiceId>
      <JapaneseText>ブレイナーって奴、
ここにいんだろ？
確かめる……！</JapaneseText>
      <EnglishText>Brainer is here, right? I'll
make sure of it, myself...!</EnglishText>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>37</Id>
      <BubbleId>2</BubbleId>
      <Status>Proofreading</Status>
    </Entry>
