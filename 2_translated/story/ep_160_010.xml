    </Entry>
    <Entry>
      <PointerOffset>316808</PointerOffset>
      <VoiceId>&lt;audio:VSM_160_010_039&gt;</VoiceId>
      <JapaneseText>&lt;Cless&gt;</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>37</Id>
      <BubbleId>1</BubbleId>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>316808</PointerOffset>
      <VoiceId>&lt;audio:VSM_160_010_040&gt;</VoiceId>
      <JapaneseText>まだ、そうって
決まってない！行こうぜ、さんブレイナーって奴、
ここにいんだろ？
確かめる……！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>37</Id>
      <BubbleId>2</BubbleId>
      <Status>To Do</Status>
