    <Entry>
      <PointerOffset>275268</PointerOffset>
      <VoiceId>&lt;audio:VSM_290_050_002&gt;</VoiceId>
      <JapaneseText>ここには、おまえの心の穴から
抜け落ちた答えのない愛が
眠っている俺はその我利の化身、残存思念だよ</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>1</Id>
      <BubbleId>1</BubbleId>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>275344</PointerOffset>
      <VoiceId>&lt;audio:VSM_290_050_003&gt;</VoiceId>
      <JapaneseText>どういう……こと……？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>3</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>275416</PointerOffset>
      <VoiceId>&lt;audio:VSM_290_050_004&gt;</VoiceId>
      <JapaneseText>何だったの、今の……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>4</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>275508</PointerOffset>
      <VoiceId>&lt;audio:VSM_290_050_005&gt;</VoiceId>
      <JapaneseText>あの人は……わたし？
わたしが……え……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>5</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>275576</PointerOffset>
      <VoiceId>&lt;audio:VSM_290_050_006&gt;</VoiceId>
      <JapaneseText>クルクルール！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>4</SpeakerId>
      <Id>6</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>275676</PointerOffset>
      <VoiceId>&lt;audio:VSM_290_050_007&gt;</VoiceId>
      <JapaneseText>&lt;Mel&gt;&lt;Mel&gt;、どうしたの！？
しっかりして！　！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>7</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>275760</PointerOffset>
      <VoiceId>&lt;audio:VSM_290_050_008&gt;</VoiceId>
      <JapaneseText>……平気……
平気、だから……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>8</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>275824</PointerOffset>
      <VoiceId>&lt;audio:VSM_290_050_009&gt;</VoiceId>
      <JapaneseText>あれは……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>9</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>275916</PointerOffset>
      <VoiceId>&lt;audio:VSM_290_050_010&gt;</VoiceId>
      <JapaneseText>わたしたちの因縁が
眠ってるの、あそこに</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>10</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>275988</PointerOffset>
      <VoiceId>&lt;audio:VSM_290_050_011&gt;</VoiceId>
      <JapaneseText>そうだな、
行こうぜ</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>5</SpeakerId>
      <Id>11</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>276052</PointerOffset>
      <VoiceId>&lt;audio:VSM_290_050_012&gt;</VoiceId>
      <JapaneseText>進もう……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>12</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>276132</PointerOffset>
      <VoiceId>&lt;audio:VSM_290_050_013&gt;</VoiceId>
      <JapaneseText>進むって……
どっちにだよ</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>5</SpeakerId>
      <Id>13</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>276220</PointerOffset>
      <VoiceId>&lt;audio:VSM_290_050_014&gt;</VoiceId>
      <JapaneseText>&lt;Red&gt;&lt;White&gt;ウェーランド……
そう言ってた</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>14</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>276288</PointerOffset>
      <VoiceId>&lt;audio:VSM_290_050_015&gt;</VoiceId>
      <JapaneseText>誰が言ってたの？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>15</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>276404</PointerOffset>
      <VoiceId>&lt;audio:VSM_290_050_016&gt;</VoiceId>
      <JapaneseText></JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>16</Id>
      <BubbleId>0</BubbleId>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>276404</PointerOffset>
      <VoiceId>&lt;audio:VSM_290_050_017&gt;</VoiceId>
      <JapaneseText>記憶の中で、
男の人が……そこに待ってるって</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>16</Id>
      <BubbleId>1</BubbleId>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>276480</PointerOffset>
      <VoiceId>&lt;audio:VSM_290_050_018&gt;</VoiceId>
      <JapaneseText>待ってるって……何が？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>18</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>276616</PointerOffset>
      <VoiceId>&lt;audio:VSM_290_050_019&gt;</VoiceId>
      <JapaneseText></JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>19</Id>
      <BubbleId>0</BubbleId>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>276616</PointerOffset>
      <VoiceId>&lt;audio:VSM_290_050_020&gt;</VoiceId>
      <JapaneseText>&lt;Red&gt;&lt;White&gt;わからないけど……ウェーランドは、
ここから
北東の方向だよ</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>19</Id>
      <BubbleId>1</BubbleId>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>276712</PointerOffset>
      <VoiceId>&lt;audio:VSM_290_050_021&gt;</VoiceId>
      <JapaneseText>よし、行こうぜ。
行ってみれば、わかるって</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>5</SpeakerId>
      <Id>21</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>276776</PointerOffset>
      <VoiceId>&lt;audio:VSM_290_050_022&gt;</VoiceId>
      <JapaneseText>クルール！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>4</SpeakerId>
      <Id>22</Id>
      <Status>To Do</Status>
