    <Entry>
      <PointerOffset>302672</PointerOffset>
      <VoiceId>&lt;audio:VSM_190_010_019&gt;</VoiceId>
      <JapaneseText>オレたちを
バカにしてんのか！さぁ、こそこそ
してないで早く……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>17</Id>
      <BubbleId>1</BubbleId>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>302748</PointerOffset>
      <VoiceId>&lt;audio:VSM_190_010_020&gt;</VoiceId>
      <JapaneseText>……な、なぜ……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>19</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>302816</PointerOffset>
      <VoiceId>&lt;audio:VSM_190_010_021&gt;</VoiceId>
      <JapaneseText>&lt;Rody&gt;さん！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>20</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>302884</PointerOffset>
      <VoiceId>&lt;audio:VSM_190_010_022&gt;</VoiceId>
      <JapaneseText>なんでここに？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>21</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>302984</PointerOffset>
      <VoiceId>&lt;audio:VSM_190_010_023&gt;</VoiceId>
      <JapaneseText>あはは、ふたりとも
天井に張りついて
クモみたい</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>4</SpeakerId>
      <Id>22</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>303048</PointerOffset>
      <VoiceId>&lt;audio:VSM_190_010_024&gt;</VoiceId>
      <JapaneseText>クモって……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>23</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>303136</PointerOffset>
      <VoiceId>&lt;audio:VSM_190_010_025&gt;</VoiceId>
      <JapaneseText>さて、と。
ほら、レッツエスケープ！</JapaneseText>
      <EnglishText/>
