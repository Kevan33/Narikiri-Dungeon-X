    <Entry>
      <PointerOffset>273720</PointerOffset>
      <VoiceId>&lt;audio:VSM_220_010_001&gt;</VoiceId>
      <JapaneseText>…………</JapaneseText>
      <EnglishText>...</EnglishText>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>1</Id>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset>273792</PointerOffset>
      <VoiceId>&lt;audio:VSM_220_010_002&gt;</VoiceId>
      <JapaneseText>マナ溜まってきた？</JapaneseText>
      <EnglishText>The ring is done collecting Mana, right?</EnglishText>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>2</Id>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset>273880</PointerOffset>
      <VoiceId>&lt;audio:VSM_220_010_003&gt;</VoiceId>
      <JapaneseText>またダオスのところに
行くんですね？</JapaneseText>
      <EnglishText>You're going after Dhaos now?</EnglishText>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>3</Id>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset>273940</PointerOffset>
      <VoiceId>&lt;audio:VSM_220_010_004&gt;</VoiceId>
      <JapaneseText>そうだね</JapaneseText>
      <EnglishText>Yeah.</EnglishText>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>4</Id>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset>274012</PointerOffset>
      <VoiceId>&lt;audio:VSM_220_010_005&gt;</VoiceId>
      <JapaneseText>何があったのです！？</JapaneseText>
      <EnglishText>What happened!?</EnglishText>
      <Notes/>
      <SpeakerId>4</SpeakerId>
      <Id>5</Id>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset>274228</PointerOffset>
      <VoiceId>&lt;audio:VSM_220_010_006&gt;</VoiceId>
      <JapaneseText>……プルートの……
居場所を……見つけ……</JapaneseText>
      <EnglishText>We've...found...Pluto's whereabouts...</EnglishText>
      <Notes/>
      <SpeakerId>5</SpeakerId>
      <Id>6</Id>
      <BubbleId>0</BubbleId>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset>274228</PointerOffset>
      <VoiceId>&lt;audio:VSM_220_010_007&gt;</VoiceId>
      <JapaneseText>頭領のいない間に……
里の精鋭たちで……</JapaneseText>
      <EnglishText>Since chief wasn't here...
The village's best ninja...</EnglishText>
      <Notes/>
      <SpeakerId>5</SpeakerId>
      <Id>6</Id>
      <BubbleId>1</BubbleId>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset>274228</PointerOffset>
      <VoiceId>&lt;audio:VSM_220_010_008&gt;</VoiceId>
      <JapaneseText>しかし……</JapaneseText>
      <EnglishText>But...</EnglishText>
      <Notes/>
      <SpeakerId>5</SpeakerId>
      <Id>6</Id>
      <BubbleId>2</BubbleId>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset>274228</PointerOffset>
      <VoiceId>&lt;audio:VSM_220_010_009&gt;</VoiceId>
      <JapaneseText>ぐふっ……！</JapaneseText>
      <EnglishText>Ugh...</EnglishText>
      <Notes/>
      <SpeakerId>5</SpeakerId>
      <Id>6</Id>
      <BubbleId>3</BubbleId>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset>274304</PointerOffset>
      <VoiceId>&lt;audio:VSM_220_010_010&gt;</VoiceId>
      <JapaneseText>しっかりしてください！</JapaneseText>
      <EnglishText>Please hang in there!</EnglishText>
      <Notes/>
      <SpeakerId>4</SpeakerId>
      <Id>10</Id>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset>274388</PointerOffset>
      <VoiceId>&lt;audio:VSM_220_010_011&gt;</VoiceId>
      <JapaneseText>&lt;Dio&gt;、この人、
屋敷に運ぼう！</JapaneseText>
      <EnglishText>&lt;Dio&gt;! Carry that person inside!</EnglishText>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>11</Id>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset>274448</PointerOffset>
      <VoiceId>&lt;audio:VSM_220_010_012&gt;</VoiceId>
      <JapaneseText>ああ！</JapaneseText>
      <EnglishText>Got it!</EnglishText>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>12</Id>
      <Status>Proofreading</Status>
    </Entry>
