    <Entry>
      <PointerOffset>274356</PointerOffset>
      <JapaneseText>そうそうあなたの留守中に掃除してたら、
棚の奥から、こんなものが
見つかったわよ</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>9</Id>
      <BubbleId>1</BubbleId>
      <Status>To Do</Status>
    </Entry>
