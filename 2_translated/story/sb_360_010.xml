    <Entry>
      <PointerOffset>301044</PointerOffset>
      <JapaneseText>オレンジグミを渡しますか？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <Id>13</Id>
      <Status>To Do</Status>
    </Entry>
  </Speakers>
  <Strings>
    <Section>Main</Section>
    <Entry>
      <PointerOffset>297472</PointerOffset>
      <JapaneseText>おめぇがつかえねぇからだよ！
言う通りに仕事しろよ、この野郎！！
珍妙な服を着やがって</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>1</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>297600</PointerOffset>
      <JapaneseText>なんだすとー！
今のは聞き捨てならんだすよ！！
人なのか牛なのかわからんくせに！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>2</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>297708</PointerOffset>
      <JapaneseText>おーおーおー、
よく言い切りやがったな、
この土色変色野郎が！！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>3</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>297772</PointerOffset>
      <JapaneseText>なんだすとー！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>4</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>297828</PointerOffset>
      <JapaneseText>なーんだよ！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>5</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>297904</PointerOffset>
      <JapaneseText>やーやー、
みなさんこんにちは！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>6</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>298024</PointerOffset>
      <JapaneseText>ここは、夢のアトラクション、
ありじごくでぐーるぐーるの
コーナーだすよ</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>7</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>298112</PointerOffset>
      <JapaneseText>いや、コーナーどうこうより
すっごいケンカしてたシ……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>8</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>298240</PointerOffset>
      <JapaneseText>なーにを、言ってるのか、
サーッパリわからないよー。
ここは、ありじごくコーナーさ！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>9</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>298312</PointerOffset>
      <JapaneseText>コーナーつっても、
なーんもねぇじゃん</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>4</SpeakerId>
      <Id>10</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>298420</PointerOffset>
      <JapaneseText>ちっちっちっ！
目の前にあるだすよ～
こーんな立派なものが！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>11</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>298496</PointerOffset>
      <JapaneseText>ひょっとして、
このありじごく……ですか？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>5</SpeakerId>
      <Id>12</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>298552</PointerOffset>
      <JapaneseText>そゆことー</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>13</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>298656</PointerOffset>
      <JapaneseText>このありじごくにはまって、
キャーとか、ワーとか言って
遊んだりすんの？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>6</SpeakerId>
      <Id>14</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>298756</PointerOffset>
      <JapaneseText>そんなチンケな遊びと
一緒にせんでもらいたいだす</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>15</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>298856</PointerOffset>
      <JapaneseText>この中に何か入れると、
全然違う何かがでてくるんだよ～</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>16</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>298968</PointerOffset>
      <JapaneseText>あー、もー、うぜぇだ！
さっきから何言ってるか、
サーッパリわかんねぇだよ！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>7</SpeakerId>
      <Id>17</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>299084</PointerOffset>
      <JapaneseText>そんな事を言うなら
とりあえず、試してみるかい？
オレンジグミ持ってない？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>18</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>299316</PointerOffset>
      <JapaneseText>ほいほ～い、
あんがちょ∀
それじゃ、早速</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>19</Id>
      <BubbleId>0</BubbleId>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>299316</PointerOffset>
      <JapaneseText>だべよ？　だべか？
そうだべか？？？
ごって、わくわく～～～</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>19</Id>
      <BubbleId>1</BubbleId>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>299416</PointerOffset>
      <JapaneseText>だーーー！
こいつら、捨てただ！！
オレンジグミを捨てたーよ！！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>7</SpeakerId>
      <Id>21</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>299476</PointerOffset>
      <JapaneseText>焦りなさんなって</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>22</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>299612</PointerOffset>
      <JapaneseText>ほいだら、いくだすよ！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>23</Id>
      <BubbleId>0</BubbleId>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>299612</PointerOffset>
      <JapaneseText>マジで？　ジーマー？
本気の本気で？？？
ガス、ガスガス、ガス！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>23</Id>
      <BubbleId>1</BubbleId>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>299676</PointerOffset>
      <JapaneseText>おまっとさんでした！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>25</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>299796</PointerOffset>
      <JapaneseText>さてさて、
今回のお宝はなんだすか～？？
なんだろうだすか～～～？？？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>26</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>299880</PointerOffset>
      <JapaneseText>だかだかだかだかだか～
ざざ～～～～ん！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>27</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>299952</PointerOffset>
      <JapaneseText>今回はアップルグミでした！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>28</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>300056</PointerOffset>
      <JapaneseText>はぁ？
あんで、オレンジグミ渡して
アップルグミが出てくるだーよ？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>7</SpeakerId>
      <Id>29</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>300124</PointerOffset>
      <JapaneseText>そうだよ！
バカにしてるってーの！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>4</SpeakerId>
      <Id>30</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>300224</PointerOffset>
      <JapaneseText>仕方ないよ～。
何が出てくるかは
ありじごく様のご機嫌次第</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>31</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>300324</PointerOffset>
      <JapaneseText>そうだす。
おらたちも、
何が出てくるか知らんだすよ</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>32</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>300376</PointerOffset>
      <JapaneseText>すっごい、適当～</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>6</SpeakerId>
      <Id>33</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>300428</PointerOffset>
      <JapaneseText>クルーリュゥ……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>8</SpeakerId>
      <Id>34</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>300512</PointerOffset>
      <JapaneseText>ちっちゃいことは、
気にしない気にしない</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>35</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>300620</PointerOffset>
      <JapaneseText>そうだすそうだす。
また、気が向いたら、
いつでもくるだすよ</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>36</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>300692</PointerOffset>
      <JapaneseText>ぶーぶー！
けーちけーち！！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>37</Id>
      <Status>To Do</Status>
    </Entry>
