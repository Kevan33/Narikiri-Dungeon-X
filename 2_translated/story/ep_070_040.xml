    <Entry>
      <PointerOffset>272892</PointerOffset>
      <VoiceId>&lt;audio:VSM_070_040_000&gt;</VoiceId>
      <JapaneseText>精霊もあと一体だね</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>1</Id>
      <OldPtr>258612</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>272996</PointerOffset>
      <VoiceId>&lt;audio:VSM_070_040_001&gt;</VoiceId>
      <JapaneseText>イフリート、シルフ、ノーム、
それから、ええと……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>2</Id>
      <OldPtr>258752</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>273068</PointerOffset>
      <VoiceId>&lt;audio:VSM_070_040_002&gt;</VoiceId>
      <JapaneseText>ウンディーネだな！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>3</Id>
      <OldPtr>258948</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>273392</PointerOffset>
      <VoiceId>&lt;audio:VSM_070_040_006&gt;</VoiceId>
      <JapaneseText>ウンディーネってことは
&lt;Red&gt;浸食洞&lt;White&gt;か……あそこはな……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>4</SpeakerId>
      <Id>4</Id>
      <OldPtr>259572</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>273468</PointerOffset>
      <VoiceId>&lt;audio:VSM_070_040_007&gt;</VoiceId>
      <JapaneseText>ん～？　どうしたのかな？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>5</SpeakerId>
      <Id>5</Id>
      <OldPtr>259816</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>273644</PointerOffset>
      <VoiceId>&lt;audio:VSM_070_040_008&gt;</VoiceId>
      <JapaneseText>&lt;Red&gt;浸食洞&lt;White&gt;は現在、
アルヴァニスタの管理下にある</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>4</SpeakerId>
      <Id>6</Id>
      <BubbleId>0</BubbleId>
      <OldPtr>260536</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>273644</PointerOffset>
      <VoiceId>&lt;audio:VSM_070_040_009&gt;</VoiceId>
      <JapaneseText>入るためには、
国王陛下の許可を得る
必要がある。だが……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>4</SpeakerId>
      <Id>6</Id>
      <BubbleId>1</BubbleId>
      <OldPtr>260536</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>273752</PointerOffset>
      <VoiceId>&lt;audio:VSM_070_040_010&gt;</VoiceId>
      <JapaneseText>……王様に会おうなんて
そんな簡単じゃない、
ってこと？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>5</SpeakerId>
      <Id>8</Id>
      <OldPtr>260676</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>274096</PointerOffset>
      <VoiceId>&lt;audio:VSM_070_040_014&gt;</VoiceId>
      <JapaneseText>シャクだが……
あいつを頼ってみるか</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>4</SpeakerId>
      <Id>9</Id>
      <OldPtr>261040</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>274156</PointerOffset>
      <VoiceId>&lt;audio:VSM_070_040_015&gt;</VoiceId>
      <JapaneseText>あいつ？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>10</Id>
      <OldPtr>261236</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>274248</PointerOffset>
      <VoiceId>&lt;audio:VSM_070_040_016&gt;</VoiceId>
      <JapaneseText>バジルだ。
前に会ったことがあるだろう</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>4</SpeakerId>
      <Id>11</Id>
      <OldPtr>261536</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>274336</PointerOffset>
      <VoiceId>&lt;audio:VSM_070_040_017&gt;</VoiceId>
      <JapaneseText>エレメンツポットを
くれた人ですね</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>12</Id>
      <OldPtr>261732</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>274448</PointerOffset>
      <VoiceId>&lt;audio:VSM_070_040_018&gt;</VoiceId>
      <JapaneseText>ああ。ああ見えても、
あいつは陛下の信認厚い
魔法学者の一人だ</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>4</SpeakerId>
      <Id>13</Id>
      <OldPtr>262040</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>274516</PointerOffset>
      <VoiceId>&lt;audio:VSM_070_040_019&gt;</VoiceId>
      <JapaneseText>魔法学者ねぇ……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>5</SpeakerId>
      <Id>14</Id>
      <OldPtr>262180</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>274576</PointerOffset>
      <VoiceId>&lt;audio:VSM_070_040_020&gt;</VoiceId>
      <JapaneseText>なんだ？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>4</SpeakerId>
      <Id>15</Id>
      <OldPtr>262488</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>274676</PointerOffset>
      <VoiceId>&lt;audio:VSM_070_040_021&gt;</VoiceId>
      <JapaneseText>魔法学者って響きが、
なんかうさんくさくってね</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>5</SpeakerId>
      <Id>16</Id>
      <OldPtr>262628</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>274756</PointerOffset>
      <VoiceId>&lt;audio:VSM_070_040_022&gt;</VoiceId>
      <JapaneseText>……私も一応、魔法学者だが</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>4</SpeakerId>
      <Id>17</Id>
      <OldPtr>262768</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>274836</PointerOffset>
      <VoiceId>&lt;audio:VSM_070_040_023&gt;</VoiceId>
      <JapaneseText>&lt;Claus&gt;はいいのよ、
&lt;Claus&gt;は</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>5</SpeakerId>
      <Id>18</Id>
      <OldPtr>262908</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>274952</PointerOffset>
      <VoiceId>&lt;audio:VSM_070_040_024&gt;</VoiceId>
      <JapaneseText>バジルさんに
お願いすれば&lt;Red&gt;浸食洞&lt;White&gt;に
入る許可がもらえるんですね</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>19</Id>
      <OldPtr>263104</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>275048</PointerOffset>
      <VoiceId>&lt;audio:VSM_070_040_025&gt;</VoiceId>
      <JapaneseText>あの人、&lt;Red&gt;ヴァルハラ村&lt;White&gt;に
いるんだよな？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>20</Id>
      <OldPtr>263412</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>275232</PointerOffset>
      <VoiceId>&lt;audio:VSM_070_040_027&gt;</VoiceId>
      <JapaneseText>とにかく行ってみよう</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>4</SpeakerId>
      <Id>21</Id>
      <OldPtr>263720</OldPtr>
      <Status>To Do</Status>
    </Entry>
