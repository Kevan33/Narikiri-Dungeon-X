    <Section>Main</Section>
    <Entry>
      <PointerOffset>289284</PointerOffset>
      <VoiceId>&lt;audio:VSM_310_020_001&gt;</VoiceId>
      <JapaneseText>おまえたちは
ダオス様には会えぬ！</JapaneseText>
      <EnglishText>You will not reach Lord Dhaos!</EnglishText>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>1</Id>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset>289348</PointerOffset>
      <VoiceId>&lt;audio:VSM_310_020_002&gt;</VoiceId>
      <JapaneseText>なんだと！？</JapaneseText>
      <EnglishText>What did you say!?</EnglishText>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>2</Id>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset>289452</PointerOffset>
      <VoiceId>&lt;audio:VSM_310_020_003&gt;</VoiceId>
      <JapaneseText>なぜなら、
おまえたちは、
ここで死ぬからだ！</JapaneseText>
      <EnglishText>Because this is where you shall die!</EnglishText>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>3</Id>
      <Status>Proofreading</Status>
    </Entry>
