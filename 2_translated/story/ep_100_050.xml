  <Strings>
    <Section>Main</Section>
    <Entry>
      <PointerOffset>271652</PointerOffset>
      <VoiceId>&lt;audio:VSM_100_050_001Z&gt;</VoiceId>
      <JapaneseText>ああ、きみたち。
無事だったんだ、良かった。
それで、何か用かな</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>1</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>271744</PointerOffset>
      <VoiceId>&lt;audio:VSM_100_050_002&gt;</VoiceId>
      <JapaneseText>はい。その……
また少し話を聞きたくて</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>2</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>271836</PointerOffset>
      <VoiceId>&lt;audio:VSM_100_050_003Z&gt;</VoiceId>
      <JapaneseText>私にわかることなら
協力するが</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>3</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>271936</PointerOffset>
      <VoiceId>&lt;audio:VSM_100_050_004&gt;</VoiceId>
      <JapaneseText>実は精霊の力を
使いこなせる術士を
探していて……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>4</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>272148</PointerOffset>
      <VoiceId>&lt;audio:VSM_100_050_005Z&gt;</VoiceId>
      <JapaneseText></JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>5</Id>
      <BubbleId>0</BubbleId>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>272148</PointerOffset>
      <VoiceId>&lt;audio:VSM_100_050_006Z&gt;</VoiceId>
      <JapaneseText>精霊の力だって！　本当に
実在したのか……きみたちは
不思議な力を持っているな術士と言われても……
精霊に会ったことすら
ないんだ</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>5</Id>
      <BubbleId>1</BubbleId>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>272212</PointerOffset>
      <VoiceId>&lt;audio:VSM_100_050_007&gt;</VoiceId>
      <JapaneseText>そんな……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>7</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>272308</PointerOffset>
      <VoiceId>&lt;audio:VSM_100_050_008Z&gt;</VoiceId>
      <JapaneseText>申し訳ないが
私ではわからないな</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>8</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>272368</PointerOffset>
      <VoiceId>&lt;audio:VSM_100_050_009&gt;</VoiceId>
      <JapaneseText>マジか？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>9</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>272480</PointerOffset>
      <VoiceId>&lt;audio:VSM_100_050_010Z&gt;</VoiceId>
      <JapaneseText>きみたちの役に立てれば
よかったんだが、すまない</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>10</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>272552</PointerOffset>
      <VoiceId>&lt;audio:VSM_100_050_011&gt;</VoiceId>
      <JapaneseText>どうしよう、エト……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>11</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>272624</PointerOffset>
      <VoiceId>&lt;audio:VSM_100_050_012&gt;</VoiceId>
      <JapaneseText>一旦、家に戻らない？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>4</SpeakerId>
      <Id>12</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>272724</PointerOffset>
      <VoiceId>&lt;audio:VSM_100_050_013&gt;</VoiceId>
      <JapaneseText>&lt;Red&gt;&lt;White&gt;でも、ヴァルハラを
あのままにしとけねーよ！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>13</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>272840</PointerOffset>
      <VoiceId>&lt;audio:VSM_100_050_014&gt;</VoiceId>
      <JapaneseText></JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>4</SpeakerId>
      <Id>14</Id>
      <BubbleId>0</BubbleId>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>272840</PointerOffset>
      <VoiceId>&lt;audio:VSM_100_050_015&gt;</VoiceId>
      <JapaneseText>だからだよ今は家に戻って
落ち着いて考えよう</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>4</SpeakerId>
      <Id>14</Id>
      <BubbleId>1</BubbleId>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>272928</PointerOffset>
      <VoiceId>&lt;audio:VSM_100_050_016&gt;</VoiceId>
      <JapaneseText>そうだね……
何か方法を
思いつくかも</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>16</Id>
      <Status>To Do</Status>
    </Entry>
