    <Entry>
      <PointerOffset>291596</PointerOffset>
      <JapaneseText>我、今、魔界の者に
ねがいたてまつる</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>1</Id>
      <BubbleId>0</BubbleId>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>291596</PointerOffset>
      <JapaneseText>偉大なる者の盟約のもと、
我に彼の者を従わせたまえ</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>1</Id>
      <BubbleId>1</BubbleId>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>291596</PointerOffset>
      <JapaneseText>我が名は&lt;Dio&gt;</JapaneseText>
