    <Entry>
      <PointerOffset>273580</PointerOffset>
      <VoiceId>&lt;audio:VSM_130_060_000&gt;</VoiceId>
      <JapaneseText>こうして、
ふたりきりで会うのって
久しぶり、だね……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>1</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>273684</PointerOffset>
      <VoiceId>&lt;audio:VSM_130_060_001&gt;</VoiceId>
      <JapaneseText>ダオスと戦う前……
アーリィでお話して以来、
ですね</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>2</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>273760</PointerOffset>
      <VoiceId>&lt;audio:VSM_130_060_002&gt;</VoiceId>
      <JapaneseText>えっと……そう、だっけ？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>3</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>273848</PointerOffset>
      <VoiceId>&lt;audio:VSM_130_060_003&gt;</VoiceId>
      <JapaneseText>あれから……１年半も
経ったんですね</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>4</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>273960</PointerOffset>
      <VoiceId>&lt;audio:VSM_130_060_004&gt;</VoiceId>
      <JapaneseText></JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>5</Id>
      <BubbleId>0</BubbleId>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>273960</PointerOffset>
      <VoiceId>&lt;audio:VSM_130_060_005&gt;</VoiceId>
      <JapaneseText>１年半……？……そうか。
もうそんなに……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>5</Id>
      <BubbleId>1</BubbleId>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>274048</PointerOffset>
      <VoiceId>&lt;audio:VSM_130_060_006&gt;</VoiceId>
      <JapaneseText>僕たち、本当に
これでいいのかな……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>7</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
