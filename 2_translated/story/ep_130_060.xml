      <VoiceId>&lt;audio:VSM_130_060_010&gt;</VoiceId>
      <JapaneseText>&lt;Cless&gt;さん……？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>8</Id>
      <Status>To Do</Status>
    </Entry>
