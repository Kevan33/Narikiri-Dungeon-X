    <Entry>
      <PointerOffset>274600</PointerOffset>
      <VoiceId>&lt;audio:VSM_130_060_013&gt;</VoiceId>
      <JapaneseText>戦ってる時は
無我夢中だった父さんたちの仇を取りたい、
使命を引き継ぎたいって
ずっと思ってたなのに、終わってみれば、
世界を救った英雄として、
まつりあげられて</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>9</Id>
      <BubbleId>2</BubbleId>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>274788</PointerOffset>
      <VoiceId>&lt;audio:VSM_130_060_014&gt;</VoiceId>
      <JapaneseText>&lt;Cless&gt;</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>12</Id>
      <BubbleId>0</BubbleId>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>274788</PointerOffset>
      <VoiceId>&lt;audio:VSM_130_060_015&gt;</VoiceId>
      <JapaneseText>……さんは、
英雄として、人々のために
がんばってます私は……本当に
皆さんのご期待に
添えているのでしょうか？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>12</Id>
      <BubbleId>1</BubbleId>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>274948</PointerOffset>
      <VoiceId>&lt;audio:VSM_130_060_016&gt;</VoiceId>
      <JapaneseText>&lt;Mint&gt;</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>14</Id>
      <BubbleId>0</BubbleId>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>274948</PointerOffset>
      <VoiceId>&lt;audio:VSM_130_060_017&gt;</VoiceId>
      <JapaneseText>何言ってるんだ、君は十分にみんなの声を
聞いてるし、みんなに
喜ばれてるじゃないか</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>14</Id>
      <BubbleId>1</BubbleId>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>275116</PointerOffset>
      <VoiceId>&lt;audio:VSM_130_060_018&gt;</VoiceId>
      <JapaneseText></JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>16</Id>
      <BubbleId>0</BubbleId>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>275116</PointerOffset>
      <VoiceId>&lt;audio:VSM_130_060_019&gt;</VoiceId>
      <JapaneseText>……確かに法術師の力を
使えば、皆さんの体を
治すことはできますでも、人の心までは
治せないんです</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>16</Id>
      <BubbleId>1</BubbleId>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>275472</PointerOffset>
      <VoiceId>&lt;audio:VSM_130_060_023&gt;</VoiceId>
      <JapaneseText>&lt;Mint&gt;……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>18</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>275576</PointerOffset>
      <VoiceId>&lt;audio:VSM_130_060_024&gt;</VoiceId>
      <JapaneseText>&lt;Cless&gt;さんの
心ひとつだって……
私には治せない……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>19</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>275660</PointerOffset>
      <VoiceId>&lt;audio:VSM_130_060_025&gt;</VoiceId>
      <JapaneseText>そんな……僕は
君さえいれば……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>20</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>275728</PointerOffset>
      <VoiceId>&lt;audio:VSM_130_060_026&gt;</VoiceId>
      <JapaneseText>&lt;Cless&gt;さん……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>21</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>275824</PointerOffset>
      <VoiceId>&lt;audio:VSM_130_060_027&gt;</VoiceId>
      <JapaneseText>……僕たちはどこへ
流されていくんだろう……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>22</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>275932</PointerOffset>
      <VoiceId>&lt;audio:VSM_130_060_028&gt;</VoiceId>
      <JapaneseText>&lt;Cless&gt;どこへだって……
さんと一緒なら
……私は平気ですよ</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>23</Id>
      <Status>To Do</Status>
