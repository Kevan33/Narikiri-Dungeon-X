      <PointerOffset>276064</PointerOffset>
      <VoiceId>&lt;audio:VSM_020_010_005&gt;</VoiceId>
      <JapaneseText>もともとここは貧しい人が
集まってできた街だったかラあれって、
何年前だったんだっけ？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>4</Id>
