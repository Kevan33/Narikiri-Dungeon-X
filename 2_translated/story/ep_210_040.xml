    <Entry>
      <PointerOffset>274112</PointerOffset>
      <VoiceId>&lt;audio:VSM_210_040_001&gt;</VoiceId>
      <JapaneseText>はい！　いっちょ上がり</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>1</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>274216</PointerOffset>
      <VoiceId>&lt;audio:VSM_210_040_002&gt;</VoiceId>
      <JapaneseText>&lt;Dio&gt;さすが、！
なかなかやるじゃないか</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>2</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>274280</PointerOffset>
      <VoiceId>&lt;audio:VSM_210_040_003&gt;</VoiceId>
      <JapaneseText>えっへへー</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>3</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>274364</PointerOffset>
      <VoiceId>&lt;audio:VSM_210_040_004&gt;</VoiceId>
      <JapaneseText>洗濯物のお手伝い、
終わったよ！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>4</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>274468</PointerOffset>
      <VoiceId>&lt;audio:VSM_210_040_005&gt;</VoiceId>
      <JapaneseText>&lt;Suzu&gt;んじゃあ、ひと休み。
ちゃん、アイス食べるか？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>5</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>274540</PointerOffset>
      <VoiceId>&lt;audio:VSM_210_040_006&gt;</VoiceId>
      <JapaneseText>え？　あ、は、はい！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>4</SpeakerId>
      <Id>6</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>274636</PointerOffset>
      <VoiceId>&lt;audio:VSM_210_040_007&gt;</VoiceId>
      <JapaneseText>アイス屋さんだったら、
噴水広場の方にいたよ</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>7</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>274728</PointerOffset>
      <VoiceId>&lt;audio:VSM_210_040_008&gt;</VoiceId>
      <JapaneseText>じゃ、広場まで駆けっこだ！
ヨーイ……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>8</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>274800</PointerOffset>
      <VoiceId>&lt;audio:VSM_210_040_009&gt;</VoiceId>
      <JapaneseText>&lt;Dio&gt;！　ずるい！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>9</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>274904</PointerOffset>
      <VoiceId>&lt;audio:VSM_210_040_010&gt;</VoiceId>
      <JapaneseText>わかっています、
私にもこんな可能性が
あったことを</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>4</SpeakerId>
      <Id>10</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>275112</PointerOffset>
      <VoiceId>&lt;audio:VSM_210_040_012&gt;</VoiceId>
      <JapaneseText>そこに忍びの頭領でないわたしが
いるかもしれない可能性を</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>4</SpeakerId>
      <Id>11</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>275208</PointerOffset>
      <VoiceId>&lt;audio:VSM_210_040_013&gt;</VoiceId>
      <JapaneseText>だったら、
忍びの頭領なんて、
やめればいい</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>5</SpeakerId>
      <Id>12</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>275412</PointerOffset>
      <VoiceId>&lt;audio:VSM_210_040_015&gt;</VoiceId>
      <JapaneseText>自分の好きな道を
好きなように進めばいい</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>5</SpeakerId>
      <Id>13</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>275560</PointerOffset>
      <VoiceId>&lt;audio:VSM_210_040_016&gt;</VoiceId>
      <JapaneseText></JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>4</SpeakerId>
      <Id>14</Id>
      <BubbleId>0</BubbleId>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>275560</PointerOffset>
      <VoiceId>&lt;audio:VSM_210_040_017&gt;</VoiceId>
      <JapaneseText>私は
その可能性を知りながら、
敢えてこの道を選んだのです……幻術よ、去れ！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>4</SpeakerId>
      <Id>14</Id>
      <BubbleId>1</BubbleId>
      <Status>To Do</Status>
    </Entry>
