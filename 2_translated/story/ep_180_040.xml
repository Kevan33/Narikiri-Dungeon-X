    <Entry>
      <PointerOffset>294216</PointerOffset>
      <VoiceId>&lt;audio:VSM_180_040_001&gt;</VoiceId>
      <JapaneseText>マザーコンピュータールームへようこそ</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>1</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>294292</PointerOffset>
      <VoiceId>&lt;audio:VSM_180_040_002&gt;</VoiceId>
      <JapaneseText>うぉっ！　でけー顔！？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>2</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>294424</PointerOffset>
      <VoiceId>&lt;audio:VSM_180_040_003&gt;</VoiceId>
      <JapaneseText>&lt;Red&gt;&lt;White&gt;私はトールシティの全機能をサポートする
マザーコンピューターシステム・オズ</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>3</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>294508</PointerOffset>
      <VoiceId>&lt;audio:VSM_180_040_004&gt;</VoiceId>
      <JapaneseText>これで時間転移できる
ってわけね</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>4</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>294644</PointerOffset>
      <VoiceId>&lt;audio:VSM_180_040_005&gt;</VoiceId>
      <JapaneseText>時を犯そうとする愚か者よ、
あなた方にここのシステムを
使わせるわけにはいきません</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>4</SpeakerId>
      <Id>5</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>294704</PointerOffset>
      <VoiceId>&lt;audio:VSM_180_040_006&gt;</VoiceId>
      <JapaneseText>誰……？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>5</SpeakerId>
      <Id>6</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>294768</PointerOffset>
      <VoiceId>&lt;audio:VSM_180_040_007&gt;</VoiceId>
      <JapaneseText>アスカ……！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>6</SpeakerId>
      <Id>7</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>294852</PointerOffset>
      <VoiceId>&lt;audio:VSM_180_040_008&gt;</VoiceId>
      <JapaneseText>これは今の人の手には
あまる技術</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>7</SpeakerId>
      <Id>8</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>295056</PointerOffset>
      <VoiceId>&lt;audio:VSM_180_040_010&gt;</VoiceId>
      <JapaneseText>強引にでも使うというのであれば、
私はそれを阻止します</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>7</SpeakerId>
      <Id>9</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>295156</PointerOffset>
      <VoiceId>&lt;audio:VSM_180_040_011&gt;</VoiceId>
      <JapaneseText>あんたをぶっ倒せば、
使ってもいいってことだな</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>10</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>295288</PointerOffset>
      <VoiceId>&lt;audio:VSM_180_040_012&gt;</VoiceId>
      <JapaneseText></JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>7</SpeakerId>
      <Id>11</Id>
      <BubbleId>0</BubbleId>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>295288</PointerOffset>
      <VoiceId>&lt;audio:VSM_180_040_013&gt;</VoiceId>
      <JapaneseText>なかなかいい覚悟ですしかし、あなた方に
私を倒せるでしょうか</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>7</SpeakerId>
      <Id>11</Id>
      <BubbleId>1</BubbleId>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>295400</PointerOffset>
      <VoiceId>&lt;audio:VSM_180_040_014&gt;</VoiceId>
      <JapaneseText>倒します。
わたしたちは自分の時代に
戻らなきゃいけないから</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>5</SpeakerId>
      <Id>13</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>295476</PointerOffset>
      <VoiceId>&lt;audio:VSM_180_040_015&gt;</VoiceId>
      <JapaneseText>いいでしょう、来なさい！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>7</SpeakerId>
      <Id>14</Id>
      <Status>To Do</Status>
    </Entry>
