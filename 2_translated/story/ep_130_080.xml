    </Entry>
    <Entry>
      <PointerOffset>281652</PointerOffset>
      <VoiceId>&lt;audio:VSM_130_080_001&gt;</VoiceId>
      <JapaneseText>さんも、さんも……なんか思ってたのと
全然違った……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>1</Id>
      <BubbleId>1</BubbleId>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>281744</PointerOffset>
      <VoiceId>&lt;audio:VSM_130_080_002&gt;</VoiceId>
      <JapaneseText>英雄っていうのとは、
違う感じがするよね</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>3</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>281824</PointerOffset>
      <VoiceId>&lt;audio:VSM_130_080_003&gt;</VoiceId>
      <JapaneseText>なんか、
がっかりなんだよな</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>4</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>281908</PointerOffset>
      <VoiceId>&lt;audio:VSM_130_080_004&gt;</VoiceId>
      <JapaneseText>そう？
わたしは親近感湧いたけど</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>5</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>281972</PointerOffset>
      <VoiceId>&lt;audio:VSM_130_080_005&gt;</VoiceId>
      <JapaneseText>う～ん……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>6</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>282212</PointerOffset>
      <VoiceId>&lt;audio:VSM_130_080_008&gt;</VoiceId>
      <JapaneseText>やぁ、ふたりとも</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>7</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>282368</PointerOffset>
      <VoiceId>&lt;audio:VSM_130_080_009&gt;</VoiceId>
      <JapaneseText>&lt;Cless&gt;&lt;Mint&gt;</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>8</Id>
      <BubbleId>0</BubbleId>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>282368</PointerOffset>
      <VoiceId>&lt;audio:VSM_130_080_010&gt;</VoiceId>
      <JapaneseText>あ、さん、さんゴメンなさい……
代わりなんて言ってて
全然役に立てなくて</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>8</Id>
      <BubbleId>1</BubbleId>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>282516</PointerOffset>
      <VoiceId>&lt;audio:VSM_130_080_011&gt;</VoiceId>
      <JapaneseText></JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>4</SpeakerId>
      <Id>10</Id>
      <BubbleId>0</BubbleId>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>282516</PointerOffset>
      <VoiceId>&lt;audio:VSM_130_080_012&gt;</VoiceId>
      <JapaneseText>いいえ……皆さん、
喜んでくださっていましたよあなたは
とても聞き上手だって</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>4</SpeakerId>
      <Id>10</Id>
      <BubbleId>1</BubbleId>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>282584</PointerOffset>
      <VoiceId>&lt;audio:VSM_130_080_013&gt;</VoiceId>
      <JapaneseText>本当ですか……？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>12</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>282668</PointerOffset>
      <VoiceId>&lt;audio:VSM_130_080_014&gt;</VoiceId>
      <JapaneseText>それにカワイイって
評判でした</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>4</SpeakerId>
      <Id>13</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>282744</PointerOffset>
      <VoiceId>&lt;audio:VSM_130_080_015&gt;</VoiceId>
      <JapaneseText>&lt;Dio&gt;も。
ありがとう</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>14</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>282904</PointerOffset>
      <VoiceId>&lt;audio:VSM_130_080_016&gt;</VoiceId>
      <JapaneseText>&lt;Cless&gt;</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>15</Id>
      <BubbleId>0</BubbleId>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>282904</PointerOffset>
      <VoiceId>&lt;audio:VSM_130_080_017&gt;</VoiceId>
      <JapaneseText>&lt;Cless&gt;オレ……
あんまうまくさんの
代わり、できなかったさんの
役に立ちたかったのに</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>15</Id>
      <BubbleId>1</BubbleId>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>283060</PointerOffset>
      <VoiceId>&lt;audio:VSM_130_080_018&gt;</VoiceId>
      <JapaneseText></JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>17</Id>
      <BubbleId>0</BubbleId>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>283060</PointerOffset>
      <VoiceId>&lt;audio:VSM_130_080_019&gt;</VoiceId>
      <JapaneseText>十分だよ。おかげで
僕たちもゆっくり
会う時間ができたしさて、と……
僕はこれで行くよ</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>17</Id>
      <BubbleId>1</BubbleId>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>283144</PointerOffset>
      <VoiceId>&lt;audio:VSM_130_080_020&gt;</VoiceId>
      <JapaneseText>&lt;Cless&gt;私もさんと
一緒に行きます</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>4</SpeakerId>
      <Id>19</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>283212</PointerOffset>
      <VoiceId>&lt;audio:VSM_130_080_021&gt;</VoiceId>
      <JapaneseText>&lt;Mint&gt;、君は……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>20</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>283388</PointerOffset>
      <VoiceId>&lt;audio:VSM_130_080_022&gt;</VoiceId>
      <JapaneseText></JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>4</SpeakerId>
      <Id>21</Id>
      <BubbleId>0</BubbleId>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>283388</PointerOffset>
      <VoiceId>&lt;audio:VSM_130_080_023&gt;</VoiceId>
      <JapaneseText>村の人たちに行ってきなさいと
言われましたケガをする方もいるでしょう。
法術師の力は
必要じゃありませんか？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>4</SpeakerId>
      <Id>21</Id>
      <BubbleId>1</BubbleId>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>283472</PointerOffset>
      <VoiceId>&lt;audio:VSM_130_080_024&gt;</VoiceId>
      <JapaneseText>いいや……助かるよ。
ありがとう</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>23</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>283540</PointerOffset>
      <VoiceId>&lt;audio:VSM_130_080_025&gt;</VoiceId>
      <JapaneseText>いえ……それに私</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>4</SpeakerId>
      <Id>24</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>283624</PointerOffset>
      <VoiceId>&lt;audio:VSM_130_080_026&gt;</VoiceId>
      <JapaneseText>&lt;Cless&gt;さんのそばで
戦いたいから</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>4</SpeakerId>
      <Id>25</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>283696</PointerOffset>
      <VoiceId>&lt;audio:VSM_130_080_027&gt;</VoiceId>
      <JapaneseText>……オレも行くよ！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>26</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>283760</PointerOffset>
      <VoiceId>&lt;audio:VSM_130_080_028&gt;</VoiceId>
      <JapaneseText>クルール？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>5</SpeakerId>
      <Id>27</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>283848</PointerOffset>
      <VoiceId>&lt;audio:VSM_130_080_029&gt;</VoiceId>
      <JapaneseText>&lt;Dio&gt;、突然、
何を言い出すの！？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>6</SpeakerId>
      <Id>28</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>284092</PointerOffset>
      <VoiceId>&lt;audio:VSM_130_080_030&gt;</VoiceId>
      <JapaneseText>&lt;Mel&gt;&lt;Mint&gt;</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>29</Id>
      <BubbleId>0</BubbleId>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>284092</PointerOffset>
      <VoiceId>&lt;audio:VSM_130_080_031&gt;</VoiceId>
      <JapaneseText>&lt;Cless&gt;</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>29</Id>
      <BubbleId>1</BubbleId>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>284092</PointerOffset>
      <VoiceId>&lt;audio:VSM_130_080_032&gt;</VoiceId>
      <JapaneseText>はちゃんと
さんの代わりできたのに、
オレ、ダメだったから……オレ、ちゃんと、
さんの力になりたい！オレの力でできること、
やりたいんだ！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>29</Id>
      <BubbleId>2</BubbleId>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>284184</PointerOffset>
      <VoiceId>&lt;audio:VSM_130_080_033&gt;</VoiceId>
      <JapaneseText>わかってるの！？
ぼくたちの目的は……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>6</SpeakerId>
      <Id>32</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>284312</PointerOffset>
      <VoiceId>&lt;audio:VSM_130_080_034&gt;</VoiceId>
      <JapaneseText></JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>33</Id>
      <BubbleId>0</BubbleId>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>284312</PointerOffset>
      <VoiceId>&lt;audio:VSM_130_080_035&gt;</VoiceId>
      <JapaneseText>虹輪はノルンの力が
抑えてくれてんだろ？少しくらいは……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>33</Id>
      <BubbleId>1</BubbleId>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>284380</PointerOffset>
      <VoiceId>&lt;audio:VSM_130_080_036&gt;</VoiceId>
      <JapaneseText>そうだけド……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>6</SpeakerId>
      <Id>35</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>284560</PointerOffset>
      <VoiceId>&lt;audio:VSM_130_080_037&gt;</VoiceId>
      <JapaneseText></JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>36</Id>
      <BubbleId>0</BubbleId>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>284560</PointerOffset>
      <VoiceId>&lt;audio:VSM_130_080_038&gt;</VoiceId>
      <JapaneseText>協力はありがたいし、
前に戦って
君の実力はわかってるでも、敵は誰も
手加減してくれないし、
情けも容赦もない</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>36</Id>
      <BubbleId>1</BubbleId>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>284656</PointerOffset>
      <VoiceId>&lt;audio:VSM_130_080_039&gt;</VoiceId>
      <JapaneseText>足手まといになんなら、
捨ててってくれていい</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>38</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>284744</PointerOffset>
      <VoiceId>&lt;audio:VSM_130_080_040&gt;</VoiceId>
      <JapaneseText>……わかった。
その覚悟があるなら</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>39</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>284848</PointerOffset>
      <VoiceId>&lt;audio:VSM_130_080_041&gt;</VoiceId>
      <JapaneseText>&lt;Dio&gt;わたしも行きます。
ひとりじゃ
心配すぎるから</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>40</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>284912</PointerOffset>
      <VoiceId>&lt;audio:VSM_130_080_042&gt;</VoiceId>
      <JapaneseText>クルール！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>5</SpeakerId>
      <Id>41</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>285140</PointerOffset>
      <VoiceId>&lt;audio:VSM_130_080_045&gt;</VoiceId>
      <JapaneseText>それから、これを……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>4</SpeakerId>
      <Id>42</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>285204</PointerOffset>
      <VoiceId>&lt;audio:VSM_130_080_046&gt;</VoiceId>
      <JapaneseText>これは……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>43</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>285320</PointerOffset>
      <VoiceId>&lt;audio:VSM_130_080_047&gt;</VoiceId>
      <JapaneseText>聖なる力がきっと
あなたたちの今後の戦いを
支えてくれるはずです</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>4</SpeakerId>
      <Id>44</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>285392</PointerOffset>
      <VoiceId>&lt;audio:VSM_130_080_048&gt;</VoiceId>
      <JapaneseText>ありがとうございます</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>45</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>285008</PointerOffset>
      <VoiceId>&lt;audio:VSM_130_080_043&gt;</VoiceId>
      <JapaneseText>それじゃあ、
準備が済んだら
出発するとしよう</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>46</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>285068</PointerOffset>
      <VoiceId>&lt;audio:VSM_130_080_044&gt;</VoiceId>
      <JapaneseText>…………</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>6</SpeakerId>
      <Id>47</Id>
      <Status>To Do</Status>
    </Entry>
