    <Entry>
      <PointerOffset>272472</PointerOffset>
      <VoiceId>&lt;audio:VSM_320_040_001&gt;</VoiceId>
      <JapaneseText>……驚きの頭脳だな……
まだ１３だと言うのに</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>1</Id>
      <BubbleId>0</BubbleId>
      <OldPtr>260656</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>272472</PointerOffset>
      <VoiceId>&lt;audio:VSM_320_040_002&gt;</VoiceId>
      <JapaneseText>おまえのその頭脳は、
いつか我が国を支える、
偉大な財産となる</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>1</Id>
      <BubbleId>1</BubbleId>
      <OldPtr>260656</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>272472</PointerOffset>
      <VoiceId>&lt;audio:VSM_320_040_003&gt;</VoiceId>
      <JapaneseText>よく学べ、メルティア。
おまえは私の自慢の娘だ</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>1</Id>
      <BubbleId>2</BubbleId>
      <OldPtr>260656</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>272536</PointerOffset>
      <VoiceId>&lt;audio:VSM_320_040_004&gt;</VoiceId>
      <JapaneseText>…………</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>4</Id>
      <OldPtr>260796</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>272764</PointerOffset>
      <VoiceId>&lt;audio:VSM_320_040_005&gt;</VoiceId>
      <JapaneseText>わたしは本当の親に
いらないと言われて
捨てられた</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>5</Id>
      <BubbleId>0</BubbleId>
      <OldPtr>261308</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>272764</PointerOffset>
      <VoiceId>&lt;audio:VSM_320_040_006&gt;</VoiceId>
      <JapaneseText>ずっと、誰かに
必要とされたかった</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>5</Id>
      <BubbleId>1</BubbleId>
      <OldPtr>261308</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>272764</PointerOffset>
      <VoiceId>&lt;audio:VSM_320_040_007&gt;</VoiceId>
      <JapaneseText>だから、
１３歳のわたしは、
魔科学研究者を志したの</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>5</Id>
      <BubbleId>2</BubbleId>
      <OldPtr>261308</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>272848</PointerOffset>
      <VoiceId>&lt;audio:VSM_320_040_008&gt;</VoiceId>
      <JapaneseText>そして
魔科学兵器を作ったんだ</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>8</Id>
      <OldPtr>261652</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>273236</PointerOffset>
      <VoiceId>&lt;audio:VSM_320_040_009&gt;</VoiceId>
      <JapaneseText>そう、お父様に
喜んでいただくため</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>9</Id>
      <BubbleId>0</BubbleId>
      <OldPtr>261792</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>273236</PointerOffset>
      <VoiceId>&lt;audio:VSM_320_040_010&gt;</VoiceId>
      <JapaneseText>そうすれば、
わたしはずっとお父様に
必要とされる</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>9</Id>
      <BubbleId>1</BubbleId>
      <OldPtr>261792</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>273236</PointerOffset>
      <VoiceId>&lt;audio:VSM_320_040_011&gt;</VoiceId>
      <JapaneseText>でも、わたしには、
いつも恐怖があった</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>9</Id>
      <BubbleId>2</BubbleId>
      <OldPtr>261792</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>273236</PointerOffset>
      <VoiceId>&lt;audio:VSM_320_040_012&gt;</VoiceId>
      <JapaneseText>もし、何もできなくなったら、
わたしはまたいらないって
言われるんじゃないかって</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>9</Id>
      <BubbleId>3</BubbleId>
      <OldPtr>261792</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>273236</PointerOffset>
      <VoiceId>&lt;audio:VSM_320_040_013&gt;</VoiceId>
      <JapaneseText>だから、必死でがんばったの。
お父様に愛される子でいるために</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>9</Id>
      <BubbleId>4</BubbleId>
      <OldPtr>261792</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>273400</PointerOffset>
      <VoiceId>&lt;audio:VSM_320_040_014&gt;</VoiceId>
      <JapaneseText>本当に、そう？
そこまでしなくても、
あなたを……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>14</Id>
      <BubbleId>0</BubbleId>
      <OldPtr>262196</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>273400</PointerOffset>
      <VoiceId>&lt;audio:VSM_320_040_015&gt;</VoiceId>
      <JapaneseText>わたしを
必要としてくれる人は、
他にも……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>14</Id>
      <BubbleId>1</BubbleId>
      <OldPtr>262196</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>273600</PointerOffset>
      <VoiceId>&lt;audio:VSM_320_040_016&gt;</VoiceId>
      <JapaneseText>あなたにはわからない！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>16</Id>
      <BubbleId>0</BubbleId>
      <OldPtr>262596</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>273600</PointerOffset>
      <VoiceId>&lt;audio:VSM_320_040_017&gt;</VoiceId>
      <JapaneseText>あなたが妬ましかった。
不必要だと言われることなく、</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>16</Id>
      <BubbleId>1</BubbleId>
      <OldPtr>262596</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>273600</PointerOffset>
      <VoiceId>&lt;audio:VSM_320_040_018&gt;</VoiceId>
      <JapaneseText>常に何者かに
守られているあなたが</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>16</Id>
      <BubbleId>2</BubbleId>
      <OldPtr>262596</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>273668</PointerOffset>
      <VoiceId>&lt;audio:VSM_320_040_019&gt;</VoiceId>
      <JapaneseText>わたし、は……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>19</Id>
      <OldPtr>263124</OldPtr>
      <Status>To Do</Status>
    </Entry>
  </Strings>
