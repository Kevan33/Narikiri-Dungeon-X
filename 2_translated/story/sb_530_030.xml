  <Strings>
    <Section>Main</Section>
    <Entry>
      <PointerOffset>273188</PointerOffset>
      <JapaneseText>くっ……やりますね、
正解です</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>1</Id>
      <OldPtr>259728</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>273272</PointerOffset>
      <JapaneseText>正解……はっ！
あ、ありがとうございます</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>2</Id>
      <OldPtr>259924</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>273340</PointerOffset>
      <JapaneseText>……やっとご飯が食べられます</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>3</Id>
      <OldPtr>260064</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>274560</PointerOffset>
      <JapaneseText>だ、ダメです……
不正解です</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>4</Id>
      <OldPtr>260332</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>274656</PointerOffset>
      <JapaneseText>わたしたちが食べたかったのは
これじゃありません……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>5</Id>
      <OldPtr>260472</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>274732</PointerOffset>
      <JapaneseText>……お、お腹が
空きすぎまくりです</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>6</Id>
      <OldPtr>260612</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>273536</PointerOffset>
      <JapaneseText>本当にありがとう！
これでお店もあの子達も助かるわ</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>4</SpeakerId>
      <Id>7</Id>
      <BubbleId>0</BubbleId>
      <OldPtr>262072</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>273536</PointerOffset>
      <JapaneseText>店長も&lt;Mel&gt;ちゃんのこと
ウェイトレス、いや、
かわいいメイドさんのようだー！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>4</SpeakerId>
      <Id>7</Id>
      <BubbleId>1</BubbleId>
      <OldPtr>262072</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>273536</PointerOffset>
      <JapaneseText>……って
大絶賛だったわ</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>4</SpeakerId>
      <Id>7</Id>
      <BubbleId>2</BubbleId>
      <OldPtr>262072</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>273600</PointerOffset>
      <JapaneseText>あははは……
よ、よかったです</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>5</SpeakerId>
      <Id>10</Id>
      <OldPtr>262212</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>273708</PointerOffset>
      <JapaneseText>いや、それにしても
あいつらおかしいだろ！？
本当に誰得なんだよ、こんなの？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>6</SpeakerId>
      <Id>11</Id>
      <OldPtr>262352</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>273916</PointerOffset>
      <JapaneseText>そうね、普通はそうかもしれない。
でもね、ここはみんなが笑顔になれる、
そんなお店を目指しているの</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>4</SpeakerId>
      <Id>12</Id>
      <BubbleId>0</BubbleId>
      <OldPtr>262492</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>273916</PointerOffset>
      <JapaneseText>だから、あの子達も例外じゃない。
ただご飯が美味しいだけじゃダメなの</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>4</SpeakerId>
      <Id>12</Id>
      <BubbleId>1</BubbleId>
      <OldPtr>262492</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>273980</PointerOffset>
      <JapaneseText>……方向性違うんじゃないか？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>6</SpeakerId>
      <Id>14</Id>
      <OldPtr>262632</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>274100</PointerOffset>
      <JapaneseText>わたしはいいと思うな、それ。
ウェイトレスさん、よかったら
こんどまたお手伝いしますね</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>5</SpeakerId>
      <Id>15</Id>
      <OldPtr>262772</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>274196</PointerOffset>
      <JapaneseText>本当に？　ありがとう！
あ、そうだ。これはお礼ね∀</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>4</SpeakerId>
      <Id>16</Id>
      <OldPtr>262912</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>274252</PointerOffset>
      <JapaneseText>わあ、いいんですか？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>5</SpeakerId>
      <Id>17</Id>
      <OldPtr>263052</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>274320</PointerOffset>
      <JapaneseText>バイト代だと思って、ね∀</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>4</SpeakerId>
      <Id>18</Id>
      <OldPtr>263192</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>274376</PointerOffset>
      <JapaneseText>ありがとうございます！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>5</SpeakerId>
      <Id>19</Id>
      <OldPtr>263332</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>274492</PointerOffset>
      <JapaneseText>こちらこそ！
ふふ、よかったらまた来てね。
あなたたちならいつでも大歓迎よ</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>4</SpeakerId>
      <Id>20</Id>
      <OldPtr>263472</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>274800</PointerOffset>
      <JapaneseText>ダメだったみたいね……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>4</SpeakerId>
      <Id>21</Id>
      <OldPtr>263620</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>274856</PointerOffset>
      <JapaneseText>ご、ごめんなさい……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>5</SpeakerId>
      <Id>22</Id>
      <OldPtr>263816</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>274964</PointerOffset>
      <JapaneseText>ああ、ううん？　気にしないで？
それより手伝ってくれてありがとう</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>4</SpeakerId>
      <Id>23</Id>
      <OldPtr>263956</OldPtr>
      <Status>To Do</Status>
    </Entry>
