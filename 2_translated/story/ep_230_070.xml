    <Entry>
      <PointerOffset>299916</PointerOffset>
      <VoiceId>&lt;audio:VSM_230_070_001&gt;</VoiceId>
      <JapaneseText>ヴォルト！
オレらに力を貸してくれ！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>1</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>299992</PointerOffset>
      <VoiceId>&lt;audio:VSM_230_070_002&gt;</VoiceId>
      <JapaneseText>あー待って！　あたしも！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>2</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>300076</PointerOffset>
      <VoiceId>&lt;audio:VSM_230_070_003&gt;</VoiceId>
      <JapaneseText>なぁ……
オレたちも行かないか？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>3</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>300168</PointerOffset>
      <VoiceId>&lt;audio:VSM_230_070_004&gt;</VoiceId>
      <JapaneseText>&lt;Arche&gt;なんだ、と
離れがたくなったか？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>4</SpeakerId>
      <Id>4</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>300448</PointerOffset>
      <VoiceId>&lt;audio:VSM_230_070_005&gt;</VoiceId>
      <JapaneseText></JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>5</Id>
      <BubbleId>0</BubbleId>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>300448</PointerOffset>
      <VoiceId>&lt;audio:VSM_230_070_006&gt;</VoiceId>
      <JapaneseText></JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>5</Id>
      <BubbleId>1</BubbleId>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>300448</PointerOffset>
      <VoiceId>&lt;audio:VSM_230_070_007&gt;</VoiceId>
      <JapaneseText>な、何言ってるんだよ、
そんなわけないだろ！オレは、ただ……何の縁か
みんながこうやって、このふたりに
関わることになったんだしだからこいつらのことも、せめて
最後まで見届けてやりたいなって……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>5</Id>
      <BubbleId>2</BubbleId>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>300536</PointerOffset>
      <VoiceId>&lt;audio:VSM_230_070_008&gt;</VoiceId>
      <JapaneseText>そうだな……
よし、僕も一緒に行こう</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>5</SpeakerId>
      <Id>8</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>300600</PointerOffset>
      <VoiceId>&lt;audio:VSM_230_070_009&gt;</VoiceId>
      <JapaneseText>私も一緒に</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>6</SpeakerId>
      <Id>9</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>300668</PointerOffset>
      <VoiceId>&lt;audio:VSM_230_070_010&gt;</VoiceId>
      <JapaneseText>私もお供します</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>7</SpeakerId>
      <Id>10</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>300768</PointerOffset>
      <VoiceId>&lt;audio:VSM_230_070_011&gt;</VoiceId>
      <JapaneseText>やれやれ……
これで私だけ行かないとは
言えないな</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>4</SpeakerId>
      <Id>11</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>300868</PointerOffset>
      <VoiceId>&lt;audio:VSM_230_070_012&gt;</VoiceId>
      <JapaneseText>……えっと……
ありがとう……？
とは違うか……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>12</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>300964</PointerOffset>
      <VoiceId>&lt;audio:VSM_230_070_013&gt;</VoiceId>
      <JapaneseText>何も言うなって。
オレたちが好きで
行くだけだ</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>13</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>301032</PointerOffset>
      <VoiceId>&lt;audio:VSM_230_070_014&gt;</VoiceId>
      <JapaneseText>じゃあ、戻ろう</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>5</SpeakerId>
      <Id>14</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>301132</PointerOffset>
      <VoiceId>&lt;audio:VSM_230_070_015&gt;</VoiceId>
      <JapaneseText>ちょっ、待ってよ、
こんな人数乗れんの、この機械</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>15</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>301208</PointerOffset>
      <VoiceId>&lt;audio:VSM_230_070_016&gt;</VoiceId>
      <JapaneseText>まあ、なんとかなるだろう</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>4</SpeakerId>
      <Id>16</Id>
      <Status>To Do</Status>
    </Entry>
