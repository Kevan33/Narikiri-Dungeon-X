    <Entry>
      <PointerOffset>273588</PointerOffset>
      <VoiceId>&lt;audio:VSM_190_040_001&gt;</VoiceId>
      <JapaneseText>&lt;Rody&gt;そう言えば、
はなんでいんだ？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>1</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>273696</PointerOffset>
      <VoiceId>&lt;audio:VSM_190_040_002&gt;</VoiceId>
      <JapaneseText>時間転移装置使って、
ダオスを追ったんじゃ
ないんですか？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>2</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>273760</PointerOffset>
      <VoiceId>&lt;audio:VSM_190_040_003&gt;</VoiceId>
      <JapaneseText>クルール？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>3</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>273844</PointerOffset>
      <VoiceId>&lt;audio:VSM_190_040_004&gt;</VoiceId>
      <JapaneseText>それが、その装置が
壊れててさ</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>4</SpeakerId>
      <Id>4</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>273908</PointerOffset>
      <VoiceId>&lt;audio:VSM_190_040_005&gt;</VoiceId>
      <JapaneseText>…………！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>5</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>274016</PointerOffset>
      <VoiceId>&lt;audio:VSM_190_040_006&gt;</VoiceId>
      <JapaneseText>もしかして……
オレらが元の時代に
戻れなかったのも……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>6</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>274204</PointerOffset>
      <VoiceId>&lt;audio:VSM_190_040_007&gt;</VoiceId>
      <JapaneseText></JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>4</SpeakerId>
      <Id>7</Id>
      <BubbleId>0</BubbleId>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>274204</PointerOffset>
      <VoiceId>&lt;audio:VSM_190_040_008&gt;</VoiceId>
      <JapaneseText>&lt;Suzu&gt;</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>4</SpeakerId>
      <Id>7</Id>
      <BubbleId>1</BubbleId>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>274204</PointerOffset>
      <VoiceId>&lt;audio:VSM_190_040_009&gt;</VoiceId>
      <JapaneseText>ご名答それで、私は昔なじみの
ちゃんのお家にご厄介にそしたら君たちが
捕まってた、と。
ね？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>4</SpeakerId>
      <Id>7</Id>
      <BubbleId>2</BubbleId>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>274264</PointerOffset>
      <VoiceId>&lt;audio:VSM_190_040_010&gt;</VoiceId>
      <JapaneseText>はい……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>5</SpeakerId>
      <Id>10</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>274436</PointerOffset>
      <VoiceId>&lt;audio:VSM_190_040_011&gt;</VoiceId>
      <JapaneseText>&lt;Suzu&gt;</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>4</SpeakerId>
      <Id>11</Id>
      <BubbleId>0</BubbleId>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>274436</PointerOffset>
      <VoiceId>&lt;audio:VSM_190_040_012&gt;</VoiceId>
      <JapaneseText>ちゃんに道具借りたから、
これで直せるかな期待しててよね。
直ったら、君たちも
元の時代に戻れるよ</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>4</SpeakerId>
      <Id>11</Id>
      <BubbleId>1</BubbleId>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>274540</PointerOffset>
      <VoiceId>&lt;audio:VSM_190_040_013&gt;</VoiceId>
      <JapaneseText>あっちが直っても
エトが見つからないと
戻れないよ……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>13</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>274612</PointerOffset>
      <VoiceId>&lt;audio:VSM_190_040_014&gt;</VoiceId>
      <JapaneseText>だな。
エト探そうぜ</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>14</Id>
      <Status>To Do</Status>
    </Entry>
