  <Strings>
    <Section>Main</Section>
    <Entry>
      <PointerOffset>273060</PointerOffset>
      <VoiceId>&lt;audio:VSM_150_040_001&gt;</VoiceId>
      <JapaneseText>君たちは
マクスウェルのところへ
行くんだよね</JapaneseText>
      <EnglishText>So I assume you'll be leaving to
meet with Maxwell now, right? </EnglishText>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>1</Id>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset>273176</PointerOffset>
      <VoiceId>&lt;audio:VSM_150_040_002&gt;</VoiceId>
      <JapaneseText>そのことなんですけど……</JapaneseText>
      <EnglishText>That's what we normally would do, but...</EnglishText>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>2</Id>
      <BubbleId>0</BubbleId>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset>273176</PointerOffset>
      <VoiceId>&lt;audio:VSM_150_040_003&gt;</VoiceId>
      <JapaneseText>&lt;Dio&gt;、どうする？</JapaneseText>
      <EnglishText>&lt;Dio&gt;, what do you think we should do?</EnglishText>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>2</Id>
      <BubbleId>1</BubbleId>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset>273236</PointerOffset>
      <VoiceId>&lt;audio:VSM_150_040_004&gt;</VoiceId>
      <JapaneseText>…………</JapaneseText>
      <EnglishText>...</EnglishText>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>4</Id>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset>273312</PointerOffset>
      <VoiceId>&lt;audio:VSM_150_040_005&gt;</VoiceId>
      <JapaneseText>&lt;Dio&gt;？　どうしたの？</JapaneseText>
      <EnglishText>&lt;Dio&gt;? What's on your mind?</EnglishText>
      <Notes/>
      <SpeakerId>4</SpeakerId>
      <Id>5</Id>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset>273388</PointerOffset>
      <VoiceId>&lt;audio:VSM_150_040_006&gt;</VoiceId>
      <JapaneseText>え……あ、え、何だよ？</JapaneseText>
      <EnglishText>Wh-What? What is it?</EnglishText>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>6</Id>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset>273476</PointerOffset>
      <VoiceId>&lt;audio:VSM_150_040_007&gt;</VoiceId>
      <JapaneseText>……これから、
どうするかってこと</JapaneseText>
      <EnglishText>...We're asking you what we should do.</EnglishText>
      <Notes/>
      <SpeakerId>4</SpeakerId>
      <Id>7</Id>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset>273588</PointerOffset>
      <VoiceId>&lt;audio:VSM_150_040_008&gt;</VoiceId>
      <JapaneseText>どうするって……オレは
あのブレイナーって
のをなんとかしたい</JapaneseText>
      <EnglishText>Me? I think I'd like to go after Brainer.</EnglishText>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>8</Id>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset>273656</PointerOffset>
      <VoiceId>&lt;audio:VSM_150_040_009&gt;</VoiceId>
      <JapaneseText>ブレイナーを？</JapaneseText>
      <EnglishText>Brainer, out of all people?</EnglishText>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>9</Id>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset>273832</PointerOffset>
      <VoiceId>&lt;audio:VSM_150_040_010&gt;</VoiceId>
      <JapaneseText>……あ、あいつのせいで、
エレメンツポット
壊れたようなもんだろ</JapaneseText>
      <EnglishText>...W-Well, one way or another, it's
his fault the Elements' Pot broke!</EnglishText>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>10</Id>
      <BubbleId>0</BubbleId>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset>273832</PointerOffset>
      <VoiceId>&lt;audio:VSM_150_040_011&gt;</VoiceId>
      <JapaneseText>一発ぶん殴っとかないと、
気がすまないんだ</JapaneseText>
      <EnglishText>I need to beat his ass at least
once or else I won't feel satisfied.</EnglishText>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>10</Id>
      <BubbleId>1</BubbleId>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset>274232</PointerOffset>
      <VoiceId>&lt;audio:VSM_150_040_015&gt;</VoiceId>
      <JapaneseText>わたしもそっちに行くよ</JapaneseText>
      <EnglishText>Yeah, let me join you!</EnglishText>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>12</Id>
      <BubbleId>0</BubbleId>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset>274232</PointerOffset>
      <VoiceId>&lt;audio:VSM_150_040_016&gt;</VoiceId>
      <JapaneseText>言ったじゃない、
大変な状況になってるのに
放っておけないもん</JapaneseText>
      <EnglishText>I'm serious. This situation is too
dangerious to leave as is.</EnglishText>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>12</Id>
      <BubbleId>1</BubbleId>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset>274328</PointerOffset>
      <VoiceId>&lt;audio:VSM_150_040_017&gt;</VoiceId>
      <JapaneseText>力を貸してもらえるのは、
ありがたいけど……</JapaneseText>
      <EnglishText>I thank you very much
for offering, but...</EnglishText>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>14</Id>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset>274392</PointerOffset>
      <VoiceId>&lt;audio:VSM_150_040_018&gt;</VoiceId>
      <JapaneseText>クルール！</JapaneseText>
      <EnglishText>Kuruuru!</EnglishText>
      <Notes/>
      <SpeakerId>5</SpeakerId>
      <Id>15</Id>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset>274496</PointerOffset>
      <VoiceId>&lt;audio:VSM_150_040_019&gt;</VoiceId>
      <JapaneseText>オレらだって……
&lt;Cless&gt;さんたちの力に
なりたいんだ</JapaneseText>
      <EnglishText>I want...to become your strength!</EnglishText>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>16</Id>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset>274552</PointerOffset>
      <VoiceId>&lt;audio:VSM_150_040_020&gt;</VoiceId>
      <JapaneseText>うん</JapaneseText>
      <EnglishText>Me too!</EnglishText>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>17</Id>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset>274624</PointerOffset>
      <VoiceId>&lt;audio:VSM_150_040_021&gt;</VoiceId>
      <JapaneseText>……そうか、わかった</JapaneseText>
      <EnglishText>All right, I get it.</EnglishText>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>18</Id>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset>274712</PointerOffset>
      <VoiceId>&lt;audio:VSM_150_040_022&gt;</VoiceId>
      <JapaneseText>向かいましょう、
&lt;Red&gt;スルト深林&lt;White&gt;へ</JapaneseText>
      <EnglishText>Let's journey to the &lt;Red&gt;Deep
Forest Surt&lt;White&gt; together, then!</EnglishText>
      <Notes/>
      <SpeakerId>6</SpeakerId>
      <Id>19</Id>
      <Status>Proofreading</Status>
    </Entry>
  </Strings>
