    <Section>Main</Section>
    <Entry>
      <PointerOffset>277428</PointerOffset>
      <VoiceId>&lt;audio:VSM_030_010_014&gt;</VoiceId>
      <JapaneseText>おまえ、強いんだな……</JapaneseText>
      <EnglishText>Hey! You're actually pretty strong... </EnglishText>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>1</Id>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset>277504</PointerOffset>
      <VoiceId>&lt;audio:VSM_030_010_015&gt;</VoiceId>
      <JapaneseText>今すぐ出ていくのじゃ～！</JapaneseText>
      <EnglishText>You there! Leave this place immediately! </EnglishText>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>2</Id>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset>277580</PointerOffset>
      <VoiceId>&lt;audio:VSM_030_010_016&gt;</VoiceId>
      <JapaneseText>誰……？
もしかして……</JapaneseText>
      <EnglishText>Who's that...? Could it be, perhaps...? </EnglishText>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>3</Id>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset>277652</PointerOffset>
      <VoiceId>&lt;audio:VSM_030_010_017&gt;</VoiceId>
      <JapaneseText>出たな、悪い魔女！</JapaneseText>
      <EnglishText>Come out now, you magician wacko! </EnglishText>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>4</Id>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset>277736</PointerOffset>
      <VoiceId>&lt;audio:VSM_030_010_018&gt;</VoiceId>
      <JapaneseText>出ていかないと、
ヒドイぞぉ～</JapaneseText>
      <EnglishText>I don't like appearing in front of jerks,
thank you very much! </EnglishText>
      <Notes/>
      <SpeakerId>4</SpeakerId>
      <Id>5</Id>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset>277836</PointerOffset>
      <VoiceId>&lt;audio:VSM_030_010_019&gt;</VoiceId>
      <JapaneseText>ヒドイって、
今みたいに弱っちぃ敵を
出すことか？</JapaneseText>
      <EnglishText>Jerks? Look who welcomed us with monsters, first! </EnglishText>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>6</Id>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset>277976</PointerOffset>
      <VoiceId>&lt;audio:VSM_030_010_020&gt;</VoiceId>
      <JapaneseText>う、ぐっ……</JapaneseText>
      <EnglishText>Well, that's...um... </EnglishText>
      <Notes/>
      <SpeakerId>4</SpeakerId>
      <Id>7</Id>
      <BubbleId>0</BubbleId>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset>277976</PointerOffset>
      <VoiceId>&lt;audio:VSM_030_010_021&gt;</VoiceId>
      <JapaneseText>生意気なお子様どもがぁ～！
来れるもんなら来てみろー！！</JapaneseText>
      <EnglishText>What impertinent little pests we have here! I'll anxiously 
be enjoying your futile efforts to find me! </EnglishText>
      <Notes/>
      <SpeakerId>4</SpeakerId>
      <Id>7</Id>
      <BubbleId>1</BubbleId>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset>278048</PointerOffset>
      <VoiceId>&lt;audio:VSM_030_010_022&gt;</VoiceId>
      <JapaneseText>……よしっ……行こ</JapaneseText>
      <EnglishText>We'll see about that! Let's go! </EnglishText>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>9</Id>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset>278116</PointerOffset>
      <VoiceId>&lt;audio:VSM_030_010_023&gt;</VoiceId>
      <JapaneseText>……あ、ああ……</JapaneseText>
      <EnglishText>S-Sure... </EnglishText>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>10</Id>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset>278368</PointerOffset>
      <VoiceId>&lt;audio:VSM_030_010_026&gt;</VoiceId>
      <JapaneseText>んじゃあ、行くか！</JapaneseText>
      <EnglishText>Let's keep moving! </EnglishText>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>11</Id>
      <BubbleId>0</BubbleId>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset>278368</PointerOffset>
      <VoiceId>&lt;audio:VSM_030_010_027&gt;</VoiceId>
      <JapaneseText>……っと、
おまえも来るか？</JapaneseText>
      <EnglishText>Oh right! You tagging along? </EnglishText>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>11</Id>
      <BubbleId>1</BubbleId>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset>278436</PointerOffset>
      <VoiceId>&lt;audio:VSM_030_010_028&gt;</VoiceId>
      <JapaneseText>クルール！</JapaneseText>
      <EnglishText>Kururu! </EnglishText>
      <Notes/>
      <SpeakerId>5</SpeakerId>
      <Id>13</Id>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset>278544</PointerOffset>
      <VoiceId>&lt;audio:VSM_030_010_029&gt;</VoiceId>
      <JapaneseText>そう、じゃあ、一緒においで、
ええっとぉ……名前は……</JapaneseText>
      <EnglishText>All right, let's stick together! Let's see....
a name for you... </EnglishText>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>14</Id>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset>278612</PointerOffset>
      <VoiceId>&lt;audio:VSM_030_010_030&gt;</VoiceId>
      <JapaneseText>クルール！</JapaneseText>
      <EnglishText>Kururu! </EnglishText>
      <Notes/>
      <SpeakerId>5</SpeakerId>
      <Id>15</Id>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset>278696</PointerOffset>
      <VoiceId>&lt;audio:VSM_030_010_031&gt;</VoiceId>
      <JapaneseText>&lt;Couleur&gt;だね。
よろしく、&lt;Couleur&gt;</JapaneseText>
      <EnglishText>&lt;Couleur&gt; it is then. Nice to meet you &lt;Couleur&gt;! </EnglishText>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>16</Id>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset>278760</PointerOffset>
      <VoiceId>&lt;audio:VSM_030_010_032&gt;</VoiceId>
      <JapaneseText>よろしくな</JapaneseText>
      <EnglishText>Nice to meet ya! </EnglishText>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>17</Id>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
