    <Section>Main</Section>
    <Entry>
      <PointerOffset>271696</PointerOffset>
      <VoiceId>&lt;audio:VSM_320_060_001&gt;</VoiceId>
      <JapaneseText>来たか</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>1</Id>
      <OldPtr>259184</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>271844</PointerOffset>
      <VoiceId>&lt;audio:VSM_320_060_002&gt;</VoiceId>
      <JapaneseText>この先でノルンが待ってるわ</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>2</Id>
      <BubbleId>0</BubbleId>
      <OldPtr>259324</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>271844</PointerOffset>
      <VoiceId>&lt;audio:VSM_320_060_003&gt;</VoiceId>
      <JapaneseText>そこでノルンがわたしたちに
審判を下してくれる</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>2</Id>
      <BubbleId>1</BubbleId>
      <OldPtr>259324</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>271932</PointerOffset>
      <VoiceId>&lt;audio:VSM_320_060_004&gt;</VoiceId>
      <JapaneseText>“審判”は
わたしたち自身でつける</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>4</Id>
      <OldPtr>259744</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>272016</PointerOffset>
      <VoiceId>&lt;audio:VSM_320_060_005&gt;</VoiceId>
      <JapaneseText>それがおまえたちの言う決着か</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>5</Id>
      <OldPtr>260204</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>272092</PointerOffset>
      <VoiceId>&lt;audio:VSM_320_060_006&gt;</VoiceId>
      <JapaneseText>いいわ、やりましょう</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>6</Id>
      <OldPtr>260344</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>272164</PointerOffset>
      <VoiceId>&lt;audio:VSM_320_060_007&gt;</VoiceId>
      <JapaneseText>&lt;Dio&gt;……&lt;Mel&gt;……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>4</SpeakerId>
      <Id>7</Id>
      <OldPtr>260524</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>272268</PointerOffset>
      <VoiceId>&lt;audio:VSM_320_060_008&gt;</VoiceId>
      <JapaneseText>全然だいじょーぶだって。
こいつら、オレらなんだから</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>5</SpeakerId>
      <Id>8</Id>
      <OldPtr>261116</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>272368</PointerOffset>
      <VoiceId>&lt;audio:VSM_320_060_009&gt;</VoiceId>
      <JapaneseText>わたしたちには
『なりきり士』の力が
ついてるもん</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>9</Id>
      <OldPtr>261436</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>272460</PointerOffset>
      <VoiceId>&lt;audio:VSM_320_060_010&gt;</VoiceId>
      <JapaneseText>おまえたちはオレたちに
絶対、勝てない</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>10</Id>
      <OldPtr>261668</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>272556</PointerOffset>
      <VoiceId>&lt;audio:VSM_320_060_011&gt;</VoiceId>
      <JapaneseText>そんなん、やってみないと
わかんねーだろ！？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>5</SpeakerId>
      <Id>11</Id>
      <OldPtr>262260</OldPtr>
      <Status>To Do</Status>
    </Entry>
