    <Entry>
      <PointerOffset>268572</PointerOffset>
      <VoiceId>&lt;audio:VSM_260_070_001&gt;</VoiceId>
      <JapaneseText>バンディ将軍、
あの子も養子候補ですか</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>1</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>268676</PointerOffset>
      <VoiceId>&lt;audio:VSM_260_070_002&gt;</VoiceId>
      <JapaneseText>ああ……親も探してはみたが、
見つからなかった</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>2</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>268872</PointerOffset>
      <VoiceId>&lt;audio:VSM_260_070_003&gt;</VoiceId>
      <JapaneseText></JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>3</Id>
      <BubbleId>0</BubbleId>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>268872</PointerOffset>
      <VoiceId>&lt;audio:VSM_260_070_004&gt;</VoiceId>
      <JapaneseText>近頃、生活に困窮し
子どもを捨てる親が
増えていますいくら呼びかけても
向こうは捨てたわけですから
名乗り出るわけありません</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>3</Id>
      <BubbleId>1</BubbleId>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>268984</PointerOffset>
      <VoiceId>&lt;audio:VSM_260_070_005&gt;</VoiceId>
      <JapaneseText>これもすべて……
長引く戦争で
民が飢えているせいか……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>5</Id>
      <Status>To Do</Status>
    </Entry>
