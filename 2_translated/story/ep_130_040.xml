    <Section>Main</Section>
    <Entry>
      <PointerOffset>276408</PointerOffset>
      <VoiceId>&lt;audio:VSM_130_040_001&gt;</VoiceId>
      <JapaneseText>いっち！　にぃ！
いっち！　にぃ！</JapaneseText>
      <EnglishText>One! Two! One! Two!</EnglishText>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>1</Id>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset>276484</PointerOffset>
      <VoiceId>&lt;audio:VSM_130_040_002&gt;</VoiceId>
      <JapaneseText>なんだ、あのガキ？</JapaneseText>
      <EnglishText>What the...!? Who's that brat?</EnglishText>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>2</Id>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset>276568</PointerOffset>
      <VoiceId>&lt;audio:VSM_130_040_003&gt;</VoiceId>
      <JapaneseText>&lt;Cless&gt;さんの代わりだとか</JapaneseText>
      <EnglishText>He's replacing Mister &lt;Cless&gt; on duty.</EnglishText>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>3</Id>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset>276720</PointerOffset>
      <VoiceId>&lt;audio:VSM_130_040_005&gt;</VoiceId>
      <JapaneseText>おい、おまえ！</JapaneseText>
      <EnglishText>Hey, you!</EnglishText>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>4</Id>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset>276796</PointerOffset>
      <VoiceId>&lt;audio:VSM_130_040_006&gt;</VoiceId>
      <JapaneseText>え？　あ、な、何だよ？</JapaneseText>
      <EnglishText>Huh? What is it?</EnglishText>
      <Notes/>
      <SpeakerId>4</SpeakerId>
      <Id>5</Id>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset>276904</PointerOffset>
      <VoiceId>&lt;audio:VSM_130_040_007&gt;</VoiceId>
      <JapaneseText>&lt;Cless&gt;の代わりなら、
オレと手合わせしてみろよ！</JapaneseText>
      <EnglishText>Let's decide who can replace
&lt;Cless&gt; with a little game!</EnglishText>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>6</Id>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset>276972</PointerOffset>
      <VoiceId>&lt;audio:VSM_130_040_008&gt;</VoiceId>
      <JapaneseText>お、おぉ……！</JapaneseText>
      <EnglishText>W-What?</EnglishText>
      <Notes/>
      <SpeakerId>4</SpeakerId>
      <Id>7</Id>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset>277048</PointerOffset>
      <VoiceId>&lt;audio:VSM_130_040_009&gt;</VoiceId>
      <JapaneseText>ボロボロにしてやる</JapaneseText>
      <EnglishText>Let's mess him up.</EnglishText>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>8</Id>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset>277116</PointerOffset>
      <VoiceId>&lt;audio:VSM_130_040_010&gt;</VoiceId>
      <JapaneseText>だぁあっ！</JapaneseText>
      <EnglishText>Take this!</EnglishText>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>9</Id>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset>277256</PointerOffset>
      <VoiceId>&lt;audio:VSM_130_040_011&gt;</VoiceId>
      <JapaneseText>ちっ……</JapaneseText>
      <EnglishText>Ugh...</EnglishText>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>10</Id>
      <BubbleId>0</BubbleId>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset>277256</PointerOffset>
      <VoiceId>&lt;audio:VSM_130_040_012&gt;</VoiceId>
      <JapaneseText>こんなガキに
教えてもらっても、
どうにもなんねえよ！</JapaneseText>
      <EnglishText>What the hell could a brat
like you teach us, anyways!?</EnglishText>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>10</Id>
      <BubbleId>1</BubbleId>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset>277332</PointerOffset>
      <VoiceId>&lt;audio:VSM_130_040_013&gt;</VoiceId>
      <JapaneseText>え……？
あ、待てよ！</JapaneseText>
      <EnglishText>Hey, wait!</EnglishText>
      <Notes/>
      <SpeakerId>4</SpeakerId>
      <Id>12</Id>
      <Status>Proofreading</Status>
    </Entry>
