      <PointerOffset>273572</PointerOffset>
      <VoiceId>&lt;audio:VSM_300_040_001&gt;</VoiceId>
      <JapaneseText>……メルティア、
あれを使う</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>1</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>273676</PointerOffset>
      <VoiceId>&lt;audio:VSM_300_040_002&gt;</VoiceId>
      <JapaneseText>あれを……！
どうして、ディオス、
あなたが……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>2</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>273768</PointerOffset>
      <VoiceId>&lt;audio:VSM_300_040_003&gt;</VoiceId>
      <JapaneseText>閣下は死んだ。
将軍代行はこのオレだ</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>3</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>273840</PointerOffset>
      <VoiceId>&lt;audio:VSM_300_040_004&gt;</VoiceId>
      <JapaneseText>お父様が……！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>4</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>273904</PointerOffset>
      <VoiceId>&lt;audio:VSM_300_040_005&gt;</VoiceId>
      <JapaneseText>発射準備を</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>5</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>274012</PointerOffset>
      <VoiceId>&lt;audio:VSM_300_040_006&gt;</VoiceId>
      <JapaneseText>ダメ！
まだ調整が済んでない！
今、それを使えば……！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>6</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>274108</PointerOffset>
      <VoiceId>&lt;audio:VSM_300_040_007&gt;</VoiceId>
      <JapaneseText>世界中のマナを
使い果たしてしまう、か？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>7</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>274228</PointerOffset>
      <VoiceId>&lt;audio:VSM_300_040_008&gt;</VoiceId>
      <JapaneseText>そうよ！　マナは
デリス・カーラーンの生命
の源、なくなれば……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>8</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>274308</PointerOffset>
      <VoiceId>&lt;audio:VSM_300_040_009&gt;</VoiceId>
      <JapaneseText>調整にどれくらいかかる？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>9</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>274396</PointerOffset>
      <VoiceId>&lt;audio:VSM_300_040_010&gt;</VoiceId>
      <JapaneseText>３日……
いえ、２日でなんとか</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>10</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
