  <Strings>
    <Section>Main</Section>
    <Entry>
      <PointerOffset>273572</PointerOffset>
      <VoiceId>&lt;audio:VSM_300_040_001&gt;</VoiceId>
      <JapaneseText>……メルティア、
あれを使う</JapaneseText>
      <EnglishText>...Meltia, we need to use it.</EnglishText>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>1</Id>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset>273676</PointerOffset>
      <VoiceId>&lt;audio:VSM_300_040_002&gt;</VoiceId>
      <JapaneseText>あれを……！
どうして、ディオス、
あなたが……</JapaneseText>
      <EnglishText>Use it...!? Why are you asking
me to do this, Dios!?</EnglishText>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>2</Id>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset>273768</PointerOffset>
      <VoiceId>&lt;audio:VSM_300_040_003&gt;</VoiceId>
      <JapaneseText>閣下は死んだ。
将軍代行はこのオレだ</JapaneseText>
      <EnglishText>His Excellency has passed away.
Now I'm the new general.</EnglishText>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>3</Id>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset>273840</PointerOffset>
      <VoiceId>&lt;audio:VSM_300_040_004&gt;</VoiceId>
      <JapaneseText>お父様が……！</JapaneseText>
      <EnglishText>No... You don't mean father...!</EnglishText>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>4</Id>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset>273904</PointerOffset>
      <VoiceId>&lt;audio:VSM_300_040_005&gt;</VoiceId>
      <JapaneseText>発射準備を</JapaneseText>
      <EnglishText>Commence firing preparations.</EnglishText>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>5</Id>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset>274012</PointerOffset>
      <VoiceId>&lt;audio:VSM_300_040_006&gt;</VoiceId>
      <JapaneseText>ダメ！
まだ調整が済んでない！
今、それを使えば……！</JapaneseText>
      <EnglishText>No, don't! It still needs modification
before it can be used at full power!
If you use it now...!</EnglishText>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>6</Id>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset>274108</PointerOffset>
      <VoiceId>&lt;audio:VSM_300_040_007&gt;</VoiceId>
      <JapaneseText>世界中のマナを
使い果たしてしまう、か？</JapaneseText>
      <EnglishText>The entire world's Mana
will be exhausted, no?</EnglishText>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>7</Id>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset>274228</PointerOffset>
      <VoiceId>&lt;audio:VSM_300_040_008&gt;</VoiceId>
      <JapaneseText>そうよ！　マナは
デリス・カーラーンの生命
の源、なくなれば……</JapaneseText>
      <EnglishText>Exactly! Mana is the source of all
life in Derris Kharlan! Therefore...!</EnglishText>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>8</Id>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset>274308</PointerOffset>
      <VoiceId>&lt;audio:VSM_300_040_009&gt;</VoiceId>
      <JapaneseText>調整にどれくらいかかる？</JapaneseText>
      <EnglishText>How long would the adjustments take?</EnglishText>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>9</Id>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset>274396</PointerOffset>
      <VoiceId>&lt;audio:VSM_300_040_010&gt;</VoiceId>
      <JapaneseText>３日……
いえ、２日でなんとか</JapaneseText>
      <EnglishText>3 days...no 2 days will be enough.</EnglishText>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>10</Id>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset>274536</PointerOffset>
      <VoiceId>&lt;audio:VSM_300_040_011&gt;</VoiceId>
      <JapaneseText>そんなには待てない</JapaneseText>
      <EnglishText>We don't have that much time.</EnglishText>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>11</Id>
      <BubbleId>0</BubbleId>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset>274536</PointerOffset>
      <VoiceId>&lt;audio:VSM_300_040_012&gt;</VoiceId>
      <JapaneseText>今すぐに手を打たなければ、
我が国は滅びてしまう</JapaneseText>
      <EnglishText>If we don't take immediate action, our
country will be completely annihilated!</EnglishText>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>11</Id>
      <BubbleId>1</BubbleId>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset>274600</PointerOffset>
      <VoiceId>&lt;audio:VSM_300_040_013&gt;</VoiceId>
      <JapaneseText>でも……</JapaneseText>
      <EnglishText>B-But...</EnglishText>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>13</Id>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset>274696</PointerOffset>
      <VoiceId>&lt;audio:VSM_300_040_014&gt;</VoiceId>
      <JapaneseText>将軍の……父上の、
仇を討ちたくないのか？</JapaneseText>
      <EnglishText>Don't you...don't you want to
avenge the general!? Our father!?</EnglishText>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>14</Id>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset>274772</PointerOffset>
      <VoiceId>&lt;audio:VSM_300_040_015&gt;</VoiceId>
      <JapaneseText>お父様の……仇……</JapaneseText>
      <EnglishText>Avenge...father...</EnglishText>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>15</Id>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset>274840</PointerOffset>
      <VoiceId>&lt;audio:VSM_300_040_015A&gt;</VoiceId>
      <JapaneseText>…………！</JapaneseText>
      <EnglishText>...!</EnglishText>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>16</Id>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset>274908</PointerOffset>
      <VoiceId>&lt;audio:VSM_300_040_016&gt;</VoiceId>
      <JapaneseText>ダメ……！</JapaneseText>
      <EnglishText>NO!</EnglishText>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>17</Id>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset>275148</PointerOffset>
      <VoiceId>&lt;audio:VSM_300_040_017&gt;</VoiceId>
      <JapaneseText>Target check complete...</JapaneseText>
      <EnglishText>Target check complete...</EnglishText>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>18</Id>
      <BubbleId>0</BubbleId>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset>275148</PointerOffset>
      <VoiceId>&lt;audio:VSM_300_040_018&gt;</VoiceId>
      <JapaneseText>Sorcery  energy
density ninety-nine percent...</JapaneseText>
      <EnglishText>Sorcery energy density
ninety-nine percent...</EnglishText>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>18</Id>
      <BubbleId>1</BubbleId>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset>275148</PointerOffset>
      <VoiceId>&lt;audio:VSM_300_040_019&gt;</VoiceId>
      <JapaneseText>Laser operation system
all clear...</JapaneseText>
      <EnglishText>Laser operation system, all clear...</EnglishText>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>18</Id>
      <BubbleId>2</BubbleId>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset>275148</PointerOffset>
      <VoiceId>&lt;audio:VSM_300_040_020&gt;</VoiceId>
      <JapaneseText>All systems ready...</JapaneseText>
      <EnglishText>All systems, ready...</EnglishText>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>18</Id>
      <BubbleId>3</BubbleId>
      <Status>Proofreading</Status>
    </Entry>
