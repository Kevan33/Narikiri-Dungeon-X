    <Entry>
      <PointerOffset>275560</PointerOffset>
      <JapaneseText>……あ、あいつ、かな……？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>1</Id>
      <OldPtr>258512</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>275672</PointerOffset>
      <JapaneseText>オホホホ……あの
ミッドガル料理屋からも金を
巻き上げられそうザマス～</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>2</Id>
      <OldPtr>258708</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>275724</PointerOffset>
      <JapaneseText>アイツ、だよな……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>3</Id>
      <OldPtr>259120</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>275800</PointerOffset>
      <JapaneseText>他のお店にもお金を
貸してるみたいだね……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>4</Id>
      <OldPtr>259260</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>275960</PointerOffset>
      <JapaneseText>次のカモは、人の好い
あの魔術研究員ザマスかね～</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>5</Id>
      <BubbleId>0</BubbleId>
      <OldPtr>259456</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>275960</PointerOffset>
      <JapaneseText>バンバン金貸して、また
返せなくして、たんまり
延滞金ふんだくるザマスよ</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>5</Id>
      <BubbleId>1</BubbleId>
      <OldPtr>259456</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>276012</PointerOffset>
      <JapaneseText>カモってなんだ？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>7</Id>
      <OldPtr>259816</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>276076</PointerOffset>
      <JapaneseText>利用しやすい相手
のことだよ</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>4</SpeakerId>
      <Id>8</Id>
      <OldPtr>260124</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>276120</PointerOffset>
      <JapaneseText>あいつ……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>9</Id>
      <OldPtr>260684</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>276332</PointerOffset>
      <JapaneseText>ま、研究員では、
ふんだくれるものがあまり
ないのは残念ザマスけどね</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>10</Id>
      <BubbleId>0</BubbleId>
      <OldPtr>260880</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>276332</PointerOffset>
      <JapaneseText>そういう意味では
あの小物屋は
おいしかったザマス</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>10</Id>
      <BubbleId>1</BubbleId>
      <OldPtr>260880</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>276332</PointerOffset>
      <JapaneseText>この借用書さえあれば、
あの店は
あたしのものザマス～</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>10</Id>
      <BubbleId>2</BubbleId>
      <OldPtr>260880</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>276384</PointerOffset>
      <JapaneseText>その借用書、返せ！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>13</Id>
      <OldPtr>261380</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>276500</PointerOffset>
      <JapaneseText>何ザマスか、
いきなり、あーたは</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>14</Id>
      <BubbleId>0</BubbleId>
      <OldPtr>262096</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>276500</PointerOffset>
      <JapaneseText>……ははぁ、
あの小物屋の
回し者ザマスね</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>14</Id>
      <BubbleId>1</BubbleId>
      <OldPtr>262096</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>276592</PointerOffset>
      <JapaneseText>その小物屋さんのお金、
返すの少し待って
あげられませんか？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>16</Id>
      <OldPtr>262372</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>276684</PointerOffset>
      <JapaneseText>オホホ……誰も
待たないなんて言って
ないザマスよ</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>17</Id>
      <OldPtr>262512</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>276768</PointerOffset>
      <JapaneseText>でも、待ったら、
待っただけ金払えって
言うんだろ？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>18</Id>
      <OldPtr>262652</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>276848</PointerOffset>
      <JapaneseText>それはそういう
約束だったザマスから～</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>19</Id>
      <OldPtr>262792</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>276920</PointerOffset>
      <JapaneseText>払えないのわかってて、
貸しただろ！？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>20</Id>
      <OldPtr>262932</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>276996</PointerOffset>
      <JapaneseText>だとしたら、
どうだというザマス？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>21</Id>
      <OldPtr>263072</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>277040</PointerOffset>
      <JapaneseText>え……？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>22</Id>
      <OldPtr>263212</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>277200</PointerOffset>
      <JapaneseText>あたしは世間様のルール通りに
お金を貸して返してもらってる
だけざます</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>23</Id>
      <BubbleId>0</BubbleId>
      <OldPtr>263352</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>277200</PointerOffset>
      <JapaneseText>私がどういうつもりだったか
なんて関係ないザマス</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>23</Id>
      <BubbleId>1</BubbleId>
      <OldPtr>263352</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>277248</PointerOffset>
      <JapaneseText>それは……！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>25</Id>
      <OldPtr>263556</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>277360</PointerOffset>
      <JapaneseText>さっさと返せと
言ってくるザマス</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>26</Id>
      <BubbleId>0</BubbleId>
      <OldPtr>263696</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>277360</PointerOffset>
      <JapaneseText>そうしたら、
この借用書も返すザマス</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>26</Id>
      <BubbleId>1</BubbleId>
      <OldPtr>263696</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>277404</PointerOffset>
      <JapaneseText>くっ……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>28</Id>
      <OldPtr>263900</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>277456</PointerOffset>
      <JapaneseText>&lt;Dio&gt;……行こ……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>29</Id>
      <OldPtr>264140</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>277528</PointerOffset>
      <JapaneseText>……あいつ、
まだあそこに行るぜ……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>30</Id>
      <OldPtr>265196</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>277596</PointerOffset>
      <JapaneseText>借用書見て
時々ニヤニヤしてるね</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>4</SpeakerId>
      <Id>31</Id>
      <OldPtr>265336</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>277688</PointerOffset>
      <JapaneseText>でもさ、あの人に
もう何言っても、
聞いてくれなさそう……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>32</Id>
      <OldPtr>265904</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>277736</PointerOffset>
      <JapaneseText>……だよな……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>33</Id>
      <OldPtr>266212</OldPtr>
      <Status>To Do</Status>
    </Entry>
