    <Entry>
      <PointerOffset>271788</PointerOffset>
      <JapaneseText>ホント？助かるわ。
じゃああの右奥にいる
三つ子のお客様の注文とって来て</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>65</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>271876</PointerOffset>
      <JapaneseText>終ったらアタシのところに戻って、
その注文を教えてね？
じゃあよろしくっ！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>66</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>271956</PointerOffset>
      <JapaneseText>……それだけか？
そんくらいなら何でもねーじゃん</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>10</SpeakerId>
      <Id>67</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>272009</PointerOffset>
      <JapaneseText>とりあえず
すぐ行ってこよう？
右奥の、三つ子、だよね</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>11</SpeakerId>
      <Id>68</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>272069</PointerOffset>
      <JapaneseText>わりーけど、おれたち
バイトじゃないんだ。ごめんな</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>10</SpeakerId>
      <Id>69</Id>
      <Status>To Do</Status>
    </Entry>
