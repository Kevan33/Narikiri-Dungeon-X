    <Entry>
      <PointerOffset>270920</PointerOffset>
      <JapaneseText>ああ、忙しい、忙しい……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>1</Id>
      <BubbleId>0</BubbleId>
