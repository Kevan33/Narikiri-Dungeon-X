    </Entry>
    <Entry>
      <PointerOffset>270920</PointerOffset>
      <JapaneseText>ん？はい！
ご注文ですか？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>1</Id>
      <BubbleId>1</BubbleId>
      <OldPtr>258220</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>270996</PointerOffset>
      <JapaneseText>あ、いや、わたしたちは
そうじゃなくて……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>3</Id>
      <OldPtr>258636</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>271196</PointerOffset>
      <JapaneseText>ということは……
バイトォォォォォー！？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>4</Id>
      <BubbleId>0</BubbleId>
      <OldPtr>258832</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>271196</PointerOffset>
      <JapaneseText>やたー！
これで人手不足は解消よ！？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>4</Id>
      <BubbleId>1</BubbleId>
      <OldPtr>258832</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>271196</PointerOffset>
      <JapaneseText>うん！即、採用ッ！
店長にはあたしが話しておくわ。
じゃあ早速行きましょうか！！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>4</Id>
      <BubbleId>2</BubbleId>
      <OldPtr>258832</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>271248</PointerOffset>
      <JapaneseText>え？
あ、あの……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>7</Id>
      <OldPtr>259332</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>271316</PointerOffset>
