    <Entry>
      <PointerOffset>278532</PointerOffset>
      <VoiceId>&lt;audio:VSM_140_050_019&gt;</VoiceId>
      <JapaneseText>くっ……！
一体、ヤツはどこへ……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>1</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>278788</PointerOffset>
      <VoiceId>&lt;audio:VSM_140_050_020&gt;</VoiceId>
      <JapaneseText></JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>2</Id>
      <BubbleId>0</BubbleId>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>278788</PointerOffset>
      <VoiceId>&lt;audio:VSM_140_050_021&gt;</VoiceId>
      <JapaneseText>&lt;Red&gt;&lt;White&gt;&lt;Red&gt;&lt;White&gt;</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>2</Id>
      <BubbleId>1</BubbleId>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>278788</PointerOffset>
      <VoiceId>&lt;audio:VSM_140_050_022&gt;</VoiceId>
      <JapaneseText>&lt;Red&gt;&lt;White&gt;ご報告します！ユークリッド及びトーティス、
その他、多くの街が
魔物に襲撃されています！どうやら、その魔物たちは
スルト深林から来ていると
思われます！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>2</Id>
      <BubbleId>2</BubbleId>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>278940</PointerOffset>
      <VoiceId>&lt;audio:VSM_140_050_023&gt;</VoiceId>
      <JapaneseText>&lt;Red&gt;&lt;White&gt;</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>5</Id>
      <BubbleId>0</BubbleId>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>278940</PointerOffset>
      <VoiceId>&lt;audio:VSM_140_050_024&gt;</VoiceId>
      <JapaneseText>スルト深林だと？確かあの森には、
無害な獣しか住んで
いなかったはずでは……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>5</Id>
      <BubbleId>1</BubbleId>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>279088</PointerOffset>
      <VoiceId>&lt;audio:VSM_140_050_025&gt;</VoiceId>
      <JapaneseText></JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>4</SpeakerId>
      <Id>7</Id>
      <BubbleId>0</BubbleId>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>279088</PointerOffset>
      <VoiceId>&lt;audio:VSM_140_050_026&gt;</VoiceId>
      <JapaneseText>まさか、魔界の扉……あの森の深くに
魔界と人間界をつなぐ
扉があると言います！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>4</SpeakerId>
      <Id>7</Id>
      <BubbleId>1</BubbleId>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>279248</PointerOffset>
      <VoiceId>&lt;audio:VSM_140_050_027&gt;</VoiceId>
      <JapaneseText></JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>9</Id>
      <BubbleId>0</BubbleId>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>279248</PointerOffset>
      <VoiceId>&lt;audio:VSM_140_050_028&gt;</VoiceId>
      <JapaneseText>封印が解かれた……
魔界の民を操る…………ブレイナーが
言っていたのは
このことなのか！？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>9</Id>
      <BubbleId>1</BubbleId>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>279376</PointerOffset>
      <VoiceId>&lt;audio:VSM_140_050_029&gt;</VoiceId>
      <JapaneseText>&lt;Red&gt;&lt;White&gt;&lt;Red&gt;&lt;White&gt;このままでは、
トーティスやユークリッドで
多くの犠牲者が出ます！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>11</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>279488</PointerOffset>
      <VoiceId>&lt;audio:VSM_140_050_030&gt;</VoiceId>
      <JapaneseText>全軍を各方面に回せ！
魔物の排除と、
住民の保護を最優先だ！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>12</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>279700</PointerOffset>
      <VoiceId>&lt;audio:VSM_140_050_032&gt;</VoiceId>
      <JapaneseText>&lt;Cless&gt;&lt;Red&gt;&lt;White&gt;さん……わたしたちは
スルト深林へ行った方が
いいのではないでしょうか？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>4</SpeakerId>
      <Id>13</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>279792</PointerOffset>
      <VoiceId>&lt;audio:VSM_140_050_033&gt;</VoiceId>
      <JapaneseText>そうか……ブレイナーを
捕まえないと……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>14</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>279920</PointerOffset>
      <VoiceId>&lt;audio:VSM_140_050_034&gt;</VoiceId>
      <JapaneseText>ええ、それに扉を閉じなければ、
多くの魔物たちがこちらの
世界へ流れ出てきます</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>4</SpeakerId>
      <Id>15</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>280036</PointerOffset>
      <VoiceId>&lt;audio:VSM_140_050_035&gt;</VoiceId>
      <JapaneseText>じゃあ、村は彼らに任せて、
僕たちは魔物を
抑えに行った方がいいね</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>16</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>280136</PointerOffset>
      <VoiceId>&lt;audio:VSM_140_050_036&gt;</VoiceId>
      <JapaneseText>&lt;Red&gt;&lt;White&gt;はい。それでは
12星座の塔へ行きましょう！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>4</SpeakerId>
      <Id>17</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>280224</PointerOffset>
      <VoiceId>&lt;audio:VSM_140_050_037&gt;</VoiceId>
      <JapaneseText>12星座の……
ルナのところに……？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>18</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>280344</PointerOffset>
      <VoiceId>&lt;audio:VSM_140_050_038&gt;</VoiceId>
      <JapaneseText>魔界の扉はルナの光で
封印されていたはずです。
彼女の力を借りなければ</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>4</SpeakerId>
      <Id>19</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>280516</PointerOffset>
      <VoiceId>&lt;audio:VSM_140_050_039&gt;</VoiceId>
      <JapaneseText></JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>20</Id>
      <BubbleId>0</BubbleId>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>280516</PointerOffset>
      <VoiceId>&lt;audio:VSM_140_050_040&gt;</VoiceId>
      <JapaneseText>&lt;Red&gt;&lt;White&gt;</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>20</Id>
      <BubbleId>1</BubbleId>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>280516</PointerOffset>
      <VoiceId>&lt;audio:VSM_140_050_041&gt;</VoiceId>
      <JapaneseText>わかった僕たちは、これから
12星座の塔へ行く。
君たちとはここでお別れだ急ごう</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>20</Id>
      <BubbleId>2</BubbleId>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>280604</PointerOffset>
      <VoiceId>&lt;audio:VSM_140_050_042&gt;</VoiceId>
      <JapaneseText>わたし、行くよ、
いいでしょ？　エト</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>5</SpeakerId>
      <Id>23</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>280688</PointerOffset>
      <VoiceId>&lt;audio:VSM_140_050_043&gt;</VoiceId>
      <JapaneseText>きみたちは
虹輪を消さなきゃ！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>6</SpeakerId>
      <Id>24</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>280864</PointerOffset>
      <VoiceId>&lt;audio:VSM_140_050_044&gt;</VoiceId>
      <JapaneseText></JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>5</SpeakerId>
      <Id>25</Id>
      <BubbleId>0</BubbleId>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>280864</PointerOffset>
      <VoiceId>&lt;audio:VSM_140_050_045&gt;</VoiceId>
      <JapaneseText>でも、今、この世界は
大変なことになってるんだよ？それを目の前で
放っておくなんて、わたし……
できないよ</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>5</SpeakerId>
      <Id>25</Id>
      <BubbleId>1</BubbleId>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>280960</PointerOffset>
      <VoiceId>&lt;audio:VSM_140_050_046&gt;</VoiceId>
      <JapaneseText>&lt;Cless&gt;行こうぜ……！
さんたちの後を追おう</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>7</SpeakerId>
      <Id>27</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>281040</PointerOffset>
      <VoiceId>&lt;audio:VSM_140_050_047&gt;</VoiceId>
      <JapaneseText>&lt;Dio&gt;……、
もう平気なの？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>5</SpeakerId>
      <Id>28</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>281120</PointerOffset>
      <VoiceId>&lt;audio:VSM_140_050_048&gt;</VoiceId>
      <JapaneseText>ああ……
確かめなきゃ……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>7</SpeakerId>
      <Id>29</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>281192</PointerOffset>
      <VoiceId>&lt;audio:VSM_140_050_049&gt;</VoiceId>
      <JapaneseText>&lt;Dio&gt;どうしたの、</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>6</SpeakerId>
      <Id>30</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>281284</PointerOffset>
      <VoiceId>&lt;audio:VSM_140_050_050&gt;</VoiceId>
      <JapaneseText>&lt;Red&gt;&lt;White&gt;なんでもない……
12星座の塔に行こう</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>7</SpeakerId>
      <Id>31</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>281348</PointerOffset>
      <VoiceId>&lt;audio:VSM_140_050_051&gt;</VoiceId>
      <JapaneseText>クルルー！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>8</SpeakerId>
      <Id>32</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>281416</PointerOffset>
      <VoiceId>&lt;audio:VSM_140_050_052&gt;</VoiceId>
      <JapaneseText>……確かめなきゃ</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>7</SpeakerId>
      <Id>33</Id>
      <Status>To Do</Status>
    </Entry>
