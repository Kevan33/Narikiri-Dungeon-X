    <Entry>
      <PointerOffset>275460</PointerOffset>
      <JapaneseText>ちょっと、
向こうのオアシスで
砂嵐だって！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>1</Id>
      <OldPtr>258556</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>275540</PointerOffset>
      <JapaneseText>マジで！？
きっとブライトローズの
せいよ！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>2</Id>
      <OldPtr>258752</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>275640</PointerOffset>
      <JapaneseText>そういや、雑貨屋のご主人
ったら屋根から落ちて
骨折したって</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>3</Id>
      <OldPtr>258892</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>275732</PointerOffset>
      <JapaneseText>マジでマジで！？
きっとそれも
ブライトローズのせいよ！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>4</Id>
      <OldPtr>259088</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>275804</PointerOffset>
      <JapaneseText>もう１年以上、
雨が降ってない！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>5</Id>
      <OldPtr>259228</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>275876</PointerOffset>
      <JapaneseText>それも
ブライトローズのせいだわ！！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>6</Id>
      <OldPtr>259368</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>275944</PointerOffset>
      <JapaneseText>そのブライトローズって
悪いヤツね</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>7</Id>
      <OldPtr>259676</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>275992</PointerOffset>
      <JapaneseText>&lt;Arche&gt;さん……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>4</SpeakerId>
      <Id>8</Id>
      <OldPtr>260220</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>276076</PointerOffset>
      <JapaneseText>え？　あ……
もしかして、それって……
あたし！？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>9</Id>
      <OldPtr>260472</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>276184</PointerOffset>
      <JapaneseText>ちょっとちょっと！
あたし、砂嵐のこととか、
雑貨屋の主人とか知らないよ！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>10</Id>
      <OldPtr>261380</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>276256</PointerOffset>
      <JapaneseText>え……あ、あなた、
もしかして……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>11</Id>
      <OldPtr>261616</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>276348</PointerOffset>
      <JapaneseText>その服の色、明るい薔薇色……
ブライトローズだわ！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>12</Id>
      <OldPtr>261812</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>276532</PointerOffset>
      <JapaneseText>だから、ブライトローズって
勝手にあたしの知らないとこで、
名前つけないでよね</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>13</Id>
      <BubbleId>0</BubbleId>
      <OldPtr>261952</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>276532</PointerOffset>
      <JapaneseText>それに、なんかあたしに
関係ないところまで、
あたしのせいになってない！？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>13</Id>
      <BubbleId>1</BubbleId>
      <OldPtr>261952</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>276584</PointerOffset>
      <JapaneseText>なってるわよ？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>15</Id>
      <OldPtr>262092</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>276624</PointerOffset>
      <JapaneseText>え？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>16</Id>
      <OldPtr>262232</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>276720</PointerOffset>
      <JapaneseText>ゴメンなさいね、
本物がここへ来るとは
思わなかったから</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>17</Id>
      <OldPtr>262428</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>276776</PointerOffset>
      <JapaneseText>でも、どうして……？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>18</Id>
      <OldPtr>262568</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>276896</PointerOffset>
      <JapaneseText>誰のせいにもできないこと
ってあるでしょ</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>19</Id>
      <BubbleId>0</BubbleId>
      <OldPtr>262764</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>276896</PointerOffset>
      <JapaneseText>そういうのを
みんな誰かのせいに
したいのよ</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>19</Id>
      <BubbleId>1</BubbleId>
      <OldPtr>262764</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>277052</PointerOffset>
      <JapaneseText>そうそう、そういう時にね、
イタズラ好きの魔女が
いるってから</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>21</Id>
      <BubbleId>0</BubbleId>
      <OldPtr>262904</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>277052</PointerOffset>
      <JapaneseText>みんな、そういうのを
その魔女のせいに
し始めたのよね</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>21</Id>
      <BubbleId>1</BubbleId>
      <OldPtr>262904</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>277156</PointerOffset>
      <JapaneseText>そうしたら、なんか
話が大げさになって、
全部、あんたのせいになって</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>23</Id>
      <OldPtr>263100</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>277204</PointerOffset>
      <JapaneseText>んーもお……！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>24</Id>
      <OldPtr>263240</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>277276</PointerOffset>
      <JapaneseText>ごめんなさい。
あ、そうだ……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>25</Id>
      <OldPtr>263380</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>277332</PointerOffset>
      <JapaneseText>これ、お詫びに</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>26</Id>
      <OldPtr>263732</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>277376</PointerOffset>
      <JapaneseText>これは……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>27</Id>
      <OldPtr>263872</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>277560</PointerOffset>
      <JapaneseText>うちのおばあちゃんが若い頃に、
掃除の手伝いに来てくれた
魔女の女の子がいて、</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>28</Id>
      <BubbleId>0</BubbleId>
      <OldPtr>264012</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>277560</PointerOffset>
      <JapaneseText>その娘がそのホウキを
うちに忘れてったの。
その子ってあなたでしょ？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>28</Id>
      <BubbleId>1</BubbleId>
      <OldPtr>264012</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>277684</PointerOffset>
      <JapaneseText>うん……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>30</Id>
      <BubbleId>0</BubbleId>
      <OldPtr>264208</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>277684</PointerOffset>
      <JapaneseText>……そっか、これ、あの時、
ここに忘れてたんだな</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>30</Id>
      <BubbleId>1</BubbleId>
      <OldPtr>264208</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>277684</PointerOffset>
      <JapaneseText>うん、ありがたく
いただいとくよ！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>30</Id>
      <BubbleId>2</BubbleId>
      <OldPtr>264208</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>277832</PointerOffset>
      <JapaneseText>でも、悪い魔女って噂、
嘘だったんですね</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>4</SpeakerId>
      <Id>33</Id>
      <OldPtr>264556</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>277928</PointerOffset>
      <JapaneseText>あったりまえじゃん。
あたしが、そんな
ひどいことするとでも？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>34</Id>
      <OldPtr>264856</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>278020</PointerOffset>
      <JapaneseText>でも、砂漠のバジリスクに
目を書いたのあなたよね？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>35</Id>
      <OldPtr>264996</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>278120</PointerOffset>
      <JapaneseText>オアシスの池を全部、
アップルジュースにしたのも
あなたじゃない？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>36</Id>
      <OldPtr>265408</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>278204</PointerOffset>
      <JapaneseText>村のヤシの実に、紙ふぶきも
仕込んだでしょ？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>37</Id>
      <OldPtr>265604</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>278252</PointerOffset>
      <JapaneseText>&lt;Arche&gt;さん……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>4</SpeakerId>
      <Id>38</Id>
      <OldPtr>266040</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>278300</PointerOffset>
      <JapaneseText>えっへへ～……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>39</Id>
      <OldPtr>266236</OldPtr>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>278348</PointerOffset>
      <JapaneseText>自業自得……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>5</SpeakerId>
      <Id>40</Id>
      <OldPtr>266376</OldPtr>
      <Status>To Do</Status>
    </Entry>
