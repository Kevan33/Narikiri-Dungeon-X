      <PointerOffset>276328</PointerOffset>
      <VoiceId>&lt;audio:VSM_210_010_002&gt;</VoiceId>
      <JapaneseText>&lt;Suzu&gt;この人たち、
ちゃんの村にいた……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>2</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>276420</PointerOffset>
      <VoiceId>&lt;audio:VSM_210_010_003&gt;</VoiceId>
      <JapaneseText>しっかりしてください！
しっかり……！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>3</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>276488</PointerOffset>
      <VoiceId>&lt;audio:VSM_210_010_004&gt;</VoiceId>
      <JapaneseText>……ダメです……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>4</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>276556</PointerOffset>
      <VoiceId>&lt;audio:VSM_210_010_005&gt;</VoiceId>
      <JapaneseText>この人たちは？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>5</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>276692</PointerOffset>
      <VoiceId>&lt;audio:VSM_210_010_006&gt;</VoiceId>
      <JapaneseText></JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>6</Id>
      <BubbleId>0</BubbleId>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>276692</PointerOffset>
      <VoiceId>&lt;audio:VSM_210_010_007&gt;</VoiceId>
      <JapaneseText>この一帯に調査に
向かった仲間たちですプルートの根城を探して……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>6</Id>
      <BubbleId>1</BubbleId>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>276796</PointerOffset>
      <VoiceId>&lt;audio:VSM_210_010_008&gt;</VoiceId>
      <JapaneseText>じゃあ、この人たち、
プルートにやられたってこと？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>4</SpeakerId>
      <Id>8</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>276868</PointerOffset>
      <VoiceId>&lt;audio:VSM_210_010_009&gt;</VoiceId>
      <JapaneseText>かもしれません……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>9</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>276972</PointerOffset>
      <VoiceId>&lt;audio:VSM_210_010_010&gt;</VoiceId>
      <JapaneseText>もし、この洞窟に
プルートがいるなら
エトが危ないよ！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>10</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>277036</PointerOffset>
      <VoiceId>&lt;audio:VSM_210_010_011&gt;</VoiceId>
      <JapaneseText>急ごうぜ！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>11</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>277144</PointerOffset>
      <VoiceId>&lt;audio:VSM_210_010_012&gt;</VoiceId>
      <JapaneseText>ここにプルートがいるのならば
慎重に行く必要があります</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>12</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>277220</PointerOffset>
      <VoiceId>&lt;audio:VSM_210_010_013&gt;</VoiceId>
      <JapaneseText>相手は魔界の王様、か……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>4</SpeakerId>
      <Id>13</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>277284</PointerOffset>
      <VoiceId>&lt;audio:VSM_210_010_014&gt;</VoiceId>
      <JapaneseText>いいですね？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>14</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>277352</PointerOffset>
      <VoiceId>&lt;audio:VSM_210_010_015&gt;</VoiceId>
      <JapaneseText>……行きましょう</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>15</Id>
      <Status>To Do</Status>
