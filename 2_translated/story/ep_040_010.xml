      <VoiceId>&lt;audio:VSM_040_010_001&gt;</VoiceId>
      <JapaneseText>&lt;Red&gt;&lt;White&gt;ここがユークリッド村？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>1</Id>
      <Status>To Do</Status>
