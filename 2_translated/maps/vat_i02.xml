    </Entry>
    <Entry>
      <PointerOffset>295703</PointerOffset>
      <JapaneseText>よろしく頼むわ！
右奥の三つ子、よ</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>64</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>295760</PointerOffset>
      <JapaneseText>特上焼肉セット
本まぐろ丼
お水と塩
もうちょっと待って！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>22</SpeakerId>
      <Id>65</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>295866</PointerOffset>
      <JapaneseText>あら、いらっしゃい</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>66</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>295909</PointerOffset>
      <JapaneseText>特上焼肉セット３つお願いします。
わたしの注文が本当です</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>23</SpeakerId>
      <Id>67</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>295978</PointerOffset>
      <JapaneseText>ハンバーグ……
カレー……
パスタ……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>23</SpeakerId>
      <Id>68</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>296028</PointerOffset>
      <JapaneseText>べっ、別にあなたたちのために
イジワルしたんじゃないんだからねっ！
……です</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>23</SpeakerId>
      <Id>69</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>296116</PointerOffset>
      <JapaneseText>べっ、べつにお店に嫌がらせに
来てるんじゃないんだからねっ！
……です</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>23</SpeakerId>
      <Id>70</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>296211</PointerOffset>
      <JapaneseText>少女ちゃんのはウソですよ。
今日はお肉よりもお魚！
本まぐろ丼をお願いします</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>24</SpeakerId>
      <Id>71</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>296301</PointerOffset>
      <JapaneseText>わたしたちはどこから来て
どこへ行くというのでしょう……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>24</SpeakerId>
      <Id>72</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>296372</PointerOffset>
      <JapaneseText>うちの家系は代々
このお店の常連なんです</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>24</SpeakerId>
      <Id>73</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>296427</PointerOffset>
      <JapaneseText>あのウェイトレスさんの家系も
代々このお店に勤めているそうです</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>24</SpeakerId>
      <Id>74</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>296504</PointerOffset>
      <JapaneseText>こうなるともはや宿命……
そう、宿命のライバルです</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>24</SpeakerId>
      <Id>75</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>296569</PointerOffset>
      <JapaneseText>ああ……レストランに来ると
おかみを呼べ！
……って叫びたくなってしまいます</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>24</SpeakerId>
      <Id>76</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>296659</PointerOffset>
      <JapaneseText>口あたりはまったり
それでいてしつこくないこの味、
さすがです</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>24</SpeakerId>
      <Id>77</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>296744</PointerOffset>
      <JapaneseText>最近太っちゃったので、
全員お水と塩で。
女の子ちゃんの注文はダミーです！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>25</SpeakerId>
      <Id>78</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>296830</PointerOffset>
      <JapaneseText>お腹……
空きました……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>25</SpeakerId>
      <Id>79</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>296867</PointerOffset>
      <JapaneseText>空腹は最高の調味料。
それとホビーを融合させたのが
私たちの究極の注文法なのです</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>25</SpeakerId>
      <Id>80</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>296959</PointerOffset>
      <JapaneseText>私たちの祖母も三つ子で
このお店に通っていたそうです</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>25</SpeakerId>
      <Id>81</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>297024</PointerOffset>
      <JapaneseText>いつもいつも
お腹、いーっぱい食べられると
うれしいかもです</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>25</SpeakerId>
      <Id>82</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>297094</PointerOffset>
      <JapaneseText>ちょっ……
仕事をほっぽっといて
帰るわけには行かないだーよ</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>19</SpeakerId>
      <Id>83</Id>
      <Status>To Do</Status>
    </Entry>
