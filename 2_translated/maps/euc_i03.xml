    <Entry>
      <PointerOffset>269880</PointerOffset>
      <JapaneseText>なんだよ、しつこいな
村の名物ってやつを
作るんだよそれはな……
いや、なんでもない</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
