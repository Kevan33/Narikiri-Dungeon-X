      <EnglishText/>
      <Notes/>
      <SpeakerId>5</SpeakerId>
      <Id>38</Id>
      <BubbleId>0</BubbleId>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>314176</PointerOffset>
      <JapaneseText>いつかこの村のために
働きたいと思っているんだ</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>5</SpeakerId>
      <Id>38</Id>
      <BubbleId>1</BubbleId>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>314180</PointerOffset>
      <JapaneseText>なんだよ、おまえ！！
勝手に入ってくんな！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>6</SpeakerId>
      <Id>40</Id>
      <BubbleId>0</BubbleId>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>314180</PointerOffset>
      <JapaneseText>子どもがこんなとこに
