  <Strings>
    <Section>Place</Section>
    <Entry>
      <PointerOffset>280996</PointerOffset>
      <JapaneseText>熱砂の洞窟　地下３階</JapaneseText>
      <EnglishText/>
      <Notes/>
      <Id>1</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>281056</PointerOffset>
      <JapaneseText>&lt;SQUARE&gt;でソーサラーリング発射</JapaneseText>
      <EnglishText/>
      <Notes/>
      <Id>2</Id>
      <Status>To Do</Status>
    </Entry>
  </Strings>
  <Strings>
    <Section>Main</Section>
    <Entry>
      <PointerOffset>280528</PointerOffset>
      <VoiceId>&lt;audio:VSM_050_020_000&gt;</VoiceId>
      <JapaneseText>おーおー。
ソーサラーリングを
手に入れただな</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>1</Id>
      <BubbleId>0</BubbleId>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>280528</PointerOffset>
      <VoiceId>&lt;audio:VSM_050_020_001&gt;</VoiceId>
      <JapaneseText>ソーサラーリングっつーのは
魔法のアイテムだーよ</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>1</Id>
      <BubbleId>1</BubbleId>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>280528</PointerOffset>
      <VoiceId>&lt;audio:VSM_050_020_002&gt;</VoiceId>
      <JapaneseText>とりあえんず、
&lt;SQUARE&gt;を押して、
打ってみりゃわかるだ</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>1</Id>
      <BubbleId>2</BubbleId>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>280644</PointerOffset>
      <VoiceId>&lt;audio:VSM_050_020_003&gt;</VoiceId>
      <JapaneseText>ははーんわかっただか？
こんな具合に、
炎の球が発射されんだど</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>4</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>280932</PointerOffset>
      <VoiceId>&lt;audio:VSM_050_020_005&gt;</VoiceId>
      <JapaneseText>気になるような
怪しいところがあれば、
まず打って試してみれ</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>5</Id>
      <BubbleId>0</BubbleId>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>280932</PointerOffset>
      <VoiceId>&lt;audio:VSM_050_020_006&gt;</VoiceId>
      <JapaneseText>ひょっとすっど、
先に進む大きな助けに
なってくれるかもしんね</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>5</Id>
      <BubbleId>1</BubbleId>
      <Status>To Do</Status>
    </Entry>
