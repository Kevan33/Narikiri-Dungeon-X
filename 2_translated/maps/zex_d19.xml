    <Entry>
      <PointerOffset>282071</PointerOffset>
      <JapaneseText>命知らずめが……
この先へ行くというのか？
死んでもしらぬぞ</JapaneseText>
      <EnglishText>You reckless fool…are you truly going any
further? Don’t say I didn't warn you.</EnglishText>
      <Notes/>
      <SpeakerId>6</SpeakerId>
      <Id>65</Id>
      <Status>Editing</Status>
    </Entry>
    <Entry>
      <PointerOffset>282147</PointerOffset>
      <JapaneseText>             はい             
            いいえ             </JapaneseText>
      <EnglishText>             Yes             
             No             </EnglishText>
      <Notes/>
      <SpeakerId>7</SpeakerId>
      <Id>66</Id>
      <Status>Editing</Status>
    </Entry>
    <Entry>
      <PointerOffset>282243</PointerOffset>
      <JapaneseText>            はい              
            いいえ             </JapaneseText>
      <EnglishText>            Yes              
