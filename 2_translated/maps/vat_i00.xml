    <Entry>
      <PointerOffset>274120</PointerOffset>
      <JapaneseText>悪い魔女の噂聞いた？
私ね、あれ魔女じゃないと
思うのよ噂なんて
あてにならないもの</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>1</Id>
      <BubbleId>1</BubbleId>
      <Status>To Do</Status>
