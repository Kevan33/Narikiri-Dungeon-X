      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>274192</PointerOffset>
      <JapaneseText>お外が騒がしいの……
みんな悲鳴とか怒る声とか
あげて……どうしちゃったの、みんな
こわいの？　こわくなんてないよ？
だってパパが守ってくれるもん</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>4</SpeakerId>
      <Id>40</Id>
      <BubbleId>1</BubbleId>
      <Status>To Do</Status>
