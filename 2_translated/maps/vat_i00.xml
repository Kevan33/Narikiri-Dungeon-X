      <Id>3</Id>
      <BubbleId>0</BubbleId>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>274124</PointerOffset>
      <JapaneseText>魔女ってことはさ
魔法が使える
つまりエルフってことよね？なんでエルフがエルフの村に
住んでないの？
おかしいじゃない</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>3</Id>
      <BubbleId>1</BubbleId>
      <Status>To Do</Status>
    </Entry>
    <Entry>
