    </Entry>
    <Entry>
      <PointerOffset>274148</PointerOffset>
      <JapaneseText>うちの妻、
ちまたのニュースに
興味を持つのはいいんだけど……家事を放り出すんだよ。
どうしたらいいかな？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>16</Id>
      <BubbleId>1</BubbleId>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>274152</PointerOffset>
      <JapaneseText>&lt;Dio&gt;&lt;Mel&gt;</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>18</Id>
      <BubbleId>0</BubbleId>
