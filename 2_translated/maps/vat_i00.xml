    <Entry>
      <PointerOffset>274196</PointerOffset>
      <JapaneseText>うちのパパは
世界一強いんだよ？何があっても
あたしを守るって
約束してくれたもん</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>4</SpeakerId>
      <Id>42</Id>
      <BubbleId>1</BubbleId>
