    <Entry>
      <PointerOffset>272904</PointerOffset>
      <JapaneseText>あら？　洞窟の時は
ありがとう</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>1</Id>
      <BubbleId>0</BubbleId>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>272904</PointerOffset>
      <JapaneseText>&lt;Klarth&gt;をよろしくね。
役に立つかどうか
わからないけど</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>1</Id>
      <BubbleId>1</BubbleId>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>272908</PointerOffset>
      <JapaneseText>まだ小さいのに、
しっかりしてるのね</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>3</Id>
      <BubbleId>0</BubbleId>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>272908</PointerOffset>
      <JapaneseText>「おばさん」はないと
思うけど……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>3</Id>
      <BubbleId>1</BubbleId>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>272912</PointerOffset>
      <JapaneseText>まったく帰ってきたら
帰ってきたで、
うるさいわね……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>5</Id>
      <BubbleId>0</BubbleId>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>272912</PointerOffset>
      <JapaneseText>いえ、こっちの話よ
うふふ……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>5</Id>
      <BubbleId>1</BubbleId>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>272916</PointerOffset>
      <JapaneseText>いなければいないで
色々心配させるくせに……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>7</Id>
      <BubbleId>0</BubbleId>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>272916</PointerOffset>
      <JapaneseText>いえ、こっちの話よ
うふふ……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>7</Id>
      <BubbleId>1</BubbleId>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>272920</PointerOffset>
      <JapaneseText>アルマイト36に
クンツァイト21を
加えて……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>9</Id>
      <BubbleId>0</BubbleId>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>272920</PointerOffset>
      <JapaneseText>何やってるのかって？
&lt;Klarth&gt;の研究の
手伝いをちょっとね……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>9</Id>
      <BubbleId>1</BubbleId>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>272924</PointerOffset>
      <JapaneseText>もうこんな時間だわ。
夕飯の準備しなくちゃ</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>11</Id>
      <BubbleId>0</BubbleId>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>272924</PointerOffset>
      <JapaneseText>今晩はあの人の好物に
しようかしらね……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>11</Id>
      <BubbleId>1</BubbleId>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>272928</PointerOffset>
      <JapaneseText>おや？　何か忘れ物か？
時間があるなら
ゆっくりしていくといい</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>13</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>272932</PointerOffset>
      <JapaneseText>虹輪の方はどうなった？
悠長にここでウロウロも
してられないんじゃないか？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>14</Id>
      <Status>To Do</Status>
    </Entry>
