    <Entry>
      <PointerOffset>282752</PointerOffset>
      <JapaneseText>スルト深林のグレムリンレアー
ですが、魔界に帰りそこない
捕らえられました現在、こちらの教会で、
確保しております</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>1</Id>
      <BubbleId>1</BubbleId>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>282948</PointerOffset>
      <JapaneseText></JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
