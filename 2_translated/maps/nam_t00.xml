    <Entry>
      <PointerOffset>358856</PointerOffset>
      <VoiceId>&lt;audio:VSS_039_020_002&gt;</VoiceId>
      <JapaneseText>見つけてくれて
サンキュー！ご褒美よ！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>1</Id>
      <BubbleId>1</BubbleId>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>358940</PointerOffset>
      <VoiceId>&lt;audio:VSS_039_020_003&gt;</VoiceId>
      <JapaneseText>……では、サラバっ！！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>3</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>361772</PointerOffset>
      <JapaneseText>会話、見に来た？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>4</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>360164</PointerOffset>
      <JapaneseText>あやややや、あんたは先生が
言ってた今日歌ってくれる
歌い手さんさん？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>5</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>360324</PointerOffset>
      <JapaneseText></JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>6</Id>
      <BubbleId>0</BubbleId>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>360324</PointerOffset>
      <JapaneseText>やっぱやっぱ、そっかっか。
先生にあんたが歌う歌詞を
預かってんよぅほらほらほらほら、
今日、ステージで
歌ってくれんでしょ</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>6</Id>
      <BubbleId>1</BubbleId>
      <Status>To Do</Status>
    </Entry>
  </Strings>
  <Strings>
    <Section>Npc</Section>
    <Entry>
      <PointerOffset>350440</PointerOffset>
      <JapaneseText>ただいま、試運転中だすよ。
だから、空っぽで回してるだす</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>4</SpeakerId>
      <Id>1</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>350444</PointerOffset>
      <JapaneseText>そりゃ、直らなきゃ
乗せられないだすよ。
直るまで、永遠に待っているだす</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>4</SpeakerId>
      <Id>2</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>350448</PointerOffset>
      <JapaneseText>この先は、ただいま準備中の
新設エリアだにょー。
だから通れないよーん</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>5</SpeakerId>
      <Id>3</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>350452</PointerOffset>
      <JapaneseText>新しいエリアはねぇ
上に行ったり下に行ったり
そりゃもう大騒ぎの場所だよ～</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>5</SpeakerId>
      <Id>4</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>350456</PointerOffset>
      <JapaneseText>聖職者たるもの
このように俗物に溢れる場所は
汚らわしくていけません！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>6</SpeakerId>
      <Id>5</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>350460</PointerOffset>
      <JapaneseText>なーんちゃって。
あたしってば、テーマパークとか
大っ好きなんだよねぇ∀</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>6</SpeakerId>
      <Id>6</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>350464</PointerOffset>
      <JapaneseText></JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>7</SpeakerId>
      <Id>7</Id>
      <BubbleId>0</BubbleId>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>350464</PointerOffset>
      <JapaneseText>お嬢様のお姿を見失って
どれぐらいの時間が
経ってしまったのか……どこで遊ばれているのやら……。
どうしたもんですかなぁ？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>7</SpeakerId>
      <Id>7</Id>
      <BubbleId>1</BubbleId>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>350468</PointerOffset>
      <JapaneseText>お嬢様も好きに遊ばれてるはず。
なので、私も羽を伸ばして
満喫させて頂きましょう</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>7</SpeakerId>
      <Id>9</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>350472</PointerOffset>
      <JapaneseText>わーい！
回る回る
ぐるぐるーぐるーーー！！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>8</SpeakerId>
      <Id>10</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>350476</PointerOffset>
      <JapaneseText>次はどのアトラクションに
乗ろうかな？　かな？
えへへへへへーー！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>8</SpeakerId>
      <Id>11</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>350480</PointerOffset>
      <JapaneseText>ここのレストランって
絶対に入れないのよねぇ。
気になってしょうがないわ</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>9</SpeakerId>
      <Id>12</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>350484</PointerOffset>
      <JapaneseText></JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>9</SpeakerId>
      <Id>13</Id>
      <BubbleId>0</BubbleId>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>350484</PointerOffset>
      <JapaneseText>でも、開門直後に来たのに
すでに満席で、予約も無理って
おかしくない？？？一部の人間たちの
特権なのかと疑いたくなるわ</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>9</SpeakerId>
      <Id>13</Id>
      <BubbleId>1</BubbleId>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>350488</PointerOffset>
      <JapaneseText>くぅん……
くん…………
くぅ～～～ん……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>10</SpeakerId>
      <Id>15</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>350492</PointerOffset>
      <JapaneseText>なんちゃって。
実は着ぐるみでしたー。
ビックリした？　した？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>10</SpeakerId>
      <Id>16</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>350496</PointerOffset>
      <JapaneseText>今日のパティちゃんライブ
絶対に最前列で見るんだ！
こっからここまで俺の席ー！！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>11</SpeakerId>
      <Id>17</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>350500</PointerOffset>
      <JapaneseText>最前列でカメラ構えないと
いろいろ意味がないんだ。
素人は知らなくていいから</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>11</SpeakerId>
      <Id>18</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>350504</PointerOffset>
      <JapaneseText></JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>12</SpeakerId>
      <Id>19</Id>
      <BubbleId>0</BubbleId>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>350504</PointerOffset>
      <JapaneseText>あら、あたし、
このパークの
人間じゃないわよそれとも、一緒に
写真でも撮りたいの？
うふ∀</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>12</SpeakerId>
      <Id>19</Id>
      <BubbleId>1</BubbleId>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>350508</PointerOffset>
      <JapaneseText></JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>12</SpeakerId>
      <Id>21</Id>
      <BubbleId>0</BubbleId>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>350508</PointerOffset>
      <JapaneseText>わかる、わかるわー。
わたしの魅力に
参っちゃったのよね？仕方ないわねぇ。
一枚だけなら
撮ってもいいわよ∀</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>12</SpeakerId>
      <Id>21</Id>
      <BubbleId>1</BubbleId>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>350512</PointerOffset>
      <JapaneseText>うひょーーー！
すげぇ、すげぇ！！
あは、あは、あは</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>13</SpeakerId>
      <Id>23</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>350516</PointerOffset>
      <JapaneseText>たまんねぇ！
もう、たまんねぇ！！
我慢できねぇずぇー！！！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>13</SpeakerId>
      <Id>24</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>350520</PointerOffset>
      <JapaneseText>おーれは、ながーれの
ぎょうしょうーにん。
なんかー、買っていーくといい</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>14</SpeakerId>
      <Id>25</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>350524</PointerOffset>
      <JapaneseText>_shop_</JapaneseText>
