      <PointerOffset>270864</PointerOffset>
      <JapaneseText>はい、ここは
道具屋「天地無用」
ほしいもんは遠慮なく言っとくれ</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>1</Id>
      <Status>To Do</Status>
