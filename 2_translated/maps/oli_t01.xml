    <Entry>
      <PointerOffset>318620</PointerOffset>
      <VoiceId>&lt;audio:VSS_039_020_002&gt;</VoiceId>
      <JapaneseText>ご褒美よ！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>1</Id>
      <BubbleId>1</BubbleId>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>318704</PointerOffset>
      <VoiceId>&lt;audio:VSS_039_020_003&gt;</VoiceId>
      <JapaneseText>……では、サラバっ！！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>3</Id>
      <Status>To Do</Status>
    </Entry>
  </Strings>
  <Strings>
    <Section>Npc</Section>
    <Entry>
      <PointerOffset>309576</PointerOffset>
      <JapaneseText>……なんか、
木が枯れてるんだけど
暑さのせい？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>1</Id>
      <BubbleId>0</BubbleId>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>309576</PointerOffset>
      <JapaneseText>……ってもう何年も
暑いんだけど、今更？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>1</Id>
      <BubbleId>1</BubbleId>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>309580</PointerOffset>
      <JapaneseText>もしかして、
前よりも暑くなってる？
だから木が枯れた？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>3</Id>
      <BubbleId>0</BubbleId>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>309580</PointerOffset>
      <JapaneseText>いやいや……
あ、でも昨日より
今日は少し暑いかも……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>3</Id>
      <BubbleId>1</BubbleId>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>309584</PointerOffset>
      <JapaneseText>あれ～、なんか椰子の木の
葉っぱの色が変だなぁ</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>5</Id>
      <BubbleId>0</BubbleId>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>309584</PointerOffset>
      <JapaneseText>おまけに元気がない……
なんだ？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>5</Id>
      <BubbleId>1</BubbleId>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>309588</PointerOffset>
      <JapaneseText>植物が元気がない時には
水をやるのが一番だね</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>3</SpeakerId>
      <Id>7</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>309592</PointerOffset>
      <JapaneseText>宿屋の前のアイツ……
どうして……平気……なんだ……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>4</SpeakerId>
      <Id>8</Id>
      <BubbleId>0</BubbleId>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>309592</PointerOffset>
      <JapaneseText>暑い……もう死ぬ……
今死ぬ……
いや死なない……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>4</SpeakerId>
      <Id>8</Id>
      <BubbleId>1</BubbleId>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>309596</PointerOffset>
      <JapaneseText>やばい……やばすぎる……
この暑さ……禁魔術級……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>4</SpeakerId>
      <Id>10</Id>
      <BubbleId>0</BubbleId>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>309596</PointerOffset>
      <JapaneseText>目の前に、水があるのに……
飲めない……つらさ……
君たちは知らないだろ？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>4</SpeakerId>
      <Id>10</Id>
      <BubbleId>1</BubbleId>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>309600</PointerOffset>
      <JapaneseText>バジリスクの肉って
意外とやわらかくて
脂のってて美味いんだって</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>5</SpeakerId>
      <Id>12</Id>
      <BubbleId>0</BubbleId>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>309600</PointerOffset>
      <JapaneseText>でも、みんな気味悪がって
食わなかったそうだ</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>5</SpeakerId>
      <Id>12</Id>
      <BubbleId>1</BubbleId>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>309604</PointerOffset>
      <JapaneseText>今でもバジリスク料理っての
あるみたいだけど
高級料理なのさ</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>5</SpeakerId>
      <Id>14</Id>
      <BubbleId>0</BubbleId>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>309604</PointerOffset>
      <JapaneseText>一度、食ってはみたいが……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>5</SpeakerId>
      <Id>14</Id>
      <BubbleId>1</BubbleId>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>309608</PointerOffset>
      <JapaneseText>魔女のヤツめ！　許さん！
今度はホッケ焼いてたら
まんまと持っていきやがった！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>6</SpeakerId>
      <Id>16</Id>
      <BubbleId>0</BubbleId>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>309608</PointerOffset>
      <JapaneseText>にゃーんとか鳴きやがって
なんのマネだ！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>6</SpeakerId>
      <Id>16</Id>
      <BubbleId>1</BubbleId>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>309612</PointerOffset>
      <JapaneseText>オレの大事な夕食を！
オレの大切なホッケちゃんを！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>6</SpeakerId>
      <Id>18</Id>
      <BubbleId>0</BubbleId>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>309612</PointerOffset>
      <JapaneseText>返せ！　バカやろー！
あ、魔女だからヤローじゃないか</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>6</SpeakerId>
      <Id>18</Id>
      <BubbleId>1</BubbleId>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>309616</PointerOffset>
      <JapaneseText>暑い～…今日の夕飯は
チーズINハンバーグかな</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>7</SpeakerId>
      <Id>20</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>309620</PointerOffset>
      <JapaneseText>チーズがとろけてて
おいしいんだよねー！！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>7</SpeakerId>
      <Id>21</Id>
      <Status>To Do</Status>
    </Entry>
