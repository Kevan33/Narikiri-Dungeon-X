      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>270456</PointerOffset>
      <JapaneseText>東にアルヴァニスタ、
北東にミッドガルズ２つの大国の間が
今あまりよろしくないらしいよ</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>8</Id>
      <BubbleId>1</BubbleId>
      <Status>To Do</Status>
    </Entry>
