    <Entry>
      <PointerOffset>270448</PointerOffset>
      <JapaneseText>召喚術を研究してる
変人がこの村に
いるんだけど……召喚術って「精霊」だろ？
そんなもんいんのかい？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>4</Id>
      <BubbleId>1</BubbleId>
      <Status>To Do</Status>
    </Entry>
    <Entry>
