    <Entry>
      <PointerOffset>278324</PointerOffset>
      <JapaneseText>武器屋　ビショップ</JapaneseText>
      <EnglishText>Weapon Shop Bishop</EnglishText>
      <Notes/>
      <Id>1</Id>
      <Status>Editing</Status>
    </Entry>
  </Strings>
  <Strings>
    <Section>Npc</Section>
    <Entry>
      <PointerOffset>270436</PointerOffset>
      <JapaneseText>ようこそ？
武器屋「ビショップ」へ
ごゆっくりご覧ください？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>1</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>270440</PointerOffset>
      <JapaneseText>_shop_</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>2</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>270444</PointerOffset>
      <JapaneseText>ゆっくりご覧に
なれましたか？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>3</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>270448</PointerOffset>
      <JapaneseText>召喚術を研究してる
変人がこの村に
いるんだけど……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>4</Id>
      <BubbleId>0</BubbleId>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>270448</PointerOffset>
      <JapaneseText>召喚術って「精霊」だろ？
そんなもんいんのかい？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>4</Id>
      <BubbleId>1</BubbleId>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>270452</PointerOffset>
      <JapaneseText>召喚術を研究して、
今後の世界を支える
技術にするらしい</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>6</Id>
      <BubbleId>0</BubbleId>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>270452</PointerOffset>
      <JapaneseText>でも、そんな危ういもの
信用できるのかな？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>6</Id>
      <BubbleId>1</BubbleId>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>270456</PointerOffset>
      <JapaneseText>東にアルヴァニスタ、
北東にミッドガルズ</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>8</Id>
      <BubbleId>0</BubbleId>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>270456</PointerOffset>
      <JapaneseText>２つの大国の間が
今あまりよろしくないらしいよ</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>8</Id>
      <BubbleId>1</BubbleId>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>270460</PointerOffset>
      <JapaneseText>２つの国が争ってるのは
とある技術を巡ってなんだって</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>10</Id>
      <BubbleId>0</BubbleId>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>270460</PointerOffset>
      <JapaneseText>なんでもいいけど
また戦争はイヤだな……</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>10</Id>
      <BubbleId>1</BubbleId>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>270464</PointerOffset>
      <JapaneseText>&lt;Klarth&gt;博士が
魔科学の禁止を
唱えてるんだけど</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>12</Id>
      <BubbleId>0</BubbleId>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>270464</PointerOffset>
      <JapaneseText>ミッドガルズは
魔科学が便利なので
手放せないらしいよ</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>12</Id>
      <BubbleId>1</BubbleId>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>270468</PointerOffset>
      <JapaneseText>&lt;Klarth&gt;博士の
魔科学禁止を後押ししてるのは
アルヴァニスタなんだって</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>14</Id>
      <BubbleId>0</BubbleId>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>270468</PointerOffset>
      <JapaneseText>そのせいで
二つの国の関係が
悪化してるんだ</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>2</SpeakerId>
      <Id>14</Id>
      <BubbleId>1</BubbleId>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>270472</PointerOffset>
      <JapaneseText>ようこそようこそ
「ビショップ」へ？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>16</Id>
      <BubbleId>0</BubbleId>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>270472</PointerOffset>
      <JapaneseText>いい品が揃ってますよ～？</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>16</Id>
      <BubbleId>1</BubbleId>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>270476</PointerOffset>
      <JapaneseText>_shop_</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>18</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset>270480</PointerOffset>
      <JapaneseText>またようこそ！</JapaneseText>
      <EnglishText/>
      <Notes/>
      <SpeakerId>1</SpeakerId>
      <Id>19</Id>
      <Status>To Do</Status>
    </Entry>
